{%- liquid
  assign section_id = section.id
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign heading_color = section.settings.heading_color
  assign subheading_color = section.settings.subheading_color
  assign accent_color = section.settings.accent_color
  assign card_bg = section.settings.card_bg
  assign inner_card_bg = section.settings.inner_card_bg
  assign card_border_color = section.settings.card_border_color
  assign inner_border_color = section.settings.inner_border_color
  assign heading_font_size = section.settings.heading_font_size
  assign heading_font_size_mobile = section.settings.heading_font_size_mobile
  assign card_title_size = section.settings.card_title_size
  assign points_size = section.settings.points_size
  assign section_bg = section.settings.section_bg

  assign ways_title = section.settings.ways_title
  assign share_heading = section.settings.share_heading
  assign share_image = section.settings.share_image
  assign share_subheading = section.settings.share_subheading
  assign share_description = section.settings.share_description

  assign referral_heading = section.settings.referral_heading
  assign referral_step_1 = section.settings.referral_step_1
  assign referral_step_2 = section.settings.referral_step_2
  assign referral_step_3 = section.settings.referral_step_3
  assign you_get_label = section.settings.you_get_label
  assign you_get_value = section.settings.you_get_value
  assign you_get_unit = section.settings.you_get_unit
  assign they_get_label = section.settings.they_get_label
  assign they_get_value = section.settings.they_get_value
  assign they_get_unit = section.settings.they_get_unit

  assign login_url = section.settings.login_url
  assign signup_url = section.settings.signup_url
  assign logged_out_message = section.settings.logged_out_message
-%}

{%- style -%}
  #shopify-section-{{ section_id }} {
    --tstn-accent: {{ accent_color }};
    --tstn-heading-color: {{ heading_color }};
    --tstn-subheading-color: {{ subheading_color }};
    --tstn-card-bg: {{ card_bg }};
    --tstn-inner-card-bg: {{ inner_card_bg }};
    --tstn-card-border: {{ card_border_color }};
    --tstn-inner-border: {{ inner_border_color }};
    --tstn-section-bg: {{ section_bg }};
    --tstn-heading-size: {{ heading_font_size }}px;
    --tstn-heading-size-mobile: {{ heading_font_size_mobile }}px;
    --tstn-card-title-size: {{ card_title_size }}px;
    --tstn-points-size: {{ points_size }}px;
  }

  .tstn-earn-{{ section_id }} {
    background: var(--tstn-section-bg);
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .tstn-earn-{{ section_id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="tstn-earn tstn-earn-{{ section_id }} color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {%- if heading != blank or subheading != blank -%}
      <div class="tstn-earn__header">
        {%- if heading != blank -%}
          <h2 class="tstn-earn__heading">{{ heading }}</h2>
        {%- endif -%}
        {%- if subheading != blank -%}
          <p class="tstn-earn__subheading">{{ subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="tstn-earn__grid">

      {%- comment -%} ============ LEFT PANEL: WAYS TO EARN POINTS ============ {%- endcomment -%}
      <div class="tstn-earn__panel tstn-earn__panel--ways">
        {%- if ways_title != blank -%}
          <h3 class="tstn-earn__panel-title">{{ ways_title }}</h3>
        {%- endif -%}

        {%- comment -%} Logged-out message — shown only to guests via customer check {%- endcomment -%}
        {%- unless customer -%}
          {%- if logged_out_message != blank -%}
            <div class="tstn-auth-notice">
              <span class="tstn-auth-notice__text">{{ logged_out_message }}</span>
              <div class="tstn-auth-notice__actions">
                <a href="{{ signup_url | default: '/account/register' }}" class="tstn-btn tstn-btn--primary">Sign Up</a>
                <a href="{{ login_url | default: '/account/login' }}" class="tstn-btn tstn-btn--secondary">Log In</a>
              </div>
            </div>
          {%- endif -%}
        {%- endunless -%}

        <div class="tstn-earn__ways">
          <div
            class="gw-rd-ways-to-earn-page-widget-placeholder"
            data-gw-widget-shadow-root-enabled="false"
            data-gw-show-points-balance="false"
            style="display: block"
          ></div>
        </div>
      </div>

      {%- comment -%} ============ RIGHT PANEL: SHARE & EARN + REFERRAL ============ {%- endcomment -%}
      <div class="tstn-earn__panel tstn-earn__panel--share">

        <div class="tstn-share">
          {%- if share_heading != blank -%}
            <h3 class="tstn-earn__panel-title">{{ share_heading }}</h3>
          {%- endif -%}

          {%- if share_subheading != blank -%}
            <h4 class="tstn-share__subheading">{{ share_subheading }}</h4>
          {%- endif -%}

          {%- if share_description != blank -%}
            <p class="tstn-share__description">{{ share_description }}</p>
          {%- endif -%}
        </div>

        <div class="tstn-refer">
          {%- if referral_heading != blank -%}
            <h4 class="tstn-refer__heading">{{ referral_heading }}</h4>
          {%- endif -%}

          <ol class="tstn-refer__steps">
            {%- if referral_step_1 != blank -%}
              <li><span class="tstn-refer__step-num">1</span><span class="tstn-refer__step-text">{{ referral_step_1 }}</span></li>
            {%- endif -%}
            {%- if referral_step_2 != blank -%}
              <li><span class="tstn-refer__step-num">2</span><span class="tstn-refer__step-text">{{ referral_step_2 }}</span></li>
            {%- endif -%}
            {%- if referral_step_3 != blank -%}
              <li><span class="tstn-refer__step-num">3</span><span class="tstn-refer__step-text">{{ referral_step_3 }}</span></li>
            {%- endif -%}
          </ol>

          <div class="tstn-refer__rewards">
            <div class="tstn-refer__reward">
              <span class="tstn-refer__reward-label">{{ you_get_label }}</span>
              <span class="tstn-refer__reward-value">
                <strong>{{ you_get_value }}</strong> <em>{{ you_get_unit }}</em>
              </span>
            </div>
            <div class="tstn-refer__reward-divider"></div>
            <div class="tstn-refer__reward">
              <span class="tstn-refer__reward-label">{{ they_get_label }}</span>
              <span class="tstn-refer__reward-value">
                <strong>{{ they_get_value }}</strong> <em>{{ they_get_unit }}</em>
              </span>
            </div>
          </div>

          {%- if share_image != blank -%}
            <div class="tstn-share__image">
              {{ share_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: share_heading | escape }}
            </div>
          {%- endif -%}

          {%- comment -%} For guests, show our own auth CTAs and hide Growave widget — for logged-in customers, show Growave widget {%- endcomment -%}
          {%- if customer -%}
            <div class="tstn-refer__widget">
              <div
                class="gw-rd-referral-program-page-widget-placeholder tstn-referral"
                data-gw-widget-shadow-root-enabled="false"
                style="display: block"
              ></div>
            </div>
          {%- else -%}
            <div class="tstn-refer__auth">
              <p class="tstn-refer__auth-text">Sign up or log in to get your referral link</p>
              <div class="tstn-refer__auth-actions">
                <a href="{{ signup_url | default: '/account/register' }}" class="tstn-btn tstn-btn--primary">Sign Up</a>
                <a href="{{ login_url | default: '/account/login' }}" class="tstn-btn tstn-btn--secondary">Log In</a>
              </div>
            </div>
          {%- endif -%}
        </div>

      </div>
    </div>
  </div>
</div>

<style>
  /* ============================================
     SECTION HEADER
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-earn__header {
    text-align: center;
    margin-bottom: clamp(28px, 4vw, 48px);
  }

  #shopify-section-{{ section_id }} .tstn-earn__heading {
    font-family: 'Danger Neue Free Regular', sans-serif;
    font-weight: 400;
    font-size: var(--tstn-heading-size);
    color: var(--tstn-heading-color);
    text-transform: uppercase;
    margin: 0 0 12px;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  #shopify-section-{{ section_id }} .tstn-earn__subheading {
    color: var(--tstn-subheading-color);
    font-size: clamp(14px, 1.4vw, 16px);
    margin: 0;
    opacity: 0.85;
  }

  /* ============================================
     MAIN GRID
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-earn__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px, 2vw, 28px);
    align-items: stretch;
  }

  @media (min-width: 990px) {
    #shopify-section-{{ section_id }} .tstn-earn__grid {
      grid-template-columns: 1.6fr 1fr;
    }
  }

  /* ============================================
     PANEL — Outer card
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-earn__panel {
    background: var(--tstn-card-bg) !important;
    border: 1px solid var(--tstn-card-border);
    border-radius: 12px;
    padding: clamp(20px, 2.4vw, 32px);
    display: flex;
    flex-direction: column;
    gap: clamp(16px, 1.8vw, 24px);
  }

  #shopify-section-{{ section_id }} .tstn-earn__panel--ways {
    height: 100%;
  }

  #shopify-section-{{ section_id }} .tstn-earn__panel--ways .tstn-earn__ways {
    flex: 1 1 auto;
    display: flex;
    flex-direction: column;
  }

  #shopify-section-{{ section_id }} .tstn-earn__panel-title {
    font-family: 'Danger Neue Free Regular', sans-serif;
    font-weight: 400;
    font-size: var(--tstn-card-title-size);
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1;
    margin: 0;
  }

  /* ============================================
     AUTH NOTICE — Logged-out CTA in left panel
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-auth-notice {
    background: rgba(255, 106, 26, 0.08);
    border: 1px solid rgba(255, 106, 26, 0.25);
    border-radius: 8px;
    padding: clamp(14px, 1.6vw, 18px);
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #shopify-section-{{ section_id }} .tstn-auth-notice__text {
    font-family: 'Inter', 'ABC Diatype', -apple-system, sans-serif;
    font-size: clamp(12px, 1vw, 13px);
    color: #e8e8e8;
    line-height: 1.4;
  }

  #shopify-section-{{ section_id }} .tstn-auth-notice__actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }

  /* ============================================
     CUSTOM BUTTONS — Sign Up / Log In
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-btn {
    font-family: 'Inter', 'ABC Diatype', -apple-system, sans-serif;
    font-weight: 700;
    font-size: clamp(12px, 1vw, 13px);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 12px 22px;
    border-radius: 6px;
    border: 1px solid transparent;
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
    line-height: 1;
    white-space: nowrap;
  }

  #shopify-section-{{ section_id }} .tstn-btn--primary {
    background: var(--tstn-accent);
    color: #fff !important;
    border-color: var(--tstn-accent);
  }

  #shopify-section-{{ section_id }} .tstn-btn--primary:hover {
    background: transparent;
    color: var(--tstn-accent) !important;
  }

  #shopify-section-{{ section_id }} .tstn-btn--secondary {
    background: transparent;
    color: #fff !important;
    border-color: rgba(255, 255, 255, 0.25);
  }

  #shopify-section-{{ section_id }} .tstn-btn--secondary:hover {
    background: #fff;
    color: #0a0a0a !important;
    border-color: #fff;
  }

  /* ============================================
     KILL ALL GROWAVE WHITE BACKGROUNDS
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-layout,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-container,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-container.svelte-1mnbt6f,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-ways-to-earn-page-widget,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-referral-program-page-widget,
  #shopify-section-{{ section_id }} .tstn-earn .gw-layout-block,
  #shopify-section-{{ section_id }} .tstn-earn .gw-layout-stack,
  #shopify-section-{{ section_id }} .tstn-earn .gw-layout {
    background: transparent !important;
    background-color: transparent !important;
    box-shadow: none !important;
    border: none !important;
    max-width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  #shopify-section-{{ section_id }} .tstn-earn__ways .gw-rd-ways-to-earn-page-widget,
  #shopify-section-{{ section_id }} .tstn-earn__ways .gw-rd-page-widget-layout,
  #shopify-section-{{ section_id }} .tstn-earn__ways .gw-rd-page-widget-container,
  #shopify-section-{{ section_id }} .tstn-earn__ways .gw-rd-page-widget {
    height: 100% !important;
    display: flex !important;
    flex-direction: column !important;
    flex: 1 1 auto !important;
  }

  /* ============================================
     HIDE GROWAVE'S OWN AUTH/SIGNUP/LOGIN BUTTONS
     These render as auth gate cards or top-of-list CTAs.
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-auth,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-signin,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-login,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-customer,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-guest,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-popup-widget-auth,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-popup-widget-login,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-popup-widget-signup,
  #shopify-section-{{ section_id }} .tstn-earn [class*="gw-rd-page-widget-auth"],
  #shopify-section-{{ section_id }} .tstn-earn [class*="gw-rd-popup-widget-auth"],
  #shopify-section-{{ section_id }} .tstn-earn [class*="gw-rd-auth"],
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-action-btn--primary,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-action-btn,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-action-btn[class*="signup"],
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-action-btn[class*="login"],
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-action-btn[class*="signin"],
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-action-btn[class*="register"] {
    display: none !important;
  }

  /* Hide Growave's "Dummy content shown" pill and other dev/admin notices */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-dummy-notice,
  #shopify-section-{{ section_id }} .tstn-earn [class*="dummy"],
  #shopify-section-{{ section_id }} .tstn-earn [class*="placeholder-notice"],
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-notice {
    display: none !important;
  }

  /* Hide Growave's defaults: titles, balance, benefits, default reward, AND duplicated steps */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-title,
  #shopify-section-{{ section_id }} .tstn-earn h2.gw-rd-page-widget-title,
  #shopify-section-{{ section_id }} .tstn-earn h3.gw-rd-page-widget-title,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-customer-balance,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-referral-program-page-widget__benefits,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-popup-widget-referral-program__reward,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-referral-program-page-widget__steps,
  #shopify-section-{{ section_id }} .tstn-earn .tstn-referral .gw-rd-list,
  #shopify-section-{{ section_id }} .tstn-earn .tstn-referral ul.gw-rd-list,
  #shopify-section-{{ section_id }} .tstn-earn .tstn-referral .gw-rd-referral-program-page-widget__benefit-item,
  #shopify-section-{{ section_id }} .tstn-earn .tstn-referral ol,
  #shopify-section-{{ section_id }} .tstn-earn .tstn-referral .gw-rd-page-widget-howto,
  #shopify-section-{{ section_id }} .tstn-earn .tstn-referral [class*="howto"],
  #shopify-section-{{ section_id }} .tstn-earn .tstn-referral [class*="how-to"],
  #shopify-section-{{ section_id }} .tstn-earn .tstn-referral [class*="benefit"] {
    display: none !important;
  }

  /* ============================================
     LEFT PANEL — Earn cards: 3 cols / 2 / 1
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-list,
  #shopify-section-{{ section_id }} .tstn-earn ul.gw-rd-list {
    display: grid !important;
    grid-template-columns: repeat(3, minmax(0, 1fr)) !important;
    grid-auto-rows: 1fr !important;
    gap: clamp(12px, 1.2vw, 16px) !important;
    margin: 0 !important;
    padding: 0 !important;
    list-style: none !important;
    background: transparent !important;
    width: 100% !important;
    align-items: stretch !important;
  }

  #shopify-section-{{ section_id }} .tstn-earn li.gw-rd-list__item {
    flex: unset !important;
    width: 100% !important;
    max-width: 100% !important;
    height: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
    background: transparent !important;
    list-style: none !important;
    display: flex !important;
  }

  /* ============================================
     EARN CARD — Icon left + content stacked right
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card.svelte-3ln76z.svelte-3ln76z,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card--cursor-pointer.svelte-3ln76z.svelte-3ln76z,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card--completed.svelte-3ln76z.svelte-3ln76z {
    border-radius: 8px !important;
    border: 1px solid var(--tstn-inner-border) !important;
    background: var(--tstn-inner-card-bg) !important;
    background-color: var(--tstn-inner-card-bg) !important;
    box-shadow: none !important;
    color: #fff !important;
    height: 100% !important;
    width: 100% !important;
    min-height: 130px !important;
    padding: clamp(16px, 1.6vw, 22px) !important;
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    justify-content: flex-start !important;
    gap: clamp(12px, 1.2vw, 16px) !important;
    cursor: pointer;
    text-align: left !important;
    box-sizing: border-box !important;
    position: relative !important;
  }

  /* Icon */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card__icon,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card__icon.svelte-3ln76z.svelte-3ln76z {
    width: clamp(40px, 4vw, 48px) !important;
    height: clamp(40px, 4vw, 48px) !important;
    min-width: clamp(40px, 4vw, 48px) !important;
    border-radius: 0 !important;
    background: transparent !important;
    flex: 0 0 auto !important;
    color: var(--tstn-accent) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    margin: 0 !important;
    align-self: center !important;
  }

  #shopify-section-{{ section_id }} .tstn-earn .gw-image,
  #shopify-section-{{ section_id }} .tstn-earn .gw-image__img,
  #shopify-section-{{ section_id }} .tstn-earn .gw-image__img.svelte-1ijgyj3.svelte-1ijgyj3 {
    object-fit: contain !important;
    width: 100% !important;
    height: 100% !important;
    max-width: 100% !important;
  }

  /* Right content stack */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card > .gw-layout-stack,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card .gw-layout-stack,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card > .gw-layout-block {
    flex: 1 1 auto !important;
    min-width: 0 !important;
    width: 100% !important;
    text-align: left !important;
    align-items: flex-start !important;
    justify-content: center !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 8px !important;
    background: transparent !important;
  }

  #shopify-section-{{ section_id }} .tstn-earn .gw-layout-text--variant-base,
  #shopify-section-{{ section_id }} .tstn-earn .gw-layout-text--variant-base.svelte-yjnpd {
    font-family: 'Inter', 'ABC Diatype', -apple-system, sans-serif !important;
    font-weight: 700 !important;
    font-size: clamp(12px, 0.9vw, 13px) !important;
    color: #fff !important;
    text-transform: uppercase !important;
    letter-spacing: 0.04em !important;
    line-height: 1.35 !important;
    text-align: left !important;
    background: transparent !important;
    padding: 0 !important;
