{%- liquid
  assign section_id = section.id
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign heading_color = section.settings.heading_color
  assign subheading_color = section.settings.subheading_color
  assign accent_color = section.settings.accent_color
  assign card_bg = section.settings.card_bg
  assign inner_card_bg = section.settings.inner_card_bg
  assign card_border_color = section.settings.card_border_color
  assign inner_border_color = section.settings.inner_border_color
  assign heading_font_size = section.settings.heading_font_size
  assign heading_font_size_mobile = section.settings.heading_font_size_mobile
  assign card_title_size = section.settings.card_title_size
  assign points_size = section.settings.points_size
  assign section_bg = section.settings.section_bg

  assign ways_title = section.settings.ways_title
  assign share_heading = section.settings.share_heading
  assign share_image = section.settings.share_image
  assign share_subheading = section.settings.share_subheading
  assign share_description = section.settings.share_description

  assign referral_heading = section.settings.referral_heading
  assign referral_step_1 = section.settings.referral_step_1
  assign referral_step_2 = section.settings.referral_step_2
  assign referral_step_3 = section.settings.referral_step_3
  assign you_get_label = section.settings.you_get_label
  assign you_get_value = section.settings.you_get_value
  assign you_get_unit = section.settings.you_get_unit
  assign they_get_label = section.settings.they_get_label
  assign they_get_value = section.settings.they_get_value
  assign they_get_unit = section.settings.they_get_unit
-%}

{%- style -%}
  #shopify-section-{{ section_id }} {
    --tstn-accent: {{ accent_color }};
    --tstn-heading-color: {{ heading_color }};
    --tstn-subheading-color: {{ subheading_color }};
    --tstn-card-bg: {{ card_bg }};
    --tstn-inner-card-bg: {{ inner_card_bg }};
    --tstn-card-border: {{ card_border_color }};
    --tstn-inner-border: {{ inner_border_color }};
    --tstn-section-bg: {{ section_bg }};
    --tstn-heading-size: {{ heading_font_size }}px;
    --tstn-heading-size-mobile: {{ heading_font_size_mobile }}px;
    --tstn-card-title-size: {{ card_title_size }}px;
    --tstn-points-size: {{ points_size }}px;
  }

  .tstn-earn-{{ section_id }} {
    background: var(--tstn-section-bg);
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .tstn-earn-{{ section_id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="tstn-earn tstn-earn-{{ section_id }} color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {%- if heading != blank or subheading != blank -%}
      <div class="tstn-earn__header">
        {%- if heading != blank -%}
          <h2 class="tstn-earn__heading">{{ heading }}</h2>
        {%- endif -%}
        {%- if subheading != blank -%}
          <p class="tstn-earn__subheading">{{ subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="tstn-earn__grid">

      {%- comment -%} ============ LEFT PANEL: WAYS TO EARN POINTS ============ {%- endcomment -%}
      <div class="tstn-earn__panel tstn-earn__panel--ways">
        {%- if ways_title != blank -%}
          <h3 class="tstn-earn__panel-title">{{ ways_title }}</h3>
        {%- endif -%}

        <div class="tstn-earn__ways">
          <div
            class="gw-rd-ways-to-earn-page-widget-placeholder"
            data-gw-widget-shadow-root-enabled="true"
            data-gw-show-points-balance="true"
            style="display: block"
          ></div>
        </div>
      </div>

      {%- comment -%} ============ RIGHT PANEL: SHARE & EARN + REFERRAL ============ {%- endcomment -%}
      <div class="tstn-earn__panel tstn-earn__panel--share">

        <div class="tstn-share">
          {%- if share_heading != blank -%}
            <h3 class="tstn-earn__panel-title">{{ share_heading }}</h3>
          {%- endif -%}

          {%- if share_image != blank -%}
            <div class="tstn-share__image">
              {{ share_image | image_url: width: 1200 | image_tag: loading: 'lazy', alt: share_heading | escape }}
            </div>
          {%- endif -%}

          {%- if share_subheading != blank -%}
            <h4 class="tstn-share__subheading">{{ share_subheading }}</h4>
          {%- endif -%}

          {%- if share_description != blank -%}
            <p class="tstn-share__description">{{ share_description }}</p>
          {%- endif -%}
        </div>

        <div class="tstn-refer">
          {%- if referral_heading != blank -%}
            <h4 class="tstn-refer__heading">{{ referral_heading }}</h4>
          {%- endif -%}

          <ol class="tstn-refer__steps">
            {%- if referral_step_1 != blank -%}
              <li><span class="tstn-refer__step-num">1</span><span class="tstn-refer__step-text">{{ referral_step_1 }}</span></li>
            {%- endif -%}
            {%- if referral_step_2 != blank -%}
              <li><span class="tstn-refer__step-num">2</span><span class="tstn-refer__step-text">{{ referral_step_2 }}</span></li>
            {%- endif -%}
            {%- if referral_step_3 != blank -%}
              <li><span class="tstn-refer__step-num">3</span><span class="tstn-refer__step-text">{{ referral_step_3 }}</span></li>
            {%- endif -%}
          </ol>

          <div class="tstn-refer__rewards">
            <div class="tstn-refer__reward">
              <span class="tstn-refer__reward-label">{{ you_get_label }}</span>
              <span class="tstn-refer__reward-value">
                <strong>{{ you_get_value }}</strong> <em>{{ you_get_unit }}</em>
              </span>
            </div>
            <div class="tstn-refer__reward-divider"></div>
            <div class="tstn-refer__reward">
              <span class="tstn-refer__reward-label">{{ they_get_label }}</span>
              <span class="tstn-refer__reward-value">
                <strong>{{ they_get_value }}</strong> <em>{{ they_get_unit }}</em>
              </span>
            </div>
          </div>

          <div class="tstn-refer__widget">
            <div
              class="gw-rd-referral-program-page-widget-placeholder tstn-referral"
              data-gw-widget-shadow-root-enabled="true"
              style="display: block"
            ></div>
          </div>
        </div>

      </div>
    </div>
  </div>
</div>

<style>
  /* ============================================
     SECTION HEADER
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-earn__header {
    text-align: center;
    margin-bottom: clamp(28px, 4vw, 48px);
  }

  #shopify-section-{{ section_id }} .tstn-earn__heading {
    font-family: 'Danger Neue Free Regular', sans-serif;
    font-weight: 400;
    font-size: var(--tstn-heading-size);
    color: var(--tstn-heading-color);
    text-transform: uppercase;
    margin: 0 0 12px;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  #shopify-section-{{ section_id }} .tstn-earn__subheading {
    color: var(--tstn-subheading-color);
    font-size: clamp(14px, 1.4vw, 16px);
    margin: 0;
    opacity: 0.85;
  }

  /* ============================================
     MAIN GRID
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-earn__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(20px, 2vw, 28px);
    align-items: stretch;
  }

  @media (min-width: 990px) {
    #shopify-section-{{ section_id }} .tstn-earn__grid {
      grid-template-columns: 1.35fr 1fr;
    }
  }

  /* ============================================
     PANEL — Outer card
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-earn__panel {
    background: var(--tstn-card-bg) !important;
    border: 1px solid var(--tstn-card-border);
    border-radius: 12px;
    padding: clamp(20px, 2.4vw, 32px);
    display: flex;
    flex-direction: column;
    gap: clamp(16px, 1.8vw, 24px);
  }

  #shopify-section-{{ section_id }} .tstn-earn__panel-title {
    font-family: 'Danger Neue Free Regular', sans-serif;
    font-weight: 400;
    font-size: var(--tstn-card-title-size);
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    line-height: 1;
    margin: 0;
  }

  /* ============================================
     CRITICAL: KILL ALL GROWAVE WHITE BACKGROUNDS
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-layout,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-container,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-container.svelte-1mnbt6f,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-ways-to-earn-page-widget,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-referral-program-page-widget,
  #shopify-section-{{ section_id }} .tstn-earn .gw-layout-block,
  #shopify-section-{{ section_id }} .tstn-earn .gw-layout-stack,
  #shopify-section-{{ section_id }} .tstn-earn .gw-layout {
    background: transparent !important;
    background-color: transparent !important;
    box-shadow: none !important;
    border: none !important;
    max-width: 100% !important;
    padding: 0 !important;
    margin: 0 !important;
  }

  /* Hide Growave's default page titles, balance, benefits, AND its own reward box */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-title,
  #shopify-section-{{ section_id }} .tstn-earn h2.gw-rd-page-widget-title,
  #shopify-section-{{ section_id }} .tstn-earn h3.gw-rd-page-widget-title,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-customer-balance,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-referral-program-page-widget__benefits,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-popup-widget-referral-program__reward {
    display: none !important;
  }

  /* ============================================
     LEFT PANEL — Earn cards grid (2 columns)
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-list,
  #shopify-section-{{ section_id }} .tstn-earn ul.gw-rd-list {
    display: grid !important;
    grid-template-columns: repeat(2, 1fr) !important;
    gap: clamp(12px, 1.4vw, 18px) !important;
    margin: 0 !important;
    padding: 0 !important;
    list-style: none !important;
    background: transparent !important;
  }

  #shopify-section-{{ section_id }} .tstn-earn li.gw-rd-list__item {
    flex: unset !important;
    width: 100% !important;
    max-width: 100% !important;
    margin: 0 !important;
    padding: 0 !important;
    background: transparent !important;
    list-style: none !important;
  }

  /* Earn card — flat dark, icon LEFT + content RIGHT */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card.svelte-3ln76z.svelte-3ln76z,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card--cursor-pointer.svelte-3ln76z.svelte-3ln76z,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card--completed.svelte-3ln76z.svelte-3ln76z {
    border-radius: 8px !important;
    border: 1px solid var(--tstn-inner-border) !important;
    background: var(--tstn-inner-card-bg) !important;
    background-color: var(--tstn-inner-card-bg) !important;
    box-shadow: none !important;
    color: #fff !important;
    height: auto !important;
    min-height: 110px !important;
    padding: clamp(16px, 1.8vw, 22px) !important;
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    justify-content: flex-start !important;
    gap: clamp(14px, 1.5vw, 20px) !important;
    cursor: pointer;
    text-align: left !important;
  }

  /* Icon — orange, left-aligned, fixed size */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card__icon,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card__icon.svelte-3ln76z.svelte-3ln76z {
    width: clamp(44px, 5vw, 56px) !important;
    height: clamp(44px, 5vw, 56px) !important;
    min-width: clamp(44px, 5vw, 56px) !important;
    border-radius: 0 !important;
    background: transparent !important;
    flex: 0 0 auto !important;
    color: var(--tstn-accent) !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  #shopify-section-{{ section_id }} .tstn-earn .gw-image,
  #shopify-section-{{ section_id }} .tstn-earn .gw-image__img,
  #shopify-section-{{ section_id }} .tstn-earn .gw-image__img.svelte-1ijgyj3.svelte-1ijgyj3 {
    object-fit: contain !important;
    width: 100% !important;
    height: 100% !important;
    max-width: 100% !important;
  }

  /* Right side text stack — left-aligned column */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card > .gw-layout-stack,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card .gw-layout-stack,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-card .gw-layout-block {
    flex: 1 1 auto !important;
    text-align: left !important;
    align-items: flex-start !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 6px !important;
    background: transparent !important;
  }

  /* Card title — uppercase white bold */
  #shopify-section-{{ section_id }} .tstn-earn .gw-layout-text--variant-base,
  #shopify-section-{{ section_id }} .tstn-earn .gw-layout-text--variant-base.svelte-yjnpd {
    font-family: 'Inter', 'ABC Diatype', -apple-system, sans-serif !important;
    font-weight: 700 !important;
    font-size: clamp(13px, 1.1vw, 14px) !important;
    color: #fff !important;
    text-transform: uppercase !important;
    letter-spacing: 0.04em !important;
    line-height: 1.35 !important;
    text-align: left !important;
    background: transparent !important;
    padding: 0 !important;
    border: none !important;
    box-shadow: none !important;
    width: auto !important;
    display: block !important;
  }

  /* Points number — large orange Danger Neue */
  #shopify-section-{{ section_id }} .tstn-earn .gw-layout-text--variant-secondary,
  #shopify-section-{{ section_id }} .tstn-earn .gw-layout-text--variant-secondary.svelte-yjnpd {
    font-family: 'Danger Neue Free Regular', sans-serif !important;
    font-weight: 400 !important;
    font-size: var(--tstn-points-size) !important;
    color: var(--tstn-accent) !important;
    text-transform: uppercase !important;
    letter-spacing: 0.02em !important;
    line-height: 1 !important;
    background: transparent !important;
    padding: 0 !important;
    border: none !important;
    box-shadow: none !important;
    width: auto !important;
    display: inline-block !important;
    text-align: left !important;
  }

  /* "Completed" pill — minimal */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-action-completed,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-action-completed.svelte-1klamai {
    font-family: 'Inter', 'ABC Diatype', -apple-system, sans-serif !important;
    font-weight: 600 !important;
    font-size: clamp(12px, 1vw, 13px) !important;
    color: #c9c9c9 !important;
    background: transparent !important;
    padding: 0 !important;
    border: none !important;
    box-shadow: none !important;
    text-transform: uppercase !important;
    letter-spacing: 0.06em !important;
    width: auto !important;
    display: inline-flex !important;
    align-items: center !important;
    gap: 6px !important;
    line-height: 1 !important;
  }

  /* Branding accents */
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-icon-branding-color {
    color: var(--tstn-accent) !important;
    border: none !important;
    border-radius: 0 !important;
  }

  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-icon-branding-color rect,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-icon-branding-color path,
  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-icon-branding-color circle {
    fill: var(--tstn-accent) !important;
  }

  #shopify-section-{{ section_id }} .tstn-earn .gw-btn--reset.gw-rd-action-btn--secondary:hover {
    background-color: var(--tstn-accent) !important;
  }

  #shopify-section-{{ section_id }} .tstn-earn .gw-rd-page-widget-modal-body__title {
    font-family: 'Danger Neue Free Regular', sans-serif !important;
    text-transform: uppercase !important;
  }

  /* ============================================
     RIGHT PANEL — SHARE & EARN
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-share {
    display: flex;
    flex-direction: column;
    gap: clamp(12px, 1.4vw, 18px);
  }

  #shopify-section-{{ section_id }} .tstn-share__image {
    width: 100%;
    overflow: hidden;
    border-radius: 8px;
    aspect-ratio: 16 / 9;
    background: #111;
  }

  #shopify-section-{{ section_id }} .tstn-share__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #shopify-section-{{ section_id }} .tstn-share__subheading {
    font-family: 'Inter', 'ABC Diatype', -apple-system, sans-serif;
    font-weight: 700;
    font-size: clamp(14px, 1.2vw, 16px);
    color: #fff;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
    line-height: 1.3;
  }

  #shopify-section-{{ section_id }} .tstn-share__description {
    font-family: 'Inter', 'ABC Diatype', -apple-system, sans-serif;
    font-size: clamp(13px, 1.1vw, 14px);
    color: var(--tstn-subheading-color);
    margin: 0;
    line-height: 1.55;
    opacity: 0.85;
  }

  /* ============================================
     REFER A FRIEND — Inner Card
     ============================================ */
  #shopify-section-{{ section_id }} .tstn-refer {
    background: var(--tstn-inner-card-bg) !important;
    border: 1px solid var(--tstn-inner-border);
    border-radius: 8px;
    padding: clamp(18px, 2vw, 26px);
    display: flex;
    flex-direction: column;
    gap: clamp(14px, 1.6vw, 20px);
  }

  #shopify-section-{{ section_id }} .tstn-refer__heading {
    font-family: 'Danger Neue Free Regular', sans-serif;
    font-weight: 400;
    font-size: clamp(20px, 2vw, 26px);
    color: #fff !important;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
    line-height: 1;
  }

  /* Numbered steps */
  #shopify-section-{{ section_id }} .tstn-refer__steps {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: clamp(8px, 1vw, 12px);
  }

  #shopify-section-{{ section_id }} .tstn-refer__steps li {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #d8d8d8;
    font-family: 'Inter', 'ABC Diatype', -apple-system, sans-serif;
    font-size: clamp(13px, 1.1vw, 14px);
    line-height: 1.4;
    background: transparent !important;
    padding: 0 !important;
    border: none !important;
  }

  #shopify-section-{{ section_id }} .tstn-refer__step-num {
    flex: 0 0 auto;
    width: 22px;
    height: 22px;
    border-radius: 50%;
    border: 1.5px solid var(--tstn-accent);
    color: var(--tstn-accent);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 700;
    line-height: 1;
    background: transparent;
  }

  #shopify-section-{{ section_id }} .tstn-refer__step-text {
    flex: 1 1 auto;
    color: #d8d8d8 !important;
  }

  /* Reward boxes — You Get / They Get */
  #shopify-section-{{ section_id }} .tstn-refer__rewards {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    border: 1px solid var(--tstn-inner-border);
    border-radius: 8px;
    background: rgba(255, 255, 255, 0.015) !important;
    overflow: hidden;
  }

  #shopify-section-{{ section_id }} .tstn-refer__reward {
    display: flex;
    flex-direction: column;
    gap: 6px;
    padding: clamp(14px, 1.6vw, 18px);
    background: transparent !important;
  }

  #shopify-section-{{ section_id }} .tstn-refer__reward-label {
    font-family: 'Inter', 'ABC Diatype', -apple-system, sans-serif !important;
    font-weight: 700 !important;
    font-size: clamp(11px, 1vw, 12px) !important;
    color: #b8b8b8 !important;
    text-transform: uppercase !important;
    letter-spacing: 0.06em !important;
    line-height: 1 !important;
    background: transparent !important;
    padding: 0 !important;
    border: none !important;
    display: block !important;
  }

  #shopify-section-{{ section_id }} .tstn-refer__reward-value {
    display: flex !important;
    align-items: baseline !important;
    gap: 6px !important;
    line-height: 1 !important;
    background: transparent !important;
    padding: 0 !important;
    border: none !important;
  }

  #shopify-section-{{ section_id }} .tstn-refer__reward-value strong {
    font-family: 'Danger Neue Free Regular', sans-serif !important;
    font-weight: 400 !important;
    font-size: clamp(20px, 2vw, 24px) !important;
    color: var(--tstn-accent) !important;
    line-height: 1 !important;
    background: transparent !important;
  }

  #shopify-section-{{ section_id }} .tstn-refer__reward-value em {
    font-style: normal !important;
    font-family: 'Inter', 'ABC Diatype', -apple-system, sans-serif !important;
    font-weight: 600 !important;
    font-size: clamp(11px, 1vw, 13px) !important;
