{%- comment -%}
  ============================================
  JS — MutationObserver to clean up Growave
  Hides any auth/dummy/login/signup elements that Growave
  injects DYNAMICALLY (after our CSS would have applied).
  Also strips any leftover step lists in the referral widget.
  ============================================
{%- endcomment -%}
<script>
  (function() {
    var sectionEl = document.getElementById('shopify-section-{{ section_id }}');
    if (!sectionEl) return;

    var hideSelectors = [
      '.gw-rd-page-widget-auth',
      '.gw-rd-popup-widget-auth',
      '.gw-rd-page-widget-signin',
      '.gw-rd-page-widget-login',
      '.gw-rd-page-widget-customer',
      '.gw-rd-page-widget-guest',
      '.gw-rd-action-btn--primary',
      '[class*="dummy"]',
      '[class*="placeholder-notice"]',
      '.gw-rd-dummy-notice',
      '.gw-rd-page-widget-notice',
      '.gw-rd-referral-program-page-widget__steps',
      '.gw-rd-referral-program-page-widget__benefits',
      '.gw-rd-referral-program-page-widget__benefit-item',
      '.gw-rd-page-widget-howto'
    ];

    function clean(root) {
      // Hide unwanted elements within the WAYS earn widget
      var waysContainer = root.querySelector('.tstn-earn__ways');
      if (waysContainer) {
        hideSelectors.forEach(function(sel) {
          waysContainer.querySelectorAll(sel).forEach(function(el) {
            el.style.setProperty('display', 'none', 'important');
          });
        });

        // Remove any list items containing sign up / log in buttons (auth gate cards)
        waysContainer.querySelectorAll('li.gw-rd-list__item').forEach(function(li) {
          var txt = (li.textContent || '').toLowerCase().trim();
          var hasButton = li.querySelector('button, a.gw-rd-action-btn, [class*="auth"]');
          if (hasButton && (txt.indexOf('sign up') !== -1 || txt.indexOf('log in') !== -1 || txt.indexOf('login') !== -1)) {
            // Only hide if it's clearly an auth gate (very short text)
            if (txt.length < 30) {
              li.style.setProperty('display', 'none', 'important');
            }
          }
        });
      }

      // Hide unwanted elements within the REFERRAL widget
      var referralContainer = root.querySelector('.tstn-referral');
      if (referralContainer) {
        hideSelectors.forEach(function(sel) {
          referralContainer.querySelectorAll(sel).forEach(function(el) {
            el.style.setProperty('display', 'none', 'important');
          });
        });

        // Hide any ordered/unordered lists that look like duplicated step instructions
        referralContainer.querySelectorAll('ol, ul.gw-rd-list').forEach(function(list) {
          list.style.setProperty('display', 'none', 'important');
        });
      }
    }

    // Initial pass
    clean(sectionEl);

    // Observer for dynamic Growave injection
    var observer = new MutationObserver(function() {
      clean(sectionEl);
    });

    observer.observe(sectionEl, {
      childList: true,
      subtree: true
    });

    // Also re-run after a small delay in case Growave hydrates late
    setTimeout(function() { clean(sectionEl); }, 500);
    setTimeout(function() { clean(sectionEl); }, 1500);
    setTimeout(function() { clean(sectionEl); }, 3000);
  })();
</script>

