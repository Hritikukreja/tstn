{%- liquid
  assign section_id = section.id
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign heading_color = section.settings.heading_color
  assign subheading_color = section.settings.subheading_color
  assign accent_color = section.settings.accent_color
  assign card_bg_start = section.settings.card_bg_start
  assign card_bg_end = section.settings.card_bg_end
  assign card_border_color = section.settings.card_border_color
  assign label_bg_color = section.settings.label_bg_color
  assign completed_bg_color = section.settings.completed_bg_color
  assign heading_font_size = section.settings.heading_font_size
  assign heading_font_size_mobile = section.settings.heading_font_size_mobile
  assign card_label_font_size = section.settings.card_label_font_size
  assign card_height = section.settings.card_height
  assign card_height_mobile = section.settings.card_height_mobile
  assign section_bg = section.settings.section_bg
  assign referral_heading = section.settings.referral_heading
  assign referral_subtext = section.settings.referral_subtext
  assign referral_image = section.settings.referral_image
-%}

{%- style -%}
  #shopify-section-{{ section_id }} {
    --tstn-accent: {{ accent_color }};
    --tstn-heading-color: {{ heading_color }};
    --tstn-subheading-color: {{ subheading_color }};
    --tstn-card-bg-start: {{ card_bg_start }};
    --tstn-card-bg-end: {{ card_bg_end }};
    --tstn-card-border: {{ card_border_color }};
    --tstn-label-bg: {{ label_bg_color }};
    --tstn-completed-bg: {{ completed_bg_color }};
    --tstn-section-bg: {{ section_bg }};
    --tstn-heading-size: {{ heading_font_size }}px;
    --tstn-heading-size-mobile: {{ heading_font_size_mobile }}px;
    --tstn-card-label-size: {{ card_label_font_size }}px;
    --tstn-card-height: {{ card_height }}px;
    --tstn-card-height-mobile: {{ card_height_mobile }}px;
  }

  .tstn-earn-{{ section_id }} {
    background: var(--tstn-section-bg);
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .tstn-earn-{{ section_id }} {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="tstn-earn tstn-earn-{{ section_id }} color-{{ section.settings.color_scheme }}">
  <div class="page-width">
    {%- if heading != blank or subheading != blank -%}
      <div class="tstn-earn__header">
        {%- if heading != blank -%}
          <h2 class="tstn-earn__heading">{{ heading }}</h2>
        {%- endif -%}
        {%- if subheading != blank -%}
          <p class="tstn-earn__subheading">{{ subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="tstn-earn__grid">
      {%- comment -%} Ways to Earn cards — rendered by Growave {%- endcomment -%}
      <div class="tstn-earn__ways">
        <div
          class="gw-rd-ways-to-earn-page-widget-placeholder"
          data-gw-widget-shadow-root-enabled="true"
          data-gw-show-points-balance="true"
          style="display: block"
        ></div>
      </div>

      {%- comment -%} Referral card — styled to match earn cards, sits as last cell {%- endcomment -%}
      <div class="tstn-earn__referral-slot">
        <div
          class="gw-rd-referral-program-page-widget-placeholder tstn-referral"
          {% if referral_image != blank %}
            data-gw-img-url="{{ referral_image | image_url: width: 600 }}"
          {% endif %}
          data-gw-widget-shadow-root-enabled="true"
          style="display: block"
        ></div>
      </div>
    </div>
  </div>
</div>

<style>
  /* ============================================
     HEADER
     ============================================ */
  .tstn-earn__header {
    text-align: center;
    margin-bottom: 40px;
  }

  .tstn-earn__heading {
    font-family: 'Danger Neue Free Regular', sans-serif;
    font-size: var(--tstn-heading-size);
    color: var(--tstn-heading-color);
    text-transform: uppercase;
    margin: 0 0 12px;
    letter-spacing: 0.02em;
    line-height: 1;
  }

  .tstn-earn__subheading {
    color: var(--tstn-subheading-color);
    font-size: 16px;
    margin: 0;
    opacity: 0.85;
  }

  /* ============================================
     GRID — 3 cols desktop, 2 tablet, 1 mobile
     The referral box lives in its own grid cell next to earn cards
     ============================================ */
  .tstn-earn__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 25px;
    align-items: start;
  }

  .tstn-earn__ways {
    min-width: 0;
  }

  .tstn-earn__referral-slot {
    min-width: 0;
  }

  @media (min-width: 990px) {
    .tstn-earn__grid {
      grid-template-columns: 2fr 1fr;
    }
  }

  /* ============================================
     WAYS TO EARN — Growave widget overrides
     ============================================ */
  .tstn-earn h2.gw-rd-page-widget-title,
  .tstn-earn .gw-rd-page-widget-customer-balance {
    display: none !important;
  }

  .tstn-earn .gw-rd-page-widget-layout,
  .tstn-earn .gw-rd-page-widget-container {
    max-width: 100% !important;
    padding: 0 !important;
    background: transparent !important;
  }

  .tstn-earn .gw-rd-ways-to-earn-page-widget {
    background: transparent !important;
  }

  /* Earn cards grid (inside the ways widget) */
  .tstn-earn .gw-rd-list {
    display: grid !important;
    grid-template-columns: repeat(2, 1fr) !important;
    gap: 20px !important;
    margin: 0 !important;
    padding: 0 !important;
    list-style: none !important;
  }

  .tstn-earn li.gw-rd-list__item {
    flex: unset !important;
    width: 100% !important;
    max-width: 100% !important;
    height: var(--tstn-card-height) !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* Earn card styling — dark gradient */
  .tstn-earn .gw-rd-page-widget-card,
  .tstn-earn .gw-rd-page-widget-card.svelte-3ln76z.svelte-3ln76z,
  .tstn-earn .gw-rd-page-widget-card--cursor-pointer.svelte-3ln76z.svelte-3ln76z {
    border-radius: 0 !important;
    border: 1px solid var(--tstn-card-border) !important;
    color: #fff !important;
    background: linear-gradient(135deg, var(--tstn-card-bg-start), var(--tstn-card-bg-end)) !important;
    background-color: var(--tstn-card-bg-start) !important;
    box-shadow: inset 0 0 0 1px rgba(254, 254, 254, 0.03) !important;
    height: var(--tstn-card-height) !important;
    display: flex !important;
    flex-direction: column !important;
    justify-content: space-around !important;
    cursor: pointer;
    overflow: hidden;
  }

  .tstn-earn .gw-rd-page-widget-card--completed.svelte-3ln76z.svelte-3ln76z {
    height: var(--tstn-card-height) !important;
  }

  .tstn-earn .gw-rd-page-widget-card__icon,
  .tstn-earn .gw-rd-page-widget-card__icon.svelte-3ln76z.svelte-3ln76z {
    width: 100% !important;
    height: 100% !important;
    border-radius: 0 !important;
    background: transparent !important;
  }

  .tstn-earn .gw-image__img,
  .tstn-earn .gw-image__img.svelte-1ijgyj3.svelte-1ijgyj3 {
    object-fit: contain !important;
  }

  .tstn-earn .gw-image.gw-image--loaded .gw-image__img {
    max-width: 80px !important;
  }

  /* Card body text */
  .tstn-earn .gw-layout-text--variant-base,
  .tstn-earn .gw-layout-text--variant-base.svelte-yjnpd {
    font-family: 'ABC Diatype', sans-serif !important;
    text-transform: uppercase !important;
    font-size: 14px !important;
    font-weight: 400 !important;
    color: #fff !important;
  }

  /* Points pill + Completed label */
  .tstn-earn .gw-layout-text--variant-secondary,
  .tstn-earn .gw-layout-text--variant-secondary.svelte-yjnpd,
  .tstn-earn .gw-rd-page-widget-action-completed,
  .tstn-earn .gw-rd-page-widget-action-completed.svelte-1klamai {
    font-family: 'Danger Neue Free Regular', sans-serif !important;
    font-size: var(--tstn-card-label-size) !important;
    text-transform: uppercase !important;
    color: #fff !important;
    background: var(--tstn-label-bg) !important;
    width: 100%;
    display: block !important;
    padding: 10px 0;
    border: 1px solid rgba(255, 255, 255, 0.09);
    line-height: normal !important;
    box-shadow: 0 2px 5px 0 rgba(255, 255, 255, 0.15) !important;
  }

  .tstn-earn .gw-rd-page-widget-action-completed,
  .tstn-earn .gw-rd-page-widget-action-completed.svelte-1klamai {
    display: flex !important;
    justify-content: center;
    align-items: center;
    background: var(--tstn-completed-bg) !important;
    padding: 20px 0;
  }

  /* Accent elements */
  .tstn-earn .gw-rd-icon-branding-color {
    color: var(--tstn-accent) !important;
    border: 1px solid #fff;
    border-radius: 50%;
  }

  .tstn-earn .gw-rd-icon-branding-color rect {
    fill: var(--tstn-accent) !important;
  }

  .tstn-earn .gw-btn--reset.gw-rd-action-btn--secondary:hover {
    background-color: var(--tstn-accent) !important;
  }

  .tstn-earn .gw-rd-page-widget-modal-body__title {
    font-family: 'Danger Neue Free Regular', sans-serif !important;
    text-transform: uppercase !important;
  }

  /* ============================================
     REFERRAL BOX — Styled like a dark earn card
     ============================================ */
  .tstn-earn__referral-slot {
    height: 100%;
  }

  .tstn-earn .tstn-referral {
    width: 100% !important;
    height: 100%;
    display: block;
  }

  /* Hide Growave's default referral title + benefits */
  .tstn-earn .tstn-referral .gw-rd-page-widget-title,
  .tstn-earn .tstn-referral .gw-rd-page-widget-title.svelte-tmdh8j,
  .tstn-earn .tstn-referral .gw-rd-referral-program-page-widget__benefits {
    display: none !important;
  }

  /* Make the referral widget container into a dark card */
  .tstn-earn .tstn-referral .gw-rd-page-widget-container,
  .tstn-earn .tstn-referral .gw-rd-page-widget-container.svelte-1mnbt6f {
    width: 100% !important;
    max-width: 100% !important;
    padding: 50px 20px 20px !important;
    background: linear-gradient(135deg, var(--tstn-card-bg-start), var(--tstn-card-bg-end)) !important;
    border: 1px solid var(--tstn-card-border) !important;
    border-radius: 0 !important;
    box-shadow: inset 0 0 0 1px rgba(254, 254, 254, 0.03) !important;
    position: relative;
  }

  /* Custom referral heading */
  .tstn-earn .tstn-referral .gw-rd-page-widget-container::before {
    content: '{{ referral_heading | escape }}';
    display: block;
    position: absolute;
    top: 20px;
    left: 0;
    right: 0;
    color: var(--tstn-accent);
    text-align: center;
    font-size: 30px;
    font-family: 'Danger Neue Free Regular', sans-serif;
    text-transform: uppercase;
    line-height: 1;
  }

  /* Custom referral subtext */
  .tstn-earn .tstn-referral .gw-rd-page-widget-container::after {
    content: '{{ referral_subtext | escape }}';
    display: block;
    margin-top: 16px;
    text-align: center;
    width: 100%;
    text-transform: uppercase;
    color: #fff;
    font-family: 'Danger Neue Free Regular', sans-serif !important;
    font-size: 13px;
    line-height: 1.4;
    letter-spacing: 0.02em;
  }

  .tstn-earn .tstn-referral .gw-rd-referral-program-page-widget {
    width: 100% !important;
    margin: 0 !important;
    background: transparent !important;
    border: none !important;
  }

  /* Referral inner text */
  .tstn-earn .tstn-referral .gw-layout-text--variant-secondary,
  .tstn-earn .tstn-referral .gw-layout-text--variant-primary {
    font-family: 'Danger Neue Free Regular', sans-serif !important;
    text-transform: uppercase !important;
    font-size: 15px !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    padding: 4px 0 !important;
  }

  .tstn-earn .tstn-referral .gw-layout-text--variant-secondary {
    color: #fff !important;
  }

  .tstn-earn .tstn-referral .gw-layout-text--variant-primary {
    color: var(--tstn-accent) !important;
  }

  .tstn-earn .gw-rd-copy-field .gw-rd-text-field .gw-rd-text-field__input {
    color: var(--tstn-accent) !important;
  }

  .tstn-earn .gw-rd-popup-widget-referral-program__reward {
    border: 1px solid var(--tstn-card-border) !important;
  }

  .tstn-earn .gw-rd-text-field {
    border: 1px solid var(--tstn-card-border) !important;
  }

  .tstn-earn .gw-rd-copy-icon-btn {
    background: #5b5b5b !important;
  }

  .tstn-earn .gw-tooltip-content.gw-tooltip-light {
    background: #5b5b5b;
  }

  /* ============================================
     RESPONSIVE
     ============================================ */
  @media (max-width: 989px) {
    .tstn-earn .gw-rd-list {
      grid-template-columns: repeat(2, 1fr) !important;
    }
  }

  @media (max-width: 767px) {
    .tstn-earn__heading {
      font-size: var(--tstn-heading-size-mobile);
    }

    .tstn-earn__grid {
      gap: 20px;
    }

    .tstn-earn .gw-rd-list {
      grid-template-columns: 1fr !important;
      gap: 20px !important;
    }

    .tstn-earn li.gw-rd-list__item,
    .tstn-earn .gw-rd-page-widget-card,
    .tstn-earn .gw-rd-page-widget-card.svelte-3ln76z.svelte-3ln76z {
      height: var(--tstn-card-height-mobile) !important;
    }

    .tstn-earn .gw-rd-page-widget-card,
    .tstn-earn .gw-rd-page-widget-card.svelte-3ln76z.svelte-3ln76z {
      padding: 10px !important;
    }

    .tstn-earn .gw-layout-text--variant-secondary,
    .tstn-earn .gw-rd-page-widget-action-completed {
      font-size: 18px !important;
      padding: 11px 0 !important;
    }

    .tstn-earn .gw-image.gw-image--loaded .gw-image__img {
      max-width: 56px !important;
    }
  }
</style>

{% schema %}
{
  "name": "Ways To Earn",
  "tag": "section",
  "class": "section-tstn-earn",
  "settings": [
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Section Heading",
      "default": "Ways To Earn"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Section Subtext",
      "default": "Earn points every time you shop, share, and engage."
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "min": 24,
      "max": 96,
      "step": 2,
      "unit": "px",
      "label": "Heading Size (Desktop)",
      "default": 48
    },
    {
      "type": "range",
      "id": "heading_font_size_mobile",
      "min": 18,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading Size (Mobile)",
      "default": 30
    },

    {
      "type": "header",
      "content": "Referral Card"
    },
    {
      "type": "text",
      "id": "referral_heading",
      "label": "Referral Heading",
      "default": "REFER A FRIEND"
    },
    {
      "type": "text",
      "id": "referral_subtext",
      "label": "Referral Reward Text",
      "default": "You get 500 points once your friend makes a purchase"
    },
    {
      "type": "image_picker",
      "id": "referral_image",
      "label": "Referral Image (optional)"
    },

    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "section_bg",
      "label": "Section Background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#CCCCCC"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#EC560A"
    },
    {
      "type": "color",
      "id": "card_bg_start",
      "label": "Card Background (Start)",
      "default": "#0E0E0E"
    },
    {
      "type": "color",
      "id": "card_bg_end",
      "label": "Card Background (End)",
      "default": "#141414"
    },
    {
      "type": "color",
      "id": "card_border_color",
      "label": "Card Border Color",
      "default": "#303030"
    },
    {
      "type": "color",
      "id": "label_bg_color",
      "label": "Card Label Background",
      "default": "#1A1A1A"
    },
    {
      "type": "color",
      "id": "completed_bg_color",
      "label": "Completed Card Background",
      "default": "#EC560A"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },

    {
      "type": "header",
      "content": "Card Settings"
    },
    {
      "type": "range",
      "id": "card_label_font_size",
      "min": 14,
      "max": 48,
      "step": 2,
      "unit": "px",
      "label": "Card Label Size",
      "default": 30
    },
    {
      "type": "range",
      "id": "card_height",
      "min": 200,
      "max": 500,
      "step": 10,
      "unit": "px",
      "label": "Card Height (Desktop)",
      "default": 330
    },
    {
      "type": "range",
      "id": "card_height_mobile",
      "min": 160,
      "max": 400,
      "step": 10,
      "unit": "px",
      "label": "Card Height (Mobile)",
      "default": 220
    },

    {
      "type": "header",
      "content": "Section Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Ways To Earn",
      "category": "Rewards"
    }
  ]
}
{% endschema %}
