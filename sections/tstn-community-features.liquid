{% comment %}
  TSTN Community Features
  - Single dark card row
  - Left: Heading "More Than Content. It's a Community."
  - Right: 4 feature blocks (icon + title + short copy)
{% endcomment %}

<style>
  @font-face {
    font-family: 'Danger Neue Free Regular';
    src: url('https://cdn.shopify.com/s/files/1/0000/0000/files/danger-neue-free-regular.woff2?v=1') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --tstn-orange: #F56300;
    --tstn-bg: #0a0a0a;
    --tstn-card-bg: #111111;
    --tstn-text: #ffffff;
    --tstn-muted: #b0b0b0;
    --tstn-border: rgba(255,255,255,0.1);
    --tstn-font-display: "Danger Neue Free Regular", "Inter", sans-serif;
  }

  .tstn-cf {
    background: var(--tstn-bg);
    color: var(--tstn-text);
    padding: clamp(20px, 3vw, 30px) clamp(16px, 4vw, 40px);
  }
  .tstn-cf__inner {
    max-width: 1400px;
    margin: 0 auto;
    background: var(--tstn-card-bg);
    border: 1px solid var(--tstn-border);
    border-radius: 16px;
    padding: clamp(28px, 3.5vw, 44px);
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: clamp(28px, 4vw, 56px);
    align-items: center;
  }

  .tstn-cf__heading {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(22px, 2.4vw, 30px);
    margin: 0;
    line-height: 1.2;
    letter-spacing: 0.5px;
  }

  .tstn-cf__features {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(16px, 2vw, 28px);
  }

  .tstn-cf__feature {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .tstn-cf__icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--tstn-orange);
    margin-bottom: 6px;
  }
  .tstn-cf__feat-title {
    font-size: 14px;
    font-weight: 700;
    margin: 0;
    color: var(--tstn-text);
  }
  .tstn-cf__feat-text {
    font-size: 12px;
    color: var(--tstn-muted);
    line-height: 1.5;
    margin: 0;
  }

  /* Mobile */
  @media (max-width: 1000px) {
    .tstn-cf__inner { grid-template-columns: 1fr; }
    .tstn-cf__features { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .tstn-cf__features { grid-template-columns: 1fr; gap: 20px; }
  }
</style>

<section class="tstn-cf">
  <div class="tstn-cf__inner">

    <h2 class="tstn-cf__heading">{{ section.settings.heading | default: "More Than Content. It's a Community." }}</h2>

    <div class="tstn-cf__features">
      {% for block in section.blocks %}
        {% if block.type == 'feature' %}
          <div class="tstn-cf__feature" {{ block.shopify_attributes }}>
            <div class="tstn-cf__icon">
              {%- case block.settings.icon -%}
                {%- when 'chat' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path></svg>
                {%- when 'heart' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"></path></svg>
                {%- when 'star' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
                {%- when 'users' -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"></path><circle cx="9" cy="7" r="4"></circle><path d="M23 21v-2a4 4 0 0 0-3-3.87"></path><path d="M16 3.13a4 4 0 0 1 0 7.75"></path></svg>
                {%- else -%}
                  <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle></svg>
              {%- endcase -%}
            </div>
            <h3 class="tstn-cf__feat-title">{{ block.settings.title }}</h3>
            <p class="tstn-cf__feat-text">{{ block.settings.text }}</p>
          </div>
        {% endif %}
      {% endfor %}
    </div>

  </div>
</section>

{% schema %}
{
  "name": "TSTN Community Features",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "More Than Content. It's a Community." }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature",
      "settings": [
        {
          "type": "select",
          "id": "icon",
          "label": "Icon",
          "default": "chat",
          "options": [
            { "value": "chat", "label": "Chat" },
            { "value": "heart", "label": "Heart" },
            { "value": "star", "label": "Star" },
            { "value": "users", "label": "Users" }
          ]
        },
        { "type": "text", "id": "title", "label": "Title", "default": "Feature Title" },
        { "type": "textarea", "id": "text", "label": "Description", "default": "Short feature description." }
      ]
    }
  ],
  "max_blocks": 4,
  "presets": [
    {
      "name": "TSTN Community Features",
      "blocks": [
        { "type": "feature", "settings": { "icon": "chat", "title": "Real Conversations", "text": "Connect and grow with like-minded people." } },
        { "type": "feature", "settings": { "icon": "heart", "title": "Challenges & Events", "text": "Participate in fun challenges and exclusive events." } },
        { "type": "feature", "settings": { "icon": "star", "title": "Support & Motivation", "text": "Get support, share wins, and stay accountable." } },
        { "type": "feature", "settings": { "icon": "users", "title": "Grow Together", "text": "We rise by lifting each other." } }
      ]
    }
  ]
}
{% endschema %}
