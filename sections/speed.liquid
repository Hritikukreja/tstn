<script>
(function(){
  function extractPointsFromText(text){var m=String(text||'').replace(/,/g,'').match(/\d+/g);return m&&m.length?Math.max.apply(null,m.map(Number)):null;}
  function findGrowavePoints(){var s=['.gw-rd-customer-points-balance-inline-widget-placeholder','.gw-rd-customer-points-balance','[class*="points-balance"]','[class*="gw-rd"]'];for(var i=0;i<s.length;i++){var e=document.querySelectorAll(s[i]);for(var j=0;j<e.length;j++){var n=extractPointsFromText(e[j].textContent||e[j].innerText);if(n!==null)return n;}}return null;}
  function forceSetPoints(n){if(n===null||isNaN(n))return;if(typeof setValue==='function')setValue(Number(n));var v=document.querySelector('#tstnVisualPoints');if(v)v.textContent=Number(n).toLocaleString();var g=document.querySelector('#center_gauge_value');if(g)g.textContent=Number(n).toLocaleString();}
  var tries=0,t=setInterval(function(){tries++;var n=findGrowavePoints();if(n!==null)forceSetPoints(n);if(tries>80||n!==null)clearInterval(t);},250);
  document.addEventListener('DOMContentLoaded',function(){setTimeout(function(){forceSetPoints(findGrowavePoints());},700);setTimeout(function(){forceSetPoints(findGrowavePoints());},1800);setTimeout(function(){forceSetPoints(findGrowavePoints());},3500);});
})();
</script>
