{% comment %} 
/************ Main Widget - Redesigned to match attached image exactly ************/ 
{% endcomment %}

<div class="visibility_hidden">
  <span
    class="gw-rd-customer-points-balance-inline-widget-placeholder"
    data-gw-enable-points-name="true"
    style="display: block"
  ></span>
</div>

<div class="growave_tiers_wrapper tstn-club-dashboard {% unless customer %} non_customer_class {% endunless %}">
  
  {% if section.settings.feat_image != blank %}
    <img 
      src="{{ section.settings.feat_image | img_url: 'master' }}" 
      class="dashboard-background"
      alt="TSTN Club Dashboard Background"
    >
  {% endif %}

  <div class="dashboard-overlay">
    
    <!-- Top Navigation (matches image exactly) -->
    <div class="top-navigation">
      <div class="logo-wrapper">
        <img src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/TSTN_logo_white.png?v=1770384836" alt="TSTN" class="tbtn-logo">
      </div>
      <nav class="main-nav">
        <a href="#" class="nav-item">HOME</a>
        <a href="#" class="nav-item active">TSTN CLUB</a>
        <a href="#" class="nav-item">MERCH</a>
        <a href="#" class="nav-item">BRANDS</a>
        <a href="#" class="nav-item">COLLECTION</a>
      </nav>
      <div class="nav-actions">
        <button class="icon-btn search-btn">🔎</button>
        <button class="icon-btn account-btn">👤</button>
        <button class="icon-btn cart-btn">🛒</button>
