                  <div class="gauge-content">
                    <img id="tier_diagram" src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_1_a6b1bf9c-5113-4864-b2aa-53fb77a68341.png?v=1770810715" class="tier-badge" alt="Tier Badge">
                  </div>
