{% if customer %}
  {% assign vip_tier = customer.metafields["app--144550"]["growave_vip_tier"] %}
  {% if vip_tier != blank %}
    <div class="vip_tier_new_updated" style="display: none;">{{ vip_tier }}</div>
  {% endif %}
{% endif %}

<div class="visibility_hidden">
  <span class="gw-rd-customer-points-balance-inline-widget-placeholder" data-gw-enable-points-name="true" style="display: block"></span>
</div>

<div class="tstn-club-dashboard {% unless customer %} non_customer_class {% endunless %}">
  
  {% if section.settings.feat_image != blank %}
    <img src="{{ section.settings.feat_image | img_url: 'master' }}" class="dashboard-bg" alt="">
  {% endif %}

  <div class="dashboard-content">
    
    <!-- Top Navigation -->
    <div class="top-nav">
      <div class="logo">
        <img src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/TSTN_logo_white.png?v=1770384836" alt="TSTN">
      </div>
      <nav>
        <a href="#">HOME</a>
        <a href="#" class="active">TSTN CLUB</a>
        <a href="#">MERCH</a>
        <a href="#">BRANDS</a>
        <a href="#">COLLECTION</a>
      </nav>
      <div class="icons">
        <span>🔍</span>
        <span>👤</span>
        <span>🛒</span>
      </div>
    </div>

    <div class="main-section">
      
      <!-- Left Panel -->
      <div class="left-panel">
        <div class="welcome-box">
          <div class="main_wrapper_new">
            <img src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/image_1_1_76d32aab-2b4e-4c68-a411-5a2a219321bf.png?v=1770384836" alt="">
            <p>WELCOME TO TSTN CLUB</p>
          </div>
          <p class="subtitle">Join the club. Earn points for every lighting or recovery upgrade and level up your journey with TSTN.</p>
          
          <div class="action-btns">
            <a href="#" class="btn orange-btn">HOW IT WORKS →</a>
            <a href="/collections/all" class="btn white-btn">SHOP MERCH</a>
          </div>
        </div>

        <div class="badges">
          <div class="badge"><span>⭐</span> EARN POINTS<br><small>For every upgrade</small></div>
          <div class="badge"><span>🏆</span> LEVEL UP<br><small>Unlock rewards</small></div>
          <div class="badge"><span>🔒</span> EXCLUSIVE<br><small>Club benefits</small></div>
        </div>
      </div>

      <!-- Center Gauges -->
      <div class="gauges-container">
        <div class="cluster-bar">
          <span id="modeText">COMFORT</span>
          <span id="gearText">P</span>
          <span id="tempText">28°C</span>
          <span id="timeText">14:18</span>
          <span id="engineText">22C</span>
          <div class="airbag">AIR BAG</div>
          <div class="battery">
            <svg viewBox="0 0 512 512" fill="#fff"><path d="M315.27 33L96 304h128l-31.51 173.23a2.36 2.36 0 002.33 2.77h0a2.36 2.36 0 001.89-.95L416 208H288l31.66-173.25a2.45 2.45 0 00-2.44-2.75h0a2.42 2.42 0 00-1.95 1z"></path></svg>
          </div>
        </div>

        <div class="gauges-wrapper">
          <!-- Left Gauge -->
          <div class="gauge small">
            <svg id="leftGauge" viewBox="0 0 200 200" class="gauge-svg"></svg>
          </div>
          
          <!-- Center Gauge -->
          <div class="gauge large">
            <svg id="centerGauge" viewBox="0 0 200 200" class="gauge-svg"></svg>
          </div>
          
          <!-- Right Tier -->
          <div class="gauge small tier-badge">
            <img id="tier_diagram" src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_1_a6b1bf9c-5113-4864-b2aa-53fb77a68341.png?v=1770810715" alt="">
          </div>
        </div>
      </div>

      <!-- Right Panel -->
      <div class="right-panel">
        <div class="tier-info">
          <div class="tier-label">BASE CAMP</div>
          <div class="progress-container">
            <div id="meterFill" class="progress-fill"></div>
            <div class="tier-markers">
              <span>BASE CAMP</span>
              <span>SCOUT</span>
              <span>LEAD</span>
            </div>
          </div>
        </div>

        <div class="points-box">
          <div class="points-label">YOUR TSTN POINTS</div>
          <div id="points-output" class="points-number">1,250</div>
          <p class="points-hint">Keep upgrading. Keep earning.</p>
        </div>
      </div>
    </div>

    <!-- How It Works -->
    <div class="how-it-works">
      <div class="hiw-header">
        <h3>HOW IT WORKS</h3>
        <a href="#" class="view-benefits">VIEW ALL BENEFITS →</a>
      </div>
      <div class="steps">
        <div class="step"><div class="num">01</div><div class="icon">🛍️</div><strong>SHOP</strong><small>Buy eligible products</small></div>
        <div class="step"><div class="num">02</div><div class="icon">⭐</div><strong>EARN</strong><small>For every purchase</small></div>
        <div class="step"><div class="num">03</div><div class="icon">🏆</div><strong>LEVEL UP</strong><small>Unlock rewards</small></div>
        <div class="step"><div class="num">04</div><div class="icon">🎁</div><strong>REDEEM</strong><small>Merch & discounts</small></div>
      </div>
    </div>
  </div>
</div>

{% unless customer %}
<!-- Non-logged in version (keep your original) -->
<div class="none_customer_signup"> ... your existing code ... </div>
{% endunless %}

<style>
  .tstn-club-dashboard {
    position: relative;
    height: 100vh;
    min-height: 920px;
    background: #0a0a0a;
    overflow: hidden;
    border-radius: 12px;
  }
  .dashboard-bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.65);
    z-index: 1;
  }
  .dashboard-content { position: relative; z-index: 2; height: 100%; display: flex; flex-direction: column; }

  .top-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 40px;
    background: rgba(10,10,10,0.95);
    border-bottom: 1px solid rgba(255,255,255,0.08);
  }
  .top-nav nav a {
    color: #fff;
    margin: 0 20px;
    text-decoration: none;
    font-weight: 500;
  }
  .top-nav nav a.active { color: #ec5607; }

  .main-section {
    display: flex;
    flex: 1;
    padding: 40px;
    gap: 40px;
    align-items: flex-start;
  }
  .left-panel { flex: 1; max-width: 380px; }
  .gauges-container { flex: 2; display: flex; flex-direction: column; align-items: center; }
  .right-panel { flex: 1; max-width: 340px; }

  .cluster-bar {
    background: rgba(0,0,0,0.7);
    padding: 10px 30px;
    border-radius: 50px;
    display: flex;
    align-items: center;
    gap: 20px;
    font-size: 13.5px;
    margin-bottom: 20px;
  }

  .gauges-wrapper {
    display: flex;
    align-items: center;
    gap: 30px;
  }
  .gauge { position: relative; }
  .gauge.small { width: 160px; }
  .gauge.large { width: 280px; }
  .gauge-svg { width: 100%; height: auto; }

  .tier-badge img {
    width: 100%;
    border-radius: 50%;
    border: 6px solid #ec5607;
  }

  .progress-container {
    background: #1a1a1a;
    border-radius: 30px;
    height: 12px;
    position: relative;
    margin: 12px 0;
  }
  #meterFill {
    position: absolute;
    height: 100%;
    background: linear-gradient(90deg, #ec5607, #ff9f00);
    border-radius: 30px;
    transition: width 1.2s ease;
  }
  .tier-markers {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    margin-top: 6px;
    color: #aaa;
  }
  .tier-markers span:nth-child(1) { color: #ec5607; }

  .points-box {
    background: rgba(236, 86, 7, 0.1);
    border: 1px solid #ec5607;
    border-radius: 12px;
    padding: 24px;
    text-align: center;
    margin-top: 20px;
  }
  .points-number {
    font-size: 52px;
    font-weight: 700;
    color: #ec5607;
    line-height: 1;
  }

  .how-it-works {
    padding: 0 40px 40px;
    background: rgba(0,0,0,0.6);
  }
  .steps {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }
  .step {
    text-align: center;
    color: #ddd;
  }
  .step .num {
    background: #ec5607;
    color: black;
    width: 26px;
    height: 26px;
    border-radius: 50%;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    margin-bottom: 10px;
  }

  @media (max-width: 1100px) {
    .main-section { flex-direction: column; padding: 20px; }
    .gauges-wrapper { gap: 15px; }
    .gauge.small { width: 130px; }
    .gauge.large { width: 220px; }
    .steps { grid-template-columns: repeat(2, 1fr); }
  }
</style>

