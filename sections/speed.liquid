            <div id="meterFill" class="progress-fill"></div>
            <div class="tier-markers">
              <div class="tier-marker active" data-tier="base">BASE CAMP</div>
              <div class="tier-marker" data-tier="scout">SCOUT</div>
              <div class="tier-marker" data-tier="lead">LEAD</div>
