{% comment %}theme-check-disable UndefinedObject{% endcomment %}
{{ 'section-footer.css' | asset_url | stylesheet_tag }}
{{ 'component-newsletter.css' | asset_url | stylesheet_tag }}
{{ 'component-list-menu.css' | asset_url | stylesheet_tag }}
{{ 'component-list-payment.css' | asset_url | stylesheet_tag }}
{{ 'component-list-social.css' | asset_url | stylesheet_tag }}

{%- style -%}
  @import url('https://fonts.cdnfonts.com/css/danger-neue');
  @import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300&family=Montserrat:wght@300;400;500&display=swap');

  /* ═══════════════════════════════════════════════
     TSTN FOOTER — CINEMATIC REDESIGN
  ═══════════════════════════════════════════════ */

  :root {
    --tstn-gold:       #b8922a;
    --tstn-gold-lt:    rgba(184,146,42,0.18);
    --tstn-gold-glow:  rgba(184,146,42,0.06);
    --tstn-white:      #ffffff;
    --tstn-dim:        rgba(255,255,255,0.38);
    --tstn-muted:      rgba(255,255,255,0.18);
    --tstn-border:     rgba(255,255,255,0.07);
    --tstn-bg:         #060606;
  }

  /* ── WRAPPER ── */
  .tstn-footer {
    position: relative;
    background: var(--tstn-bg);
    overflow: hidden;
    margin-top: {{ section.settings.margin_top | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .tstn-footer {
      margin-top: {{ section.settings.margin_top }}px;
    }
  }

  /* ── CINEMATIC TOP SHIMMER RULE ── */
  .tstn-footer__rule {
    position: absolute;
    top: 0; left: 0; right: 0;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent 0%,
      var(--tstn-muted) 20%,
      var(--tstn-gold) 50%,
      var(--tstn-muted) 80%,
      transparent 100%
    );
    z-index: 3;
  }

  /* ── BACKGROUND WATERMARK LOGO ── */
  .tstn-footer__bg-logo {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    pointer-events: none;
    z-index: 1;
  }

  .tstn-footer__bg-logo img {
    width: {{ section.settings.bg_logo_size }}%;
    max-width: 900px;
    height: auto;
    opacity: {{ section.settings.bg_logo_opacity | divided_by: 100.0 }};
    filter: grayscale(1) brightness(2);
    object-fit: contain;
    display: block;
  }

  /* ── GRAIN TEXTURE ── */
  .tstn-footer__grain {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)' opacity='0.04'/%3E%3C/svg%3E");
    opacity: 0.55;
  }

  /* ── RADIAL VIGNETTE ── */
  .tstn-footer__vignette {
    position: absolute;
    inset: 0;
    z-index: 2;
    pointer-events: none;
    background: radial-gradient(
      ellipse 80% 100% at 50% 100%,
      transparent 30%,
      rgba(0,0,0,0.7) 100%
    );
  }

  /* ── MAIN CONTENT ── */
  .tstn-footer__inner {
    position: relative;
    z-index: 4;
    max-width: var(--page-width, 1280px);
    margin: 0 auto;
    padding: {{ section.settings.padding_top }}px 2.5rem {{ section.settings.padding_bottom }}px;
  }

  @media screen and (max-width: 749px) {
    .tstn-footer__inner {
      padding: 3rem 1.25rem 2rem;
    }
  }

  /* ── BRAND ROW ── */
  .tstn-footer__brand {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    padding-bottom: 3rem;
    gap: 0.85rem;
    animation: tstnFadeUp 0.9s ease both;
  }

  .tstn-footer__brand-logo img {
    height: 56px;
    width: auto;
    filter: brightness(0) invert(1);
    opacity: 0.9;
    display: block;
  }

  .tstn-footer__brand-name {
    font-family: 'Danger Neue', 'Impact', sans-serif;
    font-size: clamp(2.6rem, 7vw, 5.5rem);
    letter-spacing: 0.3em;
    color: var(--tstn-white);
    line-height: 1;
    text-transform: uppercase;
    margin: 0;
    text-shadow: 0 0 80px rgba(184,146,42,0.15);
  }

  .tstn-footer__brand-tagline {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-style: italic;
    font-size: 1.05rem;
    letter-spacing: 0.25em;
    color: var(--tstn-gold);
    text-transform: uppercase;
    margin: 0;
  }

  /* ── HORIZONTAL NAV ── */
  .tstn-footer__nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 0;
    padding: 1.75rem 0;
    border-top: 1px solid var(--tstn-border);
    border-bottom: 1px solid var(--tstn-border);
    animation: tstnFadeUp 0.9s 0.1s ease both;
  }

  .tstn-footer__nav-item {
    display: flex;
    align-items: center;
  }

  .tstn-footer__nav-item + .tstn-footer__nav-item::before {
    content: '';
    display: inline-block;
    width: 4px;
    height: 4px;
    border-radius: 50%;
    background: var(--tstn-gold);
    opacity: 0.5;
    margin: 0 1.25rem;
    flex-shrink: 0;
  }

  .tstn-footer__nav-link {
    font-family: 'Montserrat', sans-serif;
    font-weight: 400;
    font-size: 0.82rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.6) !important;
    text-decoration: none !important;
    transition: color 0.3s ease;
    white-space: nowrap;
    display: inline-block;
    padding: 0.2rem 0;
  }

  .tstn-footer__nav-link:hover {
    color: var(--tstn-white) !important;
  }

  .tstn-footer__nav-link.active {
    color: var(--tstn-gold) !important;
  }

  @media screen and (max-width: 600px) {
    .tstn-footer__nav {
      gap: 0.25rem 0;
    }
    .tstn-footer__nav-item + .tstn-footer__nav-item::before {
      margin: 0 0.75rem;
    }
    .tstn-footer__nav-link {
      font-size: 0.72rem;
    }
  }

  /* ── MIDDLE ROW ── */
  .tstn-footer__mid {
    display: grid;
    grid-template-columns: 1fr 1px 1fr;
    gap: 3rem;
    padding: 3.5rem 0;
    align-items: start;
    animation: tstnFadeUp 0.9s 0.2s ease both;
  }

  @media screen and (max-width: 860px) {
    .tstn-footer__mid {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
    }
    .tstn-footer__mid-divider {
      display: none;
    }
  }

  /* Thin vertical divider */
  .tstn-footer__mid-divider {
    width: 1px;
    align-self: stretch;
    background: linear-gradient(180deg, transparent, var(--tstn-border) 30%, var(--tstn-border) 70%, transparent);
  }

  /* ── SECTION LABEL ── */
  .tstn-footer__section-label {
    font-family: 'Danger Neue', 'Impact', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.35em;
    text-transform: uppercase;
    color: var(--tstn-gold);
    display: block;
    margin-bottom: 0.75rem;
  }

  /* ── NEWSLETTER ── */
  .tstn-footer__newsletter-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 300;
    font-size: 1.6rem;
    letter-spacing: 0.04em;
    color: var(--tstn-white);
    margin: 0 0 1.4rem;
    line-height: 1.35;
  }

  .tstn-footer__nl-form .tstn-field {
    display: flex;
    border: 1px solid rgba(255,255,255,0.15);
    background: rgba(255,255,255,0.04);
    max-width: 360px;
    transition: border-color 0.3s;
  }

  @media screen and (max-width: 860px) {
    .tstn-footer__nl-form .tstn-field {
      margin: 0 auto;
    }
  }

  .tstn-footer__nl-form .tstn-field:focus-within {
    border-color: rgba(184,146,42,0.55);
  }

  .tstn-footer__nl-form input[type="email"] {
    background: transparent;
    border: none;
    outline: none;
    color: var(--tstn-white);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.08em;
    padding: 0.9rem 1.1rem;
    flex: 1;
    min-width: 0;
  }

  .tstn-footer__nl-form input[type="email"]::placeholder {
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
  }

  .tstn-footer__nl-form label {
    display: none;
  }

  .tstn-footer__nl-form button[type="submit"] {
    background: transparent;
    border: none;
    border-left: 1px solid rgba(255,255,255,0.12);
    color: var(--tstn-gold);
    font-family: 'Danger Neue', 'Impact', sans-serif;
    font-size: 0.75rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    padding: 0 1.3rem;
    cursor: pointer;
    transition: background 0.3s, color 0.3s;
    white-space: nowrap;
  }

  .tstn-footer__nl-form button[type="submit"]:hover {
    background: var(--tstn-gold-lt);
    color: var(--tstn-white);
  }

  .newsletter-form__message {
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    margin-top: 0.7rem;
    color: var(--tstn-dim);
  }

  /* ── SOCIAL ── */
  .tstn-footer__social {}

  /* The Dawn social-icons snippet renders a <ul class="list-social"> with <li> items.
     We override everything here to force a clean horizontal row. */
  .tstn-footer__social-icons,
  .tstn-footer__social-icons.list-social {
    display: flex !important;
    flex-direction: row !important;
    flex-wrap: wrap !important;
    gap: 0.65rem !important;
    list-style: none !important;
    padding: 0 !important;
    margin: 0.6rem 0 0 !important;
    align-items: center !important;
  }

  @media screen and (max-width: 860px) {
    .tstn-footer__social-icons,
    .tstn-footer__social-icons.list-social {
      justify-content: center !important;
    }
  }

  /* Each list item */
  .tstn-footer__social-icons li,
  .tstn-footer__social-icons .list-social__item {
    display: block !important;
    width: auto !important;
    height: auto !important;
    margin: 0 !important;
    padding: 0 !important;
    border-radius: 0 !important;
    background: none !important;
  }

  /* The actual link inside each item */
  .tstn-footer__social-icons .list-social__link,
  .tstn-footer__social-icons a {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 42px !important;
    height: 42px !important;
    border: 1px solid rgba(255,255,255,0.12) !important;
    border-radius: 0 !important;
    background: rgba(255,255,255,0.03) !important;
    color: rgba(255,255,255,0.5) !important;
    text-decoration: none !important;
    transition: border-color 0.3s, color 0.3s, background 0.3s !important;
    /* Kill any Dawn circular styling */
    box-shadow: none !important;
    overflow: visible !important;
  }

  .tstn-footer__social-icons .list-social__link:hover,
  .tstn-footer__social-icons a:hover {
    border-color: rgba(184,146,42,0.6) !important;
    color: var(--tstn-gold) !important;
    background: rgba(184,146,42,0.08) !important;
  }

  /* SVG icons inside links */
  .tstn-footer__social-icons .icon,
  .tstn-footer__social-icons svg {
    width: 18px !important;
    height: 18px !important;
    fill: currentColor !important;
    display: block !important;
  }
  
  /* Kill Dawn's default circular button on social icons */
  .tstn-footer__social-icons .list-social__item .list-social__link {
    border-radius: 0 !important;
  }

  /* ── BOTTOM BAR ── */
  .tstn-footer__bottom {
    border-top: 1px solid var(--tstn-border);
    padding-top: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    animation: tstnFadeUp 0.9s 0.3s ease both;
  }

  @media screen and (max-width: 600px) {
    .tstn-footer__bottom {
      flex-direction: column;
      align-items: center;
      text-align: center;
    }
  }

  .tstn-footer__copy {
    font-family: 'Montserrat', sans-serif;
    font-size: 0.72rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.25);
  }

  .tstn-footer__payments .list-payment {
    display: flex;
    gap: 0.4rem;
    list-style: none;
    padding: 0;
    margin: 0;
    flex-wrap: wrap;
    align-items: center;
  }

  .tstn-footer__payments .list-payment__item svg,
  .tstn-footer__payments .list-payment__item img {
    height: 20px;
    width: auto;
    opacity: 0.22;
    filter: grayscale(1) brightness(2);
    transition: opacity 0.2s;
  }

  .tstn-footer__payments .list-payment__item:hover svg,
  .tstn-footer__payments .list-payment__item:hover img {
    opacity: 0.5;
  }

  .tstn-footer__locale {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
  }

  .tstn-footer__locale .localization-form select {
    background: rgba(255,255,255,0.04);
    border: 1px solid var(--tstn-border);
    color: var(--tstn-muted);
    font-family: 'Montserrat', sans-serif;
    font-size: 0.62rem;
    letter-spacing: 0.08em;
    padding: 0.35rem 0.65rem;
  }

  .tstn-footer__locale .caption-large.text-body {
    font-family: 'Danger Neue', 'Impact', sans-serif;
    font-size: 0.7rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--tstn-muted);
    margin-bottom: 0.3rem;
  }

  /* ── ANIMATIONS ── */
  @keyframes tstnFadeUp {
    from { opacity: 0; transform: translateY(20px); }
    to   { opacity: 1; transform: translateY(0); }
  }

{%- endstyle -%}

{%- liquid
  assign has_social_icons = true
  if settings.social_facebook_link == blank and settings.social_instagram_link == blank and settings.social_youtube_link == blank and settings.social_tiktok_link == blank and settings.social_twitter_link == blank and settings.social_pinterest_link == blank and settings.social_snapchat_link == blank and settings.social_tumblr_link == blank and settings.social_vimeo_link == blank
    assign has_social_icons = false
  endif
-%}

<footer class="tstn-footer color-{{ section.settings.color_scheme }}">

  <div class="tstn-footer__rule" aria-hidden="true"></div>
  <div class="tstn-footer__grain"   aria-hidden="true"></div>
  <div class="tstn-footer__vignette" aria-hidden="true"></div>

  {%- if section.settings.bg_logo != blank -%}
    <div class="tstn-footer__bg-logo" aria-hidden="true">
      <img src="{{ section.settings.bg_logo | img_url: 'master' }}" alt="">
    </div>
  {%- endif -%}

  <div class="tstn-footer__inner">

    <!-- ══ BRAND ══ -->
    <div class="tstn-footer__brand">
      {%- if section.settings.footer_logo != blank -%}
        <div class="tstn-footer__brand-logo">
          <img src="{{ section.settings.footer_logo | img_url: 'master' }}" alt="{{ shop.name }}">
        </div>
      {%- else -%}
        <h2 class="tstn-footer__brand-name">{{ shop.name }}</h2>
      {%- endif -%}
      {%- if section.settings.tagline != blank -%}
        <p class="tstn-footer__brand-tagline">{{ section.settings.tagline }}</p>
      {%- endif -%}
    </div>

    <!-- ══ HORIZONTAL NAV — all link_list blocks ══ -->
    {%- assign has_links = false -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'link_list' and block.settings.menu != blank -%}
        {%- assign has_links = true -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_links -%}
      <nav class="tstn-footer__nav" aria-label="Footer navigation">
        {%- for block in section.blocks -%}
          {%- if block.type == 'link_list' and block.settings.menu != blank -%}
            {%- for link in block.settings.menu.links -%}
              <div class="tstn-footer__nav-item" {{ block.shopify_attributes }}>
                <a
                  href="{{ link.url }}"
                  class="tstn-footer__nav-link{% if link.active %} active{% endif %}"
                >{{ link.title | escape }}</a>
              </div>
            {%- endfor -%}
          {%- endif -%}
        {%- endfor -%}
      </nav>
    {%- endif -%}

    <!-- ══ MIDDLE ROW: Newsletter | Divider | Social ══ -->
    <div class="tstn-footer__mid">

      <!-- Newsletter -->
      <div class="tstn-footer__newsletter">
        {%- if section.settings.newsletter_enable -%}
          <span class="tstn-footer__section-label">{{ section.settings.newsletter_label }}</span>
          {%- if section.settings.newsletter_heading != blank -%}
            <p class="tstn-footer__newsletter-title">{{ section.settings.newsletter_heading }}</p>
          {%- endif -%}
          {%- form 'customer', id: 'ContactFooter', class: 'tstn-footer__nl-form' -%}
            <input type="hidden" name="contact[tags]" value="newsletter">
            <div class="newsletter-form__field-wrapper">
              <div class="tstn-field">
                <input
                  id="NewsletterForm--{{ section.id }}"
                  type="email"
                  name="contact[email]"
                  value="{{ form.email }}"
                  aria-required="true"
                  autocorrect="off"
                  autocapitalize="off"
                  autocomplete="email"
                  {% if form.errors %}autofocus aria-invalid="true" aria-describedby="ContactFooter-error"
                  {% elsif form.posted_successfully? %}aria-describedby="ContactFooter-success"{% endif %}
                  placeholder="{{ 'newsletter.label' | t }}"
                  required
                >
                <label for="NewsletterForm--{{ section.id }}">{{ 'newsletter.label' | t }}</label>
                <button type="submit" name="commit" aria-label="{{ 'newsletter.button_label' | t }}">Join</button>
              </div>
              {%- if form.errors -%}
                <small class="newsletter-form__message form__message" id="ContactFooter-error">
                  <span class="svg-wrapper">{{- 'icon-error.svg' | inline_asset_content -}}</span>
                  {{- form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email -}}
                </small>
              {%- endif -%}
            </div>
            {%- if form.posted_successfully? -%}
              <h3 class="newsletter-form__message newsletter-form__message--success form__message"
                id="ContactFooter-success" tabindex="-1" autofocus>
                <span class="svg-wrapper">{{- 'icon-success.svg' | inline_asset_content -}}</span>
                {{- 'newsletter.success' | t }}
              </h3>
            {%- endif -%}
          {%- endform -%}
        {%- endif -%}
      </div>

      <!-- Divider line -->
      <div class="tstn-footer__mid-divider" aria-hidden="true"></div>

      <!-- Social -->
      <div class="tstn-footer__social">
        {%- if has_social_icons -%}
          <span class="tstn-footer__section-label">Follow</span>
          {%- render 'social-icons', class: 'tstn-footer__social-icons' -%}
        {%- endif -%}
        {%- if shop.features.follow_on_shop? and section.settings.enable_follow_on_shop -%}
          <div style="margin-top:1rem;">
            {{ shop | login_button: action: 'follow' }}
          </div>
        {%- endif -%}
      </div>

    </div>

    <!-- ══ BOTTOM BAR ══ -->
    <div class="tstn-footer__bottom">

      <div class="tstn-footer__copy">
        {%- if section.settings.bottom_text != blank -%}
          {{ section.settings.bottom_text }}
        {%- else -%}
          &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.
        {%- endif -%}
      </div>

      <div class="tstn-footer__locale isolate">
        {%- if section.settings.enable_country_selector and localization.available_countries.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterCountryForm', class: 'localization-form' -%}
              <h2 class="caption-large text-body" id="FooterCountryLabel">{{ 'localization.country_label' | t }}</h2>
              {%- render 'country-localization', localPosition: 'FooterCountry' -%}
            {%- endform -%}
          </localization-form>
        {%- endif -%}
        {%- if section.settings.enable_language_selector and localization.available_languages.size > 1 -%}
          <localization-form>
            {%- form 'localization', id: 'FooterLanguageForm', class: 'localization-form' -%}
              <h2 class="caption-large text-body" id="FooterLanguageLabel">{{ 'localization.language_label' | t }}</h2>
              {%- render 'language-localization', localPosition: 'FooterLanguage' -%}
            {%- endform -%}
          </localization-form>
        {%- endif -%}
      </div>

      {%- if section.settings.payment_enable -%}
        <div class="tstn-footer__payments">
          <span class="visually-hidden">{{ 'sections.footer.payment' | t }}</span>
          <ul class="list list-payment" role="list">
            {%- for type in shop.enabled_payment_types -%}
              <li class="list-payment__item">{{ type | payment_type_svg_tag: class: 'icon icon--full-color' }}</li>
            {%- endfor -%}
          </ul>
        </div>
      {%- endif -%}

    </div>

  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "blocks": [
    {
      "type": "@app"
    },
    {
      "type": "link_list",
      "name": "Navigation Menu",
      "settings": [
        {
          "type": "link_list",
          "id": "menu",
          "default": "footer",
          "label": "Menu"
        }
      ]
    }
  ],
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "footer_logo",
