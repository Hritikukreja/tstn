<section
  class="tstn-contact-cta"
  style="
    --tstn-contact-height: {{ section.settings.height }}px;
    --tstn-contact-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
  "
>
  {%- if section.settings.background_image != blank -%}
    {{
      section.settings.background_image
      | image_url: width: 2400
      | image_tag:
        loading: 'lazy',
        sizes: '100vw',
        widths: '800, 1200, 1600, 2000, 2400',
        class: 'tstn-contact-cta__bg'
    }}
  {%- else -%}
    <div class="tstn-contact-cta__bg tstn-contact-cta__bg--placeholder"></div>
  {%- endif -%}

  <div class="tstn-contact-cta__overlay" aria-hidden="true"></div>

  <div class="tstn-contact-cta__inner">
    <div class="tstn-contact-cta__content">
      {%- if section.settings.heading != blank -%}
        <h2 class="tstn-contact-cta__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <p class="tstn-contact-cta__desc">{{ section.settings.description }}</p>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link | default: '#' }}" class="tstn-contact-cta__btn">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
  .tstn-contact-cta {
    position: relative;
    background: #0a0a0a;
    color: #ffffff;
    min-height: var(--tstn-contact-height, 420px);
    overflow: hidden;
    isolation: isolate;
  }

  .tstn-contact-cta__bg {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center right;
    z-index: 1;
  }

  .tstn-contact-cta__bg--placeholder {
    background: linear-gradient(135deg, #2a2a2a, #1a1a1a);
  }

  .tstn-contact-cta__overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    background: linear-gradient(
      90deg,
      rgba(0, 0, 0, calc(var(--tstn-contact-overlay, 0.7) + 0.15)) 0%,
      rgba(0, 0, 0, var(--tstn-contact-overlay, 0.7)) 40%,
      rgba(0, 0, 0, 0.3) 75%,
      rgba(0, 0, 0, 0.1) 100%
    );
    pointer-events: none;
  }

  .tstn-contact-cta__inner {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: center;
    min-height: var(--tstn-contact-height, 420px);
    max-width: 1600px;
    margin: 0 auto;
    padding: 50px clamp(20px, 6vw, 80px);
  }

  .tstn-contact-cta__content {
    max-width: 520px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  .tstn-contact-cta__heading {
    font-family: 'Danger Neue Free Regular', 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(30px, 4vw, 52px);
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0;
    line-height: 1;
    font-weight: 400;
    text-shadow: 0 2px 16px rgba(0, 0, 0, 0.3);
  }

  .tstn-contact-cta__desc {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 15px;
    line-height: 1.55;
    color: rgba(255, 255, 255, 0.8);
    margin: 0;
    max-width: 440px;
  }

  .tstn-contact-cta__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    align-self: flex-start;
    padding: 14px 30px;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 12px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #ffffff;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.85);
    text-decoration: none;
    font-weight: 600;
    margin-top: 8px;
    transition: all 0.25s ease;
    min-width: 180px;
  }

  .tstn-contact-cta__btn:hover {
    background: #ffffff;
    color: #0a0a0a;
    border-color: #ffffff;
  }

  @media (max-width: 749px) {
    .tstn-contact-cta__inner {
      align-items: flex-end;
      padding: 40px 20px;
    }
    .tstn-contact-cta__overlay {
      background: linear-gradient(
        180deg,
        rgba(0, 0, 0, 0.2) 0%,
        rgba(0, 0, 0, 0.5) 50%,
        rgba(0, 0, 0, 0.8) 100%
      );
    }
    .tstn-contact-cta__btn {
      width: 100%;
      align-self: stretch;
    }
  }
</style>

{% schema %}
{
  "name": "Contact CTA",
  "tag": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image",
      "info": "Portrait or environmental shot; subject on the right works best."
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "NEED HELP CHOOSING THE RIGHT SETUP?"
    },
    {
      "type": "text",
      "id": "description",
      "label": "Description",
      "default": "I got you. Reach out and I'll point you in the right direction."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "CONTACT THE CREW"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Left-side overlay darkness",
      "min": 0,
      "max": 90,
      "step": 5,
      "default": 65,
      "unit": "%"
    },
    {
      "type": "range",
      "id": "height",
      "label": "Section height",
      "min": 300,
      "max": 700,
      "step": 20,
      "default": 420,
      "unit": "px"
    }
  ],
  "presets": [
    {
      "name": "Contact CTA"
    }
  ]
}
{% endschema %}
