{{ 'section-tstn-article.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<article class="tstn-article section-{{ section.id }}-padding" itemscope itemtype="http://schema.org/Article">
  <div class="tstn-article__container page-width">

    {%- comment -%} ===== BREADCRUMB ===== {%- endcomment -%}
    <nav class="tstn-breadcrumb" aria-label="breadcrumb">
      <a href="{{ routes.root_url }}">Home</a>
      <span class="tstn-breadcrumb__sep">›</span>
      <a href="{{ blog.url }}">{{ blog.title }}</a>
      {%- if article.tags.size > 0 -%}
        <span class="tstn-breadcrumb__sep">›</span>
        <a href="{{ blog.url }}/tagged/{{ article.tags.first | handle }}">{{ article.tags.first }}</a>
      {%- endif -%}
      <span class="tstn-breadcrumb__sep">›</span>
      <span class="tstn-breadcrumb__current">{{ article.title | escape | truncate: 60 }}</span>
    </nav>

    <div class="tstn-article__layout">

      {%- comment -%} ===== MAIN CONTENT COLUMN ===== {%- endcomment -%}
      <main class="tstn-article__main">

        {%- comment -%} Tag pill {%- endcomment -%}
        {%- if article.tags.size > 0 -%}
          <a href="{{ blog.url }}/tagged/{{ article.tags.first | handle }}" class="tstn-article__tag">
            {{ article.tags.first | upcase }}
          </a>
        {%- endif -%}

        {%- comment -%} Title {%- endcomment -%}
        <h1 class="tstn-article__title" itemprop="headline">
          {{ article.title | escape }}
        </h1>

        {%- comment -%} Subtitle / Excerpt {%- endcomment -%}
        {%- if article.excerpt.size > 0 -%}
          <div class="tstn-article__subtitle" itemprop="description">
            {{ article.excerpt | strip_html }}
          </div>
        {%- elsif article.metafields.custom.subtitle -%}
          <div class="tstn-article__subtitle">
            {{ article.metafields.custom.subtitle }}
          </div>
        {%- endif -%}

        {%- comment -%} Author / Meta / Share row {%- endcomment -%}
        <div class="tstn-article__meta-row">
          <div class="tstn-article__author">
            {%- if article.metafields.custom.author_image -%}
              <img
                src="{{ article.metafields.custom.author_image | image_url: width: 80 }}"
                alt="{{ article.author | escape }}"
                width="40"
                height="40"
                class="tstn-article__author-img"
                loading="lazy"
              >
            {%- else -%}
              <div class="tstn-article__author-img tstn-article__author-img--placeholder">
                {{ article.author | slice: 0 | upcase }}
              </div>
            {%- endif -%}

            <div class="tstn-article__author-info">
              <div class="tstn-article__author-name">
                <span itemprop="author">{{ article.author }}</span>
                <svg class="tstn-article__verified" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-label="Verified">
                  <path d="M12 2L14.39 5.42L18.5 4.5L18.18 8.71L22 10.5L19.42 14L22 17.5L18.18 16.29L18.5 20.5L14.39 19.58L12 23L9.61 19.58L5.5 20.5L5.82 16.29L2 17.5L4.58 14L2 10.5L5.82 8.71L5.5 4.5L9.61 5.42L12 2Z" fill="var(--tstn-accent)"/>
                  <path d="M9 12L11 14L15 10" stroke="#000" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </div>
              <div class="tstn-article__author-meta">
                <time datetime="{{ article.published_at | date: '%Y-%m-%d' }}" itemprop="datePublished">
                  {{ article.published_at | date: '%B %-d, %Y' }}
                </time>
                <span class="tstn-article__dot">·</span>
                <span>{{ article.content | strip_html | number_of_words | divided_by: 200 | at_least: 1 }} min read</span>
              </div>
            </div>
          </div>

          <div class="tstn-article__share">
            <span class="tstn-article__share-label">Share:</span>
            <a
              href="https://twitter.com/intent/tweet?url={{ shop.url }}{{ article.url }}&text={{ article.title | url_encode }}"
              target="_blank"
              rel="noopener"
              class="tstn-article__share-btn"
              aria-label="Share on Twitter"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M22.46 6c-.77.35-1.6.58-2.46.69.88-.53 1.56-1.37 1.88-2.38-.83.5-1.75.85-2.72 1.05C18.37 4.5 17.26 4 16 4c-2.35 0-4.27 1.92-4.27 4.29 0 .34.04.67.11.98C8.28 9.09 5.11 7.38 3 4.79c-.37.63-.58 1.37-.58 2.15 0 1.49.75 2.81 1.91 3.56-.71 0-1.37-.2-1.95-.5v.03c0 2.08 1.48 3.82 3.44 4.21a4.22 4.22 0 0 1-1.93.07 4.28 4.28 0 0 0 4 2.98 8.521 8.521 0 0 1-5.33 1.84c-.34 0-.68-.02-1.02-.06C3.44 20.29 5.7 21 8.12 21 16 21 20.33 14.46 20.33 8.79c0-.19 0-.37-.01-.56.84-.6 1.56-1.36 2.14-2.23z"/></svg>
            </a>
            <a
              href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url }}"
              target="_blank"
              rel="noopener"
              class="tstn-article__share-btn"
              aria-label="Share on Facebook"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M9 8h-3v4h3v12h5v-12h3.642l.358-4h-4v-1.667c0-.955.192-1.333 1.115-1.333h2.885v-5h-3.808c-3.596 0-5.192 1.583-5.192 4.615v3.385z"/></svg>
            </a>
            <button
              class="tstn-article__share-btn tstn-article__share-btn--copy"
              type="button"
              aria-label="Copy link"
              data-copy-url="{{ shop.url }}{{ article.url }}"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </button>
          </div>
        </div>

        {%- comment -%} Featured Image {%- endcomment -%}
        {%- if article.image -%}
          <figure class="tstn-article__hero">
            <img
              src="{{ article.image | image_url: width: 1200 }}"
              alt="{{ article.image.alt | default: article.title | escape }}"
              width="{{ article.image.width }}"
              height="{{ article.image.height }}"
              loading="eager"
              itemprop="image"
            >
          </figure>
        {%- endif -%}

        {%- comment -%} Article Content {%- endcomment -%}
        <div class="tstn-article__content rte" itemprop="articleBody">
          {{ article.content }}
        </div>

        {%- comment -%} Pull-quote (from metafield) {%- endcomment -%}
        {%- if article.metafields.custom.pullquote -%}
          <blockquote class="tstn-article__pullquote">
            <svg class="tstn-article__pullquote-icon" width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <path d="M9.983 3v7.391c0 5.704-3.731 9.57-8.983 10.609l-.995-2.151c2.432-.917 3.995-3.638 3.995-5.849h-4v-10h9.983zm14.017 0v7.391c0 5.704-3.748 9.57-9 10.609l-.996-2.151c2.433-.917 3.996-3.638 3.996-5.849h-3.983v-10h9.983z"/>
            </svg>
            <p>{{ article.metafields.custom.pullquote }}</p>
          </blockquote>
        {%- endif -%}

        {%- comment -%} Prev / Next Navigation {%- endcomment -%}
        {%- if blog.previous_article or blog.next_article -%}
          <nav class="tstn-article__nav" aria-label="Article navigation">
            {%- if blog.previous_article -%}
              <a href="{{ blog.previous_article }}" class="tstn-article__nav-link tstn-article__nav-link--prev">
                <span class="tstn-article__nav-label">
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"/><polyline points="12 19 5 12 12 5"/></svg>
                  Previous Article
                </span>
                <span class="tstn-article__nav-title">{{ blog.previous_article.title }}</span>
              </a>
            {%- else -%}
              <div></div>
            {%- endif -%}

            {%- if blog.next_article -%}
              <a href="{{ blog.next_article }}" class="tstn-article__nav-link tstn-article__nav-link--next">
                <span class="tstn-article__nav-label">
                  Next Article
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
                </span>
                <span class="tstn-article__nav-title">{{ blog.next_article.title }}</span>
              </a>
            {%- endif -%}
          </nav>
        {%- endif -%}

        {%- comment -%} Comments {%- endcomment -%}
        {%- if blog.comments_enabled? -%}
          <div class="tstn-article__comments" id="comments">
            {%- if article.comments_count > 0 -%}
              <h2 class="tstn-article__comments-title">{{ article.comments_count }} comments</h2>
              {%- paginate article.comments by 5 -%}
                {%- for comment in article.comments -%}
                  <div class="tstn-comment" id="{{ comment.id }}">
                    <div class="tstn-comment__author">{{ comment.author }}</div>
                    <div class="tstn-comment__date">{{ comment.created_at | date: '%B %-d, %Y' }}</div>
                    <div class="tstn-comment__body rte">{{ comment.content }}</div>
                  </div>
                {%- endfor -%}
                {%- if paginate.pages > 1 -%}
                  {%- render 'pagination', paginate: paginate -%}
                {%- endif -%}
              {%- endpaginate -%}
            {%- endif -%}

            <h2 class="tstn-article__comments-title">Leave a comment</h2>
            {%- form 'new_comment', article -%}
              {%- liquid
                assign post_message = 'blogs.article.success'
                if blog.moderated? and form.errors == nil and form.posted_successfully?
                  assign post_message = 'blogs.article.success_moderated'
                endif
              -%}

              {%- if form.errors -%}
                <div class="tstn-form-status tstn-form-status--error" role="alert">
                  {{ 'templates.contact.form.error_heading' | t }}
                  <ul>
                    {%- for field in form.errors -%}
                      <li>{{ form.errors.messages[field] }}</li>
                    {%- endfor -%}
                  </ul>
                </div>
              {%- endif -%}

              {%- if form.posted_successfully? -%}
                <div class="tstn-form-status tstn-form-status--success" role="status">
                  {{ post_message | t }}
                </div>
              {%- endif -%}

              <div class="tstn-form-grid">
                <div class="tstn-form-field">
                  <label for="CommentAuthor">Name</label>
                  <input type="text" name="comment[author]" id="CommentAuthor" autocomplete="name" value="{{ form.author }}" required>
                </div>
                <div class="tstn-form-field">
                  <label for="CommentEmail">Email</label>
                  <input type="email" name="comment[email]" id="CommentEmail" autocomplete="email" value="{{ form.email }}" required>
                </div>
              </div>
              <div class="tstn-form-field">
                <label for="CommentBody">Comment</label>
                <textarea name="comment[body]" id="CommentBody" rows="5" required>{{ form.body }}</textarea>
              </div>
              <button type="submit" class="tstn-btn tstn-btn--primary">Post comment</button>
            {%- endform -%}
          </div>
        {%- endif -%}

      </main>

      {%- comment -%} ===== SIDEBAR ===== {%- endcomment -%}
      <aside class="tstn-article__sidebar">

        {%- for block in section.blocks -%}

          {%- case block.type -%}

            {%- comment -%} ============== EQUIPMENT WIDGET ============== {%- endcomment -%}
            {%- when 'equipment' -%}
              <div class="tstn-widget" {{ block.shopify_attributes }}>
                <div class="tstn-widget__header">
                  <span class="tstn-widget__icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 19a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h4l2-3h6l2 3h4a2 2 0 0 1 2 2z"/><circle cx="12" cy="13" r="4"/></svg>
                  </span>
                  <h3 class="tstn-widget__title">{{ block.settings.heading }}</h3>
                </div>
                <ul class="tstn-widget__list">
                  {%- for i in (1..4) -%}
                    {%- assign img_key = 'item_' | append: i | append: '_image' -%}
                    {%- assign name_key = 'item_' | append: i | append: '_name' -%}
                    {%- assign desc_key = 'item_' | append: i | append: '_description' -%}
                    {%- assign link_key = 'item_' | append: i | append: '_link' -%}
                    {%- assign cta_key = 'item_' | append: i | append: '_cta' -%}

                    {%- assign item_name = block.settings[name_key] -%}
                    {%- if item_name != blank -%}
                      <li class="tstn-widget__item">
                        <div class="tstn-widget__thumb">
                          {%- if block.settings[img_key] != blank -%}
                            <img src="{{ block.settings[img_key] | image_url: width: 200 }}" alt="{{ item_name | escape }}" loading="lazy">
                          {%- endif -%}
                        </div>
                        <div class="tstn-widget__body">
                          <div class="tstn-widget__name">{{ item_name }}</div>
                          <p class="tstn-widget__desc">{{ block.settings[desc_key] }}</p>
                          {%- if block.settings[link_key] != blank -%}
                            <a href="{{ block.settings[link_key] }}" class="tstn-widget__cta">
                              {{ block.settings[cta_key] | default: 'View Setup' }} <span aria-hidden="true">→</span>
                            </a>
                          {%- endif -%}
                        </div>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
                {%- if block.settings.footer_link != blank -%}
                  <a href="{{ block.settings.footer_link }}" class="tstn-widget__footer">
                    {{ block.settings.footer_text }} <span aria-hidden="true">→</span>
                  </a>
                {%- endif -%}
              </div>

            {%- comment -%} ============== GEAR WIDGET ============== {%- endcomment -%}
            {%- when 'gear' -%}
              <div class="tstn-widget" {{ block.shopify_attributes }}>
                <div class="tstn-widget__header">
                  <span class="tstn-widget__icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M6 2L3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 0 1-8 0"/></svg>
                  </span>
                  <h3 class="tstn-widget__title">{{ block.settings.heading }}</h3>
                </div>
                <ul class="tstn-widget__list">
                  {%- for i in (1..4) -%}
                    {%- assign img_key = 'item_' | append: i | append: '_image' -%}
                    {%- assign name_key = 'item_' | append: i | append: '_name' -%}
                    {%- assign desc_key = 'item_' | append: i | append: '_description' -%}
                    {%- assign link_key = 'item_' | append: i | append: '_link' -%}
                    {%- assign cta_key = 'item_' | append: i | append: '_cta' -%}

                    {%- assign item_name = block.settings[name_key] -%}
                    {%- if item_name != blank -%}
                      <li class="tstn-widget__item">
                        <div class="tstn-widget__thumb">
                          {%- if block.settings[img_key] != blank -%}
                            <img src="{{ block.settings[img_key] | image_url: width: 200 }}" alt="{{ item_name | escape }}" loading="lazy">
                          {%- endif -%}
                        </div>
                        <div class="tstn-widget__body">
                          <div class="tstn-widget__name">{{ item_name }}</div>
                          <p class="tstn-widget__desc">{{ block.settings[desc_key] }}</p>
                          {%- if block.settings[link_key] != blank -%}
                            <a href="{{ block.settings[link_key] }}" class="tstn-widget__cta">
                              {{ block.settings[cta_key] | default: 'Shop Now' }} <span aria-hidden="true">→</span>
                            </a>
                          {%- endif -%}
                        </div>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
                {%- if block.settings.footer_link != blank -%}
                  <a href="{{ block.settings.footer_link }}" class="tstn-widget__footer">
                    {{ block.settings.footer_text }} <span aria-hidden="true">→</span>
                  </a>
                {%- endif -%}
              </div>

            {%- comment -%} ============== LOCATIONS WIDGET ============== {%- endcomment -%}
            {%- when 'locations' -%}
              <div class="tstn-widget" {{ block.shopify_attributes }}>
                <div class="tstn-widget__header">
                  <span class="tstn-widget__icon">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  </span>
                  <h3 class="tstn-widget__title">{{ block.settings.heading }}</h3>
                </div>
                <ul class="tstn-widget__list tstn-widget__list--locations">
                  {%- for i in (1..3) -%}
                    {%- assign img_key = 'loc_' | append: i | append: '_image' -%}
                    {%- assign name_key = 'loc_' | append: i | append: '_name' -%}
                    {%- assign desc_key = 'loc_' | append: i | append: '_description' -%}
                    {%- assign link_key = 'loc_' | append: i | append: '_link' -%}

                    {%- assign loc_name = block.settings[name_key] -%}
                    {%- if loc_name != blank -%}
                      <li class="tstn-widget__item tstn-widget__item--location">
                        <div class="tstn-widget__thumb tstn-widget__thumb--location">
                          {%- if block.settings[img_key] != blank -%}
                            <img src="{{ block.settings[img_key] | image_url: width: 240 }}" alt="{{ loc_name | escape }}" loading="lazy">
                          {%- endif -%}
                        </div>
                        <div class="tstn-widget__body">
                          <div class="tstn-widget__name">{{ loc_name }}</div>
                          <p class="tstn-widget__desc">{{ block.settings[desc_key] }}</p>
                          {%- if block.settings[link_key] != blank -%}
                            <a href="{{ block.settings[link_key] }}" class="tstn-widget__cta">
                              Explore Location <span aria-hidden="true">→</span>
                            </a>
                          {%- endif -%}
                        </div>
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
                {%- if block.settings.footer_link != blank -%}
                  <a href="{{ block.settings.footer_link }}" class="tstn-widget__footer">
                    {{ block.settings.footer_text }} <span aria-hidden="true">→</span>
                  </a>
                {%- endif -%}
              </div>

            {%- comment -%} ============== COMMUNITY CTA WIDGET ============== {%- endcomment -%}
            {%- when 'community_cta' -%}
              <div class="tstn-cta" {{ block.shopify_attributes }}>
                <h3 class="tstn-cta__title">{{ block.settings.heading }}</h3>
                <ul class="tstn-cta__list">
                  {%- if block.settings.bullet_1 != blank -%}<li>{{ block.settings.bullet_1 }}</li>{%- endif -%}
                  {%- if block.settings.bullet_2 != blank -%}<li>{{ block.settings.bullet_2 }}</li>{%- endif -%}
                  {%- if block.settings.bullet_3 != blank -%}<li>{{ block.settings.bullet_3 }}</li>{%- endif -%}
                  {%- if block.settings.bullet_4 != blank -%}<li>{{ block.settings.bullet_4 }}</li>{%- endif -%}
                </ul>
                {%- if block.settings.button_link != blank -%}
                  <a href="{{ block.settings.button_link }}" class="tstn-cta__btn">
                    {{ block.settings.button_text }} <span aria-hidden="true">→</span>
                  </a>
                {%- endif -%}
              </div>

          {%- endcase -%}

        {%- endfor -%}

      </aside>

    </div>
  </div>
</article>

<script>
  (function () {
    var copyBtns = document.querySelectorAll('.tstn-article__share-btn--copy');
    copyBtns.forEach(function (btn) {
      btn.addEventListener('click', function () {
        var url = btn.getAttribute('data-copy-url');
        if (navigator.clipboard) {
          navigator.clipboard.writeText(url).then(function () {
            btn.classList.add('is-copied');
            setTimeout(function () { btn.classList.remove('is-copied'); }, 1600);
          });
        }
      });
    });
  })();
</script>

{% schema %}
{
  "name": "TSTN Article",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "equipment",
      "name": "Equipment Used",
      "limit": 1,
      "settings": [
        { "type": "text", "id": "heading", "label": "Heading", "default": "EQUIPMENT USED" },
        { "type": "header", "content": "Item 1" },
        { "type": "image_picker", "id": "item_1_image", "label": "Image" },
        { "type": "text", "id": "item_1_name", "label": "Name" },
        { "type": "text", "id": "item_1_description", "label": "Description" },
        { "type": "url", "id": "item_1_link", "label": "Link" },
        { "type": "text", "id": "item_1_cta", "label": "CTA text", "default": "View Setup" },
        { "type": "header", "content": "Item 2" },
        { "type": "image_picker", "id": "item_2_image", "label": "Image" },
        { "type": "text", "id": "item_2_name", "label": "Name" },
        { "type": "text", "id": "item_2_description", "label": "Description" },
        { "type": "url", "id": "item_2_link", "label": "Link" },
