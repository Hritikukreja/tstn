<section class="tstn-gear-grid" style="--tstn-accent: {{ section.settings.accent_color }};">
  <div class="tstn-gear-grid__inner">
    {%- if section.settings.heading != blank -%}
      <h2 class="tstn-gear-grid__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    <div class="tstn-gear-grid__grid">
      {%- for block in section.blocks -%}
        {%- if block.type == 'product' -%}
          <div class="tstn-gear-grid__card" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.link | default: '#' }}" class="tstn-gear-grid__image-wrap">
              {%- if block.settings.badge != 'none' -%}
                <span class="tstn-gear-grid__badge tstn-gear-grid__badge--{{ block.settings.badge }}">
                  {{ block.settings.badge | upcase }}
                </span>
              {%- endif -%}

              {%- if block.settings.image != blank -%}
                {{
                  block.settings.image
                  | image_url: width: 600
                  | image_tag:
                    loading: 'lazy',
                    sizes: '(min-width: 1024px) 20vw, (min-width: 750px) 33vw, 50vw',
                    widths: '300, 400, 600',
                    class: 'tstn-gear-grid__image'
                }}
              {%- else -%}
                {{ 'product-2' | placeholder_svg_tag: 'tstn-gear-grid__image' }}
              {%- endif -%}
            </a>

            <div class="tstn-gear-grid__body">
              <div class="tstn-gear-grid__info">
                {%- if block.settings.brand != blank -%}
                  <p class="tstn-gear-grid__brand">{{ block.settings.brand }}</p>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <h3 class="tstn-gear-grid__title">
                    <a href="{{ block.settings.link | default: '#' }}">{{ block.settings.title }}</a>
                  </h3>
                {%- endif -%}
                <p class="tstn-gear-grid__price">
                  {%- if block.settings.price != blank -%}
                    <span class="tstn-gear-grid__price-current">{{ block.settings.price }}</span>
                  {%- endif -%}
                  {%- if block.settings.compare_price != blank -%}
                    <span class="tstn-gear-grid__price-compare">{{ block.settings.compare_price }}</span>
                  {%- endif -%}
                </p>
              </div>

              <button type="button" class="tstn-gear-grid__cart" aria-label="Add to cart">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="9" cy="21" r="1"/>
                  <circle cx="20" cy="21" r="1"/>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
                </svg>
              </button>
            </div>
          </div>
        {%- endif -%}
      {%- endfor -%}
    </div>

    {%- if section.settings.show_load_more -%}
      <div class="tstn-gear-grid__load-more-wrap">
        <button type="button" class="tstn-gear-grid__load-more">
          {{ section.settings.load_more_label }}
        </button>
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  .tstn-gear-grid {
    background: #0a0a0a;
    color: #ffffff;
    padding: clamp(40px, 5vw, 70px) 0;
  }

  .tstn-gear-grid__inner {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 clamp(20px, 6vw, 80px);
  }

  .tstn-gear-grid__heading {
    font-family: 'Danger Neue Free Regular', 'Helvetica Neue', Arial, sans-serif;
    font-size: clamp(26px, 3vw, 40px);
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: #ffffff;
    margin: 0 0 28px;
    font-weight: 400;
    line-height: 1;
  }

  .tstn-gear-grid__grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 14px;
  }

  .tstn-gear-grid__card {
    background: #141414;
    border: 1px solid rgba(255, 255, 255, 0.04);
    display: flex;
    flex-direction: column;
    overflow: hidden;
    transition: transform 0.25s ease, border-color 0.25s ease;
  }

  .tstn-gear-grid__card:hover {
    transform: translateY(-2px);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .tstn-gear-grid__image-wrap {
    position: relative;
    display: block;
    aspect-ratio: 1 / 1;
    overflow: hidden;
    background: #1a1a1a;
  }

  .tstn-gear-grid__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .tstn-gear-grid__card:hover .tstn-gear-grid__image {
    transform: scale(1.04);
  }

  .tstn-gear-grid__badge {
    position: absolute;
    top: 10px;
    left: 10px;
    z-index: 2;
    padding: 5px 10px;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: #ffffff;
    border-radius: 2px;
  }

  .tstn-gear-grid__badge--new {
    background: var(--tstn-accent, #ff6a1a);
  }

  .tstn-gear-grid__badge--sale {
    background: #e63946;
  }

  .tstn-gear-grid__body {
    padding: 14px;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 10px;
    flex: 1;
  }

  .tstn-gear-grid__info {
    display: flex;
    flex-direction: column;
    gap: 5px;
    min-width: 0;
    flex: 1;
  }

  .tstn-gear-grid__brand {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 9px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    margin: 0;
    font-weight: 500;
  }

  .tstn-gear-grid__title {
    font-family: 'Danger Neue Free Regular', 'Helvetica Neue', Arial, sans-serif;
    font-size: 14px;
    letter-spacing: 0.02em;
    text-transform: uppercase;
    margin: 0;
    font-weight: 400;
    line-height: 1.2;
  }

  .tstn-gear-grid__title a {
    color: #ffffff;
    text-decoration: none;
  }

  .tstn-gear-grid__price {
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 13px;
    margin: 2px 0 0;
    display: flex;
    gap: 8px;
    align-items: baseline;
  }

  .tstn-gear-grid__price-current {
    color: #ffffff;
    font-weight: 600;
  }

  .tstn-gear-grid__price-compare {
    color: rgba(255, 255, 255, 0.4);
    text-decoration: line-through;
    font-size: 12px;
  }

  .tstn-gear-grid__cart {
    width: 32px;
    height: 32px;
    flex-shrink: 0;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: rgba(255, 255, 255, 0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .tstn-gear-grid__cart:hover {
    background: #ffffff;
    color: #0a0a0a;
    border-color: #ffffff;
  }

  .tstn-gear-grid__load-more-wrap {
    display: flex;
    justify-content: center;
    margin-top: 32px;
  }

  .tstn-gear-grid__load-more {
    padding: 14px 40px;
    font-family: 'Helvetica Neue', Arial, sans-serif;
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #ffffff;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.7);
    cursor: pointer;
    font-weight: 600;
    transition: all 0.2s ease;
    min-width: 220px;
  }

  .tstn-gear-grid__load-more:hover {
    background: #ffffff;
    color: #0a0a0a;
    border-color: #ffffff;
  }

  @media (max-width: 1200px) {
    .tstn-gear-grid__grid {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  @media (max-width: 900px) {
    .tstn-gear-grid__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  @media (max-width: 600px) {
    .tstn-gear-grid__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
</style>

{% schema %}
{
  "name": "Product Grid",
  "tag": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "ALL GEAR"
    },
    {
      "type": "checkbox",
      "id": "show_load_more",
      "label": "Show Load More button",
      "default": true
    },
    {
      "type": "text",
      "id": "load_more_label",
      "label": "Load More label",
      "default": "LOAD MORE"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color (NEW badge)",
      "default": "#ff6a1a"
    }
  ],
  "blocks": [
    {
      "type": "product",
      "name": "Product",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Image" },
        { "type": "text", "id": "brand", "label": "Brand", "default": "BRAND" },
        { "type": "text", "id": "title", "label": "Title", "default": "PRODUCT NAME" },
        { "type": "text", "id": "price", "label": "Price", "default": "$0.00" },
        { "type": "text", "id": "compare_price", "label": "Compare-at price (for SALE)" },
        {
          "type": "select",
          "id": "badge",
          "label": "Badge",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "new", "label": "NEW" },
            { "value": "sale", "label": "SALE" }
          ],
          "default": "none"
        },
        { "type": "url", "id": "link", "label": "Product link" }
      ]
    }
  ],
  "max_blocks": 30,
  "presets": [
    {
      "name": "Product Grid",
      "blocks": [
        { "type": "product", "settings": { "badge": "new", "brand": "BLUETTI", "title": "ELITE 45 FRIDGE", "price": "$1,249.00" } },
        { "type": "product", "settings": { "badge": "sale", "brand": "FACTOR 55", "title": "ULTRAHOOK XTV", "price": "$109.00", "compare_price": "$129.00" } },
        { "type": "product", "settings": { "brand": "GOOSE GEAR", "title": "BUMPER STORAGE BOX", "price": "$299.00" } },
        { "type": "product", "settings": { "brand": "DICAM ADVENTURE CO.", "title": "95L RUGGED CASE", "price": "$199.00" } },
        { "type": "product", "settings": { "brand": "DIODE DYNAMICS", "title": "SS5 PRO LED LIGHT BAR", "price": "$499.00" } },
        { "type": "product", "settings": { "brand": "TSTN", "title": "RECOVERY SHACKLE", "price": "$54.00" } },
        { "type": "product", "settings": { "brand": "MIDLAND", "title": "MXT275 GMRS RADIO", "price": "$199.00" } },
        { "type": "product", "settings": { "brand": "FRONT RUNNER", "title": "WOLF PACK PRO", "price": "$349.00" } },
        { "type": "product", "settings": { "brand": "TSTN", "title": "PATCH HAT", "price": "$34.00" } },
        { "type": "product", "settings": { "brand": "BLUETTI", "title": "AC200L POWER STATION", "price": "$1,399.00" } }
      ]
    }
  ]
}
{% endschema %}
