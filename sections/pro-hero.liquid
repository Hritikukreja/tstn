{% liquid
  assign section_id = 'ProHero-' | append: section.id
  assign media_type = section.settings.media_type
%}

<section id="{{ section_id }}" class="pro-hero">
  <div
    class="pro-hero__media-wrap"
    style="
      --hero-height-desktop: {{ section.settings.hero_height_desktop }};
      --hero-height-mobile: {{ section.settings.hero_height_mobile }};
      --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
      --tint-opacity: {{ section.settings.tint_opacity | divided_by: 100.0 }};
      --tint-color: {{ section.settings.tint_color }};
    "
  >
    {% if media_type == 'video' and section.settings.hero_video != blank %}
      <video
        class="pro-hero__media"
        autoplay
        muted
        loop
        playsinline
        {% if section.settings.show_controls %}controls{% endif %}
      >
        <source src="{{ section.settings.hero_video.sources[1].url | default: section.settings.hero_video.sources[0].url }}" type="video/mp4">
      </video>
    {% elsif section.settings.hero_image != blank %}
      {{
        section.settings.hero_image
        | image_url: width: 3000
        | image_tag:
          loading: 'lazy',
          widths: '750, 1100, 1500, 2000, 3000',
          sizes: '100vw',
          class: 'pro-hero__media',
          alt: section.settings.hero_image.alt | escape
      }}
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'pro-hero__placeholder' }}
    {% endif %}

    <div class="pro-hero__tint" aria-hidden="true">&nbsp;</div>
    <div class="pro-hero__overlay" aria-hidden="true">&nbsp;</div>

    <div class="pro-hero__content page-width pro-hero__content--{{ section.settings.content_position }} pro-hero__content-align--{{ section.settings.content_alignment }}">
      {% if section.settings.kicker != blank %}
        <p class="pro-hero__kicker">{{ section.settings.kicker }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="pro-hero__heading main-heading">{{ section.settings.heading }}</h2>
      {% endif %}
      <div class="pro-hero__cta-wrap">
        {% if section.settings.button_label != blank %}
          {% if section.settings.product != blank %}
            {% form 'product', section.settings.product, class: 'pro-hero__buy-form' %}
              <input type="hidden" name="id" value="{{ section.settings.product.selected_or_first_available_variant.id }}">
              <button
                type="submit"
                name="add"
                class="pro-hero__button"
                {% unless section.settings.product.available %}disabled{% endunless %}
              >
                {% if section.settings.product.available %}
                  {{ section.settings.button_label }}
                {% else %}
                  Sold out
                {% endif %}
              </button>
            {% endform %}
          {% else %}
            
              class="pro-hero__button"
              href="{{ section.settings.button_link | default: routes.all_products_collection_url }}"
            >
              {{ section.settings.button_label }}
            </a>
          {% endif %}
        {% endif %}

        {% if section.settings.price_text != blank %}
          <p class="pro-hero__price">{{ section.settings.price_text }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  @font-face {
    font-family: 'Danger Neue';
    src: url('https://cdn.shopify.com/s/files/1/0686/9486/8103/files/Danger_Neue_Regular.ttf?v=1776280277') format('truetype');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #{{ section_id }} .pro-hero__media-wrap {
    position: relative;
    height: calc(var(--hero-height-desktop) * 1vh);
    display: flex;
    align-items: stretch;
    overflow: hidden;
    background: {{ section.settings.section_bg_color }};
  }

  #{{ section_id }} .pro-hero__media,
  #{{ section_id }} .pro-hero__placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #{{ section_id }} .pro-hero__tint {
    display: block !important;
    position: absolute !important;
    inset: 0;
    width: 100%;
    height: 100%;
    background-color: var(--tint-color, #000000) !important;
    opacity: var(--tint-opacity, 0) !important;
    pointer-events: none;
    z-index: 1;
    font-size: 0;
    line-height: 0;
    color: transparent;
  }

  #{{ section_id }} .pro-hero__overlay {
    display: block !important;
    position: absolute !important;
    inset: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(180deg, rgba(0,0,0,0) 45%, rgba(0,0,0,0.9) 100%) !important;
    opacity: var(--overlay-opacity, 0.35) !important;
    pointer-events: none;
    z-index: 2;
    font-size: 0;
    line-height: 0;
    color: transparent;
  }

  #{{ section_id }} .pro-hero__content {
    position: relative;
    z-index: 3;
    width: 100%;
    padding: 3rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  #{{ section_id }} .pro-hero__content--top    { justify-content: flex-start; padding-top: 5rem; }
  #{{ section_id }} .pro-hero__content--middle { justify-content: center; }
  #{{ section_id }} .pro-hero__content--bottom { justify-content: flex-end; padding-bottom: 5rem; }

  #{{ section_id }} .pro-hero__content-align--left   { text-align: left; }
  #{{ section_id }} .pro-hero__content-align--left   .pro-hero__cta-wrap { align-items: flex-start; }
  #{{ section_id }} .pro-hero__content-align--center { text-align: center; }
  #{{ section_id }} .pro-hero__content-align--center .pro-hero__cta-wrap { align-items: center; }
  #{{ section_id }} .pro-hero__content-align--right  { text-align: right; }
  #{{ section_id }} .pro-hero__content-align--right  .pro-hero__cta-wrap { align-items: flex-end; }

  #{{ section_id }} .pro-hero__kicker {
    margin: 0 0 0.5rem;
    font-family: 'Danger Neue', sans-serif;
    font-size: {{ section.settings.kicker_size }}px;
    font-weight: {{ section.settings.kicker_weight }};
    line-height: 1;
    color: {{ section.settings.kicker_color }};
  }

  #{{ section_id }} .pro-hero__heading {
    margin: 0;
    font-family: 'Danger Neue', sans-serif;
    font-size: {{ section.settings.heading_size }}px;
    font-weight: {{ section.settings.heading_weight }};
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.95;
    color: {{ section.settings.heading_color }};
  }

  #{{ section_id }} .pro-hero__cta-wrap {
    margin-top: clamp(2rem, 6vw, 5rem);
    display: inline-flex;
    flex-direction: column;
    gap: 1.1rem;
  }

  #{{ section_id }} .pro-hero__button {
    display: inline-block;
    min-width: 8rem;
    border-radius: 999px;
    padding: 0.8rem 1.7rem;
    border: none !important;
    box-shadow: none !important;
    outline: none !important;
    -webkit-appearance: none;
    appearance: none;
    background-color: {{ section.settings.button_bg_color }} !important;
    color: {{ section.settings.button_text_color }} !important;
    font-size: {{ section.settings.button_font_size }}px !important;
    font-weight: {{ section.settings.button_font_weight }} !important;
    cursor: pointer;
    text-decoration: none;
    transition: background-color 0.2s ease;
  }

  #{{ section_id }} .pro-hero__button:hover,
  #{{ section_id }} .pro-hero__button:focus,
  #{{ section_id }} .pro-hero__button:active {
    border: none !important;
    box-shadow: none !important;
    outline: none !important;
    background-color: {{ section.settings.button_hover_color }} !important;
    color: {{ section.settings.button_text_color }} !important;
  }

  #{{ section_id }} .pro-hero__price {
    margin: 0;
    font-size: {{ section.settings.price_size }}px;
    font-weight: 600;
    color: {{ section.settings.price_color }};
  }

  @media screen and (max-width: 749px) {
    #{{ section_id }} .pro-hero__media-wrap {
      height: calc(var(--hero-height-mobile) * 1vh);
    }
    #{{ section_id }} .pro-hero__content {
      padding: 2rem 1.5rem 1.8rem;
    }
  }
</style>

{% schema %}
{
  "name": "Pro hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "default": "image",
      "options": [
        { "value": "image", "label": "Image" },
        { "value": "video", "label": "Video" }
      ]
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "video",
      "id": "hero_video",
      "label": "Hero video"
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show video controls",
      "default": false
    },
    {
      "type": "range",
      "id": "hero_height_desktop",
      "label": "Height – desktop (vh)",
      "min": 40,
      "max": 120,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "label": "Height – mobile (vh)",
      "min": 40,
      "max": 120,
      "step": 5,
      "unit": "%",
      "default": 90
    },
    {
      "type": "header",
      "content": "Overlays"
    },
    {
      "type": "color",
      "id": "tint_color",
      "label": "Tint colour",
      "default": "#000000",
      "info": "Solid colour overlaid on top of the media"
    },
    {
      "type": "range",
      "id": "tint_opacity",
      "label": "Tint opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 0
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Bottom gradient opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "header",
      "content": "Content position"
    },
    {
      "type": "select",
      "id": "content_position",
      "label": "Vertical position",
      "default": "bottom",
      "options": [
        { "value": "top",    "label": "Top" },
        { "value": "middle", "label": "Middle" },
        { "value": "bottom", "label": "Bottom" }
      ]
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Horizontal alignment",
      "default": "center",
      "options": [
        { "value": "left",   "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right",  "label": "Right" }
      ]
    },
    {
      "type": "header",
      "content": "Kicker text"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker text",
      "default": "iPhone 17"
    },
    {
      "type": "color",
      "id": "kicker_color",
      "label": "Kicker colour",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "kicker_size",
      "label": "Kicker font size",
      "min": 12,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 28
    },
    {
      "type": "range",
      "id": "kicker_weight",
      "label": "Kicker font weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "default": 400
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main heading",
      "default": "PRO"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading colour",
      "default": "#ff8a2b"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading font size",
      "min": 20,
      "max": 200,
      "step": 4,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "heading_weight",
      "label": "Heading font weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "default": 400
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Buy"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product for Buy button"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link (fallback)"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_hover_color",
      "label": "Button background (hover)",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text colour",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "button_font_size",
      "label": "Button font size",
      "min": 10,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "button_font_weight",
      "label": "Button font weight",
      "min": 100,
      "max": 900,
      "step": 100,
      "default": 400
    },
    {
      "type": "header",
      "content": "Price text"
    },
    {
      "type": "text",
      "id": "price_text",
      "label": "Price text",
      "default": "From $1099 or $45.79/mo. for 24 months"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price colour",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Price font size",
      "min": 10,
      "max": 40,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "header",
      "content": "Section background"
    },
    {
      "type": "color",
      "id": "section_bg_color",
      "label": "Background colour",
      "default": "#000000"
    }
  ],
  "presets": [
    {
      "name": "Pro hero"
    }
  ]
}
{% endschema %}