{% liquid
  assign section_id = 'ProHero-' | append: section.id
  assign media_type = section.settings.media_type
%}

<section id="{{ section_id }}" class="pro-hero color-{{ section.settings.color_scheme }} gradient">
  <div
    class="pro-hero__media-wrap"
    style="
      --hero-height-desktop: {{ section.settings.hero_height_desktop }}vh;
      --hero-height-mobile: {{ section.settings.hero_height_mobile }}vh;
      --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    "
  >
    {% if media_type == 'video' and section.settings.hero_video != blank %}
      <video
        class="pro-hero__media"
        autoplay
        muted
        loop
        playsinline
        {% if section.settings.show_controls %}
          controls
        {% endif %}
      >
        <source src="{{ section.settings.hero_video.sources[1].url | default: section.settings.hero_video.sources[0].url }}" type="video/mp4">
      </video>
    {% elsif section.settings.hero_image != blank %}
      {{
        section.settings.hero_image
        | image_url: width: 3000
        | image_tag:
          loading: 'lazy',
          widths: '750, 1100, 1500, 2000, 3000',
          sizes: '100vw',
          class: 'pro-hero__media',
          alt: section.settings.hero_image.alt | escape
      }}
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'pro-hero__placeholder' }}
    {% endif %}

    <div class="pro-hero__overlay"></div>

    <div class="pro-hero__content page-width">
      {% if section.settings.kicker != blank %}
        <p class="pro-hero__kicker">{{ section.settings.kicker }}</p>
      {% endif %}

      {% if section.settings.heading != blank %}
        <h2 class="pro-hero__heading">{{ section.settings.heading }}</h2>
      {% endif %}

      <div class="pro-hero__cta-wrap">
        {% if section.settings.button_label != blank %}
          {% if section.settings.product != blank %}
            {% form 'product', section.settings.product, class: 'pro-hero__buy-form' %}
              <input type="hidden" name="id" value="{{ section.settings.product.selected_or_first_available_variant.id }}">
              <button
                type="submit"
                name="add"
                class="button button--primary pro-hero__button"
                {% unless section.settings.product.available %}
                  disabled
                {% endunless %}
              >
                {% if section.settings.product.available %}
                  {{ section.settings.button_label }}
                {% else %}
                  Sold out
                {% endif %}
              </button>
            {% endform %}
          {% else %}
            <a
              class="button button--primary pro-hero__button"
              {% if section.settings.button_link != blank %}
                href="{{ section.settings.button_link }}"
              {% else %}
                href="{{ routes.all_products_collection_url }}"
              {% endif %}
            >
              {{ section.settings.button_label }}
            </a>
          {% endif %}
        {% endif %}

        {% if section.settings.price_text != blank %}
          <p class="pro-hero__price">{{ section.settings.price_text }}</p>
        {% endif %}
      </div>
    </div>
  </div>
</section>

<style>
  #{{ section_id }} .pro-hero__media-wrap {
    position: relative;
    min-height: calc(var(--hero-height-desktop) * 1svh);
    display: flex;
    align-items: stretch;
    justify-content: center;
    overflow: hidden;
    background: #000;
  }

  #{{ section_id }} .pro-hero__media,
  #{{ section_id }} .pro-hero__placeholder {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #{{ section_id }} .pro-hero__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(0, 0, 0, 0) 45%,
      rgba(0, 0, 0, var(--overlay-opacity)) 100%
    );
    pointer-events: none;
  }

  #{{ section_id }} .pro-hero__content {
    position: relative;
    z-index: 2;
    width: 100%;
    padding-top: 3rem;
    padding-bottom: 2rem;
    color: rgb(var(--color-foreground));
    text-align: center;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: inherit;
  }

  #{{ section_id }} .pro-hero__kicker {
    margin: 0;
    font-size: clamp(2rem, 5vw, 4.2rem);
    font-weight: 500;
    letter-spacing: 0;
    line-height: 1;
    color: {{ section.settings.heading_color }};
  }

  #{{ section_id }} .pro-hero__heading {
    margin: 0.35rem 0 0;
    font-size: clamp(3.4rem, 12vw, 13rem);
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: -0.02em;
    line-height: 0.95;
    color: {{ section.settings.heading_color }};
  }

  #{{ section_id }} .pro-hero__cta-wrap {
    margin-top: clamp(2rem, 6vw, 5rem);
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 1.1rem;
  }

  #{{ section_id }} .pro-hero__button {
    min-width: 8rem;
    border-radius: 999px;
    padding-inline: 1.7rem;
  }

  #{{ section_id }} .pro-hero__buy-form {
    margin: 0;
  }

  #{{ section_id }} .pro-hero__price {
    margin: 0;
    font-size: 1.7rem;
    font-weight: 600;
    color: {{ section.settings.price_color }};
  }

  @media screen and (max-width: 749px) {
    #{{ section_id }} .pro-hero__media-wrap {
      min-height: calc(var(--hero-height-mobile) * 1svh);
    }

    #{{ section_id }} .pro-hero__content {
      padding-top: 2rem;
      padding-bottom: 1.8rem;
    }

    #{{ section_id }} .pro-hero__price {
      font-size: 1.4rem;
      line-height: 1.4;
    }
  }
</style>

{% schema %}
{
  "name": "Pro hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "select",
      "id": "media_type",
      "label": "Media type",
      "default": "image",
      "options": [
        {
          "value": "image",
          "label": "Image"
        },
        {
          "value": "video",
          "label": "Video"
        }
      ]
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Hero image"
    },
    {
      "type": "video",
      "id": "hero_video",
      "label": "Hero video"
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Show video controls",
      "default": false
    },
    {
      "type": "range",
      "id": "hero_height_desktop",
      "label": "Hero height desktop",
      "min": 40,
      "max": 120,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "range",
      "id": "hero_height_mobile",
      "label": "Hero height mobile",
      "min": 40,
      "max": 120,
      "step": 5,
      "unit": "%",
      "default": 90
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Bottom overlay opacity",
      "min": 0,
      "max": 90,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Top text",
      "default": "iPhone 17"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Main heading",
      "default": "PRO"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Buy"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product for Buy button"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link fallback"
    },
    {
      "type": "text",
      "id": "price_text",
      "label": "Editable price text",
      "default": "From $1099 or $45.79/mo. for 24 months"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ff8a2b"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#ffffff"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    }
  ],
  "presets": [
    {
      "name": "Pro hero"
    }
  ]
}
{% endschema %}
