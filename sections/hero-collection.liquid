<section
  class="tstn-hero"
  style="
    --tstn-hero-height-desktop: {{ section.settings.height_desktop }}px;
    --tstn-hero-height-mobile: {{ section.settings.height_mobile }}px;
    --tstn-hero-overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --tstn-hero-text-align: {{ section.settings.text_alignment }};
  "
>
  {%- if section.settings.background_image != blank -%}
    <div class="tstn-hero__media">
      {{
        section.settings.background_image
        | image_url: width: 3000
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '100vw',
          widths: '600, 900, 1200, 1600, 2000, 2400, 3000',
          class: 'tstn-hero__image'
      }}
    </div>
  {%- endif -%}

  <div class="tstn-hero__overlay"></div>

  <div class="tstn-hero__inner">
    <div class="tstn-hero__content">
      {%- if section.settings.overline != blank -%}
        <p class="tstn-hero__overline">{{ section.settings.overline }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h1 class="tstn-hero__heading">{{ section.settings.heading }}</h1>
      {%- endif -%}

      {%- if section.settings.subheading != blank -%}
        <div class="tstn-hero__subheading">{{ section.settings.subheading }}</div>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_link }}" class="tstn-hero__button">
          {{ section.settings.button_label }}
        </a>
      {%- endif -%}
    </div>
  </div>
</section>

<style>
.tstn-hero {
  position: relative;
  width: 100%;
  min-height: var(--tstn-hero-height-desktop);
  overflow: hidden;
  color: #fff;
}

.tstn-hero__media {
  position: absolute;
  inset: 0;
  z-index: 1;
}

.tstn-hero__image {
  width: 100%;
  height: 100%;
  object-fit: cover;
}

/* 🔥 FIXED OVERLAY */
.tstn-hero__overlay {
  position: absolute;
  inset: 0;
  z-index: 2;
  pointer-events: none;
}

.tstn-hero__overlay::before {
  content: "";
  position: absolute;
  inset: 0;
  background: #000;
  opacity: calc(var(--tstn-hero-overlay-opacity) * 0.6);
}

.tstn-hero__overlay::after {
  content: "";
  position: absolute;
  inset: 0;
  background: linear-gradient(
    90deg,
    #000 0%,
    #000 35%,
    transparent 75%
  );
  opacity: var(--tstn-hero-overlay-opacity);
}

.tstn-hero__inner {
  position: relative;
  z-index: 3;
  display: flex;
  align-items: center;
  min-height: var(--tstn-hero-height-desktop);
  padding: 60px clamp(20px, 6vw, 80px);
}

.tstn-hero__content {
  max-width: 600px;
  text-align: var(--tstn-hero-text-align);
}

.tstn-hero__heading {
  font-size: clamp(42px, 6vw, 88px);
  line-height: 1;
}

.tstn-hero__button {
  margin-top: 20px;
  padding: 14px 28px;
  border: 1px solid #fff;
  text-decoration: none;
  color: #fff;
}

/* MOBILE FIX */
@media (max-width: 749px) {
  .tstn-hero {
    min-height: var(--tstn-hero-height-mobile);
  }

  .tstn-hero__inner {
    min-height: var(--tstn-hero-height-mobile);
    align-items: flex-end;
  }

  .tstn-hero__overlay::after {
    background: linear-gradient(
      180deg,
      transparent 0%,
      #000 70%,
      #000 100%
    );
  }
}
</style>

{% schema %}
{
  "name": "Hero Collection",
  "settings": [
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Left-side overlay darkness",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 55
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "GEAR THAT GOES FURTHER"
    },
    {
      "type": "range",
      "id": "height_desktop",
      "label": "Desktop height",
      "min": 400,
      "max": 900,
      "step": 20,
      "default": 640
    },
    {
      "type": "range",
      "id": "height_mobile",
      "label": "Mobile height",
      "min": 360,
      "max": 800,
      "step": 20,
      "default": 520
    }
  ],
  "presets": [
    { "name": "Hero Collection" }
  ]
}
{% endschema %}