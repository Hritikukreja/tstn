{%- comment -%}
  ============================================================
  TSTN Club — Growave Tires Dashboard Section
  ------------------------------------------------------------
  Renders the car-dashboard style loyalty UI:
    • Left gauge   → RPM-style points indicator
    • Center gauge → Total points speedometer
    • Right gauge  → Static VIP tier badge image
    • Bottom bar   → Tier progression meter (Base → Scout → Lead)

  Powered by Growave loyalty (points injected via hidden
  placeholder, watched by a MutationObserver).
  ============================================================
{%- endcomment -%}

{%- liquid
  assign section_id    = section.id
  assign bg_image      = section.settings.feat_image
  assign gauge_scale   = section.settings.gauge_scale | default: 100
  assign gauge_opacity = section.settings.gauge_opacity | default: 100
  assign mobile_scale  = section.settings.mobile_gauge_scale | default: 70
  assign welcome_logo  = 'https://cdn.shopify.com/s/files/1/0686/9486/8103/files/image_1_1_76d32aab-2b4e-4c68-a411-5a2a219321bf.png?v=1770384836'
-%}

{%- comment -%} VIP tier metafield (read by JS to set tier UI) {%- endcomment -%}
{% if customer %}
  {% assign vip_tier = customer.metafields["app--144550"]["growave_vip_tier"] %}
  {% if vip_tier != blank %}
    <div class="vip_tier_new_updated">{{ vip_tier }}</div>
  {% endif %}
{% endif %}

{%- comment -%} Hidden Growave points placeholder {%- endcomment -%}
<div class="visibility_hidden">
  <span
    class="gw-rd-customer-points-balance-inline-widget-placeholder"
    data-gw-enable-points-name="true"
    style="display: block;"
  ></span>
</div>

<div class="growave_tiers_wrapper {% unless customer %}non_customer_class{% endunless %}">

  {%- comment -%} Background image {%- endcomment -%}
  <div class="gtw_image_wrapper">
    {% if bg_image != blank %}
      <img src="{{ bg_image | img_url: 'master' }}" alt="">
    {% endif %}
  </div>

  {%- comment -%} Main dashboard content {%- endcomment -%}
  <div class="gtw_content_wrapper">
    <div class="dashboard-wrapper">
      <div class="screen-container">

        {%- comment -%} Welcome header {%- endcomment -%}
        <div class="gtw_welcome_wrapper">
          <div class="main_wrapper_new">
            <img src="{{ welcome_logo }}" alt="TSTN Club">
            <p>WELCOME TO TSTN CLUB</p>
          </div>
          <div class="customer_name_email">
            {% if customer %}
              {% if customer.first_name or customer.last_name %}
                <h1>{{ customer.first_name }} {{ customer.last_name }}</h1>
              {% elsif customer.email %}
                {{ customer.email }}
              {% endif %}
            {% endif %}
          </div>
        </div>

        {%- comment -%} Main dashboard panel {%- endcomment -%}
        <div class="main-content_new">

          {%- comment -%} Bottom progression bar {%- endcomment -%}
          <div class="bottom-bar">
            <div class="bottom-bar-inner">
              <div class="bottom-bar-content">
                <div class="icons-row">
                  <div class="icon-box">
                    <img src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/Frame_259.png?v=1770378961" alt="Base Camp" class="icon-img">
                  </div>
                  <div class="icon-box">
                    <img src="https://cdn.shopify.com/s/files/1/0994/4979/8950/files/Group_143726226.png?v=1770370711" alt="Scout" class="icon-img">
                  </div>
                  <div class="icon-box">
                    <img src="https://cdn.shopify.com/s/files/1/0994/4979/8950/files/Group_143726227.png?v=1770370813" alt="Lead" class="icon-img">
                  </div>
                </div>
                <div class="meter-row">
                  <div class="meter-container">
                    <div id="meterFill" class="meter-fill" style="width: 0%;"></div>
                    {% for i in (1..11) %}
                      <div class="meter-segment"></div>
                    {% endfor %}
                  </div>
                </div>
              </div>
            </div>
          </div>

          {%- comment -%} Cluster info strip (mode/gear/temp/time/etc.) {%- endcomment -%}
          <div class="meter-info-wrapper">
            <div class="cluster-container">
              <img
                src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/Frame_200_2_3d5c4b39-500f-4fc5-8413-13e8b9961403.png?v=1770378141"
                alt=""
                class="cluster-img"
              >
              <div class="cluster-overlay">
                <span id="modeText">Comfort</span>
                <span id="gearText">P</span>
                <span id="tempText">28° C</span>
                <span id="timeText">00:00</span>
                <span id="engineText">22c</span>
                <div class="air-bag-box">
                  <span class="air-bag-text">Air</span>
                  <span class="air-bag-text">Bag</span>
                </div>
                <div class="battery-box">
                  <svg class="flash-svg" viewBox="0 0 512 512" fill="white">
                    <path d="M315.27 33L96 304h128l-31.51 173.23a2.36 2.36 0 002.33 2.77h0a2.36 2.36 0 001.89-.95L416 208H288l31.66-173.25a2.45 2.45 0 00-2.44-2.75h0a2.42 2.42 0 00-1.95 1z"></path>
                  </svg>
                  <div class="battery-inner">
                    <img src="https://cdn.shopify.com/s/files/1/0994/4979/8950/files/Group_143726226_1.png?v=1770370899" alt="" class="battery-img">
                  </div>
                </div>
              </div>
            </div>
          </div>

          {%- comment -%} Three gauges {%- endcomment -%}
          <div class="gauges-wrapper">

            {%- comment -%} Left gauge — RPM {%- endcomment -%}
            <div class="gauge-left">
              <div class="clock-outer clock-outer-small">
                <div class="clock-middle">
                  <div class="clock-inner">
                    <div class="gauge-content gauge-rotated">
                      <svg id="leftGauge" viewBox="0 0 200 200" class="gauge-svg" xmlns="http://www.w3.org/2000/svg"></svg>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            {%- comment -%} Center gauge — Points {%- endcomment -%}
            <div class="gauge-center">
              <div class="left_icons_wrapper custom_icons_wrapper">
                {{- 'left-icon.svg' | inline_asset_content -}}
              </div>
              <div class="right_icons_wrapper custom_icons_wrapper">
                {{- 'right-icon.svg' | inline_asset_content -}}
              </div>
              <div class="clock-outer">
                <div class="clock-middle">
                  <div class="clock-inner">
                    <div class="gauge-content">
                      <svg id="centerGauge" viewBox="0 0 200 200" class="gauge-svg" xmlns="http://www.w3.org/2000/svg"></svg>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            {%- comment -%} Right gauge — Tier badge {%- endcomment -%}
            <div class="gauge-right">
              <div class="clock-outer clock-outer-small">
                <div class="clock-middle">
                  <div class="clock-inner">
                    <div class="gauge-content">
                      <img
                        id="tier_diagram"
                        src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_1_a6b1bf9c-5113-4864-b2aa-53fb77a68341.png?v=1770810715"
                        class="scout-img"
                        alt="Tier badge"
                      >
                    </div>
                  </div>
                </div>
              </div>
            </div>

          </div>{%- comment -%} /.gauges-wrapper {%- endcomment -%}

        </div>{%- comment -%} /.main-content_new {%- endcomment -%}
      </div>{%- comment -%} /.screen-container {%- endcomment -%}
    </div>{%- comment -%} /.dashboard-wrapper {%- endcomment -%}

    <div id="points-output"></div>
  </div>{%- comment -%} /.gtw_content_wrapper {%- endcomment -%}

  {%- comment -%} Non-logged-in CTA {%- endcomment -%}
  {% unless customer %}
    <div class="none_customer_signup">
      <div class="non_custopmer_class">
        <div class="non_contact_main">
          <img src="{{ welcome_logo }}" alt="TSTN Club">
          <p>TSTN CLUB</p>
        </div>
        <h2>JOIN THE TRIBE</h2>
        <p class="margin_class_top">Earn Points. Get Featured. Unlock the Inner Circle.</p>
        <a class="new_main_createaccount" href="/account/register">Create Account</a>
      </div>
    </div>
  {% endunless %}

</div>{%- comment -%} /.growave_tiers_wrapper {%- endcomment -%}


{%- comment -%}
  ============================================================
  STYLES — section-scoped via #shopify-section-{{ section.id }}
  ============================================================
{%- endcomment -%}
<style>
  /* ---------- CSS custom properties (tweak via theme editor) ---------- */
  #shopify-section-{{ section_id }} {
    --gauge-scale: {{ gauge_scale | divided_by: 100.0 }};
    --gauge-opacity: {{ gauge_opacity | divided_by: 100.0 }};
    --mobile-gauge-scale: {{ mobile_scale | divided_by: 100.0 }};
    --tstn-orange: #ff6a1a;
    --tstn-needle: #ec5607;
    --tstn-bg: #0a0a0a;
  }

  /* ---------- Section height (Desktop) ---------- */
  #shopify-section-{{ section_id }} .growave_tiers_wrapper,
  #shopify-section-{{ section_id }} .gtw_image_wrapper {
    height: 75vh !important;
    min-height: 75vh !important;
    max-height: 75vh !important;
  }

  #shopify-section-{{ section_id }} .gtw_content_wrapper,
  #shopify-section-{{ section_id }} .dashboard-wrapper,
  #shopify-section-{{ section_id }} .screen-container {
    height: 100%;
  }

  #shopify-section-{{ section_id }} .gtw_image_wrapper img,
  #shopify-section-{{ section_id }} .none_customer_signup {
    height: 100% !important;
  }

  /* ---------- Welcome badge (Desktop) ---------- */
  #shopify-section-{{ section_id }} .main_wrapper_new {
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 12px !important;
    padding: 14px 28px !important;
  }

  #shopify-section-{{ section_id }} .main_wrapper_new img {
    width: 28px !important;
    height: auto !important;
  }

  #shopify-section-{{ section_id }} .main_wrapper_new p {
    font-family: "Danger Neue Free Regular", "Danger Neue", sans-serif !important;
    font-size: 26px !important;
    line-height: 1.2 !important;
    letter-spacing: 1.5px !important;
    margin: 0 !important;
    font-weight: 400 !important;
  }

  /* ---------- DESKTOP GAUGE SIZE & OPACITY ---------- */
  #shopify-section-{{ section_id }} .gauges-wrapper {
    transform: scale(var(--gauge-scale)) !important;
    transform-origin: center center !important;
    opacity: var(--gauge-opacity) !important;
    transition: transform 0.3s ease, opacity 0.3s ease !important;
  }

  /* Center gauge value uses the brand heading font */
  #shopify-section-{{ section_id }} #center_gauge_value {
    font-family: "Danger Neue Free Regular", "Danger Neue", sans-serif !important;
  }

  /* Cluster info strip + bottom bar fade with gauges */
  #shopify-section-{{ section_id }} .meter-info-wrapper,
  #shopify-section-{{ section_id }} .bottom-bar {
    opacity: var(--gauge-opacity) !important;
    transition: opacity 0.3s ease !important;
  }

  /* ============================================= */
  /*  MOBILE FIX — proper layout below 767px       */
  /* ============================================= */
  @media (max-width: 767px) {

    /* Allow the section to grow on mobile so nothing clips */
    #shopify-section-{{ section_id }} .growave_tiers_wrapper {
      height: auto !important;
      min-height: 100vh !important;
      max-height: none !important;
      position: relative !important;
    }

    /* Background image: cover the entire section */
    #shopify-section-{{ section_id }} .gtw_image_wrapper {
      position: absolute !important;
      top: 0 !important;
      left: 0 !important;
      right: 0 !important;
      bottom: 0 !important;
      width: 100% !important;
      height: 100% !important;
      min-height: 100% !important;
      max-height: none !important;
      z-index: 0 !important;
      overflow: hidden !important;
    }

    #shopify-section-{{ section_id }} .gtw_image_wrapper img {
      width: 100% !important;
      height: 100% !important;
      object-fit: cover !important;
    }

    /* Position content above background */
    #shopify-section-{{ section_id }} .gtw_content_wrapper {
      position: relative !important;
      z-index: 2 !important;
      height: auto !important;
      padding: 16px 0 !important;
    }

    #shopify-section-{{ section_id }} .dashboard-wrapper,
    #shopify-section-{{ section_id }} .screen-container {
      height: auto !important;
      display: flex !important;
      flex-direction: column !important;
    }

    /* ----- Welcome header on mobile ----- */
    #shopify-section-{{ section_id }} .gtw_welcome_wrapper {
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      justify-content: center !important;
      width: 100% !important;
      padding: 12px 16px !important;
      margin-bottom: 8px !important;
      position: relative !important;
      z-index: 3 !important;
    }

    #shopify-section-{{ section_id }} .main_wrapper_new {
      display: inline-flex !important;
      visibility: visible !important;
      opacity: 1 !important;
      align-items: center !important;
      justify-content: center !important;
      gap: 8px !important;
      padding: 8px 16px !important;
      width: auto !important;
      max-width: 90% !important;
    }

    #shopify-section-{{ section_id }} .main_wrapper_new img {
      width: 18px !important;
      height: auto !important;
      flex-shrink: 0 !important;
    }

    #shopify-section-{{ section_id }} .main_wrapper_new p {
      font-family: "Danger Neue Free Regular", "Danger Neue", sans-serif !important;
      font-size: 16px !important;
      line-height: 1.2 !important;
      letter-spacing: 0.8px !important;
      margin: 0 !important;
      font-weight: 400 !important;
      white-space: nowrap !important;
      display: inline-block !important;
      visibility: visible !important;
    }

    /* ----- Main dashboard panel on mobile ----- */
    #shopify-section-{{ section_id }} .main-content_new {
      display: flex !important;
      flex-direction: column !important;
      align-items: center !important;
      width: 100% !important;
      padding: 0 12px !important;
      gap: 12px !important;
    }

    /* ----- Gauges row: keep horizontal, scale down ----- */
    #shopify-section-{{ section_id }} .gauges-wrapper {
      display: flex !important;
      flex-direction: row !important;
      align-items: center !important;
      justify-content: center !important;
      width: 100% !important;
      gap: 4px !important;
      transform: scale(var(--mobile-gauge-scale)) !important;
      transform-origin: center top !important;
      order: 1 !important;
      /* Compensate for the scale so the row doesn't leave a big gap below */
      margin-bottom: calc((var(--mobile-gauge-scale) - 1) * 100px) !important;
    }

    /* Make sure all three gauges remain visible & don't overflow */
    #shopify-section-{{ section_id }} .gauge-left,
    #shopify-section-{{ section_id }} .gauge-center,
    #shopify-section-{{ section_id }} .gauge-right {
      display: flex !important;
      visibility: visible !important;
      opacity: 1 !important;
      flex: 0 0 auto !important;
      align-items: center !important;
      justify-content: center !important;
      position: relative !important;
    }

    /* Constrain the outer clock containers so they fit on a phone */
    #shopify-section-{{ section_id }} .gauge-left .clock-outer,
    #shopify-section-{{ section_id }} .gauge-right .clock-outer {
      width: 110px !important;
      height: 110px !important;
      max-width: 110px !important;
      max-height: 110px !important;
    }

    #shopify-section-{{ section_id }} .gauge-center .clock-outer {
      width: 170px !important;
      height: 170px !important;
      max-width: 170px !important;
      max-height: 170px !important;
    }

    #shopify-section-{{ section_id }} .clock-middle,
    #shopify-section-{{ section_id }} .clock-inner,
    #shopify-section-{{ section_id }} .gauge-content {
      width: 100% !important;
      height: 100% !important;
    }

    #shopify-section-{{ section_id }} .gauge-svg {
      width: 100% !important;
      height: 100% !important;
      display: block !important;
    }

    #shopify-section-{{ section_id }} #tier_diagram,
    #shopify-section-{{ section_id }} .scout-img {
      width: 70% !important;
      height: auto !important;
      max-width: 80px !important;
      object-fit: contain !important;
    }

    /* Hide the small left/right decorative arrow icons on mobile —
       they collide with the smaller gauges */
    #shopify-section-{{ section_id }} .left_icons_wrapper,
    #shopify-section-{{ section_id }} .right_icons_wrapper {
      display: none !important;
    }

    /* ----- Cluster info strip on mobile ----- */
    #shopify-section-{{ section_id }} .meter-info-wrapper {
      width: 100% !important;
      order: 2 !important;
      padding: 0 8px !important;
      opacity: var(--gauge-opacity) !important;
    }

    #shopify-section-{{ section_id }} .cluster-container {
      width: 100% !important;
      max-width: 100% !important;
      position: relative !important;
    }

    #shopify-section-{{ section_id }} .cluster-img {
      width: 100% !important;
      height: auto !important;
      max-height: 32px !important;
      object-fit: cover !important;
    }

    #shopify-section-{{ section_id }} .cluster-overlay {
      font-size: 10px !important;
      gap: 6px !important;
    }

    #shopify-section-{{ section_id }} .cluster-overlay span,
    #shopify-section-{{ section_id }} .air-bag-text {
      font-size: 10px !important;
    }

    /* ----- Bottom bar on mobile ----- */
    #shopify-section-{{ section_id }} .bottom-bar {
      width: 100% !important;
      max-width: calc(100% - 16px) !important;
      margin: 0 auto !important;
      order: 3 !important;
      opacity: var(--gauge-opacity) !important;
    }

    #shopify-section-{{ section_id }} .bottom-bar-inner,
    #shopify-section-{{ section_id }} .bottom-bar-content {
      width: 100% !important;
    }

    #shopify-section-{{ section_id }} .icons-row {
      padding: 8px 12px !important;
    }

    #shopify-section-{{ section_id }} .icon-box img {
      max-height: 36px !important;
      width: auto !important;
    }

    #shopify-section-{{ section_id }} .meter-row {
      padding: 0 12px 10px !important;
    }

    /* Non-customer signup on mobile */
    #shopify-section-{{ section_id }} .none_customer_signup {
      position: relative !important;
      z-index: 2 !important;
      height: auto !important;
    }
  }

  /* Extra-small phones */
  @media (max-width: 380px) {
    #shopify-section-{{ section_id }} .gauge-left .clock-outer,
    #shopify-section-{{ section_id }} .gauge-right .clock-outer {
      width: 95px !important;
      height: 95px !important;
    }

    #shopify-section-{{ section_id }} .gauge-center .clock-outer {
      width: 145px !important;
      height: 145px !important;
    }

    #shopify-section-{{ section_id }} .main_wrapper_new p {
      font-size: 14px !important;
      letter-spacing: 0.6px !important;
    }
  }
</style>


{%- comment -%}
  ============================================================
  SCRIPT — points + tier logic
  Refactored into clearly-named modules:
    1. Storage helpers
    2. Tier helpers
    3. Speedometer renderer
    4. Time clock
    5. UI updaters
    6. Growave observer
  ============================================================
{%- endcomment -%}
<script>
(function () {
  'use strict';

  /* ===== 1. Storage helpers ===== */
  const STORAGE_KEYS = {
    tier: 'tstn_cs_vp_m_t',
    bar:  'tstn_cs_vp_m_b'
  };

  const Storage = {
    getTier()        { return sessionStorage.getItem(STORAGE_KEYS.tier); },
    setTier(tier)    { sessionStorage.setItem(STORAGE_KEYS.tier, tier); },
    getBar()         { return Number(sessionStorage.getItem(STORAGE_KEYS.bar) || 0); },
    setBar(value)    { sessionStorage.setItem(STORAGE_KEYS.bar, value); }
  };

  /* ===== 2. Tier configuration & helpers ===== */
  const TIER_ORDER = ['base', 'scout', 'lead'];

  const TIER_CONFIG = {
    base: {
      regex: /\b(base|base\s*camp)\b/i,
      bar: 0,
      img: 'https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_1_a6b1bf9c-5113-4864-b2aa-53fb77a68341.png?v=1770810715'
    },
    scout: {
      regex: /\b(scout)\b/i,
      bar: 50,
      img: 'https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_2_fe25c4de-0871-4b74-8114-8473656bf229.png?v=1770810716'
    },
    lead: {
      regex: /\b(lead|leader)\b/i,
      bar: 100,
      img: 'https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_3_3062b154-429b-4483-939f-042e342cf355.png?v=1770810716'
    }
  };

  const TOTAL_POINTS    = 4000;
  const SCOUT_THRESHOLD = 1500;
  const LEAD_THRESHOLD  = 3000;

  function clamp(val, min, max) {
    return Math.min(Math.max(val, min), max);
  }

  function getHigherTier(t1, t2) {
    if (!t1) return t2;
    if (!t2) return t1;
    return TIER_ORDER.indexOf(t1) > TIER_ORDER.indexOf(t2) ? t1 : t2;
  }

  function getTierFromText(text) {
    if (!text) return null;
    for (const key in TIER_CONFIG) {
      if (TIER_CONFIG[key].regex.test(text)) return key;
    }
    return null;
  }

  function getTierFromPoints(points) {
    if (points >= LEAD_THRESHOLD)  return 'lead';
    if (points >= SCOUT_THRESHOLD) return 'scout';
    return 'base';
  }

  /* ===== 3. Speedometer SVG renderer ===== */
  const SVG_NS = 'http://www.w3.org/2000/svg';

  function el(name, attrs = {}) {
    const node = document.createElementNS(SVG_NS, name);
    for (const key in attrs) node.setAttribute(key, attrs[key]);
    return node;
  }

  function createSpeedometer(svgId, opts) {
    const svg = document.getElementById(svgId);
    if (!svg) return;

    const value          = opts.value !== undefined ? opts.value : 0;
    const eMax           = opts.max !== undefined ? opts.max : 240;
    const step           = opts.step !== undefined ? opts.step : 500;
    const showValue      = opts.showValue !== false;
    const showTotalScore = opts.showTotalScore !== false;
    const showTrip       = opts.showTrip !== false;
    const showHub        = opts.showHub === true;
    const showNeedle     = opts.showNeedle !== false;
    const minAngle       = opts.minAngle;
    const maxAngle       = opts.maxAngle;
    const angleRange     = maxAngle - minAngle;
    const max            = eMax / step;
    const currentValue   = value / step;
    const angle          = minAngle + (currentValue / max) * angleRange;

    svg.innerHTML = '';

    /* Major ticks + numeric labels */
    for (let i = 0; i <= max; i++) {
      const tickAngle = minAngle + (i / max) * angleRange;
      const radians   = (tickAngle * Math.PI) / 180;
      const r1 = 75, r2 = 90;
      const x1 = 100 + r1 * Math.cos(radians);
      const y1 = 100 + r1 * Math.sin(radians);
      const x2 = 100 + r2 * Math.cos(radians);
      const y2 = 100 + r2 * Math.sin(radians);

      const g = el('g');
      g.appendChild(el('line', {
        x1, y1, x2, y2,
        stroke: 'white',
        'stroke-width': '1.5',
        'stroke-linecap': 'round'
      }));

      const textRadius = 65;
      const tx = 100 + textRadius * Math.cos(radians);
      const ty = 100 + textRadius * Math.sin(radians);

      const text = el('text', {
        x: tx, y: ty,
        fill: 'white',
        'font-size': '7px',
        'font-weight': 'normal',
        'text-anchor': 'middle',
        'dominant-baseline': 'middle',
        transform: `rotate(${tickAngle + 90} ${tx} ${ty})`
      });
      text.textContent = i * step;
      g.appendChild(text);
      svg.appendChild(g);
    }

    /* Minor ticks */
    for (let i = 0; i < max * 4; i++) {
      if (i % 4 === 0) continue;
      const tickAngle = minAngle + (i / (max * 4)) * angleRange;
      const radians   = (tickAngle * Math.PI) / 180;
      const r1 = 84, r2 = 90;
      svg.appendChild(el('line', {
        x1: 100 + r1 * Math.cos(radians),
        y1: 100 + r1 * Math.sin(radians),
        x2: 100 + r2 * Math.cos(radians),
        y2: 100 + r2 * Math.sin(radians),
        stroke: 'white',
        'stroke-width': '1',
        'stroke-linecap': 'round',
        opacity: '0.6'
      }));
    }

    /* Center value text */
    if (showValue) {
      const valueText = el('text', {
        x: 100, y: 70,
        fill: 'white',
        'font-size': '18px',
        'font-weight': 'normal',
        'font-family': 'Danger Neue Free Regular',
        'text-anchor': 'middle',
        id: 'center_gauge_value',
        'dominant-baseline': 'middle'
      });
      valueText.textContent = (currentValue * step).toFixed(0);
      svg.appendChild(valueText);
    }

    if (showTotalScore) {
      svg.appendChild(el('text', {
        x: 80, y: 130,
        fill: 'white',
        'font-size': '6px',
        'font-family': 'ABC Diatype',
        'font-weight': 'bold',
        'text-anchor': 'middle',
        'dominant-baseline': 'middle'
      }));
    }

    if (showTrip) {
      svg.appendChild(el('text', {
        x: 130, y: 130,
        fill: 'white',
        'font-size': '6px',
        'font-family': 'ABC Diatype',
        'font-weight': 'bold',
        'text-anchor': 'middle',
        'dominant-baseline': 'middle'
      }));
    }

    /* Needle */
    if (showNeedle) {
      const needleGroup = el('g');
      needleGroup.setAttribute('class', 'needle-group');
      needleGroup.style.transformOrigin = '100px 100px';
      needleGroup.style.transform       = `rotate(${angle}deg)`;
      needleGroup.dataset.minAngle      = minAngle;
      needleGroup.dataset.maxAngle      = maxAngle;
      needleGroup.dataset.maxValue      = eMax;
      needleGroup.dataset.step          = step;

      /* Drop shadow line */
      needleGroup.appendChild(el('line', {
        x1: 100, y1: 100, x2: 164, y2: 100,
        stroke: 'rgba(0,0,0,0.3)',
        'stroke-width': '5',
        'stroke-linecap': 'round',
        transform: 'translate(2, 2)'
      }));

      /* Shadow shape */
      const shadowGroup = el('g');
      shadowGroup.appendChild(el('path', {
        d: 'M 100 96 L 160 98 L 160 100 L 160 100 L 100 103 Z',
        fill: 'rgba(0,0,0,0.45)',
        transform: 'translate(4,4)'
      }));
      shadowGroup.appendChild(el('circle', {
        cx: 100, cy: 100, r: 7,
        fill: 'rgba(0,0,0,0.45)',
        transform: 'translate(4,4)'
      }));

      /* Main needle */
      const mainGroup = el('g');
      mainGroup.appendChild(el('path', {
        d: 'M 100 96 L 160 98 L 160 100 L 160 100 L 100 103 Z',
        fill: '#ec5607'
      }));
      mainGroup.appendChild(el('circle', {
        cx: 100, cy: 100, r: 7,
        fill: '#ec5607'
      }));

      needleGroup.appendChild(shadowGroup);
      needleGroup.appendChild(mainGroup);
      svg.appendChild(needleGroup);
    }

    /* Center hub */
    svg.appendChild(el('circle', {
      cx: 100, cy: 100, r: 5, fill: '#ff7a00'
    }));

    if (showHub) {
      svg.appendChild(el('circle', {
        cx: 100, cy: 100, r: 3, fill: '#1c1c1c'
      }));
    }
  }

  function updateNeedle(svgId, value) {
    const svg = document.getElementById(svgId);
    if (!svg) return;
    const needleGroup = svg.querySelector('.needle-group');
    if (!needleGroup) return;

    const minAngle = Number(needleGroup.dataset.minAngle);
    const maxAngle = Number(needleGroup.dataset.maxAngle);
    const maxValue = Number(needleGroup.dataset.maxValue);
    const clamped  = clamp(value, 0, maxValue);
    const angle    = minAngle + (clamped / maxValue) * (maxAngle - minAngle);
    needleGroup.style.transform = `rotate(${angle}deg)`;
  }

  /* ===== 4. Time clock ===== */
  function updateTime() {
    const now     = new Date();
    const hours   = String(now.getHours()).padStart(2, '0');
    const minutes = String(now.getMinutes()).padStart(2, '0');
    const el      = document.getElementById('timeText');
    if (el) el.textContent = hours + ':' + minutes;
  }

  /* ===== 5. UI state + updaters ===== */
  let currentPoints  = 0;
  let tierImageEl    = null;
  let bottomBarEl    = null;

  function getBottomBarFromPoints() {
    return clamp((currentPoints / LEAD_THRESHOLD) * 100, 0, 100);
  }

  function getBottomBarWithTierFloor(tierKey) {
    const progress = getBottomBarFromPoints();
    if (!tierKey || !TIER_CONFIG[tierKey]) return progress;
    const tierMin = TIER_CONFIG[tierKey].bar;
    if (tierMin === 100) return 100;
    return Math.max(progress, tierMin);
  }

  function applyTierUI(tierKey) {
    if (!tierKey || !TIER_CONFIG[tierKey]) return;

    const storedTier = Storage.getTier();
    const finalTier  = getHigherTier(storedTier, tierKey);
    Storage.setTier(finalTier);

    const config = TIER_CONFIG[finalTier];
    if (tierImageEl) tierImageEl.src = config.img;

    if (bottomBarEl) {
      const calculatedBar = getBottomBarWithTierFloor(finalTier);
      const storedBar     = Storage.getBar();
      const finalBar      = Math.max(calculatedBar, storedBar);
      bottomBarEl.style.width = finalBar + '%';
      Storage.setBar(finalBar);
    }
  }

  function updateUIFromPoints() {
    const calculated = clamp((currentPoints / LEAD_THRESHOLD) * 100, 0, 100);
    const storedBar  = Storage.getBar();
    const finalBar   = Math.max(calculated, storedBar);
    if (bottomBarEl) bottomBarEl.style.width = finalBar + '%';
    Storage.setBar(finalBar);
  }

  function updateGauges() {
    const rpmValue = clamp((currentPoints / TOTAL_POINTS) * 7, 0, 7);
    updateNeedle('leftGauge', rpmValue);
    updateNeedle('centerGauge', currentPoints);
  }

  function updateFromVipText() {
    const vipEl = document.querySelector('.vip_tier_new_updated');
    if (!vipEl) return false;
    const tier = getTierFromText(vipEl.innerText.trim());
    if (tier) {
      applyTierUI(tier);
      return true;
    }
    return false;
  }

  function applyPointsFallback() {
    applyTierUI(getTierFromPoints(currentPoints));
    updateUIFromPoints();
  }

  function setValue(newValue) {
    const valueText = document.querySelector('#center_gauge_value');
    if (!valueText) {
      console.log('Unable to find #center_gauge_value to update');
      return;
    }
    valueText.textContent = newValue;
    currentPoints = clamp(newValue, 0, TOTAL_POINTS);

    const tierApplied = updateFromVipText();
    if (!tierApplied) applyPointsFallback();

    updateGauges();
  }

  /* ===== 6. Growave observer ===== */
  function watchGrowavePoints() {
    window.newPoints1 = null;

    const observer = new MutationObserver(() => {
      const target = document.querySelector(
        '.gw-rd-customer-points-balance-inline-widget-placeholder'
      );
      if (!target) return;
      const match = target.textContent.match(/\d+/);
      if (!match) return;
      const newPoints = Number(match[0]);
      if (window.newPoints1 !== newPoints) {
        window.newPoints1 = newPoints;
        setValue(newPoints);
      }
    });

    observer.observe(document.body, { childList: true, subtree: true });

    /* Fallback re-check */
    setTimeout(() => {
      if (window.newPoints1 !== null) setValue(window.newPoints1);
    }, 1000);
  }

  /* ===== Init ===== */
  function init() {
    tierImageEl = document.querySelector('#tier_diagram');
    bottomBarEl = document.querySelector('#meterFill');

    createSpeedometer('leftGauge', {
      step: 1, max: 7, value: 0,
      showTrip: false, showTotalScore: false, showValue: false,
      minAngle: -210, maxAngle: 0
    });

    createSpeedometer('centerGauge', {
      value: 0, max: TOTAL_POINTS, step: 500,
      showValue: true, showTotalScore: true, showTrip: true,
      trip: 12, minAngle: -200, maxAngle: 20
    });

    updateTime();
    setInterval(updateTime, 1000);

    watchGrowavePoints();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    init();
  }
})();
</script>


