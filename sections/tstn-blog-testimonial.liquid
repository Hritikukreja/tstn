{% comment %}
  TSTN Blog + Testimonial
  - Left: "From the Blog" 4-up grid of post cards (image, category, title, excerpt, read time)
  - Right: testimonial card with large quote, author, dot indicators
{% endcomment %}

<style>
  @font-face {
    font-family: 'Danger Neue Free Regular';
    src: url('https://cdn.shopify.com/s/files/1/0000/0000/files/danger-neue-free-regular.woff2?v=1') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --tstn-orange: #F56300;
    --tstn-orange-hover: #ff7a1f;
    --tstn-bg: #0a0a0a;
    --tstn-card-bg: #111111;
    --tstn-card-bg-2: #1a1a1a;
    --tstn-text: #ffffff;
    --tstn-muted: #b0b0b0;
    --tstn-border: rgba(255,255,255,0.1);
    --tstn-font-display: "Danger Neue Free Regular", "Inter", sans-serif;
  }

  .tstn-bt {
    background: var(--tstn-bg);
    color: var(--tstn-text);
    padding: clamp(20px, 3vw, 40px) clamp(16px, 4vw, 40px);
  }
  .tstn-bt__inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2.5fr 1fr;
    gap: clamp(20px, 2vw, 28px);
  }

  /* From the Blog card wrapper */
  .tstn-blog {
    background: var(--tstn-card-bg);
    border: 1px solid var(--tstn-border);
    border-radius: 16px;
    padding: clamp(24px, 3vw, 32px);
  }
  .tstn-blog__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: clamp(20px, 2.5vw, 28px);
  }
  .tstn-blog__title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(24px, 2.5vw, 32px);
    margin: 0;
    letter-spacing: 0.5px;
  }
  .tstn-blog__viewall {
    color: var(--tstn-text);
    font-size: 14px;
    text-decoration: none;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s ease;
  }
  .tstn-blog__viewall:hover { color: var(--tstn-orange); }
  .tstn-blog__viewall svg { transition: transform 0.2s ease; }
  .tstn-blog__viewall:hover svg { transform: translateX(4px); }

  .tstn-blog__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(14px, 1.6vw, 20px);
  }

  .tstn-blog__card {
    background: var(--tstn-card-bg-2);
    border: 1px solid var(--tstn-border);
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }
  .tstn-blog__card:hover {
    transform: translateY(-4px);
    border-color: rgba(245,99,0,0.4);
  }

  .tstn-blog__cover {
    aspect-ratio: 16/10;
    overflow: hidden;
    background: #222;
  }
  .tstn-blog__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .tstn-blog__card:hover .tstn-blog__cover img { transform: scale(1.05); }

  .tstn-blog__body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }
  .tstn-blog__cat {
    color: var(--tstn-orange);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
  }
  .tstn-blog__post-title {
    font-size: 15px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0;
    color: var(--tstn-text);
  }
  .tstn-blog__excerpt {
    font-size: 13px;
    color: var(--tstn-muted);
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }
  .tstn-blog__readtime {
    font-size: 12px;
    color: var(--tstn-muted);
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid var(--tstn-border);
  }

  /* Testimonial */
  .tstn-test {
    background: var(--tstn-card-bg);
    border: 1px solid var(--tstn-border);
    border-radius: 16px;
    padding: clamp(28px, 3vw, 36px);
    position: relative;
    display: flex;
    flex-direction: column;
  }
  .tstn-test__quote-mark {
    color: var(--tstn-orange);
    font-size: 50px;
    line-height: 0.7;
    font-family: Georgia, serif;
    margin-bottom: 12px;
  }
  .tstn-test__text {
    font-size: clamp(18px, 1.8vw, 22px);
    line-height: 1.4;
    font-weight: 500;
    margin: 0 0 24px;
    color: var(--tstn-text);
    flex: 1;
  }
  .tstn-test__author {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 20px;
  }
  .tstn-test__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-size: cover;
    background-position: center;
    background-color: #333;
    flex-shrink: 0;
  }
  .tstn-test__author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }
  .tstn-test__author-name { font-size: 15px; font-weight: 600; }
  .tstn-test__author-role { font-size: 13px; color: var(--tstn-muted); }

  .tstn-test__dots {
    display: flex;
    gap: 6px;
    justify-content: center;
  }
  .tstn-test__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    transition: background 0.2s ease, width 0.2s ease;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .tstn-test__dot.is-active {
    background: var(--tstn-orange);
    width: 18px;
    border-radius: 3px;
  }

  /* Mobile */
  @media (max-width: 1100px) {
    .tstn-bt__inner { grid-template-columns: 1fr; }
    .tstn-blog__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .tstn-blog__grid { grid-template-columns: 1fr; }
    .tstn-blog__head { flex-direction: column; align-items: flex-start; gap: 10px; }
  }
</style>

<section class="tstn-bt">
  <div class="tstn-bt__inner">

    <div class="tstn-blog">
      <div class="tstn-blog__head">
        <h2 class="tstn-blog__title">{{ section.settings.heading | default: 'From the Blog' }}</h2>
        <a href="{{ section.settings.viewall_link | default: '#' }}" class="tstn-blog__viewall">
          {{ section.settings.viewall_text | default: 'View all blogs' }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

      <div class="tstn-blog__grid">
        {% for block in section.blocks %}
          {% if block.type == 'post' %}
            <a href="{{ block.settings.link | default: '#' }}" class="tstn-blog__card" {{ block.shopify_attributes }}>
              <div class="tstn-blog__cover">
                {% if block.settings.image %}
                  <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.title }}">
                {% else %}
                  <div style="width:100%;height:100%;background:linear-gradient(135deg,#333,#1a1a1a);"></div>
                {% endif %}
              </div>
              <div class="tstn-blog__body">
                <span class="tstn-blog__cat">{{ block.settings.category }}</span>
                <h3 class="tstn-blog__post-title">{{ block.settings.title }}</h3>
                <p class="tstn-blog__excerpt">{{ block.settings.excerpt }}</p>
                <span class="tstn-blog__readtime">{{ block.settings.read_time }}</span>
              </div>
            </a>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <div class="tstn-test">
      <div class="tstn-test__quote-mark">"</div>
      <p class="tstn-test__text">{{ section.settings.testimonial_text | default: 'TSTN Club isn’t just content, it’s a community that pushes you to be better.' }}</p>
      <div class="tstn-test__author">
        {% if section.settings.testimonial_avatar %}
          <div class="tstn-test__avatar" style="background-image: url('{{ section.settings.testimonial_avatar | image_url: width: 100 }}');"></div>
        {% else %}
          <div class="tstn-test__avatar"></div>
        {% endif %}
        <div class="tstn-test__author-info">
          <span class="tstn-test__author-name">{{ section.settings.testimonial_name | default: 'Rohit Verma' }}</span>
          <span class="tstn-test__author-role">{{ section.settings.testimonial_role | default: 'Member' }}</span>
        </div>
      </div>
      <div class="tstn-test__dots">
        <button class="tstn-test__dot is-active" aria-label="Slide 1"></button>
        <button class="tstn-test__dot" aria-label="Slide 2"></button>
        <button class="tstn-test__dot" aria-label="Slide 3"></button>
        <button class="tstn-test__dot" aria-label="Slide 4"></button>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "TSTN Blog & Testimonial",
  "settings": [
    { "type": "header", "content": "Blog" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "From the Blog" },
    { "type": "text", "id": "viewall_text", "label": "View all link text", "default": "View all blogs" },
    { "type": "url", "id": "viewall_link", "label": "View all link" },
    { "type": "header", "content": "Testimonial" },
    { "type": "textarea", "id": "testimonial_text", "label": "Quote", "default": "TSTN Club isn’t just content, it’s a community that pushes you to be better." },
    { "type": "image_picker", "id": "testimonial_avatar", "label": "Author Avatar" },
    { "type": "text", "id": "testimonial_name", "label": "Author Name", "default": "Rohit Verma" },
    { "type": "text", "id": "testimonial_role", "label": "Author Role", "default": "Member" }
  ],
  "blocks": [
    {
      "type": "post",
      "name": "Blog Post",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Cover Image" },
        { "type": "text", "id": "category", "label": "Category", "default": "MINDSET" },
        { "type": "text", "id": "title", "label": "Title", "default": "Post Title" },
        { "type": "textarea", "id": "excerpt", "label": "Excerpt", "default": "Short description of the post." },
        { "type": "text", "id": "read_time", "label": "Read Time", "default": "5 min read" },
        { "type": "url", "id": "link", "label": "Post Link" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "TSTN Blog & Testimonial",
      "blocks": [
        { "type": "post", "settings": { "category": "MINDSET", "title": "Consistency Over Motivation", "excerpt": "Why showing up every day matters more than feeling ready.", "read_time": "5 min read" } },
        { "type": "post", "settings": { "category": "NUTRITION", "title": "Protein: How Much Do You Really Need?", "excerpt": "Simple guide to hitting your protein goals without overthinking.", "read_time": "6 min read" } },
        { "type": "post", "settings": { "category": "TRAINING", "title": "Progressive Overload Made Simple", "excerpt": "The key to getting stronger, without getting confused.", "read_time": "4 min read" } },
        { "type": "post", "settings": { "category": "LIFESTYLE", "title": "Balance Is the New Hustle", "excerpt": "How to build a life you don’t need a vacation from.", "read_time": "5 min read" } }
      ]
    }
  ]
}
{% endschema %}
