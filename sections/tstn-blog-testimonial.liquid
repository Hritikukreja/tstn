{% comment %}
  TSTN Blog + Testimonial
  - Left: "From the Blog" 4-up grid of post cards (with login gate popup)
  - Right: Testimonial carousel (multiple testimonials, auto-rotate, dots, swipe)
{% endcomment %}

<style>
  @font-face {
    font-family: 'Danger Neue Free Regular';
    src: url('https://cdn.shopify.com/s/files/1/0000/0000/files/danger-neue-free-regular.woff2?v=1') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --tstn-orange: #F56300;
    --tstn-orange-hover: #ff7a1f;
    --tstn-bg: #0a0a0a;
    --tstn-card-bg: #111111;
    --tstn-card-bg-2: #1a1a1a;
    --tstn-text: #ffffff;
    --tstn-muted: #b0b0b0;
    --tstn-border: rgba(255,255,255,0.1);
    --tstn-font-display: "Danger Neue Free Regular", "Inter", sans-serif;
  }

  .tstn-bt {
    background: var(--tstn-bg);
    color: var(--tstn-text);
    padding: clamp(20px, 3vw, 40px) clamp(16px, 4vw, 40px);
  }
  .tstn-bt__inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2.5fr 1fr;
    gap: clamp(20px, 2vw, 28px);
    align-items: stretch;
  }

  /* From the Blog card */
  .tstn-blog {
    background: var(--tstn-card-bg);
    border: 1px solid var(--tstn-border);
    border-radius: 16px;
    padding: clamp(24px, 3vw, 32px);
  }
  .tstn-blog__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: clamp(20px, 2.5vw, 28px);
  }
  .tstn-blog__title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(28px, 3vw, 38px);
    margin: 0;
    letter-spacing: 0.5px;
    line-height: 1;
  }
  .tstn-blog__viewall {
    color: var(--tstn-text);
    font-size: 14px;
    text-decoration: none;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s ease;
  }
  .tstn-blog__viewall:hover { color: var(--tstn-orange); }
  .tstn-blog__viewall svg { transition: transform 0.2s ease; }
  .tstn-blog__viewall:hover svg { transform: translateX(4px); }

  .tstn-blog__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: clamp(14px, 1.6vw, 20px);
  }

  .tstn-blog__card {
    background: var(--tstn-card-bg-2);
    border: 1px solid var(--tstn-border);
    border-radius: 12px;
    overflow: hidden;
    cursor: pointer;
    color: inherit;
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, border-color 0.3s ease;
    padding: 0;
    text-align: left;
    width: 100%;
    font: inherit;
  }
  .tstn-blog__card:hover {
    transform: translateY(-4px);
    border-color: rgba(245,99,0,0.4);
  }

  .tstn-blog__cover {
    aspect-ratio: 16/10;
    overflow: hidden;
    background: #222;
  }
  .tstn-blog__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .tstn-blog__card:hover .tstn-blog__cover img { transform: scale(1.05); }

  .tstn-blog__body {
    padding: 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    flex: 1;
  }
  .tstn-blog__cat {
    color: var(--tstn-orange);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.2px;
    text-transform: uppercase;
  }
  .tstn-blog__post-title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(17px, 1.5vw, 20px);
    line-height: 1.15;
    margin: 0;
    color: var(--tstn-text);
    letter-spacing: 0.3px;
  }
  .tstn-blog__excerpt {
    font-size: 13px;
    color: var(--tstn-muted);
    line-height: 1.5;
    margin: 0;
    flex: 1;
  }
  .tstn-blog__readtime {
    font-size: 12px;
    color: var(--tstn-muted);
    margin-top: auto;
    padding-top: 12px;
    border-top: 1px solid var(--tstn-border);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .tstn-blog__lock-hint {
    color: var(--tstn-orange);
    display: inline-flex;
    align-items: center;
    gap: 4px;
    font-size: 11px;
    font-weight: 600;
  }

  /* ============================================================
     Testimonial Carousel
     ============================================================ */
  .tstn-test {
    background: var(--tstn-card-bg);
    border: 1px solid var(--tstn-border);
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  .tstn-test__quote-mark {
    position: absolute;
    top: clamp(16px, 2vw, 24px);
    left: clamp(20px, 2.5vw, 32px);
    color: var(--tstn-orange);
    font-size: clamp(48px, 5vw, 64px);
    line-height: 0.7;
    font-family: Georgia, serif;
    z-index: 2;
    pointer-events: none;
  }

  .tstn-test__track-wrap {
    flex: 1;
    overflow: hidden;
    position: relative;
    display: flex;
  }
  .tstn-test__track {
    display: flex;
    width: 100%;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    touch-action: pan-y;
  }
  .tstn-test__slide {
    flex: 0 0 100%;
    width: 100%;
    padding: clamp(60px, 7vw, 80px) clamp(28px, 3vw, 36px) clamp(20px, 2.5vw, 28px);
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    text-align: center;
    box-sizing: border-box;
    min-height: 360px;
  }
  .tstn-test__text {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(20px, 2vw, 26px);
    line-height: 1.25;
    margin: 0 0 clamp(20px, 2.5vw, 28px);
    color: var(--tstn-text);
    letter-spacing: 0.3px;
    flex: 1;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .tstn-test__author {
    display: flex;
    align-items: center;
    gap: 12px;
    flex-shrink: 0;
  }
  .tstn-test__avatar {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background-size: cover;
    background-position: center;
    background-color: #333;
    flex-shrink: 0;
  }
  .tstn-test__author-info {
    display: flex;
    flex-direction: column;
    gap: 2px;
    text-align: left;
  }
  .tstn-test__author-name { font-size: 15px; font-weight: 600; }
  .tstn-test__author-role { font-size: 13px; color: var(--tstn-muted); }

  /* Carousel controls (same pattern as promo) */
  .tstn-test__controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 clamp(28px, 3vw, 36px) clamp(24px, 3vw, 30px);
    gap: 12px;
  }
  .tstn-test__dots {
    display: flex;
    gap: 6px;
    flex: 1;
    justify-content: center;
  }
  .tstn-test__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease, width 0.2s ease;
  }
  .tstn-test__dot.is-active {
    background: var(--tstn-orange);
    width: 18px;
    border-radius: 3px;
  }
  .tstn-test__arrows {
    display: flex;
    gap: 6px;
  }
  .tstn-test__arrow {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    background: transparent;
    color: var(--tstn-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }
  .tstn-test__arrow:hover {
    background: var(--tstn-orange);
    border-color: var(--tstn-orange);
    color: #fff;
  }

  /* ============================================================
     Modals (article + gate)
     ============================================================ */
  .tstn-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: clamp(16px, 4vw, 40px);
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .tstn-modal.is-open { display: flex; opacity: 1; }
  .tstn-modal__inner {
    position: relative;
    transform: translateY(20px);
    transition: transform 0.25s ease;
  }
  .tstn-modal.is-open .tstn-modal__inner { transform: translateY(0); }

  .tstn-modal__close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .tstn-modal__close:hover {
    background: var(--tstn-orange);
    transform: rotate(90deg);
  }

  /* Article modal */
  .tstn-modal--article .tstn-modal__inner {
    width: 100%;
    max-width: 800px;
    background: var(--tstn-card-bg);
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0,0,0,0.6);
    max-height: 90vh;
    display: flex;
    flex-direction: column;
  }
  .tstn-article__cover {
    width: 100%;
    aspect-ratio: 16/8;
    background: #1a1a1a;
    overflow: hidden;
    flex-shrink: 0;
  }
  .tstn-article__cover img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .tstn-article__body {
    padding: clamp(24px, 3vw, 36px);
    overflow-y: auto;
    flex: 1;
  }
  .tstn-article__cat {
    color: var(--tstn-orange);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 12px;
    display: inline-block;
  }
  .tstn-article__title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(26px, 3vw, 36px);
    line-height: 1.05;
    margin: 0 0 12px;
    color: var(--tstn-text);
    letter-spacing: 0.4px;
  }
  .tstn-article__meta {
    font-size: 13px;
    color: var(--tstn-muted);
    margin-bottom: 24px;
    padding-bottom: 16px;
    border-bottom: 1px solid var(--tstn-border);
  }
  .tstn-article__content {
    color: var(--tstn-text);
    font-size: 15px;
    line-height: 1.7;
  }
  .tstn-article__content p { margin: 0 0 14px; }
  .tstn-article__content p:last-child { margin-bottom: 0; }

  /* Gate modal */
  .tstn-modal--gate .tstn-modal__inner {
    width: 100%;
    max-width: 560px;
    background: var(--tstn-card-bg);
    border: 1px solid var(--tstn-border);
    border-radius: 18px;
    padding: clamp(32px, 4vw, 44px);
    overflow: hidden;
  }
  .tstn-gate__lock-bg {
    position: absolute;
    right: -10px;
    bottom: -20px;
    color: var(--tstn-orange);
    opacity: 0.35;
    width: 220px;
    height: 220px;
    pointer-events: none;
  }
  .tstn-gate__glow {
    position: absolute;
    right: -60px;
    bottom: -60px;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(245,99,0,0.18) 0%, transparent 65%);
    pointer-events: none;
  }
  .tstn-gate__pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--tstn-orange);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 18px;
    position: relative;
    z-index: 2;
  }
  .tstn-gate__pill svg { width: 14px; height: 14px; }
  .tstn-gate__title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(28px, 3.2vw, 38px);
    line-height: 1.05;
    margin: 0 0 26px;
    color: var(--tstn-text);
    letter-spacing: 0.5px;
    position: relative;
    z-index: 2;
  }
  .tstn-gate__list {
    list-style: none;
    margin: 0 0 28px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    z-index: 2;
  }
  .tstn-gate__list li {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 15px;
    color: var(--tstn-text);
    font-weight: 500;
  }
  .tstn-gate__check { color: var(--tstn-orange); flex-shrink: 0; }
  .tstn-gate__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--tstn-orange);
    color: #fff;
    padding: 13px 26px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    transition: all 0.25s ease;
    position: relative;
    z-index: 2;
  }
  .tstn-gate__cta:hover {
    background: var(--tstn-orange-hover);
    transform: translateY(-2px);
  }
  .tstn-gate__cta svg { transition: transform 0.25s ease; }
  .tstn-gate__cta:hover svg { transform: translateX(4px); }

  body.tstn-modal-open { overflow: hidden; }

  /* Mobile */
  @media (max-width: 1100px) {
    .tstn-bt__inner { grid-template-columns: 1fr; }
    .tstn-blog__grid { grid-template-columns: repeat(2, 1fr); }
    .tstn-test { min-height: auto; }
    .tstn-test__slide { min-height: 300px; }
  }
  @media (max-width: 540px) {
    .tstn-blog__grid { grid-template-columns: 1fr; }
    .tstn-blog__head { flex-direction: column; align-items: flex-start; gap: 10px; }
    .tstn-modal--gate .tstn-modal__inner { padding: 28px 24px; }
    .tstn-gate__lock-bg { width: 160px; height: 160px; }
  }
</style>

<section class="tstn-bt">
  <div class="tstn-bt__inner">

    <!-- Blog -->
    <div class="tstn-blog">
      <div class="tstn-blog__head">
        <h2 class="tstn-blog__title">{{ section.settings.heading | default: 'From the Blog' }}</h2>
        <a href="{{ section.settings.viewall_link | default: '#' }}" class="tstn-blog__viewall">
          {{ section.settings.viewall_text | default: 'View all blogs' }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

      <div class="tstn-blog__grid">
        {% for block in section.blocks %}
          {% if block.type == 'post' %}
            <button
              type="button"
              class="tstn-blog__card"
              data-tstn-blog-trigger
              data-blog-image="{% if block.settings.image %}{{ block.settings.image | image_url: width: 1200 }}{% endif %}"
              data-blog-category="{{ block.settings.category | escape }}"
              data-blog-title="{{ block.settings.title | escape }}"
              data-blog-readtime="{{ block.settings.read_time | escape }}"
              data-blog-content="{{ block.settings.content | default: block.settings.excerpt | escape }}"
              {{ block.shopify_attributes }}>
              <div class="tstn-blog__cover">
                {% if block.settings.image %}
                  <img src="{{ block.settings.image | image_url: width: 500 }}" alt="{{ block.settings.title }}">
                {% else %}
                  <div style="width:100%;height:100%;background:linear-gradient(135deg,#333,#1a1a1a);"></div>
                {% endif %}
              </div>
              <div class="tstn-blog__body">
                <span class="tstn-blog__cat">{{ block.settings.category }}</span>
                <h3 class="tstn-blog__post-title">{{ block.settings.title }}</h3>
                <p class="tstn-blog__excerpt">{{ block.settings.excerpt }}</p>
                <div class="tstn-blog__readtime">
                  <span>{{ block.settings.read_time }}</span>
                  {% unless customer %}
                    <span class="tstn-blog__lock-hint">
                      <svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect><path d="M7 11V7a5 5 0 0 1 10 0v4"></path></svg>
                      Members
                    </span>
                  {% endunless %}
                </div>
              </div>
            </button>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <!-- Testimonial Carousel -->
    {%- assign testimonial_count = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'testimonial' -%}{%- assign testimonial_count = testimonial_count | plus: 1 -%}{%- endif -%}
    {%- endfor -%}

    <div
      class="tstn-test"
      data-tstn-test
      data-autoplay="{{ section.settings.test_autoplay }}"
      data-autoplay-speed="{{ section.settings.test_autoplay_speed | default: 6000 }}">

      <div class="tstn-test__quote-mark">"</div>

      <div class="tstn-test__track-wrap">
        <div class="tstn-test__track" data-tstn-test-track>
          {% for block in section.blocks %}
            {% if block.type == 'testimonial' %}
              <div class="tstn-test__slide" {{ block.shopify_attributes }}>
                <p class="tstn-test__text">{{ block.settings.text }}</p>
                <div class="tstn-test__author">
                  {% if block.settings.avatar %}
                    <div class="tstn-test__avatar" style="background-image: url('{{ block.settings.avatar | image_url: width: 100 }}');"></div>
                  {% else %}
                    <div class="tstn-test__avatar"></div>
                  {% endif %}
                  <div class="tstn-test__author-info">
                    <span class="tstn-test__author-name">{{ block.settings.name }}</span>
                    <span class="tstn-test__author-role">{{ block.settings.role }}</span>
                  </div>
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      {% if testimonial_count > 1 %}
        <div class="tstn-test__controls">
          <div class="tstn-test__arrows">
            <button class="tstn-test__arrow" type="button" data-tstn-test-prev aria-label="Previous testimonial">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
          </div>
          <div class="tstn-test__dots" data-tstn-test-dots>
            {% assign t_idx = 0 %}
            {% for block in section.blocks %}
              {% if block.type == 'testimonial' %}
                <button class="tstn-test__dot {% if t_idx == 0 %}is-active{% endif %}" type="button" data-tstn-test-dot="{{ t_idx }}" aria-label="Testimonial {{ t_idx | plus: 1 }}"></button>
                {% assign t_idx = t_idx | plus: 1 %}
              {% endif %}
            {% endfor %}
          </div>
          <div class="tstn-test__arrows">
            <button class="tstn-test__arrow" type="button" data-tstn-test-next aria-label="Next testimonial">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          </div>
        </div>
      {% endif %}
    </div>

  </div>

  <!-- Article modal -->
  <div class="tstn-modal tstn-modal--article" id="tstn-modal-article-{{ section.id }}" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="tstn-modal__inner">
      <button class="tstn-modal__close" type="button" aria-label="Close">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <div class="tstn-article__cover" data-tstn-article-cover></div>
      <div class="tstn-article__body">
        <span class="tstn-article__cat" data-tstn-article-cat></span>
        <h3 class="tstn-article__title" data-tstn-article-title></h3>
        <div class="tstn-article__meta" data-tstn-article-meta></div>
        <div class="tstn-article__content" data-tstn-article-content></div>
      </div>
    </div>
  </div>

  <!-- Gate modal -->
  <div class="tstn-modal tstn-modal--gate" id="tstn-modal-gate-{{ section.id }}" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="tstn-modal__inner">
      <button class="tstn-modal__close" type="button" aria-label="Close">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <div class="tstn-gate__glow"></div>
      <svg class="tstn-gate__lock-bg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
      </svg>
      <div class="tstn-gate__pill">
        <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        {{ section.settings.gate_pill | default: 'MEMBERS ONLY' }}
      </div>
      <h3 class="tstn-gate__title">{{ section.settings.gate_title | default: 'Unlock Exclusive Content & Perks' }}</h3>
      <ul class="tstn-gate__list">
        {% for block in section.blocks %}
          {% if block.type == 'perk' %}
            <li {{ block.shopify_attributes }}>
              <svg class="tstn-gate__check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>{{ block.settings.text }}</span>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
      <a href="{{ section.settings.gate_cta_link | default: '/account/register' }}" class="tstn-gate__cta">
        {{ section.settings.gate_cta_text | default: 'Join TSTN Club' }}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </div>

</section>

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var section = document.getElementById('shopify-section-' + sectionId);
  if (!section) return;

  var isLoggedIn = {% if customer %}true{% else %}false{% endif %};

  /* ------------- Modals ------------- */
  var articleModal = section.querySelector('#tstn-modal-article-' + sectionId);
  var gateModal    = section.querySelector('#tstn-modal-gate-' + sectionId);
  var triggers     = section.querySelectorAll('[data-tstn-blog-trigger]');

  var coverEl   = articleModal.querySelector('[data-tstn-article-cover]');
  var catEl     = articleModal.querySelector('[data-tstn-article-cat]');
  var titleEl   = articleModal.querySelector('[data-tstn-article-title]');
  var metaEl    = articleModal.querySelector('[data-tstn-article-meta]');
  var contentEl = articleModal.querySelector('[data-tstn-article-content]');

  function openModal(modal) {
    if (!modal) return;
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('tstn-modal-open');
  }
  function closeModal(modal) {
    if (!modal) return;
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    if (!section.querySelector('.tstn-modal.is-open')) {
      document.body.classList.remove('tstn-modal-open');
    }
    if (modal === articleModal) {
      var body = articleModal.querySelector('.tstn-article__body');
      if (body) body.scrollTop = 0;
    }
  }

  function openArticle(trigger) {
    var image    = trigger.getAttribute('data-blog-image');
    var category = trigger.getAttribute('data-blog-category') || '';
    var title    = trigger.getAttribute('data-blog-title') || '';
    var readtime = trigger.getAttribute('data-blog-readtime') || '';
    var content  = trigger.getAttribute('data-blog-content') || '';

    if (image) {
      coverEl.innerHTML = '<img src="' + image + '" alt="' + title.replace(/"/g, '&quot;') + '">';
      coverEl.style.display = '';
    } else {
      coverEl.innerHTML = '';
      coverEl.style.display = 'none';
    }
    catEl.textContent   = category;
    titleEl.textContent = title;
    metaEl.textContent  = readtime;

    var paragraphs = content.split(/\n\s*\n/).filter(function(p) { return p.trim().length > 0; });
    contentEl.innerHTML = paragraphs.map(function(p) {
      var div = document.createElement('div');
      div.textContent = p.trim();
      return '<p>' + div.innerHTML.replace(/\n/g, '<br>') + '</p>';
    }).join('');

    openModal(articleModal);
  }

  triggers.forEach(function(t) {
    t.addEventListener('click', function() {
      if (isLoggedIn) openArticle(t); else openModal(gateModal);
    });
  });

  section.querySelectorAll('.tstn-modal').forEach(function(modal) {
    var closeBtn = modal.querySelector('.tstn-modal__close');
    if (closeBtn) closeBtn.addEventListener('click', function() { closeModal(modal); });
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal(modal);
    });
  });

  document.addEventListener('keydown', function(e) {
    if (e.key !== 'Escape') return;
    section.querySelectorAll('.tstn-modal.is-open').forEach(function(m) { closeModal(m); });
  });

  /* ------------- Testimonial Carousel ------------- */
  var test = section.querySelector('[data-tstn-test]');
  if (test) {
    var track = test.querySelector('[data-tstn-test-track]');
    var slides = track.querySelectorAll('.tstn-test__slide');
    var dots = test.querySelectorAll('[data-tstn-test-dot]');
    var prevBtn = test.querySelector('[data-tstn-test-prev]');
    var nextBtn = test.querySelector('[data-tstn-test-next]');
    var index = 0;
    var total = slides.length;
    var autoplay = test.getAttribute('data-autoplay') === 'true';
    var autoplaySpeed = parseInt(test.getAttribute('data-autoplay-speed'), 10) || 6000;
    var timer = null;

    function goTo(i) {
      index = (i + total) % total;
      track.style.transform = 'translateX(-' + (index * 100) + '%)';
      dots.forEach(function(d, di) { d.classList.toggle('is-active', di === index); });
    }
    function next() { goTo(index + 1); }
    function prev() { goTo(index - 1); }
    function startAuto() {
      if (!autoplay || total < 2) return;
      stopAuto();
      timer = setInterval(next, autoplaySpeed);
    }
    function stopAuto() { if (timer) { clearInterval(timer); timer = null; } }

    if (nextBtn) nextBtn.addEventListener('click', function() { next(); startAuto(); });
    if (prevBtn) prevBtn.addEventListener('click', function() { prev(); startAuto(); });
    dots.forEach(function(d) {
      d.addEventListener('click', function() {
        goTo(parseInt(d.getAttribute('data-tstn-test-dot'), 10));
        startAuto();
      });
    });

    test.addEventListener('mouseenter', stopAuto);
    test.addEventListener('mouseleave', startAuto);

    var touchStartX = 0, touchEndX = 0;
    track.addEventListener('touchstart', function(e) {
      touchStartX = e.changedTouches[0].screenX;
      stopAuto();
    }, { passive: true });
    track.addEventListener('touchend', function(e) {
      touchEndX = e.changedTouches[0].screenX;
      var diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 40) { if (diff > 0) next(); else prev(); }
      startAuto();
    }, { passive: true });

    startAuto();
  }
})();
</script>

