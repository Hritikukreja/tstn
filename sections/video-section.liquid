{% comment %}
  TSTN — Latest From The Trail (Videos Section)
  Premium black theme with orange accents
  Uses Danger Neue Free Regular for headings
{% endcomment %}

<section id="shopify-section-{{ section.id }}" class="trail-videos">
  <div class="trail-videos__container">

    {%- comment -%} Header {%- endcomment -%}
    <div class="trail-videos__header">
      <div class="trail-videos__eyebrow">
        <span class="trail-videos__eyebrow-line"></span>
        <span class="trail-videos__eyebrow-text">{{ section.settings.eyebrow }}</span>
      </div>
      {%- if section.settings.heading != blank -%}
        <h2 class="trail-videos__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
      {%- if section.settings.subheading != blank -%}
        <p class="trail-videos__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
    </div>

    {%- comment -%} Main grid: Featured video + Stats {%- endcomment -%}
    <div class="trail-videos__main">

      {%- comment -%} Featured Video {%- endcomment -%}
      <div class="trail-videos__featured">
        <a
          href="{{ section.settings.featured_video_url | default: '#' }}"
          class="trail-videos__featured-link"
          {% if section.settings.featured_video_url contains 'youtube.com' or section.settings.featured_video_url contains 'youtu.be' or section.settings.featured_video_url contains 'vimeo.com' %}target="_blank" rel="noopener"{% endif %}
        >
          <div class="trail-videos__featured-media">
            {%- if section.settings.featured_image != blank -%}
              {{ section.settings.featured_image | image_url: width: 1400 | image_tag:
                loading: 'lazy',
                class: 'trail-videos__featured-img',
                widths: '600,900,1200,1400,1800',
                sizes: '(min-width: 990px) 65vw, 100vw',
                alt: section.settings.featured_title
              }}
            {%- else -%}
              <div class="trail-videos__placeholder">
                {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {%- endif -%}

            <div class="trail-videos__overlay"></div>

            <button class="trail-videos__play trail-videos__play--featured" aria-label="Play video">
              <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="1.5"/>
                <path d="M9.5 8L16 12L9.5 16V8Z" fill="currentColor"/>
              </svg>
            </button>

            <div class="trail-videos__featured-content">
              {%- if section.settings.featured_label != blank -%}
                <span class="trail-videos__featured-label">{{ section.settings.featured_label }}</span>
              {%- endif -%}
              {%- if section.settings.featured_title != blank -%}
                <h3 class="trail-videos__featured-title">{{ section.settings.featured_title }}</h3>
              {%- endif -%}
            </div>
          </div>
        </a>
      </div>

      {%- comment -%} Stats Sidebar {%- endcomment -%}
      <div class="trail-videos__stats">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="trail-videos__stat" {{ block.shopify_attributes }}>
              <div class="trail-videos__stat-icon" aria-hidden="true">
                {%- case block.settings.icon -%}
                  {%- when 'youtube' -%}
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <rect x="2" y="5" width="20" height="14" rx="3" stroke="currentColor" stroke-width="1.5"/>
                      <path d="M10 9L15 12L10 15V9Z" fill="currentColor"/>
                    </svg>
                  {%- when 'eye' -%}
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M2 12C2 12 5 5 12 5C19 5 22 12 22 12C22 12 19 19 12 19C5 19 2 12 2 12Z" stroke="currentColor" stroke-width="1.5"/>
                      <circle cx="12" cy="12" r="3" stroke="currentColor" stroke-width="1.5"/>
                    </svg>
                  {%- when 'instagram' -%}
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <rect x="3" y="3" width="18" height="18" rx="4" stroke="currentColor" stroke-width="1.5"/>
                      <circle cx="12" cy="12" r="4" stroke="currentColor" stroke-width="1.5"/>
                      <circle cx="17.5" cy="6.5" r="1" fill="currentColor"/>
                    </svg>
                  {%- when 'tiktok' -%}
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M16 4V14.5C16 17 14 19 11.5 19C9 19 7 17 7 14.5C7 12 9 10 11.5 10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                      <path d="M16 4C16 6.5 18 8.5 20.5 8.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  {%- when 'twitter' -%}
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M4 4L20 20M20 4L4 20" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                    </svg>
                  {%- when 'facebook' -%}
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <path d="M14 4H17V8H14C13.5 8 13 8.5 13 9V12H17L16 16H13V22H9V16H6V12H9V9C9 6 11 4 14 4Z" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"/>
                    </svg>
                  {%- else -%}
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                      <circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="1.5"/>
                    </svg>
                {%- endcase -%}
              </div>
              <div class="trail-videos__stat-content">
                <div class="trail-videos__stat-value">{{ block.settings.value }}</div>
                <div class="trail-videos__stat-label">{{ block.settings.label }}</div>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>

    </div>

    {%- comment -%} Secondary video grid {%- endcomment -%}
    {%- assign video_blocks = section.blocks | where: 'type', 'video' -%}
    {%- if video_blocks.size > 0 -%}
      <div class="trail-videos__grid">
        {%- for block in video_blocks -%}
          <a
            href="{{ block.settings.video_url | default: '#' }}"
            class="trail-videos__card"
            {% if block.settings.video_url contains 'youtube.com' or block.settings.video_url contains 'youtu.be' or block.settings.video_url contains 'vimeo.com' %}target="_blank" rel="noopener"{% endif %}
            {{ block.shopify_attributes }}
          >
            <div class="trail-videos__card-media">
              {%- if block.settings.thumbnail != blank -%}
                {{ block.settings.thumbnail | image_url: width: 800 | image_tag:
                  loading: 'lazy',
                  class: 'trail-videos__card-img',
                  widths: '400,600,800,1000',
                  sizes: '(min-width: 990px) 30vw, 90vw',
                  alt: block.settings.title
                }}
              {%- else -%}
                <div class="trail-videos__placeholder">
                  {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {%- endif -%}

              <button class="trail-videos__play" aria-label="Play video">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                  <circle cx="12" cy="12" r="11" stroke="currentColor" stroke-width="1.5"/>
                  <path d="M9.5 8L16 12L9.5 16V8Z" fill="currentColor"/>
                </svg>
              </button>
            </div>

            <div class="trail-videos__card-footer">
              <div class="trail-videos__card-meta">
                {%- if block.settings.episode != blank -%}
                  <span class="trail-videos__card-episode">{{ block.settings.episode }}</span>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <span class="trail-videos__card-title">{{ block.settings.title }}</span>
                {%- endif -%}
              </div>
              <span class="trail-videos__card-arrow" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                  <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
            </div>
          </a>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- comment -%} View all CTA {%- endcomment -%}
    {%- if section.settings.cta_text != blank -%}
      <div class="trail-videos__cta-wrap">
        <a
          href="{{ section.settings.cta_url | default: '#' }}"
          class="trail-videos__cta"
          {% if section.settings.cta_url contains 'youtube.com' or section.settings.cta_url contains 'youtu.be' %}target="_blank" rel="noopener"{% endif %}
        >
          <span>{{ section.settings.cta_text }}</span>
          <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
            <path d="M5 12H19M19 12L13 6M19 12L13 18" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% stylesheet %}
  /* Font face — Danger Neue Free Regular */
  @font-face {
    font-family: 'Danger Neue Free';
    src: url('https://cdn.shopify.com/s/files/1/0000/0000/files/DangerNeueFree-Regular.woff2') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  .trail-videos {
    --tv-bg: #0a0a0a;
    --tv-surface: #141414;
    --tv-surface-2: #1a1a1a;
    --tv-border: rgba(255, 255, 255, 0.08);
    --tv-border-hover: rgba(255, 95, 31, 0.4);
    --tv-text: #ffffff;
    --tv-text-muted: rgba(255, 255, 255, 0.65);
    --tv-text-dim: rgba(255, 255, 255, 0.45);
    --tv-accent: #ff5f1f;
    --tv-accent-glow: rgba(255, 95, 31, 0.2);

    position: relative;
    background: var(--tv-bg);
    color: var(--tv-text);
    padding: clamp(60px, 8vw, 120px) 0;
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  }

  /* Subtle topographic texture overlay */
  .trail-videos::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      radial-gradient(circle at 15% 30%, rgba(255, 95, 31, 0.04) 0%, transparent 40%),
      radial-gradient(circle at 85% 70%, rgba(255, 95, 31, 0.03) 0%, transparent 40%);
    pointer-events: none;
    z-index: 0;
  }

  .trail-videos__container {
    position: relative;
    z-index: 1;
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 clamp(20px, 4vw, 60px);
  }

  /* === Header === */
  .trail-videos__header {
    margin-bottom: clamp(32px, 4vw, 56px);
  }

  .trail-videos__eyebrow {
    display: flex;
    align-items: center;
    gap: 16px;
    margin-bottom: clamp(16px, 2vw, 24px);
  }

  .trail-videos__eyebrow-line {
    display: block;
    width: clamp(32px, 4vw, 48px);
    height: 2px;
    background: var(--tv-accent);
  }

  .trail-videos__eyebrow-text {
    font-size: clamp(11px, 1vw, 13px);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--tv-accent);
  }

  .trail-videos__heading {
    font-family: 'Danger Neue Free', 'Impact', 'Bebas Neue', sans-serif !important;
    font-size: clamp(36px, 6vw, 80px);
    line-height: 0.95;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--tv-text);
    margin: 0 0 clamp(12px, 1.5vw, 20px);
    font-weight: 400;
  }

  .trail-videos__subheading {
    font-size: clamp(14px, 1.2vw, 17px);
    line-height: 1.5;
    color: var(--tv-text-muted);
    margin: 0;
    max-width: 600px;
  }

  /* === Main layout === */
  .trail-videos__main {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(24px, 3vw, 40px);
    margin-bottom: clamp(20px, 2.5vw, 32px);
  }

  @media (min-width: 990px) {
    .trail-videos__main {
      grid-template-columns: minmax(0, 2.2fr) minmax(0, 1fr);
      align-items: stretch;
    }
  }

  /* === Featured video === */
  .trail-videos__featured {
    position: relative;
  }

  .trail-videos__featured-link {
    display: block;
    text-decoration: none;
    color: inherit;
    height: 100%;
  }

  .trail-videos__featured-media {
    position: relative;
    aspect-ratio: 16 / 9;
    border-radius: clamp(8px, 1vw, 14px);
    overflow: hidden;
    background: var(--tv-surface);
    border: 1px solid var(--tv-border);
    transition: border-color 0.4s ease, transform 0.4s ease;
  }

  .trail-videos__featured-link:hover .trail-videos__featured-media {
    border-color: var(--tv-border-hover);
  }

  .trail-videos__featured-img,
  .trail-videos__card-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  .trail-videos__featured-link:hover .trail-videos__featured-img {
    transform: scale(1.03);
  }

  .trail-videos__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(0, 0, 0, 0) 0%,
      rgba(0, 0, 0, 0) 50%,
      rgba(0, 0, 0, 0.85) 100%
    );
    pointer-events: none;
  }

  .trail-videos__featured-content {
    position: absolute;
    left: clamp(20px, 3vw, 40px);
    right: clamp(20px, 3vw, 40px);
    bottom: clamp(20px, 3vw, 36px);
    z-index: 2;
  }

  .trail-videos__featured-label {
    display: inline-block;
    font-size: clamp(11px, 1vw, 13px);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--tv-accent);
    margin-bottom: clamp(8px, 1vw, 12px);
  }

  .trail-videos__featured-title {
    font-family: 'Danger Neue Free', 'Impact', 'Bebas Neue', sans-serif !important;
    font-size: clamp(20px, 2.6vw, 36px);
    line-height: 1.05;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: var(--tv-text);
    margin: 0;
    max-width: 700px;
    font-weight: 400;
  }

  /* === Play button === */
  .trail-videos__play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: clamp(48px, 5vw, 72px);
    height: clamp(48px, 5vw, 72px);
    border-radius: 50%;
    border: none;
    background: transparent;
    color: var(--tv-text);
    cursor: pointer;
    z-index: 3;
    display: grid;
    place-items: center;
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .trail-videos__play svg {
    width: 100%;
    height: 100%;
    display: block;
  }

  .trail-videos__play--featured {
    color: var(--tv-accent);
    width: clamp(56px, 6vw, 84px);
    height: clamp(56px, 6vw, 84px);
    filter: drop-shadow(0 4px 20px var(--tv-accent-glow));
  }

  .trail-videos__featured-link:hover .trail-videos__play--featured,
  .trail-videos__card:hover .trail-videos__play {
    transform: translate(-50%, -50%) scale(1.08);
  }

  /* === Stats sidebar === */
  .trail-videos__stats {
    display: flex;
    flex-direction: column;
    justify-content: space-around;
    gap: clamp(20px, 2.5vw, 32px);
    padding: clamp(20px, 2.5vw, 32px) clamp(20px, 2vw, 28px);
  }

  @media (max-width: 989px) {
    .trail-videos__stats {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      padding: 0;
    }
  }

  .trail-videos__stat {
    display: flex;
    align-items: center;
    gap: clamp(14px, 1.5vw, 20px);
    padding-bottom: clamp(20px, 2.5vw, 32px);
    border-bottom: 1px solid var(--tv-border);
  }

  .trail-videos__stat:last-child {
    padding-bottom: 0;
    border-bottom: none;
  }

  @media (max-width: 989px) {
    .trail-videos__stat {
      padding: clamp(16px, 2vw, 24px);
      border: 1px solid var(--tv-border);
      border-radius: clamp(8px, 1vw, 12px);
      background: var(--tv-surface);
    }
  }

  .trail-videos__stat-icon {
    flex-shrink: 0;
    width: clamp(36px, 3.5vw, 48px);
    height: clamp(36px, 3.5vw, 48px);
    color: var(--tv-text);
    display: grid;
    place-items: center;
  }

  .trail-videos__stat-icon svg {
    width: 100%;
    height: 100%;
  }

  .trail-videos__stat-value {
    font-family: 'Danger Neue Free', 'Impact', 'Bebas Neue', sans-serif !important;
    font-size: clamp(28px, 3.5vw, 48px);
    line-height: 1;
    letter-spacing: 0.01em;
    color: var(--tv-accent);
    margin-bottom: 4px;
    font-weight: 400;
  }

  .trail-videos__stat-label {
    font-size: clamp(10px, 0.9vw, 12px);
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--tv-text-muted);
  }

  /* === Video card grid === */
  .trail-videos__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(16px, 2vw, 24px);
    margin-top: clamp(16px, 2vw, 24px);
  }

  @media (min-width: 700px) {
    .trail-videos__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (min-width: 990px) {
    .trail-videos__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .trail-videos__card {
    display: block;
    text-decoration: none;
    color: inherit;
    background: var(--tv-surface);
    border: 1px solid var(--tv-border);
    border-radius: clamp(8px, 1vw, 14px);
    overflow: hidden;
    transition: border-color 0.4s ease, transform 0.4s ease;
  }

  .trail-videos__card:hover {
    border-color: var(--tv-border-hover);
    transform: translateY(-2px);
  }

  .trail-videos__card-media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--tv-surface-2);
  }

  .trail-videos__card:hover .trail-videos__card-img {
    transform: scale(1.05);
  }

  .trail-videos__card-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    padding: clamp(14px, 1.6vw, 20px) clamp(16px, 1.8vw, 22px);
  }

  .trail-videos__card-meta {
    display: flex;
    align-items: center;
    gap: clamp(10px, 1.2vw, 16px);
    min-width: 0;
    flex: 1;
  }

  .trail-videos__card-episode {
    font-size: clamp(10px, 0.9vw, 12px);
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--tv-accent);
    flex-shrink: 0;
  }

  .trail-videos__card-title {
    font-size: clamp(12px, 1vw, 14px);
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--tv-text);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .trail-videos__card-arrow {
    flex-shrink: 0;
    width: 18px;
    height: 18px;
    color: var(--tv-text);
    display: grid;
    place-items: center;
    transition: transform 0.3s ease, color 0.3s ease;
  }

  .trail-videos__card-arrow svg {
    width: 100%;
    height: 100%;
  }

  .trail-videos__card:hover .trail-videos__card-arrow {
    transform: translateX(4px);
    color: var(--tv-accent);
  }

  /* Card play button override */
  .trail-videos__card .trail-videos__play {
    color: var(--tv-text);
    opacity: 0.95;
  }

  /* === CTA === */
  .trail-videos__cta-wrap {
    margin-top: clamp(32px, 4vw, 56px);
    display: flex;
    justify-content: center;
  }

  .trail-videos__cta {
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(40px, 6vw, 80px);
    padding: clamp(14px, 1.5vw, 18px) clamp(28px, 3vw, 44px);
    border: 1.5px solid var(--tv-accent);
    border-radius: 4px;
    background: transparent;
    color: var(--tv-accent);
    text-decoration: none;
    font-size: clamp(11px, 1vw, 13px);
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    transition: background 0.3s ease, color 0.3s ease, transform 0.3s ease;
    min-width: clamp(280px, 30vw, 380px);
  }

  .trail-videos__cta svg {
    width: clamp(20px, 1.6vw, 24px);
    height: clamp(20px, 1.6vw, 24px);
    transition: transform 0.3s ease;
  }

  .trail-videos__cta:hover {
    background: var(--tv-accent);
    color: var(--tv-bg);
  }

  .trail-videos__cta:hover svg {
    transform: translateX(4px);
  }

  /* === Reduced motion === */
  @media (prefers-reduced-motion: reduce) {
    .trail-videos *,
    .trail-videos *::before,
    .trail-videos *::after {
      transition: none !important;
      animation: none !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Latest From Trail",
  "tag": "section",
  "class": "section-trail-videos",
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Latest From The Trail"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Fresh Drops Every Week."
    },
    {
