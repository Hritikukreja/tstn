{% comment %}
  TSTN Club Header / Navigation
  - Logo on the left, primary nav center, search + login + Join CTA on right
  - Mobile: collapses into hamburger drawer
{% endcomment %}

<style>
  @font-face {
    font-family: 'Danger Neue Free Regular';
    src: url('https://cdn.shopify.com/s/files/1/0000/0000/files/danger-neue-free-regular.woff2?v=1') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --tstn-orange: #F56300;
    --tstn-orange-hover: #ff7a1f;
    --tstn-bg: #0a0a0a;
    --tstn-text: #ffffff;
    --tstn-muted: #b0b0b0;
    --tstn-border: rgba(255,255,255,0.12);
    --tstn-font-display: "Danger Neue Free Regular", "Inter", sans-serif;
  }

  .tstn-header {
    background: var(--tstn-bg);
    border-bottom: 1px solid var(--tstn-border);
    position: sticky;
    top: 0;
    z-index: 100;
    width: 100%;
  }

  .tstn-header__inner {
    max-width: 1400px;
    margin: 0 auto;
    padding: clamp(14px, 2vw, 22px) clamp(16px, 4vw, 40px);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: clamp(16px, 3vw, 32px);
  }

  .tstn-header__logo {
    display: flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
    flex-shrink: 0;
  }
  .tstn-header__logo-tstn {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(22px, 2.4vw, 30px);
    color: var(--tstn-text);
    letter-spacing: 0.5px;
    line-height: 1;
  }
  .tstn-header__logo-club {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(22px, 2.4vw, 30px);
    color: var(--tstn-orange);
    letter-spacing: 0.5px;
    line-height: 1;
    font-style: italic;
  }

  .tstn-header__nav {
    display: flex;
    align-items: center;
    gap: clamp(20px, 2.5vw, 36px);
  }
  .tstn-header__nav-link {
    color: var(--tstn-text);
    text-decoration: none;
    font-size: 15px;
    font-weight: 500;
    padding: 6px 2px;
    position: relative;
    transition: color 0.2s ease;
  }
  .tstn-header__nav-link:hover { color: var(--tstn-orange); }
  .tstn-header__nav-link.is-active::after {
    content: "";
    position: absolute;
    left: 0; right: 0; bottom: -4px;
    height: 2px;
    background: var(--tstn-orange);
    border-radius: 2px;
  }

  .tstn-header__actions {
    display: flex;
    align-items: center;
    gap: clamp(10px, 1.4vw, 16px);
    flex-shrink: 0;
  }
  .tstn-header__search {
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: var(--tstn-text);
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    transition: background 0.2s ease;
  }
  .tstn-header__search:hover { background: rgba(255,255,255,0.08); }

  .tstn-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    padding: 10px 20px;
    border-radius: 999px;
    font-size: 14px;
    font-weight: 600;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.25s ease;
    border: 1px solid transparent;
    white-space: nowrap;
    line-height: 1;
  }
  .tstn-btn--ghost {
    background: transparent;
    color: var(--tstn-text);
    border-color: rgba(255,255,255,0.4);
  }
  .tstn-btn--ghost:hover {
    background: var(--tstn-text);
    color: var(--tstn-bg);
  }
  .tstn-btn--primary {
    background: var(--tstn-orange);
    color: #fff;
  }
  .tstn-btn--primary:hover {
    background: var(--tstn-orange-hover);
    transform: translateY(-1px);
  }

  .tstn-header__toggle {
    display: none;
    background: transparent;
    border: none;
    cursor: pointer;
    padding: 8px;
    color: var(--tstn-text);
  }

  /* Mobile */
  @media (max-width: 980px) {
    .tstn-header__nav { display: none; }
    .tstn-header__actions .tstn-btn--ghost { display: none; }
    .tstn-header__toggle { display: flex; }
    .tstn-header__nav.is-open {
      display: flex;
      position: absolute;
      top: 100%; left: 0; right: 0;
      flex-direction: column;
      background: var(--tstn-bg);
      border-bottom: 1px solid var(--tstn-border);
      padding: 20px;
      gap: 16px;
      align-items: flex-start;
    }
  }
  @media (max-width: 540px) {
    .tstn-header__actions .tstn-btn--primary { padding: 9px 14px; font-size: 13px; }
  }
</style>

<header class="tstn-header" id="tstn-header-{{ section.id }}">
  <div class="tstn-header__inner">

    <a href="{{ section.settings.logo_link | default: '/' }}" class="tstn-header__logo">
      <span class="tstn-header__logo-tstn">{{ section.settings.logo_text_one | default: 'TSTN' }}</span>
      <span class="tstn-header__logo-club">{{ section.settings.logo_text_two | default: 'CLUB' }}</span>
    </a>

    <nav class="tstn-header__nav" id="tstn-nav-{{ section.id }}">
      {% for block in section.blocks %}
        {% if block.type == 'nav_link' %}
          <a
            href="{{ block.settings.link | default: '#' }}"
            class="tstn-header__nav-link {% if block.settings.is_active %}is-active{% endif %}"
            {{ block.shopify_attributes }}>
            {{ block.settings.label }}
          </a>
        {% endif %}
      {% endfor %}
    </nav>

    <div class="tstn-header__actions">
      <button class="tstn-header__search" aria-label="Search">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </button>
      <a href="{{ section.settings.login_link | default: '/account/login' }}" class="tstn-btn tstn-btn--ghost">{{ section.settings.login_text | default: 'Login' }}</a>
      <a href="{{ section.settings.cta_link | default: '#' }}" class="tstn-btn tstn-btn--primary">{{ section.settings.cta_text | default: 'Join TSTN Club' }}</a>
      <button class="tstn-header__toggle" aria-label="Menu" onclick="document.getElementById('tstn-nav-{{ section.id }}').classList.toggle('is-open')">
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
    </div>

  </div>
</header>

{% schema %}
{
  "name": "TSTN Club Header",
  "settings": [
    { "type": "header", "content": "Logo" },
    { "type": "text", "id": "logo_text_one", "label": "Logo Text (white)", "default": "TSTN" },
    { "type": "text", "id": "logo_text_two", "label": "Logo Text (orange italic)", "default": "CLUB" },
    { "type": "url", "id": "logo_link", "label": "Logo Link" },
    { "type": "header", "content": "Account" },
    { "type": "text", "id": "login_text", "label": "Login Button Text", "default": "Login" },
    { "type": "url", "id": "login_link", "label": "Login Link" },
    { "type": "header", "content": "Primary CTA" },
    { "type": "text", "id": "cta_text", "label": "CTA Text", "default": "Join TSTN Club" },
    { "type": "url", "id": "cta_link", "label": "CTA Link" }
  ],
  "blocks": [
    {
      "type": "nav_link",
      "name": "Nav Link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "Home" },
        { "type": "url", "id": "link", "label": "Link" },
        { "type": "checkbox", "id": "is_active", "label": "Mark as active", "default": false }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "TSTN Club Header",
      "blocks": [
        { "type": "nav_link", "settings": { "label": "Home", "is_active": true } },
        { "type": "nav_link", "settings": { "label": "Videos" } },
        { "type": "nav_link", "settings": { "label": "Blogs" } },
        { "type": "nav_link", "settings": { "label": "Perks" } },
        { "type": "nav_link", "settings": { "label": "Community" } },
        { "type": "nav_link", "settings": { "label": "Events" } }
      ]
    }
  ]
}
{% endschema %}
