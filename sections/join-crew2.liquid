{% comment %}
  Section: Join The Crew - TSTN Club
  Full-width cinematic hero section with readable feature cards.
{% endcomment %}

<section id="shopify-section-{{ section.id }}" class="join-crew-section">
  <div class="join-crew-bg">
    <div class="join-crew-overlay"></div>

    <div class="join-crew-container">
      <div class="join-crew-content">
        {% if section.settings.eyebrow != blank %}
          <div class="join-crew-eyebrow">
            <span class="eyebrow-dash"></span>
            <span>{{ section.settings.eyebrow }}</span>
          </div>
        {% endif %}

        {% if section.settings.heading != blank %}
          <h2 class="join-crew-heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.subheading != blank %}
          <p class="join-crew-subheading">{{ section.settings.subheading }}</p>
        {% endif %}

        {% if section.blocks.size > 0 %}
          <div class="join-crew-features">
            {% for block in section.blocks %}
              {% if block.type == 'feature' %}
                <div class="join-crew-card" {{ block.shopify_attributes }}>
                  {% if block.settings.icon != blank %}
                    <div class="join-crew-icon">{{ block.settings.icon }}</div>
                  {% elsif block.settings.icon_image != blank %}
                    <div class="join-crew-icon">
                      <img
                        src="{{ block.settings.icon_image | image_url: width: 80 }}"
                        alt="{{ block.settings.title | escape }}"
                        loading="lazy"
                        width="40"
                        height="40"
                      >
                    </div>
                  {% endif %}

                  {% if block.settings.title != blank %}
                    <h3 class="join-crew-card-title">{{ block.settings.title }}</h3>
                  {% endif %}

                  {% if block.settings.description != blank %}
                    <p class="join-crew-card-text">{{ block.settings.description }}</p>
                  {% endif %}
                </div>
              {% endif %}
            {% endfor %}
          </div>
        {% endif %}

        {% if section.settings.button_label != blank %}
          <a href="{{ section.settings.button_link | default: '#' }}" class="join-crew-button">
            <span>{{ section.settings.button_label }}</span>
            <svg width="18" height="18" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
              <path d="M4 10H16M16 10L11 5M16 10L11 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% style %}
  @font-face {
    font-family: 'Danger Neue Free Regular';
    src: url('https://cdn.shopify.com/s/files/1/0947/0103/4503/files/DangerNeueFree-Regular.woff2?v=1758716827') format('woff2');
    font-weight: normal;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }}.section-join-crew,
  #shopify-section-{{ section.id }} .join-crew-section {
    width: 100%;
    max-width: none !important;
    margin: 0 !important;
    padding: 0 !important;
    background: #000;
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .join-crew-section {
    position: relative;
    left: 50%;
    right: 50%;
    margin-left: -50vw !important;
    margin-right: -50vw !important;
    width: 100vw;
  }

  #shopify-section-{{ section.id }} .join-crew-bg {
    position: relative;
    width: 100%;
    min-height: {{ section.settings.section_height }}vh;
    background-image: url('{{ section.settings.background_image | image_url: width: 3000 }}');
    background-size: cover;
    background-repeat: no-repeat;
    background-position: {{ section.settings.background_position_x }}% {{ section.settings.background_position_y }}%;
    display: flex;
    align-items: {{ section.settings.vertical_alignment }};
  }

  #shopify-section-{{ section.id }} .join-crew-overlay {
    position: absolute;
    inset: 0;
    z-index: 1;
    pointer-events: none;
    background:
      linear-gradient(
        90deg,
        rgba(0,0,0,{{ section.settings.overlay_left_opacity | divided_by: 100.0 }}) 0%,
        rgba(0,0,0,{{ section.settings.overlay_mid_opacity | divided_by: 100.0 }}) 42%,
        rgba(0,0,0,{{ section.settings.overlay_right_opacity | divided_by: 100.0 }}) 100%
      ),
      linear-gradient(
        180deg,
        rgba(0,0,0,{{ section.settings.overlay_top_opacity | divided_by: 100.0 }}) 0%,
        rgba(0,0,0,0) 38%,
        rgba(0,0,0,{{ section.settings.overlay_bottom_opacity | divided_by: 100.0 }}) 100%
      );
  }

  #shopify-section-{{ section.id }} .join-crew-container {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: {{ section.settings.container_width }}px;
    margin: 0 auto;
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    padding-left: {{ section.settings.padding_x }}px;
    padding-right: {{ section.settings.padding_x }}px;
  }

  #shopify-section-{{ section.id }} .join-crew-content {
    width: 100%;
    max-width: {{ section.settings.content_width }}px;
    margin-left: {% if section.settings.content_alignment == 'left' %}0{% elsif section.settings.content_alignment == 'center' %}auto{% else %}auto{% endif %};
    margin-right: {% if section.settings.content_alignment == 'left' %}auto{% elsif section.settings.content_alignment == 'center' %}auto{% else %}0{% endif %};
    color: #fff;
    transform: translateX(-{{ section.settings.content_shift_left }}px);
  }

  #shopify-section-{{ section.id }} .join-crew-eyebrow {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 14px;
    font-family: 'Danger Neue Free Regular', Impact, sans-serif;
    font-size: {{ section.settings.eyebrow_size }}px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #fff;
  }

  #shopify-section-{{ section.id }} .eyebrow-dash {
    display: block;
    width: 30px;
    height: 3px;
    background: {{ section.settings.accent_color }};
  }

  #shopify-section-{{ section.id }} .join-crew-heading {
    font-family: 'Danger Neue Free Regular', Impact, 'Arial Narrow', sans-serif !important;
    font-size: {{ section.settings.heading_size }}px;
    line-height: 0.92;
    letter-spacing: 0.025em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 22px;
    font-weight: 400;
    text-shadow: 0 4px 24px rgba(0,0,0,0.55);
  }

  #shopify-section-{{ section.id }} .join-crew-subheading {
    max-width: {{ section.settings.subheading_width }}px;
    margin: 0 0 42px;
    font-size: {{ section.settings.subheading_size }}px;
    line-height: 1.55;
    font-weight: 600;
    color: rgba(255,255,255,0.86);
    text-shadow: 0 3px 16px rgba(0,0,0,0.65);
  }

  #shopify-section-{{ section.id }} .join-crew-features {
    width: 100%;
    max-width: {{ section.settings.features_width }}px;
    display: grid;
    grid-template-columns: repeat({{ section.settings.feature_columns }}, minmax(0, 1fr));
    gap: {{ section.settings.feature_gap }}px;
    margin-bottom: 34px;
  }

  #shopify-section-{{ section.id }} .join-crew-card {
    min-height: {{ section.settings.card_min_height }}px;
    padding: {{ section.settings.card_padding }}px;
    border-radius: {{ section.settings.card_radius }}px;
    background: rgba(8,8,8,{{ section.settings.card_bg_opacity | divided_by: 100.0 }});
    border: 1px solid rgba(255,255,255,{{ section.settings.card_border_opacity | divided_by: 100.0 }});
    box-shadow: 0 18px 45px rgba(0,0,0,{{ section.settings.card_shadow_opacity | divided_by: 100.0 }});
    backdrop-filter: blur({{ section.settings.card_blur }}px);
    -webkit-backdrop-filter: blur({{ section.settings.card_blur }}px);
    transition: transform .25s ease, border-color .25s ease, background .25s ease;
  }

  #shopify-section-{{ section.id }} .join-crew-card:hover {
    transform: translateY(-3px);
    background: rgba(12,12,12,0.78);
    border-color: rgba(232,93,44,0.55);
  }

  #shopify-section-{{ section.id }} .join-crew-icon {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    margin-bottom: 14px;
    color: #fff;
  }

  #shopify-section-{{ section.id }} .join-crew-icon svg,
  #shopify-section-{{ section.id }} .join-crew-icon img {
    width: {{ section.settings.icon_size }}px;
    height: {{ section.settings.icon_size }}px;
    object-fit: contain;
    color: #fff;
    stroke: currentColor;
  }

  #shopify-section-{{ section.id }} .join-crew-card-title {
    font-family: 'Danger Neue Free Regular', Impact, 'Arial Narrow', sans-serif !important;
    font-size: {{ section.settings.feature_title_size }}px;
    line-height: 1.05;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #fff;
    margin: 0 0 10px;
    font-weight: 400;
    text-shadow: 0 2px 10px rgba(0,0,0,0.8);
  }

  #shopify-section-{{ section.id }} .join-crew-card-text {
    margin: 0;
    font-size: {{ section.settings.feature_desc_size }}px;
    line-height: 1.5;
    font-weight: 600;
    color: rgba(255,255,255,0.82);
    text-shadow: 0 2px 10px rgba(0,0,0,0.75);
  }

  #shopify-section-{{ section.id }} .join-crew-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 14px;
    min-width: {{ section.settings.button_min_width }}px;
    padding: 17px 30px;
    border: 1px solid {{ section.settings.accent_color }};
    background: rgba(0,0,0,0.30);
    color: #fff;
    font-family: 'Danger Neue Free Regular', Impact, sans-serif;
    font-size: {{ section.settings.button_size }}px;
    letter-spacing: 0.13em;
    text-transform: uppercase;
    text-decoration: none;
    transition: background .25s ease, color .25s ease, transform .25s ease;
  }

  #shopify-section-{{ section.id }} .join-crew-button:hover {
    background: {{ section.settings.accent_color }};
    color: #000;
    transform: translateY(-2px);
  }

  #shopify-section-{{ section.id }} .join-crew-button svg {
    transition: transform .25s ease;
  }

  #shopify-section-{{ section.id }} .join-crew-button:hover svg {
    transform: translateX(5px);
  }

  @media screen and (max-width: 990px) {
    #shopify-section-{{ section.id }} .join-crew-bg {
      min-height: {{ section.settings.mobile_section_height }}vh;
      background-position: {{ section.settings.mobile_background_position_x }}% {{ section.settings.mobile_background_position_y }}%;
      align-items: flex-end;
    }

    #shopify-section-{{ section.id }} .join-crew-overlay {
      background:
        linear-gradient(180deg, rgba(0,0,0,0.25) 0%, rgba(0,0,0,0.86) 52%, rgba(0,0,0,0.98) 100%),
        linear-gradient(90deg, rgba(0,0,0,0.6), rgba(0,0,0,0.25));
    }

    #shopify-section-{{ section.id }} .join-crew-container {
      padding-left: 24px;
      padding-right: 24px;
      padding-top: 70px;
      padding-bottom: 46px;
    }

    #shopify-section-{{ section.id }} .join-crew-content {
      max-width: 100%;
      margin-left: 0;
      margin-right: 0;
      transform: none;
    }

    #shopify-section-{{ section.id }} .join-crew-heading {
      font-size: {{ section.settings.mobile_heading_size }}px;
    }

    #shopify-section-{{ section.id }} .join-crew-subheading {
      font-size: {{ section.settings.mobile_subheading_size }}px;
      margin-bottom: 28px;
    }

    #shopify-section-{{ section.id }} .join-crew-features {
      max-width: 100%;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 12px;
    }
  }

  @media screen and (max-width: 560px) {
    #shopify-section-{{ section.id }} .join-crew-features {
      grid-template-columns: 1fr;
    }

    #shopify-section-{{ section.id }} .join-crew-card {
      min-height: auto;
    }

    #shopify-section-{{ section.id }} .join-crew-button {
      width: 100%;
      min-width: 0;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Join The Crew",
  "tag": "section",
  "class": "section-join-crew",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#E85D2C"
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Desktop section height",
      "min": 60,
      "max": 110,
      "step": 5,
      "unit": "vh",
      "default": 90
    },
    {
      "type": "range",
      "id": "background_position_x",
      "label": "Background position horizontal",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "background_position_y",
      "label": "Background position vertical",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    {
      "type": "select",
      "id": "vertical_alignment",
      "label": "Content vertical alignment",
      "default": "center",
      "options": [
        { "value": "flex-start", "label": "Top" },
        { "value": "center", "label": "Middle" },
        { "value": "flex-end", "label": "Bottom" }
      ]
    },
    {
      "type": "header",
      "content": "Overlay"
    },
    {
      "type": "range",
      "id": "overlay_left_opacity",
      "label": "Overlay opacity left",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 85
    },
    {
      "type": "range",
      "id": "overlay_mid_opacity",
      "label": "Overlay opacity middle",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 40
    },
    {
      "type": "range",
      "id": "overlay_right_opacity",
      "label": "Overlay opacity right",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 10
    },
    {
      "type": "range",
      "id": "overlay_top_opacity",
      "label": "Overlay opacity top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 20
    },
    {
      "type": "range",
      "id": "overlay_bottom_opacity",
      "label": "Overlay opacity bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 45
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "TSTN CLUB"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "JOIN THE CREW"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Giveaways, behind-the-scenes content, rewards, and a real community."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "LEARN ABOUT THE CLUB"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Desktop Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container width",
      "min": 1000,
      "max": 1800,
      "step": 20,
      "unit": "px",
      "default": 1500
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content block width",
      "min": 500,
      "max": 1100,
      "step": 20,
      "unit": "px",
      "default": 760
    },
    {
      "type": "select",
      "id": "content_alignment",
      "label": "Content horizontal alignment",
      "default": "center",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ]
    },
    {
      "type": "range",
      "id": "content_shift_left",
      "label": "Move content left",
      "info": "Use this when the content feels too centered. 0 = no shift, higher = further left.",
      "min": 0,
      "max": 300,
      "step": 10,
      "unit": "px",
      "default": 120
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Side padding",
      "min": 20,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 40,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 40,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 96
    },
    {
      "type": "header",
      "content": "Feature Cards"
    },
    {
      "type": "range",
      "id": "features_width",
      "label": "Feature grid width",
      "min": 500,
      "max": 1100,
      "step": 20,
      "unit": "px",
      "default": 740
    },
    {
      "type": "select",
      "id": "feature_columns",
      "label": "Desktop columns",
      "default": "3",
      "options": [
        { "value": "2", "label": "2 columns" },
        { "value": "3", "label": "3 columns" }
      ]
    },
    {
      "type": "range",
      "id": "feature_gap",
      "label": "Card gap",
      "min": 8,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "card_min_height",
      "label": "Card minimum height",
      "min": 130,
      "max": 240,
      "step": 5,
      "unit": "px",
      "default": 160
    },
    {
      "type": "range",
      "id": "card_padding",
      "label": "Card padding",
      "min": 14,
      "max": 36,
      "step": 2,
      "unit": "px",
      "default": 22
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card radius",
      "min": 0,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 6
    },
    {
      "type": "range",
      "id": "card_bg_opacity",
      "label": "Card background opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 55
    },
    {
      "type": "range",
      "id": "card_border_opacity",
      "label": "Card border opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 25
    },
    {
      "type": "range",
      "id": "card_shadow_opacity",
      "label": "Card shadow opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "range",
      "id": "card_blur",
      "label": "Card background blur",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 24,
      "max": 52,
      "step": 2,
      "unit": "px",
      "default": 34
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "eyebrow_size",
      "label": "Eyebrow size",
      "min": 10,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 13
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 44,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 76
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading size",
      "min": 13,
      "max": 26,
      "step": 1,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "subheading_width",
      "label": "Subheading width",
      "min": 300,
      "max": 760,
      "step": 20,
      "unit": "px",
      "default": 520
    },
    {
      "type": "range",
      "id": "feature_title_size",
      "label": "Feature title size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "range",
      "id": "feature_desc_size",
      "label": "Feature description size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "range",
      "id": "button_size",
      "label": "Button size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "button_min_width",
      "label": "Button minimum width",
      "min": 180,
      "max": 420,
      "step": 10,
      "unit": "px",
      "default": 300
    },
    {
      "type": "header",
      "content": "Mobile"
    },
    {
      "type": "range",
      "id": "mobile_section_height",
      "label": "Mobile section height",
      "min": 70,
      "max": 130,
      "step": 5,
      "unit": "vh",
      "default": 110
    },
    {
      "type": "range",
      "id": "mobile_background_position_x",
      "label": "Mobile background position horizontal",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 65
    },
    {
      "type": "range",
      "id": "mobile_background_position_y",
      "label": "Mobile background position vertical",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 50
    },
    {
      "type": "range",
      "id": "mobile_heading_size",
      "label": "Mobile heading size",
      "min": 34,
      "max": 78,
      "step": 2,
      "unit": "px",
      "default": 52
    },
