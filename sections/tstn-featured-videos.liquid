{% comment %}
  TSTN Featured Videos
  - Left: large primary video card + 3 smaller video list items on the right
  - Right: "Members Only" CTA card with checkmark perks list, decorative lock
{% endcomment %}

<style>
  @font-face {
    font-family: 'Danger Neue Free Regular';
    src: url('https://cdn.shopify.com/s/files/1/0000/0000/files/danger-neue-free-regular.woff2?v=1') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --tstn-orange: #F56300;
    --tstn-orange-hover: #ff7a1f;
    --tstn-bg: #0a0a0a;
    --tstn-card-bg: #111111;
    --tstn-text: #ffffff;
    --tstn-muted: #b0b0b0;
    --tstn-border: rgba(255,255,255,0.1);
    --tstn-font-display: "Danger Neue Free Regular", "Inter", sans-serif;
  }

  .tstn-fv {
    background: var(--tstn-bg);
    color: var(--tstn-text);
    padding: clamp(20px, 3vw, 40px) clamp(16px, 4vw, 40px);
  }
  .tstn-fv__inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2.2fr 1fr;
    gap: clamp(20px, 2vw, 28px);
  }

  /* ----- Featured Videos card ----- */
  .tstn-fv__videos {
    background: var(--tstn-card-bg);
    border: 1px solid var(--tstn-border);
    border-radius: 16px;
    padding: clamp(24px, 3vw, 32px);
  }
  .tstn-fv__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: clamp(20px, 2.5vw, 28px);
  }
  .tstn-fv__title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(24px, 2.5vw, 32px);
    margin: 0;
    letter-spacing: 0.5px;
  }
  .tstn-fv__viewall {
    color: var(--tstn-text);
    font-size: 14px;
    text-decoration: none;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s ease;
  }
  .tstn-fv__viewall:hover { color: var(--tstn-orange); }
  .tstn-fv__viewall svg { transition: transform 0.2s ease; }
  .tstn-fv__viewall:hover svg { transform: translateX(4px); }

  .tstn-fv__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(16px, 2vw, 24px);
  }

  /* Main video */
  .tstn-fv__main {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 16/11;
    background: #1a1a1a;
    cursor: pointer;
    display: block;
    text-decoration: none;
    color: inherit;
  }
  .tstn-fv__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .tstn-fv__main:hover img { transform: scale(1.04); }
  .tstn-fv__main::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.7) 100%);
    pointer-events: none;
  }
  .tstn-fv__play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 56px; height: 56px;
    border-radius: 50%;
    background: rgba(255,255,255,0.95);
    display: flex; align-items: center; justify-content: center;
    z-index: 2;
    transition: transform 0.25s ease, background 0.25s ease;
  }
  .tstn-fv__main:hover .tstn-fv__play {
    transform: translate(-50%, -50%) scale(1.1);
    background: var(--tstn-orange);
  }
  .tstn-fv__play svg { color: #000; transition: color 0.25s ease; }
  .tstn-fv__main:hover .tstn-fv__play svg { color: #fff; }

  .tstn-fv__main-info {
    position: absolute;
    bottom: 18px;
    left: 18px;
    right: 18px;
    z-index: 2;
  }
  .tstn-fv__main-title {
    font-size: clamp(20px, 2.2vw, 26px);
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 8px;
  }
  .tstn-fv__main-meta {
    font-size: 13px;
    color: rgba(255,255,255,0.85);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  /* Side video list */
  .tstn-fv__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .tstn-fv__item {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 14px;
    align-items: center;
    padding: 8px;
    border-radius: 10px;
    text-decoration: none;
    color: inherit;
    transition: background 0.2s ease;
  }
  .tstn-fv__item:hover { background: rgba(255,255,255,0.04); }

  .tstn-fv__thumb {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 16/10;
    background: #1a1a1a;
  }
  .tstn-fv__thumb img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .tstn-fv__thumb-play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 32px; height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.9);
    display: flex; align-items: center; justify-content: center;
  }
  .tstn-fv__thumb-duration {
    position: absolute;
    bottom: 6px;
    right: 6px;
    background: rgba(0,0,0,0.8);
    color: #fff;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 4px;
    font-weight: 600;
  }

  .tstn-fv__item-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .tstn-fv__item-title {
    font-size: 14px;
    font-weight: 600;
    line-height: 1.3;
    margin: 0;
    color: var(--tstn-text);
  }
  .tstn-fv__item-meta {
    font-size: 12px;
    color: var(--tstn-muted);
  }
  .tstn-fv__item-time {
    font-size: 12px;
    color: var(--tstn-muted);
  }

  /* ----- Members Only card ----- */
  .tstn-mo {
    background: var(--tstn-card-bg);
    border: 1px solid var(--tstn-border);
    border-radius: 16px;
    padding: clamp(24px, 3vw, 32px);
    position: relative;
    overflow: hidden;
  }
  .tstn-mo::before {
    content: "";
    position: absolute;
    right: -40px;
    bottom: -40px;
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, rgba(245,99,0,0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  .tstn-mo__lock {
    position: absolute;
    right: 20px;
    bottom: 20px;
    color: var(--tstn-orange);
    opacity: 0.35;
    width: 130px;
    height: 130px;
    pointer-events: none;
  }

  .tstn-mo__pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--tstn-orange);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .tstn-mo__title {
    font-size: clamp(22px, 2.4vw, 28px);
    font-weight: 700;
    line-height: 1.25;
    margin: 0 0 20px;
    position: relative;
    z-index: 2;
  }
  .tstn-mo__list {
    list-style: none;
    margin: 0 0 24px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
    z-index: 2;
  }
  .tstn-mo__list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--tstn-text);
  }
  .tstn-mo__check {
    color: var(--tstn-orange);
    flex-shrink: 0;
  }

  .tstn-mo__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--tstn-orange);
    color: #fff;
    padding: 12px 22px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    transition: all 0.25s ease;
    position: relative;
    z-index: 2;
  }
  .tstn-mo__btn:hover { background: var(--tstn-orange-hover); transform: translateY(-2px); }
  .tstn-mo__btn svg { transition: transform 0.25s ease; }
  .tstn-mo__btn:hover svg { transform: translateX(4px); }

  /* Mobile */
  @media (max-width: 1024px) {
    .tstn-fv__inner { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .tstn-fv__grid { grid-template-columns: 1fr; }
    .tstn-fv__item { grid-template-columns: 110px 1fr; }
  }
  @media (max-width: 460px) {
    .tstn-fv__head { flex-direction: column; align-items: flex-start; gap: 10px; }
    .tstn-fv__item { grid-template-columns: 100px 1fr; gap: 10px; }
  }
</style>

<section class="tstn-fv">
  <div class="tstn-fv__inner">

    <!-- Featured Videos card -->
    <div class="tstn-fv__videos">
      <div class="tstn-fv__head">
        <h2 class="tstn-fv__title">{{ section.settings.heading | default: 'Featured Videos' }}</h2>
        <a href="{{ section.settings.viewall_link | default: '#' }}" class="tstn-fv__viewall">
          {{ section.settings.viewall_text | default: 'View all videos' }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

      <div class="tstn-fv__grid">

        <!-- Main video -->
        <a href="{{ section.settings.main_link | default: '#' }}" class="tstn-fv__main">
          {% if section.settings.main_image %}
            <img src="{{ section.settings.main_image | image_url: width: 800 }}" alt="{{ section.settings.main_title }}">
          {% else %}
            <div style="width:100%;height:100%;background:linear-gradient(135deg,#222,#111);"></div>
          {% endif %}
          <div class="tstn-fv__play">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
              <polygon points="6,4 20,12 6,20"/>
            </svg>
          </div>
          <div class="tstn-fv__main-info">
            <h3 class="tstn-fv__main-title">{{ section.settings.main_title | default: 'The Mindset That Changes Everything' }}</h3>
            <div class="tstn-fv__main-meta">
              <span>{{ section.settings.main_author | default: 'By Pratham Mittal' }}</span>
              <span>{{ section.settings.main_duration | default: '12:45' }}</span>
            </div>
          </div>
        </a>

        <!-- Side list -->
        <div class="tstn-fv__list">
          {% for block in section.blocks %}
            {% if block.type == 'video_item' %}
              <a href="{{ block.settings.link | default: '#' }}" class="tstn-fv__item" {{ block.shopify_attributes }}>
                <div class="tstn-fv__thumb">
                  {% if block.settings.image %}
                    <img src="{{ block.settings.image | image_url: width: 300 }}" alt="{{ block.settings.title }}">
                  {% else %}
                    <div style="width:100%;height:100%;background:linear-gradient(135deg,#333,#1a1a1a);"></div>
                  {% endif %}
                  <div class="tstn-fv__thumb-play">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="#000">
                      <polygon points="6,4 20,12 6,20"/>
                    </svg>
                  </div>
                  {% if block.settings.duration != blank %}
                    <span class="tstn-fv__thumb-duration">{{ block.settings.duration }}</span>
                  {% endif %}
                </div>
                <div class="tstn-fv__item-info">
                  <h4 class="tstn-fv__item-title">{{ block.settings.title }}</h4>
                  <span class="tstn-fv__item-meta">{{ block.settings.author }}</span>
                  <span class="tstn-fv__item-time">{{ block.settings.time }}</span>
                </div>
              </a>
            {% endif %}
          {% endfor %}
        </div>

      </div>
    </div>

    <!-- Members Only card -->
    <div class="tstn-mo">
      <div class="tstn-mo__pill">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1l3 6 6 .9-4.5 4.4 1 6.3L12 15.8 6.5 18.6l1-6.3L3 7.9 9 7l3-6z"/></svg>
        {{ section.settings.mo_pill | default: 'MEMBERS ONLY' }}
      </div>
      <h3 class="tstn-mo__title">{{ section.settings.mo_title | default: 'Unlock Exclusive Content & Perks' }}</h3>

      <ul class="tstn-mo__list">
        {% for block in section.blocks %}
          {% if block.type == 'perk' %}
            <li {{ block.shopify_attributes }}>
              <svg class="tstn-mo__check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>{{ block.settings.text }}</span>
            </li>
          {% endif %}
        {% endfor %}
      </ul>

      <a href="{{ section.settings.mo_cta_link | default: '#' }}" class="tstn-mo__btn">
        {{ section.settings.mo_cta_text | default: 'Join TSTN Club' }}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>

      <!-- Decorative lock -->
      <svg class="tstn-mo__lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
      </svg>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "TSTN Featured Videos",
  "settings": [
    { "type": "header", "content": "Section Heading" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Videos" },
    { "type": "text", "id": "viewall_text", "label": "View all link text", "default": "View all videos" },
    { "type": "url", "id": "viewall_link", "label": "View all link" },
    { "type": "header", "content": "Main Featured Video" },
    { "type": "image_picker", "id": "main_image", "label": "Cover Image" },
    { "type": "text", "id": "main_title", "label": "Title", "default": "The Mindset That Changes Everything" },
    { "type": "text", "id": "main_author", "label": "Author/By line", "default": "By Pratham Mittal" },
    { "type": "text", "id": "main_duration", "label": "Duration", "default": "12:45" },
    { "type": "url", "id": "main_link", "label": "Video Link" },
    { "type": "header", "content": "Members Only Card" },
    { "type": "text", "id": "mo_pill", "label": "Pill", "default": "MEMBERS ONLY" },
    { "type": "text", "id": "mo_title", "label": "Title", "default": "Unlock Exclusive Content & Perks" },
    { "type": "text", "id": "mo_cta_text", "label": "CTA", "default": "Join TSTN Club" },
    { "type": "url", "id": "mo_cta_link", "label": "CTA Link" }
  ],
  "blocks": [
    {
      "type": "video_item",
      "name": "Video List Item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Thumbnail" },
        { "type": "text", "id": "title", "label": "Title", "default": "Video Title" },
        { "type": "text", "id": "author", "label": "Author" },
        { "type": "text", "id": "time", "label": "Time" },
        { "type": "text", "id": "duration", "label": "Duration label (e.g. 10:32)" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    },
    {
      "type": "perk",
      "name": "Members Perk",
      "settings": [
        { "type": "text", "id": "text", "label": "Perk", "default": "Exclusive Videos" }
      ]
    }
  ],
  "max_blocks": 12,
  "presets": [
    {
      "name": "TSTN Featured Videos",
      "blocks": [
        { "type": "video_item", "settings": { "title": "Building Discipline That Lasts", "author": "Pratham Mittal", "time": "10:32", "duration": "10:32" } },
        { "type": "video_item", "settings": { "title": "Nutrition Myths Busted!", "author": "Nitika Choudhary", "time": "08:15", "duration": "08:15" } },
        { "type": "video_item", "settings": { "title": "From Setbacks to Comebacks", "author": "Real Member Story", "time": "07:28", "duration": "07:28" } },
        { "type": "perk", "settings": { "text": "Exclusive Videos" } },
        { "type": "perk", "settings": { "text": "In-depth Blogs" } },
        { "type": "perk", "settings": { "text": "Live Sessions" } },
        { "type": "perk", "settings": { "text": "Member Discounts" } },
        { "type": "perk", "settings": { "text": "Early Access to Events" } }
      ]
    }
  ]
}
{% endschema %}
