{% comment %}
  TSTN Featured Videos
  - Login-gated:
      logged-in -> click any video -> opens modal popup with embedded player
      logged-out -> blurred grid with "Members Only" gate overlay (no modal)
  - Supports YouTube, Vimeo and direct video files (auto-detects)
{% endcomment %}

<style>
  @font-face {
    font-family: 'Danger Neue Free Regular';
    src: url('https://cdn.shopify.com/s/files/1/0000/0000/files/danger-neue-free-regular.woff2?v=1') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --tstn-orange: #F56300;
    --tstn-orange-hover: #ff7a1f;
    --tstn-bg: #0a0a0a;
    --tstn-card-bg: #111111;
    --tstn-text: #ffffff;
    --tstn-muted: #b0b0b0;
    --tstn-border: rgba(255,255,255,0.1);
    --tstn-font-display: "Danger Neue Free Regular", "Inter", sans-serif;
  }

  .tstn-fv {
    background: var(--tstn-bg);
    color: var(--tstn-text);
    padding: clamp(20px, 3vw, 40px) clamp(16px, 4vw, 40px);
  }
  .tstn-fv__inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2.2fr 1fr;
    gap: clamp(20px, 2vw, 28px);
  }

  /* ----- Featured Videos card ----- */
  .tstn-fv__videos {
    background: var(--tstn-card-bg);
    border: 1px solid var(--tstn-border);
    border-radius: 16px;
    padding: clamp(24px, 3vw, 32px);
    position: relative;
  }
  .tstn-fv__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: clamp(20px, 2.5vw, 28px);
  }
  .tstn-fv__title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(28px, 3vw, 38px);
    margin: 0;
    letter-spacing: 0.5px;
    line-height: 1;
  }
  .tstn-fv__viewall {
    color: var(--tstn-text);
    font-size: 14px;
    text-decoration: none;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s ease;
  }
  .tstn-fv__viewall:hover { color: var(--tstn-orange); }
  .tstn-fv__viewall svg { transition: transform 0.2s ease; }
  .tstn-fv__viewall:hover svg { transform: translateX(4px); }

  /* Wrap that holds either the video grid OR the gate */
  .tstn-fv__body {
    position: relative;
  }

  .tstn-fv__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(16px, 2vw, 24px);
  }

  /* When gate is active we blur/dim the grid behind it */
  .tstn-fv__body--gated .tstn-fv__grid {
    filter: blur(6px) brightness(0.5);
    pointer-events: none;
    user-select: none;
  }

  /* Main video trigger (button-styled-as-block) */
  .tstn-fv__main {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 16/11;
    background: #1a1a1a;
    cursor: pointer;
    display: block;
    border: none;
    padding: 0;
    text-align: left;
    color: inherit;
    width: 100%;
    font: inherit;
  }
  .tstn-fv__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .tstn-fv__main:hover img { transform: scale(1.04); }
  .tstn-fv__main::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.7) 100%);
    pointer-events: none;
  }
  .tstn-fv__play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 56px; height: 56px;
    border-radius: 50%;
    background: rgba(255,255,255,0.95);
    display: flex; align-items: center; justify-content: center;
    z-index: 2;
    transition: transform 0.25s ease, background 0.25s ease;
  }
  .tstn-fv__main:hover .tstn-fv__play {
    transform: translate(-50%, -50%) scale(1.1);
    background: var(--tstn-orange);
  }
  .tstn-fv__play svg { color: #000; transition: color 0.25s ease; }
  .tstn-fv__main:hover .tstn-fv__play svg { color: #fff; }

  .tstn-fv__main-info {
    position: absolute;
    bottom: 18px;
    left: 18px;
    right: 18px;
    z-index: 2;
  }
  .tstn-fv__main-title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(24px, 2.6vw, 32px);
    line-height: 1.05;
    margin: 0 0 10px;
    letter-spacing: 0.4px;
  }
  .tstn-fv__main-meta {
    font-size: 13px;
    color: rgba(255,255,255,0.85);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  /* Side video list */
  .tstn-fv__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .tstn-fv__item {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 14px;
    align-items: center;
    padding: 8px;
    border-radius: 10px;
    cursor: pointer;
    color: inherit;
    transition: background 0.2s ease;
    border: none;
    background: transparent;
    width: 100%;
    text-align: left;
    font: inherit;
  }
  .tstn-fv__item:hover { background: rgba(255,255,255,0.04); }

  .tstn-fv__thumb {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 16/10;
    background: #1a1a1a;
  }
  .tstn-fv__thumb img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .tstn-fv__thumb-play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 32px; height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.9);
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s ease;
  }
  .tstn-fv__item:hover .tstn-fv__thumb-play { background: var(--tstn-orange); }
  .tstn-fv__item:hover .tstn-fv__thumb-play svg { fill: #fff; }

  .tstn-fv__thumb-duration {
    position: absolute;
    bottom: 6px;
    right: 6px;
    background: rgba(0,0,0,0.8);
    color: #fff;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 4px;
    font-weight: 600;
  }

  .tstn-fv__item-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .tstn-fv__item-title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.15;
    margin: 0;
    color: var(--tstn-text);
    letter-spacing: 0.3px;
  }
  .tstn-fv__item-meta {
    font-size: 12px;
    color: var(--tstn-muted);
  }
  .tstn-fv__item-time {
    font-size: 12px;
    color: var(--tstn-muted);
  }

  /* ----- Login Gate Overlay ----- */
  .tstn-fv__gate {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    padding: 16px;
  }
  .tstn-fv__gate-card {
    background: rgba(17, 17, 17, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid var(--tstn-border);
    border-radius: 16px;
    padding: clamp(28px, 3vw, 40px);
    max-width: 460px;
    width: 100%;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .tstn-fv__gate-card::before {
    content: "";
    position: absolute;
    right: -40px;
    bottom: -40px;
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, rgba(245,99,0,0.18) 0%, transparent 70%);
    pointer-events: none;
  }
  .tstn-fv__gate-lock {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: rgba(245,99,0,0.15);
    border: 1px solid rgba(245,99,0,0.4);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    color: var(--tstn-orange);
    margin-bottom: 18px;
    position: relative;
    z-index: 2;
  }
  .tstn-fv__gate-pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--tstn-orange);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 12px;
    position: relative;
    z-index: 2;
  }
  .tstn-fv__gate-title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(24px, 2.6vw, 32px);
    line-height: 1.1;
    margin: 0 0 10px;
    color: var(--tstn-text);
    letter-spacing: 0.4px;
    position: relative;
    z-index: 2;
  }
  .tstn-fv__gate-text {
    font-size: 14px;
    color: var(--tstn-muted);
    line-height: 1.5;
    margin: 0 0 22px;
    position: relative;
    z-index: 2;
  }
  .tstn-fv__gate-actions {
    display: flex;
    gap: 10px;
    justify-content: center;
    flex-wrap: wrap;
    position: relative;
    z-index: 2;
  }
  .tstn-fv__gate-btn {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 12px 22px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    transition: all 0.25s ease;
    border: 1px solid transparent;
    line-height: 1;
  }
  .tstn-fv__gate-btn--primary {
    background: var(--tstn-orange);
    color: #fff;
  }
  .tstn-fv__gate-btn--primary:hover { background: var(--tstn-orange-hover); transform: translateY(-2px); }
  .tstn-fv__gate-btn--ghost {
    background: transparent;
    color: var(--tstn-text);
    border-color: rgba(255,255,255,0.3);
  }
  .tstn-fv__gate-btn--ghost:hover { background: var(--tstn-text); color: var(--tstn-bg); }

  /* ----- Members Only sidebar ----- */
  .tstn-mo {
    background: var(--tstn-card-bg);
    border: 1px solid var(--tstn-border);
    border-radius: 16px;
    padding: clamp(24px, 3vw, 32px);
    position: relative;
    overflow: hidden;
  }
  .tstn-mo::before {
    content: "";
    position: absolute;
    right: -40px;
    bottom: -40px;
    width: 280px;
    height: 280px;
    background: radial-gradient(circle, rgba(245,99,0,0.15) 0%, transparent 70%);
    pointer-events: none;
  }
  .tstn-mo__lock {
    position: absolute;
    right: 20px;
    bottom: 20px;
    color: var(--tstn-orange);
    opacity: 0.35;
    width: 130px;
    height: 130px;
    pointer-events: none;
  }
  .tstn-mo__pill {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    color: var(--tstn-orange);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 16px;
  }
  .tstn-mo__title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(26px, 2.8vw, 34px);
    line-height: 1.1;
    margin: 0 0 22px;
    position: relative;
    z-index: 2;
    letter-spacing: 0.4px;
  }
  .tstn-mo__list {
    list-style: none;
    margin: 0 0 24px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 10px;
    position: relative;
    z-index: 2;
  }
  .tstn-mo__list li {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 14px;
    color: var(--tstn-text);
  }
  .tstn-mo__check {
    color: var(--tstn-orange);
    flex-shrink: 0;
  }
  .tstn-mo__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--tstn-orange);
    color: #fff;
    padding: 12px 22px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    transition: all 0.25s ease;
    position: relative;
    z-index: 2;
  }
  .tstn-mo__btn:hover { background: var(--tstn-orange-hover); transform: translateY(-2px); }
  .tstn-mo__btn svg { transition: transform 0.25s ease; }
  .tstn-mo__btn:hover svg { transform: translateX(4px); }

  /* ----- Modal ----- */
  .tstn-fv__modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: clamp(16px, 4vw, 40px);
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .tstn-fv__modal.is-open {
    display: flex;
    opacity: 1;
  }
  .tstn-fv__modal-inner {
    position: relative;
    width: 100%;
    max-width: 1100px;
    background: #000;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0,0,0,0.6);
    transform: translateY(20px);
    transition: transform 0.25s ease;
  }
  .tstn-fv__modal.is-open .tstn-fv__modal-inner {
    transform: translateY(0);
  }
  .tstn-fv__modal-close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .tstn-fv__modal-close:hover {
    background: var(--tstn-orange);
    transform: rotate(90deg);
  }
  .tstn-fv__modal-frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    background: #000;
  }
  .tstn-fv__modal-frame iframe,
  .tstn-fv__modal-frame video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
  .tstn-fv__modal-meta {
    padding: 16px clamp(16px, 2vw, 24px);
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: var(--tstn-card-bg);
    border-top: 1px solid var(--tstn-border);
  }
  .tstn-fv__modal-title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(20px, 2.2vw, 26px);
    margin: 0;
    color: var(--tstn-text);
    letter-spacing: 0.3px;
    line-height: 1.15;
  }
  .tstn-fv__modal-author {
    font-size: 13px;
    color: var(--tstn-muted);
  }

  body.tstn-fv-modal-open {
    overflow: hidden;
  }

  /* Mobile */
  @media (max-width: 1024px) {
    .tstn-fv__inner { grid-template-columns: 1fr; }
  }
  @media (max-width: 720px) {
    .tstn-fv__grid { grid-template-columns: 1fr; }
    .tstn-fv__item { grid-template-columns: 110px 1fr; }
  }
  @media (max-width: 460px) {
    .tstn-fv__head { flex-direction: column; align-items: flex-start; gap: 10px; }
    .tstn-fv__item { grid-template-columns: 100px 1fr; gap: 10px; }
    .tstn-fv__item-title { font-size: 16px; }
    .tstn-fv__gate-actions { flex-direction: column; }
    .tstn-fv__gate-btn { width: 100%; justify-content: center; }
  }
</style>

<section class="tstn-fv">
  <div class="tstn-fv__inner">

    <!-- Featured Videos card -->
    <div class="tstn-fv__videos">
      <div class="tstn-fv__head">
        <h2 class="tstn-fv__title">{{ section.settings.heading | default: 'Featured Videos' }}</h2>
        <a href="{{ section.settings.viewall_link | default: '#' }}" class="tstn-fv__viewall">
          {{ section.settings.viewall_text | default: 'View all videos' }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

      <div class="tstn-fv__body {% if customer == nil %}tstn-fv__body--gated{% endif %}">

        <div class="tstn-fv__grid">

          <!-- Main video -->
          <button
            class="tstn-fv__main"
            type="button"
            {% if customer %}
              data-tstn-video-trigger
              data-video-url="{{ section.settings.main_link }}"
              data-video-title="{{ section.settings.main_title | default: 'The Mindset That Changes Everything' | escape }}"
              data-video-author="{{ section.settings.main_author | default: 'By Pratham Mittal' | escape }}"
            {% else %}
              tabindex="-1" aria-hidden="true"
            {% endif %}>
            {% if section.settings.main_image %}
              <img src="{{ section.settings.main_image | image_url: width: 800 }}" alt="{{ section.settings.main_title }}">
            {% else %}
              <div style="width:100%;height:100%;background:linear-gradient(135deg,#222,#111);"></div>
            {% endif %}
            <div class="tstn-fv__play">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <polygon points="6,4 20,12 6,20"/>
              </svg>
            </div>
            <div class="tstn-fv__main-info">
              <h3 class="tstn-fv__main-title">{{ section.settings.main_title | default: 'The Mindset That Changes Everything' }}</h3>
              <div class="tstn-fv__main-meta">
                <span>{{ section.settings.main_author | default: 'By Pratham Mittal' }}</span>
                <span>{{ section.settings.main_duration | default: '12:45' }}</span>
              </div>
            </div>
          </button>

          <!-- Side list -->
          <div class="tstn-fv__list">
            {% for block in section.blocks %}
              {% if block.type == 'video_item' %}
                <button
                  class="tstn-fv__item"
                  type="button"
                  {{ block.shopify_attributes }}
                  {% if customer %}
                    data-tstn-video-trigger
                    data-video-url="{{ block.settings.link }}"
                    data-video-title="{{ block.settings.title | escape }}"
                    data-video-author="{{ block.settings.author | escape }}"
                  {% else %}
                    tabindex="-1" aria-hidden="true"
                  {% endif %}>
                  <div class="tstn-fv__thumb">
                    {% if block.settings.image %}
                      <img src="{{ block.settings.image | image_url: width: 300 }}" alt="{{ block.settings.title }}">
                    {% else %}
                      <div style="width:100%;height:100%;background:linear-gradient(135deg,#333,#1a1a1a);"></div>
                    {% endif %}
                    <div class="tstn-fv__thumb-play">
                      <svg width="12" height="12" viewBox="0 0 24 24" fill="#000">
                        <polygon points="6,4 20,12 6,20"/>
                      </svg>
                    </div>
                    {% if block.settings.duration != blank %}
                      <span class="tstn-fv__thumb-duration">{{ block.settings.duration }}</span>
                    {% endif %}
                  </div>
                  <div class="tstn-fv__item-info">
                    <h4 class="tstn-fv__item-title">{{ block.settings.title }}</h4>
                    <span class="tstn-fv__item-meta">{{ block.settings.author }}</span>
                    <span class="tstn-fv__item-time">{{ block.settings.time }}</span>
                  </div>
                </button>
              {% endif %}
            {% endfor %}
          </div>

        </div>

        {% unless customer %}
          <div class="tstn-fv__gate">
            <div class="tstn-fv__gate-card">
              <div class="tstn-fv__gate-lock">
                <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
                  <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
                </svg>
              </div>
              <div class="tstn-fv__gate-pill">
                <svg width="12" height="12" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1l3 6 6 .9-4.5 4.4 1 6.3L12 15.8 6.5 18.6l1-6.3L3 7.9 9 7l3-6z"/></svg>
                {{ section.settings.gate_pill | default: 'MEMBERS ONLY' }}
              </div>
              <h3 class="tstn-fv__gate-title">{{ section.settings.gate_title | default: 'Unlock Exclusive Content & Perks' }}</h3>
              <p class="tstn-fv__gate-text">{{ section.settings.gate_text | default: 'Sign in or join TSTN Club to watch exclusive videos, get in-depth blogs, live sessions, member discounts and early access to events.' }}</p>
              <div class="tstn-fv__gate-actions">
                <a href="{{ section.settings.gate_join_link | default: '/account/register' }}" class="tstn-fv__gate-btn tstn-fv__gate-btn--primary">
                  {{ section.settings.gate_join_text | default: 'Join TSTN Club' }}
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </a>
                <a href="{{ section.settings.gate_login_link | default: '/account/login' }}" class="tstn-fv__gate-btn tstn-fv__gate-btn--ghost">
                  {{ section.settings.gate_login_text | default: 'Login' }}
                </a>
              </div>
            </div>
          </div>
        {% endunless %}

      </div>
    </div>

    <!-- Members Only sidebar -->
    <div class="tstn-mo">
      <div class="tstn-mo__pill">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M12 1l3 6 6 .9-4.5 4.4 1 6.3L12 15.8 6.5 18.6l1-6.3L3 7.9 9 7l3-6z"/></svg>
        {{ section.settings.mo_pill | default: 'MEMBERS ONLY' }}
      </div>
      <h3 class="tstn-mo__title">{{ section.settings.mo_title | default: 'Unlock Exclusive Content & Perks' }}</h3>

      <ul class="tstn-mo__list">
        {% for block in section.blocks %}
          {% if block.type == 'perk' %}
            <li {{ block.shopify_attributes }}>
              <svg class="tstn-mo__check" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>{{ block.settings.text }}</span>
            </li>
          {% endif %}
        {% endfor %}
      </ul>

      {% unless customer %}
        <a href="{{ section.settings.mo_cta_link | default: '/account/register' }}" class="tstn-mo__btn">
          {{ section.settings.mo_cta_text | default: 'Join TSTN Club' }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      {% endunless %}

      <svg class="tstn-mo__lock" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
      </svg>
    </div>

  </div>

  <!-- Video Modal -->
  <div class="tstn-fv__modal" id="tstn-fv-modal-{{ section.id }}" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="tstn-fv__modal-inner">
      <button class="tstn-fv__modal-close" type="button" aria-label="Close video">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <div class="tstn-fv__modal-frame" data-tstn-modal-frame></div>
      <div class="tstn-fv__modal-meta">
        <h3 class="tstn-fv__modal-title" data-tstn-modal-title></h3>
        <span class="tstn-fv__modal-author" data-tstn-modal-author></span>
      </div>
    </div>
  </div>

</section>

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var section = document.getElementById('shopify-section-' + sectionId);
  if (!section) return;

  var modal       = section.querySelector('#tstn-fv-modal-' + sectionId);
  if (!modal) return;
  var frame       = modal.querySelector('[data-tstn-modal-frame]');
  var titleEl     = modal.querySelector('[data-tstn-modal-title]');
  var authorEl    = modal.querySelector('[data-tstn-modal-author]');
  var closeBtn    = modal.querySelector('.tstn-fv__modal-close');
  var triggers    = section.querySelectorAll('[data-tstn-video-trigger]');

  // Convert any pasted YouTube/Vimeo URL to its embed form
  function buildEmbed(rawUrl) {
    if (!rawUrl) return null;
    var url = rawUrl.trim();

    // YouTube: youtu.be/ID, youtube.com/watch?v=ID, youtube.com/shorts/ID, /embed/ID
    var ytMatch = url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([A-Za-z0-9_-]{11})/);
    if (ytMatch) {
      return {
        type: 'iframe',
        src: 'https://www.youtube.com/embed/' + ytMatch[1] + '?autoplay=1&rel=0&modestbranding=1'
      };
    }

    // Vimeo: vimeo.com/ID or player.vimeo.com/video/ID
    var vimeoMatch = url.match(/(?:vimeo\.com\/(?:video\/)?|player\.vimeo\.com\/video\/)(\d+)/);
    if (vimeoMatch) {
      return {
        type: 'iframe',
        src: 'https://player.vimeo.com/video/' + vimeoMatch[1] + '?autoplay=1'
      };
    }

    // Direct video file
    if (/\.(mp4|webm|ogg|mov)(\?.*)?$/i.test(url)) {
      return { type: 'video', src: url };
    }

    // Fallback - treat as iframe (e.g. Shopify-hosted video CDN, custom player URL)
    return { type: 'iframe', src: url };
  }

  function openModal(trigger) {
    var url = trigger.getAttribute('data-video-url');
    var embed = buildEmbed(url);

    // No usable URL set - just bail (don't open empty modal)
    if (!embed || !embed.src || embed.src === '' || embed.src === '#') {
      console.warn('[TSTN] No video URL set for this trigger.');
      return;
    }

    // Inject player markup
    if (embed.type === 'iframe') {
      frame.innerHTML =
        '<iframe src="' + embed.src + '" ' +
        'allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" ' +
        'allowfullscreen></iframe>';
    } else {
      frame.innerHTML =
        '<video src="' + embed.src + '" controls autoplay playsinline></video>';
    }

    titleEl.textContent  = trigger.getAttribute('data-video-title')  || '';
    authorEl.textContent = trigger.getAttribute('data-video-author') || '';

    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('tstn-fv-modal-open');
  }

  function closeModal() {
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    document.body.classList.remove('tstn-fv-modal-open');
    // Important: clear iframe src so audio/video stops playing
    frame.innerHTML = '';
  }

  triggers.forEach(function(t) {
    t.addEventListener('click', function() { openModal(t); });
  });

  closeBtn.addEventListener('click', closeModal);

  // Click backdrop to close
  modal.addEventListener('click', function(e) {
    if (e.target === modal) closeModal();
  });

  // ESC to close
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape' && modal.classList.contains('is-open')) closeModal();
  });
})();
</script>

