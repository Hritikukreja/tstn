{% comment %}
  TSTN Featured Videos
  - Logged-in: clicking a video opens a video modal player
  - Logged-out: clicking a video opens a "Members Only" gate popup
  - Sidebar: slidable promo carousel; each slide is either a Link CTA OR
             an inline Email Capture form (Shopify built-in newsletter)
{% endcomment %}

<style>
  @font-face {
    font-family: 'Danger Neue Free Regular';
    src: url('https://cdn.shopify.com/s/files/1/0000/0000/files/danger-neue-free-regular.woff2?v=1') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --tstn-orange: #F56300;
    --tstn-orange-hover: #ff7a1f;
    --tstn-bg: #0a0a0a;
    --tstn-card-bg: #111111;
    --tstn-card-bg-2: #161616;
    --tstn-text: #ffffff;
    --tstn-muted: #b0b0b0;
    --tstn-border: rgba(255,255,255,0.1);
    --tstn-font-display: "Danger Neue Free Regular", "Inter", sans-serif;
  }

  .tstn-fv {
    background: var(--tstn-bg);
    color: var(--tstn-text);
    padding: clamp(20px, 3vw, 40px) clamp(16px, 4vw, 40px);
  }
  .tstn-fv__inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 2.2fr 1fr;
    gap: clamp(20px, 2vw, 28px);
  }

  /* ----- Featured Videos card ----- */
  .tstn-fv__videos {
    background: var(--tstn-card-bg);
    border: 1px solid var(--tstn-border);
    border-radius: 16px;
    padding: clamp(24px, 3vw, 32px);
  }
  .tstn-fv__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: clamp(20px, 2.5vw, 28px);
  }
  .tstn-fv__title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(28px, 3vw, 38px);
    margin: 0;
    letter-spacing: 0.5px;
    line-height: 1;
  }
  .tstn-fv__viewall {
    color: var(--tstn-text);
    font-size: 14px;
    text-decoration: none;
    font-weight: 500;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: color 0.2s ease;
  }
  .tstn-fv__viewall:hover { color: var(--tstn-orange); }
  .tstn-fv__viewall svg { transition: transform 0.2s ease; }
  .tstn-fv__viewall:hover svg { transform: translateX(4px); }

  .tstn-fv__grid {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: clamp(16px, 2vw, 24px);
  }

  /* Main video trigger */
  .tstn-fv__main {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    aspect-ratio: 16/11;
    background: #1a1a1a;
    cursor: pointer;
    display: block;
    border: none;
    padding: 0;
    text-align: left;
    color: inherit;
    width: 100%;
    font: inherit;
  }
  .tstn-fv__main img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.4s ease;
  }
  .tstn-fv__main:hover img { transform: scale(1.04); }
  .tstn-fv__main::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, rgba(0,0,0,0.1) 0%, rgba(0,0,0,0.7) 100%);
    pointer-events: none;
  }
  .tstn-fv__play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 56px; height: 56px;
    border-radius: 50%;
    background: rgba(255,255,255,0.95);
    display: flex; align-items: center; justify-content: center;
    z-index: 2;
    transition: transform 0.25s ease, background 0.25s ease;
  }
  .tstn-fv__main:hover .tstn-fv__play {
    transform: translate(-50%, -50%) scale(1.1);
    background: var(--tstn-orange);
  }
  .tstn-fv__play svg { color: #000; transition: color 0.25s ease; }
  .tstn-fv__main:hover .tstn-fv__play svg { color: #fff; }

  .tstn-fv__main-info {
    position: absolute;
    bottom: 18px;
    left: 18px;
    right: 18px;
    z-index: 2;
  }
  .tstn-fv__main-title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(24px, 2.6vw, 32px);
    line-height: 1.05;
    margin: 0 0 10px;
    letter-spacing: 0.4px;
  }
  .tstn-fv__main-meta {
    font-size: 13px;
    color: rgba(255,255,255,0.85);
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  /* Side video list */
  .tstn-fv__list {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }
  .tstn-fv__item {
    display: grid;
    grid-template-columns: 130px 1fr;
    gap: 14px;
    align-items: center;
    padding: 8px;
    border-radius: 10px;
    cursor: pointer;
    color: inherit;
    transition: background 0.2s ease;
    border: none;
    background: transparent;
    width: 100%;
    text-align: left;
    font: inherit;
  }
  .tstn-fv__item:hover { background: rgba(255,255,255,0.04); }

  .tstn-fv__thumb {
    position: relative;
    border-radius: 8px;
    overflow: hidden;
    aspect-ratio: 16/10;
    background: #1a1a1a;
  }
  .tstn-fv__thumb img {
    width: 100%; height: 100%;
    object-fit: cover; display: block;
  }
  .tstn-fv__thumb-play {
    position: absolute;
    top: 50%; left: 50%;
    transform: translate(-50%, -50%);
    width: 32px; height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.9);
    display: flex; align-items: center; justify-content: center;
    transition: background 0.2s ease;
  }
  .tstn-fv__item:hover .tstn-fv__thumb-play { background: var(--tstn-orange); }
  .tstn-fv__item:hover .tstn-fv__thumb-play svg { fill: #fff; }
  .tstn-fv__thumb-duration {
    position: absolute;
    bottom: 6px;
    right: 6px;
    background: rgba(0,0,0,0.8);
    color: #fff;
    font-size: 10px;
    padding: 2px 6px;
    border-radius: 4px;
    font-weight: 600;
  }
  .tstn-fv__item-info {
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .tstn-fv__item-title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: 17px;
    line-height: 1.15;
    margin: 0;
    color: var(--tstn-text);
    letter-spacing: 0.3px;
  }
  .tstn-fv__item-meta { font-size: 12px; color: var(--tstn-muted); }
  .tstn-fv__item-time { font-size: 12px; color: var(--tstn-muted); }

  /* ============================================================
     Promo Carousel
     ============================================================ */
  .tstn-promo {
    background: var(--tstn-card-bg);
    border: 1px solid var(--tstn-border);
    border-radius: 16px;
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
    min-height: 480px;
  }

  .tstn-promo__track-wrap {
    position: relative;
    flex: 1;
    overflow: hidden;
  }
  .tstn-promo__track {
    display: flex;
    height: 100%;
    transition: transform 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    touch-action: pan-y;
  }
  .tstn-promo__slide {
    flex: 0 0 100%;
    width: 100%;
    display: flex;
    flex-direction: column;
    position: relative;
  }

  .tstn-promo__media {
    position: relative;
    width: 100%;
    aspect-ratio: 16/10;
    background: var(--tstn-card-bg-2);
    overflow: hidden;
    flex-shrink: 0;
  }
  .tstn-promo__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .tstn-promo__media-fallback {
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 70% 30%, rgba(245,99,0,0.25) 0%, transparent 60%), linear-gradient(135deg, #1a1a1a, #0a0a0a);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--tstn-orange);
    opacity: 0.5;
  }
  .tstn-promo__badge {
    position: absolute;
    top: 14px;
    left: 14px;
    background: var(--tstn-orange);
    color: #fff;
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 1.2px;
    padding: 5px 11px;
    border-radius: 999px;
    text-transform: uppercase;
    z-index: 2;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }
  .tstn-promo__badge--live { background: #ff2d2d; }
  .tstn-promo__badge-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #fff;
    animation: tstn-pulse 1.4s ease-in-out infinite;
  }
  @keyframes tstn-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.5; transform: scale(1.3); }
  }

  .tstn-promo__body {
    padding: clamp(20px, 2.5vw, 26px);
    display: flex;
    flex-direction: column;
    flex: 1;
  }
  .tstn-promo__eyebrow {
    color: var(--tstn-orange);
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 10px;
  }
  .tstn-promo__title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(22px, 2.4vw, 28px);
    line-height: 1.1;
    margin: 0 0 10px;
    color: var(--tstn-text);
    letter-spacing: 0.4px;
  }
  .tstn-promo__desc {
    font-size: 13px;
    color: var(--tstn-muted);
    line-height: 1.5;
    margin: 0 0 18px;
    flex: 1;
  }

  /* CTA Link button */
  .tstn-promo__cta {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--tstn-orange);
    color: #fff;
    padding: 11px 20px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 13px;
    transition: all 0.25s ease;
    align-self: flex-start;
  }
  .tstn-promo__cta:hover {
    background: var(--tstn-orange-hover);
    transform: translateY(-2px);
  }
  .tstn-promo__cta svg { transition: transform 0.25s ease; }
  .tstn-promo__cta:hover svg { transform: translateX(3px); }

  /* Email capture form */
  .tstn-promo__form {
    margin-top: auto;
  }
  .tstn-promo__form-row {
    display: flex;
    gap: 6px;
    background: rgba(255,255,255,0.06);
    border: 1px solid var(--tstn-border);
    border-radius: 999px;
    padding: 4px;
    transition: border-color 0.2s ease;
  }
  .tstn-promo__form-row:focus-within {
    border-color: var(--tstn-orange);
  }
  .tstn-promo__form-input {
    flex: 1;
    background: transparent;
    border: none;
    outline: none;
    color: var(--tstn-text);
    font-size: 13px;
    padding: 10px 14px;
    font-family: inherit;
    min-width: 0;
  }
  .tstn-promo__form-input::placeholder {
    color: rgba(255,255,255,0.4);
  }
  .tstn-promo__form-btn {
    background: var(--tstn-orange);
    color: #fff;
    border: none;
    border-radius: 999px;
    padding: 10px 16px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: background 0.2s ease;
    flex-shrink: 0;
    font-family: inherit;
  }
  .tstn-promo__form-btn:hover { background: var(--tstn-orange-hover); }
  .tstn-promo__form-msg {
    font-size: 12px;
    color: var(--tstn-orange);
    margin-top: 8px;
    padding-left: 6px;
  }
  .tstn-promo__form-msg--success { color: #4ade80; }
  .tstn-promo__form-msg--error { color: #ff6b6b; }

  /* Carousel controls */
  .tstn-promo__controls {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 clamp(20px, 2.5vw, 26px) 20px;
    gap: 12px;
  }
  .tstn-promo__dots {
    display: flex;
    gap: 6px;
    flex: 1;
  }
  .tstn-promo__dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: rgba(255,255,255,0.2);
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s ease, width 0.2s ease;
  }
  .tstn-promo__dot.is-active {
    background: var(--tstn-orange);
    width: 18px;
    border-radius: 3px;
  }
  .tstn-promo__arrows {
    display: flex;
    gap: 6px;
  }
  .tstn-promo__arrow {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    border: 1px solid rgba(255,255,255,0.2);
    background: transparent;
    color: var(--tstn-text);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s ease;
  }
  .tstn-promo__arrow:hover {
    background: var(--tstn-orange);
    border-color: var(--tstn-orange);
    color: #fff;
  }

  /* ============================================================
     Modals
     ============================================================ */
  .tstn-modal {
    position: fixed;
    inset: 0;
    z-index: 9999;
    display: none;
    align-items: center;
    justify-content: center;
    padding: clamp(16px, 4vw, 40px);
    background: rgba(0, 0, 0, 0.85);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    opacity: 0;
    transition: opacity 0.25s ease;
  }
  .tstn-modal.is-open { display: flex; opacity: 1; }
  .tstn-modal__inner {
    position: relative;
    transform: translateY(20px);
    transition: transform 0.25s ease;
  }
  .tstn-modal.is-open .tstn-modal__inner { transform: translateY(0); }

  .tstn-modal__close {
    position: absolute;
    top: 12px;
    right: 12px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255,255,255,0.2);
    color: #fff;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 10;
    transition: background 0.2s ease, transform 0.2s ease;
  }
  .tstn-modal__close:hover {
    background: var(--tstn-orange);
    transform: rotate(90deg);
  }

  /* Video modal */
  .tstn-modal--video .tstn-modal__inner {
    width: 100%;
    max-width: 1100px;
    background: #000;
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 30px 80px rgba(0,0,0,0.6);
  }
  .tstn-modal__frame {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    background: #000;
  }
  .tstn-modal__frame iframe,
  .tstn-modal__frame video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }
  .tstn-modal__meta {
    padding: 16px clamp(16px, 2vw, 24px);
    display: flex;
    flex-direction: column;
    gap: 4px;
    background: var(--tstn-card-bg);
    border-top: 1px solid var(--tstn-border);
  }
  .tstn-modal__title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(20px, 2.2vw, 26px);
    margin: 0;
    color: var(--tstn-text);
    letter-spacing: 0.3px;
    line-height: 1.15;
  }
  .tstn-modal__author { font-size: 13px; color: var(--tstn-muted); }

  /* Gate modal */
  .tstn-modal--gate .tstn-modal__inner {
    width: 100%;
    max-width: 560px;
    background: var(--tstn-card-bg);
    border: 1px solid var(--tstn-border);
    border-radius: 18px;
    padding: clamp(32px, 4vw, 44px);
    overflow: hidden;
  }
  .tstn-gate__lock-bg {
    position: absolute;
    right: -10px;
    bottom: -20px;
    color: var(--tstn-orange);
    opacity: 0.35;
    width: 220px;
    height: 220px;
    pointer-events: none;
  }
  .tstn-gate__glow {
    position: absolute;
    right: -60px;
    bottom: -60px;
    width: 360px;
    height: 360px;
    background: radial-gradient(circle, rgba(245,99,0,0.18) 0%, transparent 65%);
    pointer-events: none;
  }
  .tstn-gate__pill {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    color: var(--tstn-orange);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    margin-bottom: 18px;
    position: relative;
    z-index: 2;
  }
  .tstn-gate__pill svg { width: 14px; height: 14px; }
  .tstn-gate__title {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(28px, 3.2vw, 38px);
    line-height: 1.05;
    margin: 0 0 26px;
    color: var(--tstn-text);
    letter-spacing: 0.5px;
    position: relative;
    z-index: 2;
  }
  .tstn-gate__list {
    list-style: none;
    margin: 0 0 28px;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 14px;
    position: relative;
    z-index: 2;
  }
  .tstn-gate__list li {
    display: flex;
    align-items: center;
    gap: 14px;
    font-size: 15px;
    color: var(--tstn-text);
    font-weight: 500;
  }
  .tstn-gate__check { color: var(--tstn-orange); flex-shrink: 0; }
  .tstn-gate__cta {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--tstn-orange);
    color: #fff;
    padding: 13px 26px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    transition: all 0.25s ease;
    position: relative;
    z-index: 2;
  }
  .tstn-gate__cta:hover {
    background: var(--tstn-orange-hover);
    transform: translateY(-2px);
  }
  .tstn-gate__cta svg { transition: transform 0.25s ease; }
  .tstn-gate__cta:hover svg { transform: translateX(4px); }

  body.tstn-modal-open { overflow: hidden; }

  /* Mobile */
  @media (max-width: 1024px) {
    .tstn-fv__inner { grid-template-columns: 1fr; }
    .tstn-promo { min-height: auto; }
  }
  @media (max-width: 720px) {
    .tstn-fv__grid { grid-template-columns: 1fr; }
    .tstn-fv__item { grid-template-columns: 110px 1fr; }
  }
  @media (max-width: 460px) {
    .tstn-fv__head { flex-direction: column; align-items: flex-start; gap: 10px; }
    .tstn-fv__item { grid-template-columns: 100px 1fr; gap: 10px; }
    .tstn-fv__item-title { font-size: 16px; }
    .tstn-modal--gate .tstn-modal__inner { padding: 28px 24px; }
    .tstn-gate__lock-bg { width: 160px; height: 160px; }
    .tstn-promo__form-row { flex-direction: column; border-radius: 14px; padding: 6px; gap: 4px; }
    .tstn-promo__form-input { padding: 10px 12px; }
    .tstn-promo__form-btn { width: 100%; justify-content: center; padding: 10px; }
  }
</style>

<section class="tstn-fv">
  <div class="tstn-fv__inner">

    <!-- Featured Videos card -->
    <div class="tstn-fv__videos">
      <div class="tstn-fv__head">
        <h2 class="tstn-fv__title">{{ section.settings.heading | default: 'Featured Videos' }}</h2>
        <a href="{{ section.settings.viewall_link | default: '#' }}" class="tstn-fv__viewall">
          {{ section.settings.viewall_text | default: 'View all videos' }}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </div>

      <div class="tstn-fv__grid">

        <button
          class="tstn-fv__main"
          type="button"
          data-tstn-video-trigger
          data-video-url="{{ section.settings.main_link }}"
          data-video-title="{{ section.settings.main_title | default: 'The Mindset That Changes Everything' | escape }}"
          data-video-author="{{ section.settings.main_author | default: 'By Pratham Mittal' | escape }}">
          {% if section.settings.main_image %}
            <img src="{{ section.settings.main_image | image_url: width: 800 }}" alt="{{ section.settings.main_title }}">
          {% else %}
            <div style="width:100%;height:100%;background:linear-gradient(135deg,#222,#111);"></div>
          {% endif %}
          <div class="tstn-fv__play">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor"><polygon points="6,4 20,12 6,20"/></svg>
          </div>
          <div class="tstn-fv__main-info">
            <h3 class="tstn-fv__main-title">{{ section.settings.main_title | default: 'The Mindset That Changes Everything' }}</h3>
            <div class="tstn-fv__main-meta">
              <span>{{ section.settings.main_author | default: 'By Pratham Mittal' }}</span>
              <span>{{ section.settings.main_duration | default: '12:45' }}</span>
            </div>
          </div>
        </button>

        <div class="tstn-fv__list">
          {% for block in section.blocks %}
            {% if block.type == 'video_item' %}
              <button
                class="tstn-fv__item"
                type="button"
                data-tstn-video-trigger
                data-video-url="{{ block.settings.link }}"
                data-video-title="{{ block.settings.title | escape }}"
                data-video-author="{{ block.settings.author | escape }}"
                {{ block.shopify_attributes }}>
                <div class="tstn-fv__thumb">
                  {% if block.settings.image %}
                    <img src="{{ block.settings.image | image_url: width: 300 }}" alt="{{ block.settings.title }}">
                  {% else %}
                    <div style="width:100%;height:100%;background:linear-gradient(135deg,#333,#1a1a1a);"></div>
                  {% endif %}
                  <div class="tstn-fv__thumb-play">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="#000"><polygon points="6,4 20,12 6,20"/></svg>
                  </div>
                  {% if block.settings.duration != blank %}
                    <span class="tstn-fv__thumb-duration">{{ block.settings.duration }}</span>
                  {% endif %}
                </div>
                <div class="tstn-fv__item-info">
                  <h4 class="tstn-fv__item-title">{{ block.settings.title }}</h4>
                  <span class="tstn-fv__item-meta">{{ block.settings.author }}</span>
                  <span class="tstn-fv__item-time">{{ block.settings.time }}</span>
                </div>
              </button>
            {% endif %}
          {% endfor %}
        </div>

      </div>
    </div>

    <!-- Promo Carousel -->
    {%- assign promo_count = 0 -%}
    {%- for block in section.blocks -%}
      {%- if block.type == 'promo' -%}{%- assign promo_count = promo_count | plus: 1 -%}{%- endif -%}
    {%- endfor -%}

    <div
      class="tstn-promo"
      data-tstn-promo
      data-autoplay="{{ section.settings.promo_autoplay }}"
      data-autoplay-speed="{{ section.settings.promo_autoplay_speed | default: 5000 }}">

      <div class="tstn-promo__track-wrap">
        <div class="tstn-promo__track" data-tstn-promo-track>
          {% for block in section.blocks %}
            {% if block.type == 'promo' %}
              <div class="tstn-promo__slide" {{ block.shopify_attributes }}>
                <div class="tstn-promo__media">
                  {% if block.settings.image %}
                    <img src="{{ block.settings.image | image_url: width: 800 }}" alt="{{ block.settings.title }}">
                  {% else %}
                    <div class="tstn-promo__media-fallback">
                      {% case block.settings.badge_type %}
                        {% when 'live' %}
                          <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="23 7 16 12 23 17 23 7"></polygon><rect x="1" y="5" width="15" height="14" rx="2" ry="2"></rect></svg>
                        {% when 'giveaway' %}
                          <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 12 20 22 4 22 4 12"></polyline><rect x="2" y="7" width="20" height="5"></rect><line x1="12" y1="22" x2="12" y2="7"></line><path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z"></path><path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z"></path></svg>
                        {% else %}
                          <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><polygon points="10 8 16 12 10 16 10 8"></polygon></svg>
                      {% endcase %}
                    </div>
                  {% endif %}

                  {% if block.settings.badge_text != blank %}
                    <span class="tstn-promo__badge {% if block.settings.badge_type == 'live' %}tstn-promo__badge--live{% endif %}">
                      {% if block.settings.badge_type == 'live' %}
                        <span class="tstn-promo__badge-dot"></span>
                      {% endif %}
                      {{ block.settings.badge_text }}
                    </span>
                  {% endif %}
                </div>

                <div class="tstn-promo__body">
                  {% if block.settings.eyebrow != blank %}
                    <span class="tstn-promo__eyebrow">{{ block.settings.eyebrow }}</span>
                  {% endif %}
                  <h3 class="tstn-promo__title">{{ block.settings.title }}</h3>
                  <p class="tstn-promo__desc">{{ block.settings.description }}</p>

                  {%- comment -%} CTA mode: link OR email capture {%- endcomment -%}
                  {% if block.settings.cta_mode == 'email' %}
                    {% form 'customer', class: 'tstn-promo__form', novalidate: 'novalidate' %}
                      <input type="hidden" name="contact[tags]" value="newsletter,promo:{{ block.settings.email_tag | default: 'general' | escape }}">
                      <div class="tstn-promo__form-row">
                        <input
                          type="email"
                          name="contact[email]"
                          class="tstn-promo__form-input"
                          placeholder="{{ block.settings.email_placeholder | default: 'Enter your email' | escape }}"
                          required
                          autocomplete="email">
                        <button type="submit" name="commit" class="tstn-promo__form-btn">
                          {{ block.settings.email_btn_text | default: 'Subscribe' }}
                          <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <line x1="5" y1="12" x2="19" y2="12"></line>
                            <polyline points="12 5 19 12 12 19"></polyline>
                          </svg>
                        </button>
                      </div>
                      {% if form.posted_successfully? %}
                        <div class="tstn-promo__form-msg tstn-promo__form-msg--success">{{ block.settings.email_success | default: '✓ Thanks! You’re on the list.' }}</div>
                      {% elsif form.errors %}
                        <div class="tstn-promo__form-msg tstn-promo__form-msg--error">{{ form.errors | default_errors }}</div>
                      {% endif %}
                    {% endform %}
                  {% else %}
                    <a href="{{ block.settings.cta_link | default: '#' }}" class="tstn-promo__cta">
                      {{ block.settings.cta_text | default: 'Learn More' }}
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                        <line x1="5" y1="12" x2="19" y2="12"></line>
                        <polyline points="12 5 19 12 12 19"></polyline>
                      </svg>
                    </a>
                  {% endif %}
                </div>
              </div>
            {% endif %}
          {% endfor %}
        </div>
      </div>

      {% if promo_count > 1 %}
        <div class="tstn-promo__controls">
          <div class="tstn-promo__dots" data-tstn-promo-dots>
            {% assign d_idx = 0 %}
            {% for block in section.blocks %}
              {% if block.type == 'promo' %}
                <button class="tstn-promo__dot {% if d_idx == 0 %}is-active{% endif %}" type="button" data-tstn-promo-dot="{{ d_idx }}" aria-label="Slide {{ d_idx | plus: 1 }}"></button>
                {% assign d_idx = d_idx | plus: 1 %}
              {% endif %}
            {% endfor %}
          </div>
          <div class="tstn-promo__arrows">
            <button class="tstn-promo__arrow" type="button" data-tstn-promo-prev aria-label="Previous">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"></polyline></svg>
            </button>
            <button class="tstn-promo__arrow" type="button" data-tstn-promo-next aria-label="Next">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"></polyline></svg>
            </button>
          </div>
        </div>
      {% endif %}
    </div>

  </div>

  <!-- Video Modal -->
  <div class="tstn-modal tstn-modal--video" id="tstn-modal-video-{{ section.id }}" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="tstn-modal__inner">
      <button class="tstn-modal__close" type="button" aria-label="Close video">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <div class="tstn-modal__frame" data-tstn-modal-frame></div>
      <div class="tstn-modal__meta">
        <h3 class="tstn-modal__title" data-tstn-modal-title></h3>
        <span class="tstn-modal__author" data-tstn-modal-author></span>
      </div>
    </div>
  </div>

  <!-- Gate Modal -->
  <div class="tstn-modal tstn-modal--gate" id="tstn-modal-gate-{{ section.id }}" role="dialog" aria-modal="true" aria-hidden="true">
    <div class="tstn-modal__inner">
      <button class="tstn-modal__close" type="button" aria-label="Close">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>

      <div class="tstn-gate__glow"></div>
      <svg class="tstn-gate__lock-bg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
        <rect x="3" y="11" width="18" height="11" rx="2" ry="2"></rect>
        <path d="M7 11V7a5 5 0 0 1 10 0v4"></path>
      </svg>

      <div class="tstn-gate__pill">
        <svg viewBox="0 0 24 24" fill="currentColor"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon></svg>
        {{ section.settings.gate_pill | default: 'MEMBERS ONLY' }}
      </div>

      <h3 class="tstn-gate__title">{{ section.settings.gate_title | default: 'Unlock Exclusive Content & Perks' }}</h3>

      <ul class="tstn-gate__list">
        {% for block in section.blocks %}
          {% if block.type == 'perk' %}
            <li {{ block.shopify_attributes }}>
              <svg class="tstn-gate__check" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
              <span>{{ block.settings.text }}</span>
            </li>
          {% endif %}
        {% endfor %}
      </ul>

      <a href="{{ section.settings.gate_cta_link | default: '/account/register' }}" class="tstn-gate__cta">
        {{ section.settings.gate_cta_text | default: 'Join TSTN Club' }}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>
  </div>

</section>

<script>
(function() {
  var sectionId = '{{ section.id }}';
  var section = document.getElementById('shopify-section-' + sectionId);
  if (!section) return;

  var isLoggedIn = {% if customer %}true{% else %}false{% endif %};

  var videoModal = section.querySelector('#tstn-modal-video-' + sectionId);
  var gateModal  = section.querySelector('#tstn-modal-gate-' + sectionId);
  var frame      = videoModal && videoModal.querySelector('[data-tstn-modal-frame]');
  var titleEl    = videoModal && videoModal.querySelector('[data-tstn-modal-title]');
  var authorEl   = videoModal && videoModal.querySelector('[data-tstn-modal-author]');
  var triggers   = section.querySelectorAll('[data-tstn-video-trigger]');

  function buildEmbed(rawUrl) {
    if (!rawUrl) return null;
    var url = rawUrl.trim();
    var ytMatch = url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/|shorts\/)|youtu\.be\/)([A-Za-z0-9_-]{11})/);
    if (ytMatch) return { type: 'iframe', src: 'https://www.youtube.com/embed/' + ytMatch[1] + '?autoplay=1&rel=0&modestbranding=1' };
    var vimeoMatch = url.match(/(?:vimeo\.com\/(?:video\/)?|player\.vimeo\.com\/video\/)(\d+)/);
    if (vimeoMatch) return { type: 'iframe', src: 'https://player.vimeo.com/video/' + vimeoMatch[1] + '?autoplay=1' };
    if (/\.(mp4|webm|ogg|mov)(\?.*)?$/i.test(url)) return { type: 'video', src: url };
    return { type: 'iframe', src: url };
  }

  function openModal(modal) {
    if (!modal) return;
    modal.classList.add('is-open');
    modal.setAttribute('aria-hidden', 'false');
    document.body.classList.add('tstn-modal-open');
  }
  function closeModal(modal) {
    if (!modal) return;
    modal.classList.remove('is-open');
    modal.setAttribute('aria-hidden', 'true');
    if (!section.querySelector('.tstn-modal.is-open')) {
      document.body.classList.remove('tstn-modal-open');
    }
    if (modal === videoModal && frame) frame.innerHTML = '';
  }

  function openVideoModal(trigger) {
    var url = trigger.getAttribute('data-video-url');
    var embed = buildEmbed(url);
    if (!embed || !embed.src || embed.src === '' || embed.src === '#') {
      console.warn('[TSTN] No video URL set for this trigger.');
      return;
    }
    if (embed.type === 'iframe') {
      frame.innerHTML = '<iframe src="' + embed.src + '" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen></iframe>';
    } else {
      frame.innerHTML = '<video src="' + embed.src + '" controls autoplay playsinline></video>';
    }
    titleEl.textContent  = trigger.getAttribute('data-video-title')  || '';
    authorEl.textContent = trigger.getAttribute('data-video-author') || '';
    openModal(videoModal);
  }

  triggers.forEach(function(t) {
    t.addEventListener('click', function() {
      if (isLoggedIn) openVideoModal(t); else openModal(gateModal);
    });
  });

  section.querySelectorAll('.tstn-modal').forEach(function(modal) {
    var closeBtn = modal.querySelector('.tstn-modal__close');
    if (closeBtn) closeBtn.addEventListener('click', function() { closeModal(modal); });
    modal.addEventListener('click', function(e) {
      if (e.target === modal) closeModal(modal);
    });
  });

  document.addEventListener('keydown', function(e) {
    if (e.key !== 'Escape') return;
    section.querySelectorAll('.tstn-modal.is-open').forEach(function(m) { closeModal(m); });
  });

  /* Promo Carousel */
  var promo = section.querySelector('[data-tstn-promo]');
  if (promo) {
    var track = promo.querySelector('[data-tstn-promo-track]');
    var slides = track.querySelectorAll('.tstn-promo__slide');
    var dots = promo.querySelectorAll('[data-tstn-promo-dot]');
    var prevBtn = promo.querySelector('[data-tstn-promo-prev]');
    var nextBtn = promo.querySelector('[data-tstn-promo-next]');
    var index = 0;
    var total = slides.length;
    var autoplay = promo.getAttribute('data-autoplay') === 'true';
    var autoplaySpeed = parseInt(promo.getAttribute('data-autoplay-speed'), 10) || 5000;
    var timer = null;

    function goTo(i) {
      index = (i + total) % total;
      track.style.transform = 'translateX(-' + (index * 100) + '%)';
      dots.forEach(function(d, di) { d.classList.toggle('is-active', di === index); });
    }
    function next() { goTo(index + 1); }
    function prev() { goTo(index - 1); }
    function startAuto() {
      if (!autoplay || total < 2) return;
      stopAuto();
      timer = setInterval(next, autoplaySpeed);
    }
    function stopAuto() { if (timer) { clearInterval(timer); timer = null; } }

    if (nextBtn) nextBtn.addEventListener('click', function() { next(); startAuto(); });
    if (prevBtn) prevBtn.addEventListener('click', function() { prev(); startAuto(); });
    dots.forEach(function(d) {
      d.addEventListener('click', function() {
        goTo(parseInt(d.getAttribute('data-tstn-promo-dot'), 10));
        startAuto();
      });
    });

    promo.addEventListener('mouseenter', stopAuto);
    promo.addEventListener('mouseleave', startAuto);

    // Don't pause/swipe when interacting with form fields
    track.querySelectorAll('input, button').forEach(function(el) {
      el.addEventListener('focus', stopAuto);
      el.addEventListener('blur', startAuto);
    });

    var touchStartX = 0, touchEndX = 0;
    track.addEventListener('touchstart', function(e) {
      // Don't intercept swipe on form fields
      if (e.target.closest('.tstn-promo__form')) return;
      touchStartX = e.changedTouches[0].screenX;
      stopAuto();
    }, { passive: true });
    track.addEventListener('touchend', function(e) {
      if (e.target.closest('.tstn-promo__form')) return;
      touchEndX = e.changedTouches[0].screenX;
      var diff = touchStartX - touchEndX;
      if (Math.abs(diff) > 40) { if (diff > 0) next(); else prev(); }
      startAuto();
    }, { passive: true });

    startAuto();
  }
})();
</script>

{% schema %}
{
  "name": "TSTN Featured Videos",
  "settings": [
    { "type": "header", "content": "Section Heading" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Featured Videos" },
    { "type": "text", "id": "viewall_text", "label": "View all link text", "default": "View all videos" },
    { "type": "url", "id": "viewall_link", "label": "View all link" },

    { "type": "header", "content": "Main Featured Video" },
    { "type": "image_picker", "id": "main_image", "label": "Cover Image" },
    { "type": "text", "id": "main_title", "label": "Title", "default": "The Mindset That Changes Everything" },
    { "type": "text", "id": "main_author", "label": "Author/By line", "default": "By Pratham Mittal" },
    { "type": "text", "id": "main_duration", "label": "Duration", "default": "12:45" },
    { "type": "url", "id": "main_link", "label": "Video URL (YouTube, Vimeo, or direct .mp4)" },

    { "type": "header", "content": "Members Only Gate Popup (logged-out)" },
    { "type": "text", "id": "gate_pill", "label": "Pill Label", "default": "MEMBERS ONLY" },
    { "type": "text", "id": "gate_title", "label": "Title", "default": "Unlock Exclusive Content & Perks" },
    { "type": "text", "id": "gate_cta_text", "label": "CTA Button Text", "default": "Join TSTN Club" },
    { "type": "url", "id": "gate_cta_link", "label": "CTA Button Link" },
    { "type": "paragraph", "content": "Add 'Members Perk' blocks below to populate the checkmark list." },

    { "type": "header", "content": "Promo Carousel" },
    { "type": "checkbox", "id": "promo_autoplay", "label": "Auto-rotate slides", "default": true },
    { "type": "range", "id": "promo_autoplay_speed", "label": "Auto-rotate speed (ms)", "min": 2000, "max": 9000, "step": 500, "default": 5000 }
  ],
  "blocks": [
    {
      "type": "video_item",
      "name": "Video List Item",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Thumbnail" },
        { "type": "text", "id": "title", "label": "Title", "default": "Video Title" },
        { "type": "text", "id": "author", "label": "Author" },
        { "type": "text", "id": "time", "label": "Time" },
        { "type": "text", "id": "duration", "label": "Duration label (e.g. 10:32)" },
        { "type": "url", "id": "link", "label": "Video URL" }
      ]
    },
    {
      "type": "perk",
      "name": "Members Perk",
      "settings": [
        { "type": "text", "id": "text", "label": "Perk", "default": "Exclusive Videos" }
      ]
    },
    {
      "type": "promo",
      "name": "Promo Slide",
      "settings": [
        { "type": "image_picker", "id": "image", "label": "Slide Image" },
        {
          "type": "select",
          "id": "badge_type",
          "label": "Badge Style",
          "default": "default",
          "options": [
            { "value": "default", "label": "Standard (orange)" },
            { "value": "live", "label": "LIVE (red, pulsing)" },
            { "value": "giveaway", "label": "Giveaway" }
          ]
        },
        { "type": "text", "id": "badge_text", "label": "Badge Text (optional)", "default": "GIVEAWAY" },
        { "type": "text", "id": "eyebrow", "label": "Eyebrow Text", "default": "Don't miss out" },
        { "type": "text", "id": "title", "label": "Title", "default": "Promo Title" },
        { "type": "textarea", "id": "description", "label": "Description", "default": "Short description of the promo." },
        { "type": "header", "content": "Call to Action" },
        {
          "type": "select",
          "id": "cta_mode",
          "label": "CTA Style",
          "default": "link",
          "options": [
            { "value": "link", "label": "Link Button" },
            { "value": "email", "label": "Email Capture Form" }
          ]
        },
        { "type": "paragraph", "content": "▼ If 'Link Button' is selected:" },
        { "type": "text", "id": "cta_text", "label": "Button Text", "default": "Learn More" },
        { "type": "url", "id": "cta_link", "label": "Button Link" },
        { "type": "paragraph", "content": "▼ If 'Email Capture Form' is selected — emails go to your Shopify customer list:" },
        { "type": "text", "id": "email_placeholder", "label": "Input Placeholder", "default": "Enter your email" },
        { "type": "text", "id": "email_btn_text", "label": "Submit Button Text", "default": "Subscribe" },
        { "type": "text", "id": "email_tag", "label": "Customer Tag (segments emails)", "default": "general", "info": "Submitted emails are tagged so you can segment them in Shopify Admin (e.g. 'live-video', 'giveaway-jan')." },
        { "type": "text", "id": "email_success", "label": "Success Message", "default": "✓ Thanks! You’re on the list." }
      ]
    }
  ],
  "max_blocks": 16,
  "presets": [
    {
      "name": "TSTN Featured Videos",
      "blocks": [
        { "type": "video_item", "settings": { "title": "Building Discipline That Lasts", "author": "Pratham Mittal", "time": "10:32", "duration": "10:32" } },
        { "type": "video_item", "settings": { "title": "Nutrition Myths Busted!", "author": "Nitika Choudhary", "time": "08:15", "duration": "08:15" } },
        { "type": "video_item", "settings": { "title": "From Setbacks to Comebacks", "author": "Real Member Story", "time": "07:28", "duration": "07:28" } },
        { "type": "perk", "settings": { "text": "Exclusive Videos" } },
        { "type": "perk", "settings": { "text": "In-depth Blogs" } },
        { "type": "perk", "settings": { "text": "Live Sessions" } },
        { "type": "perk", "settings": { "text": "Member Discounts" } },
