{% liquid
  assign section_id = 'FeatureCards-' | append: section.id
%}

<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=DM+Sans:ital,opsz,wght@0,9..40,300;0,9..40,400;1,9..40,300&display=swap" rel="stylesheet">

<section id="{{ section_id }}" class="feature-cards">
  <div class="feature-cards__page-width">

    {%- comment -%} ── Header row ── {%- endcomment -%}
    <div class="feature-cards__header">
      <div class="feature-cards__header-left">
        {%- if section.settings.heading != blank -%}
          <h2 class="feature-cards__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
      </div>
      <div class="feature-cards__header-right">
        {%- if section.settings.cta_label != blank -%}
          <a class="feature-cards__cta" href="{{ section.settings.cta_url | default: '#' }}">
            {{ section.settings.cta_label }}
            <span class="feature-cards__cta-arrow">
              <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                <path d="M2 7h10M7.5 2.5l5 4.5-5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </span>
          </a>
        {%- endif -%}
      </div>
    </div>

    {%- comment -%} ── Carousel ── {%- endcomment -%}
    <div class="feature-cards__carousel-wrap">
      <div class="feature-cards__track" id="{{ section_id }}-track">
        {%- for block in section.blocks -%}
          {%- liquid
            assign img_sizes = '340px'
            assign card_url = block.settings.link | default: '#'
          -%}
          <article class="feature-cards__card" {{ block.shopify_attributes }}>

            {%- comment -%} Decorative corner accent {%- endcomment -%}
            <span class="feature-cards__card-accent" aria-hidden="true"></span>

            <div class="feature-cards__card-body">
              <div class="feature-cards__card-text">
                {%- if block.settings.kicker != blank -%}
                  <p class="feature-cards__card-kicker">
                    <span class="feature-cards__card-kicker-dot"></span>
                    {{ block.settings.kicker }}
                  </p>
                {%- endif -%}
                {%- if block.settings.title != blank -%}
                  <h3 class="feature-cards__card-title">{{ block.settings.title }}</h3>
                {%- endif -%}
                {%- if block.settings.description != blank -%}
                  <p class="feature-cards__card-desc">{{ block.settings.description }}</p>
                {%- endif -%}
              </div>

              <div class="feature-cards__card-media">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 680
                    | image_tag:
                      loading: 'lazy',
                      widths: '340, 500, 680',
                      sizes: img_sizes,
                      class: 'feature-cards__card-img',
                      alt: block.settings.image.alt | default: block.settings.title | escape
                  }}
                {%- else -%}
                  {{ 'image' | placeholder_svg_tag: 'feature-cards__card-placeholder' }}
                {%- endif -%}
              </div>
            </div>

            {%- if card_url != '#' or block.settings.link != blank -%}
              <a class="feature-cards__card-btn" href="{{ card_url }}" aria-label="Learn more about {{ block.settings.title | escape }}">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none" aria-hidden="true">
                  <path d="M2 7h10M7.5 2.5l5 4.5-5 4.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            {%- else -%}
              <span class="feature-cards__card-btn feature-cards__card-btn--static" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 14 14" fill="none">
                  <path d="M7 2v10M2 7h10" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
                </svg>
              </span>
            {%- endif -%}

          </article>
        {%- endfor -%}
      </div>
    </div>

    {%- comment -%} ── Nav arrows ── {%- endcomment -%}
    {%- if section.blocks.size > 1 -%}
      <div class="feature-cards__nav" id="{{ section_id }}-nav">
        <button
          class="feature-cards__nav-btn feature-cards__nav-btn--prev"
          id="{{ section_id }}-prev"
          aria-label="Previous"
          disabled
        >
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M8 1L3 6l5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
        <button
          class="feature-cards__nav-btn feature-cards__nav-btn--next"
          id="{{ section_id }}-next"
          aria-label="Next"
        >
          <svg width="12" height="12" viewBox="0 0 12 12" fill="none" aria-hidden="true">
            <path d="M4 1l5 5-5 5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </button>
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  /* ── TSTN Design Tokens ── */
  #{{ section_id }} {
    --tstn-red:       #F56300;
    --tstn-red-glow:  rgba(245, 99, 0, 0.18);
    --tstn-red-dim:   rgba(245, 99, 0, 0.08);
    --tstn-white:     #FFFFFF;
    --tstn-off-white: #E8E8E8;
    --tstn-muted:     rgba(255, 255, 255, 0.45);
    --tstn-card-bg:   #111111;
    --tstn-card-border: rgba(255, 255, 255, 0.07);
    --tstn-card-border-hover: rgba(245, 99, 0, 0.5);
    --tstn-font-heading: 'Danger Neue Free Regular', 'DM Sans', sans-serif;
    --tstn-font-body:    'DM Sans', sans-serif;
  }

  /* ── Danger Neue Free (self-hosted fallback path — swap to your CDN or Shopify asset) ── */
  @font-face {
    font-family: 'Danger Neue Free Regular';
    src: url('{{ "DangerNeue-Regular.woff2" | asset_url }}') format('woff2'),
         url('{{ "DangerNeue-Regular.woff"  | asset_url }}') format('woff');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  /* ── Section ── */
  #{{ section_id }} {
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    position: relative;
    overflow: hidden;
  }

  /* Subtle grid texture overlay */
  #{{ section_id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.025) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.025) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
    z-index: 0;
  }

  /* Orange glow accent top-left */
  #{{ section_id }}::after {
    content: '';
    position: absolute;
    top: -120px;
    left: -80px;
    width: 420px;
    height: 420px;
    background: radial-gradient(circle, var(--tstn-red-glow) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  #{{ section_id }} .feature-cards__page-width {
    max-width: 128rem;
    margin: 0 auto;
    padding: 0 4.4rem;
    position: relative;
    z-index: 1;
  }

  /* ── Header ── */
  #{{ section_id }} .feature-cards__header {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 2rem;
    margin-bottom: 4rem;
  }

  #{{ section_id }} .feature-cards__heading {
    margin: 0;
    font-family: var(--tstn-font-heading);
    font-size: clamp(3.2rem, 5vw, 5.6rem);
    font-weight: 400;
    line-height: 1.0;
    letter-spacing: 0.01em;
    color: {{ section.settings.heading_color }};
    max-width: 60rem;
    text-transform: uppercase;
  }

  #{{ section_id }} .feature-cards__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    font-family: var(--tstn-font-body);
    font-size: 1.3rem;
    font-weight: 300;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: {{ section.settings.cta_color }};
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    padding-bottom: 0.4rem;
    border-bottom: 1px solid {{ section.settings.cta_color }};
    transition: color 0.2s ease, border-color 0.2s ease, gap 0.2s ease;
  }

  #{{ section_id }} .feature-cards__cta:hover {
    color: var(--tstn-white);
    border-color: var(--tstn-white);
    gap: 1.4rem;
  }

  #{{ section_id }} .feature-cards__cta-arrow {
    display: flex;
    align-items: center;
    transition: transform 0.2s ease;
  }

  #{{ section_id }} .feature-cards__cta:hover .feature-cards__cta-arrow {
    transform: translateX(3px);
  }

  /* ── Carousel track ── */
  #{{ section_id }} .feature-cards__carousel-wrap {
    overflow: hidden;
  }

  #{{ section_id }} .feature-cards__track {
    display: flex;
    gap: 1.6rem;
    transition: transform 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    will-change: transform;
    align-items: stretch;
  }

  /* ── Card ── */
  #{{ section_id }} .feature-cards__card {
    flex: 0 0 {{ section.settings.card_width }}px;
    width: {{ section.settings.card_width }}px;
    background: {{ section.settings.card_bg }};
    border: 1px solid var(--tstn-card-border);
    border-radius: 2px;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: border-color 0.3s ease, transform 0.3s ease, box-shadow 0.3s ease;
  }

  #{{ section_id }} .feature-cards__card:hover {
    border-color: var(--tstn-card-border-hover);
    transform: translateY(-3px);
    box-shadow: 0 16px 40px rgba(0, 0, 0, 0.5), 0 0 0 1px rgba(245, 99, 0, 0.18);
  }

  /* Top-edge red accent line */
  #{{ section_id }} .feature-cards__card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--tstn-red);
    opacity: 0;
    transition: opacity 0.3s ease;
    z-index: 2;
  }

  #{{ section_id }} .feature-cards__card:hover::before {
    opacity: 1;
  }

  /* ── Decorative corner accent ── */
  #{{ section_id }} .feature-cards__card-accent {
    position: absolute;
    top: 0;
    right: 0;
    width: 48px;
    height: 48px;
    border-top: 1px solid rgba(255, 255, 255, 0.12);
    border-right: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 0 2px 0 0;
    z-index: 1;
    pointer-events: none;
  }

  #{{ section_id }} .feature-cards__card-body {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    flex: 1;
    padding: 2.8rem 2.8rem 0;
    min-height: {{ section.settings.card_height }}px;
  }

  #{{ section_id }} .feature-cards__card-text {
    flex-shrink: 0;
  }

  /* ── Kicker ── */
  #{{ section_id }} .feature-cards__card-kicker {
    margin: 0 0 1.2rem;
    font-family: var(--tstn-font-body);
    font-size: 1.1rem;
    font-weight: 300;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.kicker_color }};
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  #{{ section_id }} .feature-cards__card-kicker-dot {
    display: inline-block;
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--tstn-red);
    flex-shrink: 0;
  }

  /* ── Card title ── */
  #{{ section_id }} .feature-cards__card-title {
    margin: 0 0 1.2rem;
    font-family: var(--tstn-font-heading);
    font-size: 2.4rem;
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: 0.01em;
    text-transform: uppercase;
    color: {{ section.settings.card_title_color }};
  }

  /* ── Card description ── */
  #{{ section_id }} .feature-cards__card-desc {
    margin: 0;
    font-family: var(--tstn-font-body);
    font-size: 1.3rem;
    font-weight: 300;
    line-height: 1.65;
    color: {{ section.settings.card_desc_color }};
  }

  /* ── Card image ── */
  #{{ section_id }} .feature-cards__card-media {
    margin-top: 2.4rem;
    flex: 1;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
    border-radius: 0;
    position: relative;
  }

  /* Image fade to card bg */
  #{{ section_id }} .feature-cards__card-media::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, {{ section.settings.card_bg }} 0%, transparent 30%);
    z-index: 1;
    pointer-events: none;
  }

  #{{ section_id }} .feature-cards__card-img,
  #{{ section_id }} .feature-cards__card-placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.6s ease;
  }

  #{{ section_id }} .feature-cards__card:hover .feature-cards__card-img {
    transform: scale(1.03);
  }

  #{{ section_id }} .feature-cards__card-placeholder {
    min-height: 16rem;
    opacity: 0.08;
  }

  /* ── Arrow button ── */
  #{{ section_id }} .feature-cards__card-btn {
    position: absolute;
    bottom: 2.4rem;
    right: 2.4rem;
    width: 3.6rem;
    height: 3.6rem;
    background: var(--tstn-red);
    border-radius: 2px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-decoration: none;
    color: var(--tstn-white);
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
    border: none;
    cursor: pointer;
    z-index: 3;
  }

  #{{ section_id }} .feature-cards__card-btn:hover {
    background: #E05800;
    transform: scale(1.1);
    box-shadow: 0 0 20px rgba(245, 99, 0, 0.5);
  }

  #{{ section_id }} .feature-cards__card-btn--static {
    background: rgba(255, 255, 255, 0.08);
    cursor: default;
  }

  #{{ section_id }} .feature-cards__card-btn--static:hover {
    background: rgba(255, 255, 255, 0.12);
    transform: none;
    box-shadow: none;
  }

  /* ── Nav arrows ── */
  #{{ section_id }} .feature-cards__nav {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1.2rem;
    margin-top: 4rem;
  }

  #{{ section_id }} .feature-cards__nav-btn {
    width: 4rem;
    height: 4rem;
    border-radius: 2px;
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: {{ section.settings.heading_color }};
    transition: background 0.2s ease, border-color 0.2s ease, opacity 0.2s ease;
    font-family: var(--tstn-font-body);
  }

  #{{ section_id }} .feature-cards__nav-btn:hover:not(:disabled) {
    background: var(--tstn-red);
    border-color: var(--tstn-red);
  }

  #{{ section_id }} .feature-cards__nav-btn:disabled {
    opacity: 0.2;
    cursor: default;
  }

  /* ── Mobile ── */
  @media screen and (max-width: 749px) {
    #{{ section_id }} .feature-cards__page-width {
      padding: 0 2rem;
    }

    #{{ section_id }} .feature-cards__header {
      flex-direction: column;
      align-items: flex-start;
      gap: 1.6rem;
      margin-bottom: 2.8rem;
    }

    #{{ section_id }} .feature-cards__heading {
      font-size: clamp(2.8rem, 8vw, 4rem);
    }

    #{{ section_id }} .feature-cards__card {
      flex: 0 0 calc(100vw - 6rem);
      width: calc(100vw - 6rem);
    }
  }
</style>

<script>
  (function () {
    const trackEl = document.getElementById('{{ section_id }}-track');
    const prevBtn = document.getElementById('{{ section_id }}-prev');
    const nextBtn = document.getElementById('{{ section_id }}-next');

    if (!trackEl || !prevBtn || !nextBtn) return;

    const cards = Array.from(trackEl.children);
    if (cards.length === 0) return;

    let currentIndex = 0;

    function getVisibleCount() {
      const wrapWidth = trackEl.parentElement.offsetWidth;
      const cardWidth = cards[0].offsetWidth;
      const gap = 16;
      return Math.max(1, Math.floor((wrapWidth + gap) / (cardWidth + gap)));
    }

    function maxIndex() {
      return Math.max(0, cards.length - getVisibleCount());
    }

    function getOffset(index) {
      const cardWidth = cards[0].offsetWidth;
      const gap = 16;
      return index * (cardWidth + gap);
    }

    function go(index) {
      currentIndex = Math.max(0, Math.min(index, maxIndex()));
      trackEl.style.transform = `translateX(-${getOffset(currentIndex)}px)`;
      prevBtn.disabled = currentIndex === 0;
      nextBtn.disabled = currentIndex >= maxIndex();
    }

    prevBtn.addEventListener('click', () => go(currentIndex - 1));
    nextBtn.addEventListener('click', () => go(currentIndex + 1));

    // ── Touch / swipe support ──
    let touchStartX = 0;
    let touchStartY = 0;
    let isDragging = false;

    trackEl.addEventListener('touchstart', (e) => {
      touchStartX = e.touches[0].clientX;
      touchStartY = e.touches[0].clientY;
      isDragging = true;
    }, { passive: true });

    trackEl.addEventListener('touchmove', (e) => {
      if (!isDragging) return;
      const deltaX = e.touches[0].clientX - touchStartX;
      const deltaY = e.touches[0].clientY - touchStartY;
      // If scrolling vertically more than horizontally, don't hijack scroll
      if (Math.abs(deltaY) > Math.abs(deltaX)) {
        isDragging = false;
        return;
      }
      e.preventDefault();
    }, { passive: false });

    trackEl.addEventListener('touchend', (e) => {
      if (!isDragging) return;
      isDragging = false;
      const deltaX = e.changedTouches[0].clientX - touchStartX;
      const threshold = 50;
      if (deltaX < -threshold) {
        go(currentIndex + 1);
      } else if (deltaX > threshold) {
        go(currentIndex - 1);
      }
    }, { passive: true });

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(() => go(Math.min(currentIndex, maxIndex())), 100);
    });

    go(0);
  })();
</script>

{% schema %}
{
  "name": "Feature cards carousel",
  "tag": "section",
  "class": "section",
  "max_blocks": 10,
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Why we're the best place to buy."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop now"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Cards"
    },
    {
      "type": "range",
      "id": "card_width",
      "min": 240,
      "max": 480,
      "step": 8,
      "unit": "px",
      "label": "Card width",
      "default": 320
    },
    {
      "type": "range",
      "id": "card_height",
      "min": 300,
      "max": 700,
      "step": 4,
      "unit": "px",
      "label": "Card min height",
      "default": 444
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#0A0A0A"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Card background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Section heading color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "CTA link color",
      "default": "#F56300"
    },
    {
      "type": "color",
      "id": "kicker_color",
      "label": "Card kicker color",
      "default": "#888888"
    },
    {
      "type": "color",
      "id": "card_title_color",
      "label": "Card title color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "card_desc_color",
      "label": "Card description color",
      "default": "#999999"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Feature card",
      "settings": [
        {
          "type": "text",
          "id": "kicker",
          "label": "Kicker (small top label)",
          "default": "Feature"
        },
        {
          "type": "textarea",
          "id": "title",
          "label": "Title",
          "default": "A compelling reason to choose us."
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "A short supporting sentence that adds context to the title above."
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Card image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card link",
          "info": "Links the arrow button. Leave blank to show a static + icon."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature cards carousel",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "kicker": "Trade In",
            "title": "Save on a new purchase with a trade-in.",
            "description": "Get credit toward your next purchase when you trade in your old one."
          }
        },
        {
          "type": "card",
          "settings": {
            "kicker": "Ways to Buy",
            "title": "Get 0% APR monthly payments.",
            "description": "Choose an easy way to finance your purchase with convenient monthly payment options."
          }
        },
        {
          "type": "card",
          "settings": {
