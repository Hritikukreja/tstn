{% liquid
  assign section_id = 'ProductShowcase-' | append: section.id
%}

<section id="{{ section_id }}" class="product-showcase">
  <div class="product-showcase__inner page-width">

    {%- if section.settings.kicker != blank or section.settings.heading != blank or section.settings.cta_label != blank -%}
      <div class="product-showcase__header">
        {%- if section.settings.kicker != blank -%}
          <p class="product-showcase__kicker">{{ section.settings.kicker }}</p>
        {%- endif -%}
        {%- if section.settings.heading != blank -%}
          <h2 class="product-showcase__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}
        {%- if section.settings.cta_label != blank -%}
          <a class="product-showcase__cta" href="{{ section.settings.cta_url | default: '#' }}">
            {{ section.settings.cta_label }}
            <svg width="10" height="10" viewBox="0 0 10 10" fill="none" aria-hidden="true">
              <path d="M2 5h6M5.5 2l3 3-3 3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </a>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.blocks.size > 0 -%}
      <div class="product-showcase__grid product-showcase__grid--{{ section.blocks.size }}">
        {%- for block in section.blocks -%}
          {%- liquid
            assign product        = block.settings.product
            assign custom_image   = block.settings.custom_image
            assign title_override = block.settings.title_override
            assign description    = block.settings.description

            if custom_image != blank
              assign display_image = custom_image
            elsif product != blank and product.featured_image != blank
              assign display_image = product.featured_image
            else
              assign display_image = nil
            endif

            if title_override != blank
              assign display_title = title_override
            elsif product != blank
              assign display_title = product.title
            else
              assign display_title = 'Product title'
            endif

            if description == blank and product != blank
              assign description = product.description | strip_html | truncatewords: 30
            endif

            if product != blank
              assign card_url = product.url
            elsif block.settings.custom_url != blank
              assign card_url = block.settings.custom_url
            else
              assign card_url = '#'
            endif
          -%}

          <div class="product-showcase__card" {{ block.shopify_attributes }}>
            <a class="product-showcase__image-link" href="{{ card_url }}" aria-label="{{ display_title | escape }}">
              <div class="product-showcase__image-wrap">
                {%- if display_image != nil -%}
                  {%- liquid
                    assign img_sizes = '(min-width: 990px) calc(100vw / ' | append: section.blocks.size | append: ' - 4rem), (min-width: 750px) calc(50vw - 3rem), 100vw'
                  -%}
                  {{
                    display_image
                    | image_url: width: 1200
                    | image_tag:
                      loading: 'lazy',
                      widths: '400, 600, 800, 1000, 1200',
                      sizes: img_sizes,
                      class: 'product-showcase__image',
                      alt: display_image.alt | default: display_title | escape
                  }}
                {%- else -%}
                  {{ 'product-1' | placeholder_svg_tag: 'product-showcase__placeholder' }}
                {%- endif -%}
                <div class="product-showcase__overlay"></div>
              </div>
            </a>

            <div class="product-showcase__caption">
              <p class="product-showcase__caption-text">
                {%- if display_title != blank -%}
                  <a class="product-showcase__product-link" href="{{ card_url }}">
                    <strong class="product-showcase__product-name">{{ display_title }}.</strong>
                  </a>
                {%- endif -%}
                {%- if description != blank -%}
                  {{ description }}
                {%- endif -%}
              </p>
            </div>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  @import url('https://fonts.cdnfonts.com/css/danger-neue');

  #{{ section_id }} {
    background: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    position: relative;
  }

  /* Subtle grain texture overlay */
  #{{ section_id }}::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 0;
  }

  #{{ section_id }} .product-showcase__inner {
    max-width: 120rem;
    margin: 0 auto;
    padding-left: 2.4rem;
    padding-right: 2.4rem;
    position: relative;
    z-index: 1;
  }

  /* ── Header ── */
  #{{ section_id }} .product-showcase__header {
    text-align: center;
    margin-bottom: 5.6rem;
  }

  #{{ section_id }} .product-showcase__kicker {
    margin: 0 0 1.4rem;
    font-size: 1.1rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: {{ section.settings.kicker_color }};
  }

  #{{ section_id }} .product-showcase__heading {
    margin: 0 0 2rem;
    font-family: 'Danger Neue', sans-serif;
    font-weight: 400;
    font-size: clamp(4rem, 7vw, 7.2rem);
    line-height: 1.04;
    letter-spacing: -0.01em;
    color: {{ section.settings.heading_color }};
  }

  #{{ section_id }} .product-showcase__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 1.3rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: {{ section.settings.cta_color }};
    text-decoration: none;
    border-bottom: 1px solid currentColor;
    padding-bottom: 0.2rem;
    transition: opacity 0.2s ease, gap 0.2s ease;
  }

  #{{ section_id }} .product-showcase__cta:hover {
    opacity: 0.7;
    gap: 0.9rem;
  }

  #{{ section_id }} .product-showcase__cta svg {
    flex-shrink: 0;
  }

  /* ── Grid ── */
  #{{ section_id }} .product-showcase__grid {
    display: grid;
    gap: 1.6rem;
    grid-template-columns: 1fr;
  }

  @media screen and (min-width: 750px) {
    #{{ section_id }} .product-showcase__grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    #{{ section_id }} .product-showcase__grid--1 { grid-template-columns: 1fr; }
    #{{ section_id }} .product-showcase__grid--2 { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    #{{ section_id }} .product-showcase__grid--3 { grid-template-columns: repeat(3, minmax(0, 1fr)); }
    #{{ section_id }} .product-showcase__grid--4 { grid-template-columns: repeat(4, minmax(0, 1fr)); }
    #{{ section_id }} .product-showcase__grid--5 { grid-template-columns: repeat(5, minmax(0, 1fr)); }
  }

  /* ── Card ── */
  #{{ section_id }} .product-showcase__image-link {
    display: block;
    text-decoration: none;
    border-radius: 1.2rem;
    overflow: hidden;
    background: {{ section.settings.card_bg_color }};
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: border-color 0.3s ease;
  }

  #{{ section_id }} .product-showcase__image-link:hover {
    border-color: rgba({{ section.settings.kicker_color | remove: '#' }}, 0.35);
  }

  #{{ section_id }} .product-showcase__image-wrap {
    position: relative;
    aspect-ratio: {{ section.settings.image_aspect_ratio }};
    overflow: hidden;
  }

  #{{ section_id }} .product-showcase__image,
  #{{ section_id }} .product-showcase__placeholder {
    width: 100%;
    height: 100%;
    object-fit: {{ section.settings.image_fit }};
    display: block;
    transition: transform 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  #{{ section_id }} .product-showcase__image-link:hover .product-showcase__image {
    transform: scale(1.04);
  }

  #{{ section_id }} .product-showcase__overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(0,0,0,0.45) 0%, transparent 55%);
    pointer-events: none;
  }

  /* ── Caption ── */
  #{{ section_id }} .product-showcase__caption {
    margin-top: 1.4rem;
    padding: 0 0.4rem;
  }

  #{{ section_id }} .product-showcase__caption-text {
    margin: 0;
    font-size: 1.4rem;
    line-height: 1.6;
    color: {{ section.settings.caption_color }};
  }

  #{{ section_id }} .product-showcase__product-link {
    text-decoration: none;
    color: inherit;
  }

  #{{ section_id }} .product-showcase__product-name {
    font-family: 'Danger Neue', sans-serif;
    font-weight: 400;
    font-size: 1.6rem;
    color: {{ section.settings.caption_name_color }};
    letter-spacing: 0.01em;
    transition: color 0.2s ease;
  }

  #{{ section_id }} .product-showcase__product-link:hover .product-showcase__product-name {
    color: {{ section.settings.kicker_color }};
  }
</style>

{% schema %}
{
  "name": "Product showcase",
  "tag": "section",
  "class": "section",
  "max_blocks": 5,
  "settings": [
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "kicker",
      "label": "Kicker text",
      "default": "Accessories"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pro pairings."
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Shop all accessories"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "CTA link"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_bg_color",
      "label": "Card background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "kicker_color",
      "label": "Kicker / accent color",
      "default": "#C9A84C"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#F5F5F5"
    },
    {
      "type": "color",
      "id": "cta_color",
      "label": "CTA link color",
      "default": "#C9A84C"
    },
    {
      "type": "color",
      "id": "caption_color",
      "label": "Caption text color",
      "default": "#888888"
    },
    {
      "type": "color",
      "id": "caption_name_color",
      "label": "Product name color",
      "default": "#F5F5F5"
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "text",
      "id": "image_aspect_ratio",
      "label": "Image aspect ratio",
      "info": "e.g. 3 / 4, 1 / 1, 4 / 5",
      "default": "3 / 4"
    },
    {
      "type": "select",
      "id": "image_fit",
      "label": "Image fit",
      "default": "cover",
      "options": [
        { "value": "cover",   "label": "Cover (crop to fill)" },
        { "value": "contain", "label": "Contain (show full image)" }
      ]
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Top padding",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 160,
      "step": 8,
      "unit": "px",
      "label": "Bottom padding",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product card",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Product",
          "info": "Pulls title, image, and description automatically"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Override image",
          "info": "Replaces the product's featured image"
        },
        {
          "type": "text",
          "id": "title_override",
          "label": "Override title",
          "info": "Leave blank to use the product title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Override description",
          "info": "Leave blank to use the product description"
        },
        {
          "type": "url",
          "id": "custom_url",
          "label": "Override link",
          "info": "Leave blank to link to the product page"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product showcase",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
