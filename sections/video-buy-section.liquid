{% comment %}
  Section: Video + Buy Now Panel
  Layout: 70% video | 30% buy panel, rich text below
{% endcomment %}

{%- liquid
  assign video_type = section.settings.video_type
  assign youtube_url = section.settings.youtube_url
  assign mp4_video = section.settings.mp4_video
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign product = section.settings.product
  assign btn_label = section.settings.button_label | default: 'Buy Now'
  assign btn_url = section.settings.button_url | default: product.url
  assign richtext = section.settings.richtext
  assign section_padding_top = section.settings.padding_top
  assign section_padding_bottom = section.settings.padding_bottom
-%}

<section
  id="video-buy-{{ section.id }}"
  class="vb-section"
  style="padding-top: {{ section_padding_top }}px; padding-bottom: {{ section_padding_bottom }}px;"
>
  <div class="vb-wrapper">

    {%- comment -%} ── TOP SPLIT ROW ── {%- endcomment -%}
    <div class="vb-split">

      {%- comment -%} VIDEO COLUMN – 70% {%- endcomment -%}
      <div class="vb-video-col">
        <div class="vb-video-frame">

          {%- if video_type == 'youtube' and youtube_url != blank -%}
            {%- comment -%} Extract YouTube ID from full URL or bare ID {%- endcomment -%}
            {%- assign yt_id = youtube_url -%}
            {%- if youtube_url contains 'youtu.be/' -%}
              {%- assign yt_id = youtube_url | split: 'youtu.be/' | last | split: '?' | first -%}
            {%- elsif youtube_url contains 'watch?v=' -%}
              {%- assign yt_id = youtube_url | split: 'watch?v=' | last | split: '&' | first -%}
            {%- elsif youtube_url contains 'embed/' -%}
              {%- assign yt_id = youtube_url | split: 'embed/' | last | split: '?' | first -%}
            {%- endif -%}

            <iframe
              class="vb-iframe"
              src="https://www.youtube.com/embed/{{ yt_id }}?rel=0&modestbranding=1"
              title="{{ heading | escape }}"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
              allowfullscreen
            ></iframe>

          {%- elsif video_type == 'file' and mp4_video != blank -%}
            <video
              class="vb-video"
              controls
              playsinline
              preload="metadata"
              {%- if section.settings.video_poster != blank -%}
                poster="{{ section.settings.video_poster | image_url: width: 1600 }}"
              {%- endif -%}
            >
              <source src="{{ mp4_video }}" type="video/mp4">
              Your browser does not support HTML5 video.
            </video>

          {%- else -%}
            {%- comment -%} Placeholder when no video is configured {%- endcomment -%}
            <div class="vb-placeholder">
              <svg width="64" height="64" viewBox="0 0 64 64" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <circle cx="32" cy="32" r="31" stroke="rgba(255,255,255,0.2)" stroke-width="2"/>
                <polygon points="26,20 50,32 26,44" fill="rgba(255,255,255,0.4)"/>
              </svg>
              <p>Add a video in the theme editor</p>
            </div>
          {%- endif -%}

        </div>
      </div>
      {%- comment -%} END VIDEO COLUMN {%- endcomment -%}

      {%- comment -%} BUY PANEL – 30% {%- endcomment -%}
      <div class="vb-buy-col">
        <div class="vb-buy-panel">

          {%- if heading != blank -%}
            <h2 class="vb-heading">{{ heading }}</h2>
          {%- endif -%}

          {%- if subheading != blank -%}
            <p class="vb-subheading">{{ subheading }}</p>
          {%- endif -%}

          {%- if product != blank -%}
            <div class="vb-price">
              {%- if product.compare_at_price > product.price -%}
                <span class="vb-price--compare">{{ product.compare_at_price | money }}</span>
              {%- endif -%}
              <span class="vb-price--current">{{ product.price | money }}</span>
            </div>
          {%- endif -%}

          <div class="vb-btn-wrap">
            <a
              href="{{ btn_url }}"
              class="vb-btn"
              {%- if btn_url == blank -%} aria-disabled="true" {%- endif -%}
            >
              {{ btn_label }}
              <svg class="vb-btn-arrow" width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                <path d="M3 9H15M15 9L10 4M15 9L10 14" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </a>
          </div>

          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_badge' -%}
              <div class="vb-badge" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <span class="vb-badge-icon">{{ block.settings.icon }}</span>
                {%- endif -%}
                <span class="vb-badge-text">{{ block.settings.text }}</span>
              </div>
            {%- endif -%}
          {%- endfor -%}

        </div>
      </div>
      {%- comment -%} END BUY PANEL {%- endcomment -%}

    </div>
    {%- comment -%} END SPLIT ROW {%- endcomment -%}

    {%- comment -%} ── RICH TEXT BELOW ── {%- endcomment -%}
    {%- if richtext != blank -%}
      <div class="vb-richtext rte">
        {{ richtext }}
      </div>
    {%- endif -%}

  </div>
</section>

<style>
  /* ─────────────────────────────────────────
     VIDEO + BUY SECTION  –  inline styles
     (move to assets/video-buy-section.css
      if preferred)
  ───────────────────────────────────────── */

  #video-buy-{{ section.id }} {
    --vb-bg:          {{ section.settings.bg_color }};
    --vb-text:        {{ section.settings.text_color }};
    --vb-accent:      {{ section.settings.accent_color }};
    --vb-panel-bg:    {{ section.settings.panel_bg_color }};
    --vb-border:      rgba(255,255,255,0.1);
    --vb-radius:      12px;
    --vb-gap:         2px;
  }

  .vb-section {
    background: var(--vb-bg);
    color: var(--vb-text);
    width: 100%;
  }

  .vb-wrapper {
    max-width: {{ section.settings.max_width }}px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ── Split row ── */
  .vb-split {
    display: flex;
    gap: var(--vb-gap);
    align-items: stretch;
    border-radius: var(--vb-radius);
    overflow: hidden;
  }

  .vb-video-col {
    flex: 0 0 70%;
    min-width: 0;
  }

  .vb-buy-col {
    flex: 0 0 calc(30% - var(--vb-gap));
    min-width: 0;
  }

  /* ── Video frame ── */
  .vb-video-frame {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 420px;
    background: #000;
  }

  .vb-iframe,
  .vb-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
    border: none;
  }

  .vb-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 16px;
    background: #111;
    color: rgba(255,255,255,0.4);
    font-size: 14px;
    letter-spacing: 0.04em;
  }

  /* ── Buy panel ── */
  .vb-buy-panel {
    background: var(--vb-panel-bg);
    height: 100%;
    padding: 36px 28px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    border-left: 1px solid var(--vb-border);
  }

  .vb-heading {
    font-size: clamp(20px, 2vw, 28px);
    font-weight: 700;
    line-height: 1.2;
    color: var(--vb-text);
    margin: 0;
  }

  .vb-subheading {
    font-size: 14px;
    line-height: 1.6;
    color: rgba(255,255,255,0.6);
    margin: 0;
  }

  .vb-price {
    display: flex;
    align-items: baseline;
    gap: 10px;
    flex-wrap: wrap;
  }

  .vb-price--compare {
    font-size: 15px;
    color: rgba(255,255,255,0.4);
    text-decoration: line-through;
  }

  .vb-price--current {
    font-size: clamp(22px, 2.2vw, 30px);
    font-weight: 700;
    color: var(--vb-text);
    letter-spacing: -0.02em;
  }

  /* ── Button ── */
  .vb-btn-wrap {
    margin-top: auto;
  }

  .vb-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    width: 100%;
    padding: 16px 24px;
    background: var(--vb-accent);
    color: var(--vb-bg);
    font-size: 15px;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 8px;
    border: 2px solid var(--vb-accent);
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease, transform 0.15s ease;
  }

  .vb-btn:hover {
    background: transparent;
    color: var(--vb-accent);
    transform: translateY(-2px);
  }

  .vb-btn-arrow {
    flex-shrink: 0;
    transition: transform 0.2s ease;
  }

  .vb-btn:hover .vb-btn-arrow {
    transform: translateX(4px);
  }

  /* ── Trust badges ── */
  .vb-badge {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: rgba(255,255,255,0.55);
    border-top: 1px solid var(--vb-border);
    padding-top: 14px;
  }

  .vb-badge-icon {
    font-size: 16px;
  }

  /* ── Rich text ── */
  .vb-richtext {
    margin-top: 40px;
    padding-top: 40px;
    border-top: 1px solid var(--vb-border);
    color: var(--vb-text);
    line-height: 1.75;
    font-size: 15px;
  }

  .vb-richtext h1,
  .vb-richtext h2,
  .vb-richtext h3,
  .vb-richtext h4 {
    color: var(--vb-text);
    margin-top: 1.5em;
  }

  .vb-richtext a {
    color: var(--vb-accent);
    text-decoration: underline;
  }

  .vb-richtext ul,
  .vb-richtext ol {
    padding-left: 1.4em;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .vb-split {
      flex-direction: column;
    }

    .vb-video-col,
    .vb-buy-col {
      flex: 0 0 100%;
    }

    .vb-video-frame {
      min-height: 56vw; /* 16:9 approx on mobile */
    }

    .vb-buy-panel {
      border-left: none;
      border-top: 1px solid var(--vb-border);
    }
  }
</style>

{% schema %}
{
  "name": "Video + Buy Now",
  "tag": "section",
  "class": "section-video-buy",
  "settings": [
    {
      "type": "header",
      "content": "Video"
    },
    {
      "type": "select",
      "id": "video_type",
      "label": "Video source",
      "options": [
        { "value": "youtube", "label": "YouTube" },
        { "value": "file", "label": "Hosted video file (MP4)" }
      ],
      "default": "youtube"
    },
    {
      "type": "text",
      "id": "youtube_url",
      "label": "YouTube URL or video ID",
      "placeholder": "https://www.youtube.com/watch?v=dQw4w9WgXcQ",
      "info": "Paste a full YouTube URL or just the video ID. Shown when Video source is set to YouTube."
    },
    {
      "type": "text",
      "id": "mp4_video",
      "label": "MP4 video URL",
      "placeholder": "https://cdn.shopify.com/…/video.mp4",
      "info": "Paste the URL of an MP4 file uploaded to Files. Shown when Video source is set to Hosted video."
    },
    {
      "type": "image_picker",
      "id": "video_poster",
      "label": "Video poster image",
      "info": "Shown before the hosted video plays."
    },
    {
      "type": "header",
      "content": "Buy Panel"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Product Name"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading / short description",
      "default": "A short, punchy line about the product."
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product (for price & link)"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Buy Now"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL",
      "info": "Overrides the product URL if set."
    },
    {
      "type": "header",
      "content": "Rich Text"
    },
    {
      "type": "richtext",
      "id": "richtext",
      "label": "Body content",
      "default": "<p>Add detailed product information, features, specifications, or any supporting copy here.</p>"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Section background",
      "default": "#0a0a0a"
    },
    {
      "type": "color",
      "id": "panel_bg_color",
      "label": "Buy panel background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent / button color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max section width (px)",
      "min": 800,
      "max": 1600,
      "step": 40,
      "default": 1280
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding top (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding bottom (px)",
      "min": 0,
      "max": 120,
      "step": 4,
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "trust_badge",
      "name": "Trust badge",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji or symbol)",
          "default": "✓"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Badge text",
          "default": "Free shipping on orders over $99"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Video + Buy Now",
      "blocks": [
        {
          "type": "trust_badge",
          "settings": {
            "icon": "✓",
            "text": "Free shipping on orders over $99"
          }
        },
        {
          "type": "trust_badge",
          "settings": {
            "icon": "↩",
            "text": "30-day returns"
          }
        }
      ]
    }
  ]
}
{% endschema %}
