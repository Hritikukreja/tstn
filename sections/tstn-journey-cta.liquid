{% comment %}
  TSTN Journey CTA
  - Wide horizontal banner card
  - Left: heading "Your Journey. Our Support. Let's Build the Best Version of You.",
    subtitle and a Join CTA pill
  - Right: scenic background image with "Stronger Together" handwritten orange overlay
{% endcomment %}

<style>
  @font-face {
    font-family: 'Danger Neue Free Regular';
    src: url('https://cdn.shopify.com/s/files/1/0000/0000/files/danger-neue-free-regular.woff2?v=1') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --tstn-orange: #F56300;
    --tstn-orange-hover: #ff7a1f;
    --tstn-bg: #0a0a0a;
    --tstn-card-bg: #111111;
    --tstn-text: #ffffff;
    --tstn-muted: #b0b0b0;
    --tstn-border: rgba(255,255,255,0.1);
    --tstn-font-display: "Danger Neue Free Regular", "Inter", sans-serif;
  }

  .tstn-journey {
    background: var(--tstn-bg);
    color: var(--tstn-text);
    padding: clamp(20px, 3vw, 30px) clamp(16px, 4vw, 40px) clamp(40px, 5vw, 60px);
  }
  .tstn-journey__inner {
    max-width: 1400px;
    margin: 0 auto;
    background: var(--tstn-card-bg);
    border: 1px solid var(--tstn-border);
    border-radius: 16px;
    overflow: hidden;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    min-height: 240px;
    position: relative;
  }

  .tstn-journey__content {
    padding: clamp(28px, 3.5vw, 44px);
    z-index: 2;
    position: relative;
  }
  .tstn-journey__heading {
    font-size: clamp(22px, 2.4vw, 30px);
    font-weight: 700;
    line-height: 1.25;
    margin: 0 0 12px;
    color: var(--tstn-text);
  }
  .tstn-journey__sub {
    font-size: 14px;
    color: var(--tstn-muted);
    margin: 0 0 24px;
  }
  .tstn-journey__btn {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    background: var(--tstn-orange);
    color: #fff;
    padding: 13px 24px;
    border-radius: 999px;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    transition: all 0.25s ease;
  }
  .tstn-journey__btn:hover { background: var(--tstn-orange-hover); transform: translateY(-2px); }
  .tstn-journey__btn svg { transition: transform 0.25s ease; }
  .tstn-journey__btn:hover svg { transform: translateX(4px); }

  .tstn-journey__visual {
    position: relative;
    height: 100%;
    min-height: 240px;
  }
  .tstn-journey__visual img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }
  .tstn-journey__visual::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, var(--tstn-card-bg) 0%, rgba(17,17,17,0.5) 25%, transparent 60%);
    z-index: 1;
  }

  .tstn-journey__script {
    position: absolute;
    left: 6%;
    top: 38%;
    color: var(--tstn-orange);
    font-family: 'Brush Script MT', 'Lucida Handwriting', cursive;
    font-size: clamp(28px, 3.5vw, 44px);
    font-weight: 400;
    line-height: 1;
    transform: rotate(-6deg);
    z-index: 2;
    text-shadow: 0 2px 12px rgba(0,0,0,0.5);
    pointer-events: none;
  }
  .tstn-journey__script-underline {
    display: block;
    width: 70%;
    height: 2px;
    background: var(--tstn-orange);
    margin-top: 4px;
    border-radius: 2px;
  }

  /* Mobile */
  @media (max-width: 880px) {
    .tstn-journey__inner {
      grid-template-columns: 1fr;
      min-height: auto;
    }
    .tstn-journey__visual {
      order: 2;
      min-height: 240px;
    }
    .tstn-journey__visual::before {
      background: linear-gradient(180deg, var(--tstn-card-bg) 0%, rgba(17,17,17,0.4) 30%, transparent 70%);
    }
    .tstn-journey__script {
      left: 50%;
      top: 50%;
      transform: translate(-50%, -50%) rotate(-6deg);
    }
  }
</style>

<section class="tstn-journey">
  <div class="tstn-journey__inner">

    <div class="tstn-journey__content">
      <h2 class="tstn-journey__heading">{{ section.settings.heading | default: "Your Journey. Our Support. Let's Build the Best Version of You." }}</h2>
      <p class="tstn-journey__sub">{{ section.settings.sub | default: 'Join thousands of members already growing with TSTN Club.' }}</p>
      <a href="{{ section.settings.cta_link | default: '#' }}" class="tstn-journey__btn">
        {{ section.settings.cta_text | default: 'Join TSTN Club Today' }}
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

    <div class="tstn-journey__visual">
      {% if section.settings.image %}
        <img src="{{ section.settings.image | image_url: width: 1200 }}" alt="{{ section.settings.image.alt | default: 'TSTN Community' }}">
      {% else %}
        <div style="position:absolute;inset:0;background:linear-gradient(135deg,#2a2a2a,#1a1a1a);"></div>
      {% endif %}
      <div class="tstn-journey__script">
        {{ section.settings.script_text | default: 'Stronger<br>Together' }}
        <span class="tstn-journey__script-underline"></span>
      </div>
    </div>

  </div>
</section>

{% schema %}
{
  "name": "TSTN Journey CTA",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Your Journey. Our Support. Let's Build the Best Version of You." },
    { "type": "text", "id": "sub", "label": "Subtitle", "default": "Join thousands of members already growing with TSTN Club." },
    { "type": "text", "id": "cta_text", "label": "CTA", "default": "Join TSTN Club Today" },
    { "type": "url", "id": "cta_link", "label": "CTA Link" },
    { "type": "image_picker", "id": "image", "label": "Background Image" },
    { "type": "text", "id": "script_text", "label": "Script Overlay (use <br> for line break)", "default": "Stronger<br>Together" }
  ],
  "presets": [
    { "name": "TSTN Journey CTA" }
  ]
}
{% endschema %}
