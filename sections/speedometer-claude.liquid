<!-- ══════════════════════════════════════════════════════════════ SCRIPTS -->
<script>
(function() {
  'use strict';

  /* ───────── storage helpers ───────── */
  const STORAGE_KEYS = {
    tier: "tstn_cs_vp_m_t",
  };
  function getStoredTier() { return sessionStorage.getItem(STORAGE_KEYS.tier); }
  function setStoredTier(tier) { sessionStorage.setItem(STORAGE_KEYS.tier, tier); }

  const TIER_ORDER = ["base", "scout", "lead"];
  function getHigherTier(t1, t2) {
    if (!t1) return t2;
    if (!t2) return t1;
    const i1 = TIER_ORDER.indexOf(t1);
    const i2 = TIER_ORDER.indexOf(t2);
    return i1 > i2 ? t1 : t2;
  }

  /* ───────── DOM refs (lazy-resolved) ───────── */
  let cardPointsEl, cardTierNameEl, baseIcon, scoutIcon, leadIcon, thresholdsEl;

  function resolveDom() {
    cardPointsEl     = document.getElementById('display_points');
    cardTierNameEl   = document.getElementById('display_tier_name');
    baseIcon         = document.getElementById('base-icon-wrap');
    scoutIcon        = document.getElementById('scout-icon-wrap');
    leadIcon         = document.getElementById('lead-icon-wrap');
    thresholdsEl     = document.querySelector('.tstn-tier-thresholds');
  }

  /* ───────── Tier configuration ───────── */
  function getTierConfig() {
    const scoutMin = thresholdsEl ? Number(thresholdsEl.dataset.scoutMin) || 1500 : 1500;
    const leadMin  = thresholdsEl ? Number(thresholdsEl.dataset.leadMin)  || 2500 : 2500;

    const baseName  = cardTierNameEl ? (cardTierNameEl.dataset.tierBase  || 'BASE CAMP') : 'BASE CAMP';
    const scoutName = cardTierNameEl ? (cardTierNameEl.dataset.tierScout || 'SCOUT')     : 'SCOUT';
    const leadName  = cardTierNameEl ? (cardTierNameEl.dataset.tierLead  || 'LEAD')      : 'LEAD';

    return {
      scoutMin: scoutMin,
      leadMin:  leadMin,
      base:  { regex: /\b(base|base\s*camp)\b/i, name: baseName  },
      scout: { regex: /\b(scout)\b/i,             name: scoutName },
      lead:  { regex: /\b(lead|leader)\b/i,       name: leadName  },
    };
  }

  function getTierFromPoints(points, cfg) {
    if (points >= cfg.leadMin)  return "lead";
    if (points >= cfg.scoutMin) return "scout";
    return "base";
  }

  function getTierFromText(text, cfg) {
    if (!text) return null;
    if (cfg.lead.regex.test(text))  return "lead";
    if (cfg.scout.regex.test(text)) return "scout";
    if (cfg.base.regex.test(text))  return "base";
    return null;
  }

  /* ───────── Animated counter ───────── */
  function animateCount(el, target) {
    if (!el) return;
    const start = parseInt(el.textContent.replace(/,/g,'')) || 0;
    const dur = 1200, t0 = performance.now();
    (function step(now) {
      const p = Math.min((now - t0) / dur, 1);
      const e = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(start + (target - start) * e).toLocaleString();
      if (p < 1) requestAnimationFrame(step);
    })(t0);
  }

  /* ───────── Apply tier UI ───────── */
  function applyTierUI(tierKey, cfg) {
    if (!tierKey) return;
    const storedTier = getStoredTier();
    const finalTier = getHigherTier(storedTier, tierKey);
    setStoredTier(finalTier);

    if (cardTierNameEl) {
      cardTierNameEl.textContent = cfg[finalTier].name;
    }
    if (baseIcon)  baseIcon.classList.add('active');
    if (scoutIcon) scoutIcon.classList.toggle('active', finalTier === 'scout' || finalTier === 'lead');
    if (leadIcon)  leadIcon.classList.toggle('active',  finalTier === 'lead');
  }

  /* ───────── Master update function ───────── */
  function setValue(newValue) {
    const cfg = getTierConfig();
    const points = Math.max(0, Number(newValue) || 0);

    animateCount(cardPointsEl, points);

    let tier = null;
    const vipEl = document.querySelector(".vip_tier_new_updated");
    if (vipEl) {
      tier = getTierFromText(vipEl.innerText.trim(), cfg);
    }
    if (!tier) {
      tier = getTierFromPoints(points, cfg);
    }
    applyTierUI(tier, cfg);
  }

  /* ───────── Boot ───────── */
  function boot() {
    resolveDom();

    const target = document.querySelector(".gw-rd-customer-points-balance-inline-widget-placeholder");
    if (target) {
      const match = target.textContent.match(/\d+/);
      if (match) {
        const newPoints = Number(match[0]);
        window.newPoints1 = newPoints;
        setValue(newPoints);
      }
    }

    const vipEl = document.querySelector(".vip_tier_new_updated");
    if (vipEl && (window.newPoints1 == null)) {
      const cfg = getTierConfig();
      const tier = getTierFromText(vipEl.innerText.trim(), cfg);
      if (tier) {
        applyTierUI(tier, cfg);
      }
    }

    if (baseIcon) baseIcon.classList.add('active');
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', boot);
  } else {
    boot();
  }

  /* ───────── MutationObserver for Growave point injection ───────── */
  window.newPoints1 = window.newPoints1 || null;
  const observer = new MutationObserver(() => {
    const target = document.querySelector(".gw-rd-customer-points-balance-inline-widget-placeholder");
    if (!target) return;
    const match = target.textContent.match(/\d+/);
    if (!match) return;
    const newPoints = Number(match[0]);
    if (window.newPoints1 !== newPoints) {
      window.newPoints1 = newPoints;
      setValue(window.newPoints1);
    }
  });
  observer.observe(document.body, { childList: true, subtree: true });

  /* ───────── Polling fallback ───────── */
  let pollCount = 0;
  const pollInterval = setInterval(() => {
    pollCount++;
    if (pollCount > 60) {
      clearInterval(pollInterval);
      return;
    }
    const target = document.querySelector(".gw-rd-customer-points-balance-inline-widget-placeholder");
    if (!target) return;
    const match = target.textContent.match(/\d+/);
    if (!match) return;
    const newPoints = Number(match[0]);
    if (window.newPoints1 !== newPoints) {
      window.newPoints1 = newPoints;
      setValue(window.newPoints1);
      clearInterval(pollInterval);
    }
  }, 500);

  setTimeout(() => {
    if (window.newPoints1 !== null) setValue(window.newPoints1);
  }, 1000);

})();
</script>

