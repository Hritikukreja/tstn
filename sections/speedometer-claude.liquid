</style>

<!-- ═════════════════════════════════════════════════════════ SCRIPTS ═══ -->
<script>
(function() {
  /* ── Storage ── */
  const KEYS = { tier: "tstn_cs_vp_m_t", bar: "tstn_cs_vp_m_b" };
  const getStoredTier = () => sessionStorage.getItem(KEYS.tier);
  const setStoredTier = t => sessionStorage.setItem(KEYS.tier, t);
  const getStoredBar  = () => Number(sessionStorage.getItem(KEYS.bar) || 0);
  const setStoredBar  = v => sessionStorage.setItem(KEYS.bar, v);

  const TIER_ORDER = ["base", "scout", "lead"];
  function getHigherTier(t1, t2) {
    if (!t1) return t2; if (!t2) return t1;
    return TIER_ORDER.indexOf(t1) > TIER_ORDER.indexOf(t2) ? t1 : t2;
  }

  const baseTierImage  = "https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_1_a6b1bf9c-5113-4864-b2aa-53fb77a68341.png?v=1770810715";
  const scoutTierImage = "https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_2_fe25c4de-0871-4b74-8114-8473656bf229.png?v=1770810716";
  const leadTierImage  = "https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_3_3062b154-429b-4483-939f-042e342cf355.png?v=1770810716";

  const TIER_CONFIG = {
    base:  { regex: /\b(base|base\s*camp)\b/i, bar: 0,   img: baseTierImage,  name: "BASE CAMP" },
    scout: { regex: /\b(scout)\b/i,             bar: 50,  img: scoutTierImage, name: "SCOUT" },
    lead:  { regex: /\b(lead|leader)\b/i,       bar: 100, img: leadTierImage,  name: "LEAD" },
  };

  const TOTAL_POINTS = 4000;
  let value = 0;
  let tier_image_el, cardProgressFill, cardPointsEl, cardTierNameEl, meterFill;

  /* ── Clock ── */
  function updateTime() {
    const el = document.getElementById("timeText");
    if (!el) return;
    const now = new Date();
    el.textContent = String(now.getHours()).padStart(2,"0") + ":" + String(now.getMinutes()).padStart(2,"0");
  }
  updateTime();
  setInterval(updateTime, 1000);

  /* ── Speedometer builder ── */
  function clamp(v, lo, hi) { return Math.min(Math.max(v, lo), hi); }

  function createSpeedometer(svgId, opts) {
    const svg = document.getElementById(svgId);
    if (!svg) return;
    const step      = opts.step  ?? 500;
    const eMax      = opts.max   ?? 240;
    const val       = opts.value ?? 0;
    const minAngle  = opts.minAngle;
    const maxAngle  = opts.maxAngle;
    const angleRange = maxAngle - minAngle;
    const max        = eMax / step;
    const currentVal = val / step;
    const angle      = minAngle + (currentVal / max) * angleRange;

    svg.innerHTML = "";

    /* Major ticks + labels */
    for (let i = 0; i <= max; i++) {
      const a   = minAngle + (i / max) * angleRange;
      const rad = a * Math.PI / 180;
      const g   = document.createElementNS("http://www.w3.org/2000/svg","g");
      const ln  = document.createElementNS("http://www.w3.org/2000/svg","line");
      ln.setAttribute("x1", 100 + 75 * Math.cos(rad));
      ln.setAttribute("y1", 100 + 75 * Math.sin(rad));
      ln.setAttribute("x2", 100 + 90 * Math.cos(rad));
      ln.setAttribute("y2", 100 + 90 * Math.sin(rad));
      ln.setAttribute("stroke","white"); ln.setAttribute("stroke-width","1.5"); ln.setAttribute("stroke-linecap","round");
      g.appendChild(ln);
      if (opts.showValue !== false || opts.step) {
        const tx = 100 + 65 * Math.cos(rad);
        const ty = 100 + 65 * Math.sin(rad);
        const t  = document.createElementNS("http://www.w3.org/2000/svg","text");
        t.setAttribute("x",tx); t.setAttribute("y",ty);
        t.setAttribute("fill","white"); t.setAttribute("font-size","7px");
        t.setAttribute("font-weight","normal"); t.setAttribute("text-anchor","middle");
        t.setAttribute("dominant-baseline","middle");
        t.setAttribute("transform",`rotate(${a+90} ${tx} ${ty})`);
        t.textContent = i * step;
        g.appendChild(t);
      }
      svg.appendChild(g);
    }

    /* Minor ticks */
    for (let i = 0; i < max * 4; i++) {
      if (i % 4 === 0) continue;
      const a   = minAngle + (i / (max * 4)) * angleRange;
      const rad = a * Math.PI / 180;
      const ln  = document.createElementNS("http://www.w3.org/2000/svg","line");
      ln.setAttribute("x1", 100 + 84 * Math.cos(rad));
      ln.setAttribute("y1", 100 + 84 * Math.sin(rad));
      ln.setAttribute("x2", 100 + 90 * Math.cos(rad));
      ln.setAttribute("y2", 100 + 90 * Math.sin(rad));
      ln.setAttribute("stroke","white"); ln.setAttribute("stroke-width","1"); ln.setAttribute("opacity","0.6"); ln.setAttribute("stroke-linecap","round");
      svg.appendChild(ln);
    }

    /* Center value */
    if (opts.showValue !== false) {
      const vt = document.createElementNS("http://www.w3.org/2000/svg","text");
      vt.setAttribute("x","100"); vt.setAttribute("y","70");
      vt.setAttribute("fill","white"); vt.setAttribute("font-size","18px");
      vt.setAttribute("font-family","Danger Neue Free Regular, Danger Neue, Rajdhani, sans-serif");
      vt.setAttribute("text-anchor","middle"); vt.setAttribute("dominant-baseline","middle");
      vt.setAttribute("id","center_gauge_value");
      vt.textContent = (currentVal * step).toFixed(0);
      svg.appendChild(vt);
    }

    /* Needle */
    if (opts.showNeedle !== false) {
      const ng = document.createElementNS("http://www.w3.org/2000/svg","g");
      ng.setAttribute("class","needle-group");
      ng.style.transformOrigin = "100px 100px";
      ng.style.transform = `rotate(${angle}deg)`;
      ng.dataset.minAngle = minAngle;
      ng.dataset.maxAngle = maxAngle;
      ng.dataset.maxValue = eMax;
      ng.dataset.step     = step;

      const shadowShaft = document.createElementNS("http://www.w3.org/2000/svg","path");
      shadowShaft.setAttribute("d","M 100 96 L 160 98 L 160 100 L 160 100 L 100 103 Z");
      shadowShaft.setAttribute("fill","rgba(0,0,0,0.45)");
      shadowShaft.setAttribute("transform","translate(4,4)");

      const shaft = document.createElementNS("http://www.w3.org/2000/svg","path");
      shaft.setAttribute("d","M 100 96 L 160 98 L 160 100 L 160 100 L 100 103 Z");
      shaft.setAttribute("fill","#ec5607");

      const hub = document.createElementNS("http://www.w3.org/2000/svg","circle");
      hub.setAttribute("cx","100"); hub.setAttribute("cy","100"); hub.setAttribute("r","7");
      hub.setAttribute("fill","#ec5607");

      ng.appendChild(shadowShaft);
      ng.appendChild(shaft);
      ng.appendChild(hub);
      svg.appendChild(ng);
    }

    const hubDot = document.createElementNS("http://www.w3.org/2000/svg","circle");
    hubDot.setAttribute("cx","100"); hubDot.setAttribute("cy","100"); hubDot.setAttribute("r","5");
    hubDot.setAttribute("fill","#ff7a00");
    svg.appendChild(hubDot);
  }

  function updateNeedle(svgId, val) {
    const svg = document.getElementById(svgId);
    if (!svg) return;
    const ng = svg.querySelector(".needle-group");
    if (!ng) return;
    const min = +ng.dataset.minAngle, max2 = +ng.dataset.maxAngle;
    const maxVal = +ng.dataset.maxValue;
    const clamped = clamp(val, 0, maxVal);
    ng.style.transform = `rotate(${min + (clamped / maxVal) * (max2 - min)}deg)`;
  }

  /* ── Tier logic ── */
  function applyTierUI(tierKey) {
    if (!tierKey || !TIER_CONFIG[tierKey]) return;
    const finalTier = getHigherTier(getStoredTier(), tierKey);
    setStoredTier(finalTier);
    const cfg = TIER_CONFIG[finalTier];

    if (tier_image_el) tier_image_el.src = cfg.img;
    if (cardTierNameEl) cardTierNameEl.textContent = cfg.name;

    /* Unlock tier icon opacity */
    const scoutIcon = document.querySelector(".tstn-tier-icon--scout");
    const leadIcon  = document.querySelector(".tstn-tier-icon--lead");
    if (scoutIcon) scoutIcon.style.opacity = (finalTier === "scout" || finalTier === "lead") ? "1" : "0.45";
    if (leadIcon)  leadIcon.style.opacity  = finalTier === "lead" ? "1" : "0.45";

    const calculated = clamp((value / 3000) * 100, 0, 100);
    const tierMin    = cfg.bar;
    const finalBar   = Math.max(Math.max(calculated, tierMin), getStoredBar());
    setStoredBar(finalBar);

    if (meterFill)        meterFill.style.width        = finalBar + "%";
    if (cardProgressFill) cardProgressFill.style.width = finalBar + "%";
  }

  function getTierFromText(text) {
    if (!text) return null;
    for (const key in TIER_CONFIG) {
      if (TIER_CONFIG[key].regex.test(text)) return key;
    }
    return null;
  }

  function updateFromVipText() {
    const el = document.querySelector(".vip_tier_new_updated");
    if (!el) return false;
    const tier = getTierFromText(el.innerText.trim());
    if (tier) { applyTierUI(tier); return true; }
    return false;
  }

  function getDerivedTier() {
    if (value >= 3000) return "lead";
    if (value >= 1500) return "scout";
    return "base";
  }

  function setValue(newVal) {
    value = clamp(newVal, 0, TOTAL_POINTS);
    const vt = document.getElementById("center_gauge_value");
    if (vt) vt.textContent = value;
    if (cardPointsEl) {
      /* Animate counting */
      const start  = parseInt(cardPointsEl.textContent.replace(/,/g,"")) || 0;
      const end    = value;
      const dur    = 1200;
      const t0     = performance.now();
      function step(now) {
        const p = Math.min((now - t0) / dur, 1);
        const eased = 1 - Math.pow(1 - p, 3);
        cardPointsEl.textContent = Math.round(start + (end - start) * eased).toLocaleString();
        if (p < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }
    const rpmVal = clamp((value / TOTAL_POINTS) * 7, 0, 7);
    updateNeedle("leftGauge", rpmVal);
    updateNeedle("centerGauge", value);

    if (!updateFromVipText()) applyTierUI(getDerivedTier());

    /* Also sync bar from raw points */
    const calculated = clamp((value / 3000) * 100, 0, 100);
    const finalBar   = Math.max(calculated, getStoredBar());
    setStoredBar(finalBar);
    if (meterFill)        meterFill.style.width        = finalBar + "%";
    if (cardProgressFill) cardProgressFill.style.width = finalBar + "%";
  }

  /* ── Init ── */
  document.addEventListener("DOMContentLoaded", () => {
    tier_image_el    = document.getElementById("tier_diagram");
    meterFill        = document.getElementById("meterFill");
    cardProgressFill = document.getElementById("cardProgressFill");
    cardPointsEl     = document.getElementById("display_points");
    cardTierNameEl   = document.getElementById("display_tier_name");

    createSpeedometer("leftGauge", {
      step: 1, max: 7, value: 0,
      showValue: false, showNeedle: true,
      minAngle: -210, maxAngle: 0,
    });
    createSpeedometer("centerGauge", {
      step: 500, max: TOTAL_POINTS, value: 0,
      showValue: true, showNeedle: true,
      minAngle: -200, maxAngle: 20,
    });
  });

  /* ── Points observer ── */
  window.newPoints1 = null;
  const observer = new MutationObserver(() => {
    const target = document.querySelector(".gw-rd-customer-points-balance-inline-widget-placeholder");
    if (!target) return;
    const match = target.textContent.match(/\d+/);
    if (!match) return;
    const pts = Number(match[0]);
    if (window.newPoints1 !== pts) {
      window.newPoints1 = pts;
      setValue(pts);
    }
  });
  observer.observe(document.body, { childList: true, subtree: true });

  setTimeout(() => {
    if (window.newPoints1 !== null) setValue(window.newPoints1);
  }, 1000);
})();
</script>

