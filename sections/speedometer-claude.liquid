{% if customer %}
  {% assign vip_tier = customer.metafields["app--144550"]["growave_vip_tier"] %}
  {% if vip_tier != blank %}
    <div class="vip_tier_new_updated">{{ vip_tier }}</div>
  {% endif %}
{% endif %}

<div class="visibility_hidden">
  <span
    class="gw-rd-customer-points-balance-inline-widget-placeholder"
    data-gw-enable-points-name="true"
    style="display: block"
  ></span>
</div>

<div class="growave_tiers_wrapper {% unless customer %} non_customer_class {% endunless %}">

  <!-- BACKGROUND IMAGE -->
  <div class="gtw_image_wrapper">
    {% if section.settings.feat_image != blank %}
      <img src="{{ section.settings.feat_image | img_url:'master' }}" alt="">
    {% endif %}
  </div>

  <div class="gtw_content_wrapper">

    <!-- ══════════════════ HERO OVERLAY LAYOUT ══════════════════ -->
    <div class="tstn-hero-layout">

      <!-- LEFT COPY -->
      <div class="tstn-copy">
        <div class="tstn-welcome-row">
          <img src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/image_1_1_76d32aab-2b4e-4c68-a411-5a2a219321bf.png?v=1770384836" alt="TSTN" class="tstn-logo-icon">
          <span class="tstn-welcome-text">WELCOME TO</span>
        </div>
        <h1 class="tstn-heading">TSTN CLUB</h1>
        <p class="tstn-desc">Join the club. Earn points for every lighting or recovery upgrade and level up your journey with TSTN.</p>
        <div class="tstn-ctas">
          <a href="#tstn-how-it-works" class="tstn-btn tstn-btn--gold">HOW IT WORKS <span>›</span></a>
          <a href="/collections/merch" class="tstn-btn tstn-btn--outline">SHOP MERCH</a>
        </div>
        <div class="tstn-badges">
          <div class="tstn-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            <div>
              <span class="tstn-badge-title gold">EARN POINTS</span>
              <span class="tstn-badge-sub">For every upgrade</span>
            </div>
          </div>
          <div class="tstn-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
            <div>
              <span class="tstn-badge-title">LEVEL UP</span>
              <span class="tstn-badge-sub">Unlock rewards</span>
            </div>
          </div>
          <div class="tstn-badge">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
            <div>
              <span class="tstn-badge-title gold">EXCLUSIVE</span>
              <span class="tstn-badge-sub">Club benefits</span>
            </div>
          </div>
        </div>
      </div>

      <!-- RIGHT DASHBOARD — original structure preserved exactly -->
      <div class="tstn-dashboard-wrap">
        <div class="dashboard-wrapper">
          <div class="screen-container">
            <div class="gtw_welcome_wrapper" style="display:none;">
              <div class="main_wrapper_new">
                <img src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/image_1_1_76d32aab-2b4e-4c68-a411-5a2a219321bf.png?v=1770384836">
                <p>WELCOME TO TSTN CLUB</p>
              </div>
              <div class="customer_name_email">
                {% if customer %}
                  {% if customer.first_name or customer.last_name %}
                    <h1>{{ customer.first_name }} {{ customer.last_name }}</h1>
                  {% elsif customer.email %}
                    {{ customer.email }}
                  {% endif %}
                {% endif %}
              </div>
            </div>

            <div class="main-content_new">
              <div class="bottom-bar">
                <div class="bottom-bar-inner">
                  <div class="bottom-bar-content">
                    <div class="icons-row">
                      <div class="icon-box">
                        <img src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/Frame_259.png?v=1770378961" alt="base-image-icon" class="icon-img">
                      </div>
                      <div class="icon-box">
                        <img src="https://cdn.shopify.com/s/files/1/0994/4979/8950/files/Group_143726226.png?v=1770370711" alt="scout-image-icon" class="icon-img">
                      </div>
                      <div class="icon-box">
                        <img src="https://cdn.shopify.com/s/files/1/0994/4979/8950/files/Group_143726227.png?v=1770370813" alt="lead-image-icon" class="icon-img">
                      </div>
                    </div>
                    <div class="meter-row">
                      <div class="meter-container">
                        <div id="meterFill" class="meter-fill" style="width: 0%;"></div>
                        <div class="meter-segment"></div>
                        <div class="meter-segment"></div>
                        <div class="meter-segment"></div>
                        <div class="meter-segment"></div>
                        <div class="meter-segment"></div>
                        <div class="meter-segment"></div>
                        <div class="meter-segment"></div>
                        <div class="meter-segment"></div>
                        <div class="meter-segment"></div>
                        <div class="meter-segment"></div>
                        <div class="meter-segment"></div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="meter-info-wrapper">
                <div class="cluster-container">
                  <img
                    src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/Frame_200_2_3d5c4b39-500f-4fc5-8413-13e8b9961403.png?v=1770378141"
                    alt="image"
                    class="cluster-img"
                  >
                  <div class="cluster-overlay">
                    <span id="modeText">Comfort</span>
                    <span id="gearText">P</span>
                    <span id="tempText">28° C</span>
                    <span id="timeText">00:00</span>
                    <span id="engineText">22c</span>
                    <div class="air-bag-box">
                      <span class="air-bag-text">Air</span>
                      <span class="air-bag-text">Bag</span>
                    </div>
                    <div class="battery-box">
                      <svg class="flash-svg" viewBox="0 0 512 512" fill="white">
                        <path d="M315.27 33L96 304h128l-31.51 173.23a2.36 2.36 0 002.33 2.77h0a2.36 2.36 0 001.89-.95L416 208H288l31.66-173.25a2.45 2.45 0 00-2.44-2.75h0a2.42 2.42 0 00-1.95 1z"></path>
                      </svg>
                      <div class="battery-inner">
                        <img
                          src="https://cdn.shopify.com/s/files/1/0994/4979/8950/files/Group_143726226_1.png?v=1770370899"
                          alt="battery"
                          class="battery-img"
                        >
                      </div>
                    </div>
                  </div>
                </div>
              </div>

              <div class="gauges-wrapper">
                <div class="gauge-left">
                  <div class="clock-outer clock-outer-small">
                    <div class="clock-middle">
                      <div class="clock-inner">
                        <div class="gauge-content gauge-rotated">
                          <svg id="leftGauge" viewBox="0 0 200 200" class="gauge-svg" xmlns="http://www.w3.org/2000/svg"></svg>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="gauge-center">
                  <div class="left_icons_wrapper custom_icons_wrapper">
                    {{- 'left-icon.svg' | inline_asset_content -}}
                  </div>
                  <div class="right_icons_wrapper custom_icons_wrapper">
                    {{- 'right-icon.svg' | inline_asset_content -}}
                  </div>
                  <div class="clock-outer">
                    <div class="clock-middle">
                      <div class="clock-inner">
                        <div class="gauge-content">
                          <svg id="centerGauge" viewBox="0 0 200 200" class="gauge-svg" xmlns="http://www.w3.org/2000/svg"></svg>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>

                <div class="gauge-right">
                  <div class="clock-outer clock-outer-small">
                    <div class="clock-middle">
                      <div class="clock-inner">
                        <div class="gauge-content">
                          <img
                            id="tier_diagram"
                            src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_1_a6b1bf9c-5113-4864-b2aa-53fb77a68341.png?v=1770810715"
                            class="scout-img"
                            alt="img"
                          >
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </div>
            </div><!-- /main-content_new -->

          </div><!-- /screen-container -->
        </div><!-- /dashboard-wrapper -->
      </div><!-- /tstn-dashboard-wrap -->

    </div><!-- /tstn-hero-layout -->

    <!-- ══════════════════ PROGRESS + POINTS CARDS ══════════════ -->
    {% if customer %}
    <div class="tstn-cards-row">
      <div class="tstn-progress-card">
        <div class="tstn-card-label">YOUR PROGRESS</div>
        <div class="tstn-tier-header">
          <span class="tstn-current-tier-name" id="display_tier_name">BASE CAMP</span>
          <div class="tstn-tier-icons-right">
            <div class="tstn-tier-icon" id="scout-icon-wrap">
              <img src="https://cdn.shopify.com/s/files/1/0994/4979/8950/files/Group_143726226.png?v=1770370711" alt="Scout">
              <span>SCOUT</span>
            </div>
            <div class="tstn-tier-icon" id="lead-icon-wrap">
              <img src="https://cdn.shopify.com/s/files/1/0994/4979/8950/files/Group_143726227.png?v=1770370813" alt="Lead">
              <span>LEAD</span>
            </div>
          </div>
        </div>
        <div class="tstn-bar-wrap">
          <div class="tstn-bar-track">
            <div class="tstn-bar-fill" id="cardProgressFill" style="width:0%"></div>
            <div class="tstn-bar-seg"></div>
            <div class="tstn-bar-seg"></div>
            <div class="tstn-bar-seg"></div>
          </div>
        </div>
        <div class="tstn-bar-labels">
          <span>BASE CAMP</span><span>SCOUT</span><span>LEAD</span>
        </div>
      </div>
      <div class="tstn-points-card">
        <div class="tstn-card-label">YOUR TSTN POINTS</div>
        <div class="tstn-points-value" id="display_points">0</div>
        <div class="tstn-points-sub">Keep upgrading. Keep earning.</div>
      </div>
    </div>
    {% endif %}

    <!-- ══════════════════ HOW IT WORKS ══════════════════════════ -->
    <div class="tstn-how-section" id="tstn-how-it-works">
      <div class="tstn-how-header">
        <h2 class="tstn-how-heading">HOW IT WORKS</h2>
        <a href="/pages/tstn-club" class="tstn-view-all">VIEW ALL BENEFITS ›</a>
      </div>
      <div class="tstn-steps-grid">
        <div class="tstn-step">
          <span class="tstn-step-num">01</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          <div><strong>SHOP</strong><p>Buy eligible lighting or recovery products.</p></div>
        </div>
        <div class="tstn-step">
          <span class="tstn-step-num">02</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <div><strong>EARN</strong><p>Earn points for every qualified purchase.</p></div>
        </div>
        <div class="tstn-step">
          <span class="tstn-step-num">03</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
          <div><strong>LEVEL UP</strong><p>Climb ranks and unlock exclusive rewards.</p></div>
        </div>
        <div class="tstn-step">
          <span class="tstn-step-num">04</span>
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>
          <div><strong>REDEEM</strong><p>Use your points for merch, discounts & more.</p></div>
        </div>
      </div>
    </div>

  </div><!-- /gtw_content_wrapper -->

  <!-- ══════════════════ GUEST SIGNUP ══════════════════════════ -->
  {% unless customer %}
  <div class="none_customer_signup">
    <div class="non_custopmer_class">
      <div class="non_contact_main">
        <img src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/image_1_1_76d32aab-2b4e-4c68-a411-5a2a219321bf.png?v=1770384836">
        <p>TSTN CLUB</p>
      </div>
      <h2>JOIN THE TRIBE</h2>
      <p class="margin_class_top">Earn Points. Get Featured. Unlock the Inner Circle.</p>
      <a class="new_main_createaccount" href="/account/register">Create Account</a>
    </div>
  </div>
  {% endunless %}

</div><!-- /growave_tiers_wrapper -->

<div id="points-output"></div>

<!-- ═══════════════════════════════════════════════════════════════ STYLES -->
<style>
  /* ─── CSS Tokens ─────────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} {
    --gold:     #c8922a;
    --gold-lt:  #e8a93a;
    --gold-dk:  #8a6010;
    --bg:       #0d0c0a;
    --bg2:      #151412;
    --bg3:      #1c1a16;
    --border:   rgba(200,146,42,0.2);
    --text:     #e6e1d6;
    --muted:    #7a7060;
    --orange:   #ec5607;
    --ff-head:  "Danger Neue Free Regular","Danger Neue",sans-serif;
    --ff-body:  "Rajdhani","ABC Diatype",sans-serif;
  }

  #shopify-section-{{ section.id }} *, #shopify-section-{{ section.id }} *::before, #shopify-section-{{ section.id }} *::after { box-sizing: border-box; }

  /* ─── Growave wrapper / bg (preserve original structure) ────────────── */
  #shopify-section-{{ section.id }} .growave_tiers_wrapper {
    position: relative;
    width: 100%;
    background: var(--bg);
    color: var(--text);
    font-family: var(--ff-body);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .gtw_image_wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .gtw_image_wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    opacity: 0.5;
    filter: brightness(0.55) saturate(0.65);
  }

  #shopify-section-{{ section.id }} .gtw_content_wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  /* ─── HERO LAYOUT ────────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .tstn-hero-layout {
    display: grid;
    grid-template-columns: 42% 58%;
    align-items: center;
    min-height: 75vh;
    max-width: 1400px;
    margin: 0 auto;
    padding: 60px 48px 40px;
    gap: 0;
  }

  /* ─── LEFT COPY ──────────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .tstn-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-right: 32px;
  }

  #shopify-section-{{ section.id }} .tstn-welcome-row {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 4px;
  }
  #shopify-section-{{ section.id }} .tstn-logo-icon {
    width: 18px;
    height: auto;
    opacity: 0.9;
  }
  #shopify-section-{{ section.id }} .tstn-welcome-text {
    font-family: var(--ff-head);
    font-size: 13px;
    letter-spacing: 3px;
    color: var(--gold);
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .tstn-heading {
    font-family: var(--ff-head);
    font-size: clamp(48px, 5.5vw, 80px);
    font-weight: 400;
    line-height: 0.9;
    letter-spacing: 2px;
    color: #fff;
    margin: 0 0 18px;
    text-transform: uppercase;
    text-shadow: 0 2px 20px rgba(0,0,0,0.5);
  }

  #shopify-section-{{ section.id }} .tstn-desc {
    font-size: 14px;
    line-height: 1.7;
    color: rgba(230,225,214,0.72);
    max-width: 320px;
    margin: 0 0 26px;
  }

  #shopify-section-{{ section.id }} .tstn-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  #shopify-section-{{ section.id }} .tstn-btn {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 12px 22px;
    font-family: var(--ff-body);
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    text-decoration: none;
    cursor: pointer;
    transition: all 0.2s;
    border-radius: 2px;
  }
  #shopify-section-{{ section.id }} .tstn-btn--gold {
    background: var(--gold);
    color: #111;
    border: 2px solid var(--gold);
  }
  #shopify-section-{{ section.id }} .tstn-btn--gold:hover { background: var(--gold-lt); border-color: var(--gold-lt); }
  #shopify-section-{{ section.id }} .tstn-btn--outline {
    background: rgba(0,0,0,0.3);
    color: var(--text);
    border: 2px solid rgba(230,225,214,0.35);
    backdrop-filter: blur(4px);
  }
  #shopify-section-{{ section.id }} .tstn-btn--outline:hover { border-color: var(--text); }

  /* ─── Badges ────────────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .tstn-badges {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  #shopify-section-{{ section.id }} .tstn-badge {
    display: flex;
    align-items: center;
    gap: 8px;
  }
  #shopify-section-{{ section.id }} .tstn-badge svg { color: var(--muted); flex-shrink: 0; }
  #shopify-section-{{ section.id }} .tstn-badge-title {
    display: block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 1.5px;
    color: var(--text);
  }
  #shopify-section-{{ section.id }} .tstn-badge-title.gold { color: var(--gold); }
  #shopify-section-{{ section.id }} .tstn-badge-sub {
    display: block;
    font-size: 11px;
    color: var(--muted);
  }

  /* ─── RIGHT DASHBOARD WRAP ───────────────────────────────────────────── */
  /* This is the key fix: give the dashboard a fixed size context so the     */
  /* original gauge/cluster CSS (which uses % sizing) works as intended.     */
  #shopify-section-{{ section.id }} .tstn-dashboard-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    height: 100%;
  }

  #shopify-section-{{ section.id }} .dashboard-wrapper {
    width: 100%;
    max-width: 520px;
  }
  #shopify-section-{{ section.id }} .screen-container {
    width: 100%;
    position: relative;
  }

  /* Progress bar strip at top of dashboard */
  #shopify-section-{{ section.id }} .bottom-bar {
    width: 100%;
    margin-bottom: 0;
  }
  #shopify-section-{{ section.id }} .bottom-bar-inner {
    background: rgba(5,4,3,0.65);
    border: 1px solid rgba(200,146,42,0.15);
    border-bottom: none;
    border-radius: 6px 6px 0 0;
    padding: 10px 16px 8px;
    backdrop-filter: blur(6px);
  }
  #shopify-section-{{ section.id }} .bottom-bar-content {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  #shopify-section-{{ section.id }} .icons-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 0 2px;
  }
  #shopify-section-{{ section.id }} .icon-box {
    display: flex;
    align-items: center;
    justify-content: center;
  }
  #shopify-section-{{ section.id }} .icon-img {
    width: 32px;
    height: 32px;
    object-fit: contain;
  }
  #shopify-section-{{ section.id }} .meter-row { width: 100%; }
  #shopify-section-{{ section.id }} .meter-container {
    position: relative;
    height: 8px;
    background: rgba(255,255,255,0.07);
    border-radius: 4px;
    overflow: hidden;
    display: flex;
  }
  #shopify-section-{{ section.id }} .meter-fill {
    position: absolute;
    left: 0; top: 0; bottom: 0;
    background: linear-gradient(90deg, var(--gold-dk), var(--gold), var(--gold-lt));
    border-radius: 4px;
    transition: width 1.4s cubic-bezier(0.4,0,0.2,1);
    z-index: 1;
    box-shadow: 0 0 14px rgba(200,146,42,0.55);
  }
  #shopify-section-{{ section.id }} .meter-segment {
    flex: 1;
    border-right: 1px solid rgba(0,0,0,0.4);
    z-index: 2;
    position: relative;
  }
  #shopify-section-{{ section.id }} .meter-segment:last-child { border-right: none; }

  /* Cluster info bar */
  #shopify-section-{{ section.id }} .meter-info-wrapper {
    width: 100%;
    position: relative;
  }
  #shopify-section-{{ section.id }} .cluster-container {
    width: 100%;
    position: relative;
  }
  #shopify-section-{{ section.id }} .cluster-img {
    width: 100%;
    display: block;
    opacity: 0.9;
  }
  #shopify-section-{{ section.id }} .cluster-overlay {
    position: absolute;
    bottom: 10%;
    left: 0; right: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 16px;
    font-size: 9px;
    letter-spacing: 1px;
    color: rgba(255,255,255,0.65);
    font-family: var(--ff-body);
  }
