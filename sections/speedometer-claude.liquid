<!-- ══════════════════════════════════════════════════════════════ SCRIPTS -->
<script>
(function() {
  'use strict';

  /* ── Storage helpers ── */
  const KEYS = { tier: 'tstn_vp_tier_v2', bar: 'tstn_vp_bar_v2' };
  const getStoredTier = () => sessionStorage.getItem(KEYS.tier);
  const setStoredTier = t  => sessionStorage.setItem(KEYS.tier, t);
  const getStoredBar  = () => Number(sessionStorage.getItem(KEYS.bar) || 0);
  const setStoredBar  = v  => sessionStorage.setItem(KEYS.bar, v);

  const TIER_ORDER = ['base', 'scout', 'lead'];
  function getHigherTier(t1, t2) {
    if (!t1) return t2; if (!t2) return t1;
    return TIER_ORDER.indexOf(t1) >= TIER_ORDER.indexOf(t2) ? t1 : t2;
  }

  /* ── Constants ── */
  const IMAGES = {
    base:  'https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_1_a6b1bf9c-5113-4864-b2aa-53fb77a68341.png?v=1770810715',
    scout: 'https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_2_fe25c4de-0871-4b74-8114-8473656bf229.png?v=1770810716',
    lead:  'https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_3_3062b154-429b-4483-939f-042e342cf355.png?v=1770810716',
  };
  const TIER_CONFIG = {
    base:  { regex: /\b(base|base\s*camp)\b/i, bar: 0,   name: 'BASE CAMP' },
    scout: { regex: /\b(scout)\b/i,             bar: 50,  name: 'SCOUT'     },
    lead:  { regex: /\b(lead|leader)\b/i,       bar: 100, name: 'LEAD'      },
  };
  const TOTAL_POINTS       = 4000;
  const MAX_BAR_POINTS     = 3000;

  let currentValue = 0;

  /* ── DOM refs (populated after DOMContentLoaded) ── */
  let $tierImg, $meterFill, $cardBar, $cardPoints, $cardTierName,
      $scoutIcon, $leadIcon;

  /* ── Clock ── */
  function updateTime() {
    const el = document.getElementById('timeText');
    if (!el) return;
    const n = new Date();
    el.textContent = String(n.getHours()).padStart(2,'0') + ':' + String(n.getMinutes()).padStart(2,'0');
  }

  /* ── Gauge builder (identical logic to original) ── */
  function clamp(v, lo, hi) { return Math.min(Math.max(v, lo), hi); }

  function createSpeedometer(svgId, opts) {
    const svg = document.getElementById(svgId);
    if (!svg) return;

    const step      = opts.step      ?? 500;
    const eMax      = opts.max       ?? 240;
    const val       = opts.value     ?? 0;
    const minAngle  = opts.minAngle;
    const maxAngle  = opts.maxAngle;
    const showValue = opts.showValue !== false;
    const showNeedle= opts.showNeedle !== false;
    const angleRange = maxAngle - minAngle;
    const max        = eMax / step;
    const curVal     = val  / step;
    const initAngle  = minAngle + (curVal / max) * angleRange;

    svg.innerHTML = '';

    /* Major ticks + labels */
    for (let i = 0; i <= max; i++) {
      const a   = minAngle + (i / max) * angleRange;
      const rad = a * Math.PI / 180;
      const g   = document.createElementNS('http://www.w3.org/2000/svg','g');
      const ln  = document.createElementNS('http://www.w3.org/2000/svg','line');
      ln.setAttribute('x1', 100 + 75 * Math.cos(rad)); ln.setAttribute('y1', 100 + 75 * Math.sin(rad));
      ln.setAttribute('x2', 100 + 90 * Math.cos(rad)); ln.setAttribute('y2', 100 + 90 * Math.sin(rad));
      ln.setAttribute('stroke','white'); ln.setAttribute('stroke-width','1.5'); ln.setAttribute('stroke-linecap','round');
      g.appendChild(ln);
      const tx = 100 + 65 * Math.cos(rad), ty = 100 + 65 * Math.sin(rad);
      const t  = document.createElementNS('http://www.w3.org/2000/svg','text');
      t.setAttribute('x',tx); t.setAttribute('y',ty); t.setAttribute('fill','white');
      t.setAttribute('font-size','7px'); t.setAttribute('text-anchor','middle');
      t.setAttribute('dominant-baseline','middle');
      t.setAttribute('transform',`rotate(${a+90} ${tx} ${ty})`);
      t.textContent = i * step;
      g.appendChild(t);
      svg.appendChild(g);
    }

    /* Minor ticks */
    for (let i = 0; i < max * 4; i++) {
      if (i % 4 === 0) continue;
      const a   = minAngle + (i / (max * 4)) * angleRange;
      const rad = a * Math.PI / 180;
      const ln  = document.createElementNS('http://www.w3.org/2000/svg','line');
      ln.setAttribute('x1', 100 + 84 * Math.cos(rad)); ln.setAttribute('y1', 100 + 84 * Math.sin(rad));
      ln.setAttribute('x2', 100 + 90 * Math.cos(rad)); ln.setAttribute('y2', 100 + 90 * Math.sin(rad));
      ln.setAttribute('stroke','white'); ln.setAttribute('stroke-width','1'); ln.setAttribute('opacity','0.6'); ln.setAttribute('stroke-linecap','round');
      svg.appendChild(ln);
    }

    /* Value text */
    if (showValue) {
      const vt = document.createElementNS('http://www.w3.org/2000/svg','text');
      vt.setAttribute('id','center_gauge_value'); vt.setAttribute('x','100'); vt.setAttribute('y','70');
      vt.setAttribute('fill','white'); vt.setAttribute('font-size','18px');
      vt.setAttribute('font-family','Danger Neue Free Regular, Danger Neue, sans-serif');
      vt.setAttribute('text-anchor','middle'); vt.setAttribute('dominant-baseline','middle');
      vt.textContent = (curVal * step).toFixed(0);
      svg.appendChild(vt);
    }

    /* Needle */
    if (showNeedle) {
      const ng = document.createElementNS('http://www.w3.org/2000/svg','g');
      ng.setAttribute('class','needle-group');
      ng.style.transformOrigin = '100px 100px';
      ng.style.transform = `rotate(${initAngle}deg)`;
      ng.dataset.minAngle = minAngle; ng.dataset.maxAngle = maxAngle;
      ng.dataset.maxValue = eMax;     ng.dataset.step     = step;

      const sShaft = document.createElementNS('http://www.w3.org/2000/svg','path');
      sShaft.setAttribute('d','M 100 96 L 160 98 L 160 100 L 160 100 L 100 103 Z');
      sShaft.setAttribute('fill','rgba(0,0,0,0.45)'); sShaft.setAttribute('transform','translate(4,4)');
      const shaft = document.createElementNS('http://www.w3.org/2000/svg','path');
      shaft.setAttribute('d','M 100 96 L 160 98 L 160 100 L 160 100 L 100 103 Z');
      shaft.setAttribute('fill','#ec5607');
      const hub = document.createElementNS('http://www.w3.org/2000/svg','circle');
      hub.setAttribute('cx','100'); hub.setAttribute('cy','100'); hub.setAttribute('r','7'); hub.setAttribute('fill','#ec5607');

      ng.appendChild(sShaft); ng.appendChild(shaft); ng.appendChild(hub);
      svg.appendChild(ng);
    }

    /* Orange hub dot */
    const dot = document.createElementNS('http://www.w3.org/2000/svg','circle');
    dot.setAttribute('cx','100'); dot.setAttribute('cy','100'); dot.setAttribute('r','5'); dot.setAttribute('fill','#ff7a00');
    svg.appendChild(dot);
  }

  function updateNeedle(svgId, val) {
    const svg = document.getElementById(svgId);
    if (!svg) return;
    const ng = svg.querySelector('.needle-group');
    if (!ng) return;
    const mn = +ng.dataset.minAngle, mx = +ng.dataset.maxAngle, mv = +ng.dataset.maxValue;
    ng.style.transform = `rotate(${mn + (clamp(val, 0, mv) / mv) * (mx - mn)}deg)`;
  }

  /* ── Tier UI updater ── */
  function applyTierUI(tierKey) {
    if (!tierKey || !TIER_CONFIG[tierKey]) return;
    const final = getHigherTier(getStoredTier(), tierKey);
    setStoredTier(final);
    const cfg = TIER_CONFIG[final];

    if ($tierImg) $tierImg.src = IMAGES[final];
    if ($cardTierName) $cardTierName.textContent = cfg.name;

    if ($scoutIcon) $scoutIcon.classList.toggle('active', final === 'scout' || final === 'lead');
    if ($leadIcon)  $leadIcon.classList.toggle('active',  final === 'lead');

    const ptsPct  = clamp((currentValue / MAX_BAR_POINTS) * 100, 0, 100);
    const tierMin = cfg.bar;
    const finalBar = Math.max(Math.max(ptsPct, tierMin), getStoredBar());
    setStoredBar(finalBar);
    if ($meterFill) $meterFill.style.width = finalBar + '%';
    if ($cardBar)   $cardBar.style.width   = finalBar + '%';
  }

  function getTierFromText(text) {
    for (const k in TIER_CONFIG) if (TIER_CONFIG[k].regex.test(text)) return k;
    return null;
  }
  function updateFromVipText() {
    const el = document.querySelector('.vip_tier_new_updated');
    if (!el) return false;
    const tier = getTierFromText(el.innerText.trim());
    if (tier) { applyTierUI(tier); return true; }
    return false;
  }
  function getDerivedTier() {
    if (currentValue >= 3000) return 'lead';
    if (currentValue >= 1500) return 'scout';
    return 'base';
  }

  /* ── Animated counter ── */
  function animateCount(el, target) {
    if (!el) return;
    const start = parseInt(el.textContent.replace(/,/g,'')) || 0;
    const dur = 1200, t0 = performance.now();
    (function step(now) {
      const p = Math.min((now - t0) / dur, 1);
      const e = 1 - Math.pow(1 - p, 3);
      el.textContent = Math.round(start + (target - start) * e).toLocaleString();
      if (p < 1) requestAnimationFrame(step);
    })(t0);
  }

  /* ── Main setValue ── */
  function setValue(v) {
    currentValue = clamp(v, 0, TOTAL_POINTS);

    /* Gauge center display */
    const vt = document.getElementById('center_gauge_value');
    if (vt) vt.textContent = currentValue;

    /* Points card */
    animateCount($cardPoints, currentValue);

    /* Needles */
    updateNeedle('leftGauge',   clamp((currentValue / TOTAL_POINTS) * 7, 0, 7));
    updateNeedle('centerGauge', currentValue);

    /* Tier */
    if (!updateFromVipText()) applyTierUI(getDerivedTier());
  }

  /* ── Init on DOM ready ── */
  document.addEventListener('DOMContentLoaded', function() {
    $tierImg      = document.getElementById('tier_diagram');
    $meterFill    = document.getElementById('meterFill');
    $cardBar      = document.getElementById('cardProgressFill');
    $cardPoints   = document.getElementById('display_points');
    $cardTierName = document.getElementById('display_tier_name');
    $scoutIcon    = document.getElementById('scout-icon-wrap');
    $leadIcon     = document.getElementById('lead-icon-wrap');

    updateTime();
    setInterval(updateTime, 1000);

    createSpeedometer('leftGauge', {
      step: 1, max: 7, value: 0,
      showValue: false, showNeedle: true,
      minAngle: -210, maxAngle: 0,
    });
    createSpeedometer('centerGauge', {
      step: 500, max: TOTAL_POINTS, value: 0,
      showValue: true, showNeedle: true,
      minAngle: -200, maxAngle: 20,
    });
  });

  /* ── Points observer (identical to original) ── */
  window.newPoints1 = null;
  const observer = new MutationObserver(function() {
    const target = document.querySelector('.gw-rd-customer-points-balance-inline-widget-placeholder');
    if (!target) return;
    const match = target.textContent.match(/\d+/);
    if (!match) return;
    const pts = Number(match[0]);
    if (window.newPoints1 !== pts) { window.newPoints1 = pts; setValue(pts); }
  });
  observer.observe(document.body, { childList: true, subtree: true });

  setTimeout(function() {
    if (window.newPoints1 !== null) setValue(window.newPoints1);
  }, 1000);

})();
</script>

