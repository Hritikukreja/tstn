{% if customer %}
  {% assign vip_tier = customer.metafields["app--144550"]["growave_vip_tier"] %}
  {% if vip_tier != blank %}
    <div class="vip_tier_new_updated">{{ vip_tier }}</div>
  {% endif %}
{% endif %}

<div class="visibility_hidden">
  <span
    class="gw-rd-customer-points-balance-inline-widget-placeholder"
    data-gw-enable-points-name="true"
    style="display: block"
  ></span>
</div>

<div class="growave_tiers_wrapper {% unless customer %} non_customer_class {% endunless %}">

  <!-- BACKGROUND IMAGE -->
  <div class="gtw_image_wrapper">
    {% if section.settings.feat_image != blank %}
      <img src="{{ section.settings.feat_image | img_url:'master' }}" alt="">
    {% endif %}
  </div>

  <div class="gtw_content_wrapper">

    <!-- ══════════════════ HERO LAYOUT ══════════════════ -->
    <div class="tstn-hero-layout">

      <!-- LEFT COPY -->
      <div class="tstn-copy">
        {% if section.settings.welcome_text != blank %}
          <div class="tstn-welcome-row">
            <span class="tstn-welcome-text">{{ section.settings.welcome_text }}</span>
          </div>
        {% endif %}
        {% if section.settings.hero_heading != blank %}
          <h1 class="tstn-heading">{{ section.settings.hero_heading }}</h1>
        {% endif %}
        {% if section.settings.hero_description != blank %}
          <p class="tstn-desc">{{ section.settings.hero_description }}</p>
        {% endif %}
        <div class="tstn-ctas">
          {% if section.settings.cta_primary_label != blank %}
            <a href="{{ section.settings.cta_primary_url | default: '#tstn-how-it-works' }}" class="tstn-btn tstn-btn--gold">{{ section.settings.cta_primary_label }} <span>›</span></a>
          {% endif %}
          {% if section.settings.cta_secondary_label != blank %}
            <a href="{{ section.settings.cta_secondary_url | default: '/collections/merch' }}" class="tstn-btn tstn-btn--outline">{{ section.settings.cta_secondary_label }}</a>
          {% endif %}
        </div>
        <div class="tstn-badges">
          {% if section.settings.badge_1_title != blank or section.settings.badge_1_sub != blank %}
            <div class="tstn-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
              <div>
                <span class="tstn-badge-title gold">{{ section.settings.badge_1_title }}</span>
                <span class="tstn-badge-sub">{{ section.settings.badge_1_sub }}</span>
              </div>
            </div>
          {% endif %}
          {% if section.settings.badge_2_title != blank or section.settings.badge_2_sub != blank %}
            <div class="tstn-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              <div>
                <span class="tstn-badge-title">{{ section.settings.badge_2_title }}</span>
                <span class="tstn-badge-sub">{{ section.settings.badge_2_sub }}</span>
              </div>
            </div>
          {% endif %}
          {% if section.settings.badge_3_title != blank or section.settings.badge_3_sub != blank %}
            <div class="tstn-badge">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" width="18" height="18"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
              <div>
                <span class="tstn-badge-title gold">{{ section.settings.badge_3_title }}</span>
                <span class="tstn-badge-sub">{{ section.settings.badge_3_sub }}</span>
              </div>
            </div>
          {% endif %}
        </div>

        <!-- ══════════════════ STATUS + POINTS CARDS ══════════════ -->
        {% if customer %}
        <div class="tstn-cards-row">
          <div class="tstn-status-card">
            {% if section.settings.status_card_label != blank %}
              <div class="tstn-card-label">{{ section.settings.status_card_label }}</div>
            {% endif %}
            <div class="tstn-status-tier">
              <span
                class="tstn-current-tier-name"
                id="display_tier_name"
                data-tier-base="{{ section.settings.tier_base_name | default: 'BASE CAMP' }}"
                data-tier-scout="{{ section.settings.tier_scout_name | default: 'SCOUT' }}"
                data-tier-lead="{{ section.settings.tier_lead_name | default: 'LEAD' }}"
              >{{ section.settings.tier_base_name | default: 'BASE CAMP' }}</span>
            </div>
            <div class="tstn-status-icons">
              <div class="tstn-tier-icon" id="base-icon-wrap">
                {% if section.settings.tier_base_icon != blank %}
                  <img src="{{ section.settings.tier_base_icon | img_url:'master' }}" alt="{{ section.settings.tier_base_name | default: 'Base Camp' }}">
                {% else %}
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 2L2 22h20L12 2z"/><path d="M12 8v6"/></svg>
                {% endif %}
                <span>{{ section.settings.tier_base_name | default: 'BASE CAMP' }}</span>
              </div>
              <div class="tstn-tier-icon" id="scout-icon-wrap">
                {% if section.settings.tier_scout_icon != blank %}
                  <img src="{{ section.settings.tier_scout_icon | img_url:'master' }}" alt="{{ section.settings.tier_scout_name | default: 'Scout' }}">
                {% else %}
                  <img src="https://cdn.shopify.com/s/files/1/0994/4979/8950/files/Group_143726226.png?v=1770370711" alt="Scout">
                {% endif %}
                <span>{{ section.settings.tier_scout_name | default: 'SCOUT' }}</span>
              </div>
              <div class="tstn-tier-icon" id="lead-icon-wrap">
                {% if section.settings.tier_lead_icon != blank %}
                  <img src="{{ section.settings.tier_lead_icon | img_url:'master' }}" alt="{{ section.settings.tier_lead_name | default: 'Lead' }}">
                {% else %}
                  <img src="https://cdn.shopify.com/s/files/1/0994/4979/8950/files/Group_143726227.png?v=1770370813" alt="Lead">
                {% endif %}
                <span>{{ section.settings.tier_lead_name | default: 'LEAD' }}</span>
              </div>
            </div>
            <div
              class="tstn-tier-thresholds"
              data-scout-min="{{ section.settings.scout_min_points | default: 1500 }}"
              data-lead-min="{{ section.settings.lead_min_points | default: 2500 }}"
              style="display:none;"
            ></div>
          </div>
          <div class="tstn-points-card">
            {% if section.settings.points_card_label != blank %}
              <div class="tstn-card-label">{{ section.settings.points_card_label }}</div>
            {% endif %}
            <div class="tstn-points-value" id="display_points">0</div>
            {% if section.settings.points_card_sub != blank %}
              <div class="tstn-points-sub">{{ section.settings.points_card_sub }}</div>
            {% endif %}
          </div>
        </div>
        {% endif %}

      </div><!-- /tstn-copy -->

      <!-- ═════ GUEST OVERLAY ═════ -->
      {% unless customer %}
      <div class="none_customer_signup">
        <div class="non_custopmer_class">
          <div class="non_contact_main">
            {% if section.settings.guest_logo != blank %}
              <img src="{{ section.settings.guest_logo | img_url:'master' }}" alt="logo">
            {% endif %}
            {% if section.settings.guest_brand_label != blank %}
              <p>{{ section.settings.guest_brand_label }}</p>
            {% endif %}
          </div>
          {% if section.settings.guest_heading != blank %}
            <h2>{{ section.settings.guest_heading }}</h2>
          {% endif %}
          {% if section.settings.guest_description != blank %}
            <p class="margin_class_top">{{ section.settings.guest_description }}</p>
          {% endif %}
          {% if section.settings.guest_cta_label != blank %}
            <a class="new_main_createaccount" href="{{ section.settings.guest_cta_url | default: '/account/register' }}">{{ section.settings.guest_cta_label }}</a>
          {% endif %}
        </div>
      </div>
      {% endunless %}

    </div><!-- /tstn-hero-layout -->

  </div><!-- /gtw_content_wrapper -->

</div><!-- /growave_tiers_wrapper -->

<!-- ══════════════════ HOW IT WORKS — SEPARATE SECTION ══════════════ -->
<div class="tstn-howworks-block" id="tstn-how-it-works">
  <div class="tstn-howworks-inner">
    <div class="tstn-how-header">
      {% if section.settings.how_heading != blank %}
        <h2 class="tstn-how-heading">{{ section.settings.how_heading }}</h2>
      {% endif %}
      {% if section.settings.benefits_label != blank %}
        <a href="{{ section.settings.benefits_url | default: '/pages/tstn-club' }}" class="tstn-view-all">{{ section.settings.benefits_label }} ›</a>
      {% endif %}
    </div>
    <div class="tstn-how-divider"></div>
    <div class="tstn-steps-grid">
      {% if section.settings.step_1_title != blank or section.settings.step_1_desc != blank %}
        <div class="tstn-step">
          <span class="tstn-step-num">{{ section.settings.step_1_num | default: '01' }}</span>
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
          <div><strong>{{ section.settings.step_1_title }}</strong><p>{{ section.settings.step_1_desc }}</p></div>
        </div>
      {% endif %}
      {% if section.settings.step_2_title != blank or section.settings.step_2_desc != blank %}
        <div class="tstn-step">
          <span class="tstn-step-num">{{ section.settings.step_2_num | default: '02' }}</span>
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
          <div><strong>{{ section.settings.step_2_title }}</strong><p>{{ section.settings.step_2_desc }}</p></div>
        </div>
      {% endif %}
      {% if section.settings.step_3_title != blank or section.settings.step_3_desc != blank %}
        <div class="tstn-step">
          <span class="tstn-step-num">{{ section.settings.step_3_num | default: '03' }}</span>
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><circle cx="12" cy="8" r="6"/><path d="M15.477 12.89L17 22l-5-3-5 3 1.523-9.11"/></svg>
          <div><strong>{{ section.settings.step_3_title }}</strong><p>{{ section.settings.step_3_desc }}</p></div>
        </div>
      {% endif %}
      {% if section.settings.step_4_title != blank or section.settings.step_4_desc != blank %}
        <div class="tstn-step">
          <span class="tstn-step-num">{{ section.settings.step_4_num | default: '04' }}</span>
          <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2"><polyline points="20 12 20 22 4 22 4 12"/><rect x="2" y="7" width="20" height="5"/><line x1="12" y1="22" x2="12" y2="7"/><path d="M12 7H7.5a2.5 2.5 0 010-5C11 2 12 7 12 7z"/><path d="M12 7h4.5a2.5 2.5 0 000-5C13 2 12 7 12 7z"/></svg>
          <div><strong>{{ section.settings.step_4_title }}</strong><p>{{ section.settings.step_4_desc }}</p></div>
        </div>
      {% endif %}
    </div>
  </div>
</div>

<div id="points-output"></div>

<!-- ═══════════════════════════════════════════════════════════════ STYLES -->
<style>
  /* ─── CSS Tokens ─────────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} {
    --gold:     #c8922a;
    --gold-lt:  #e8a93a;
    --gold-dk:  #8a6010;
    --orange-cta: #ec5607;
    --bg:       #0d0c0a;
    --bg2:      #0a0a0a;
    --bg3:      #1c1a16;
    --card-bg:  rgba(20, 20, 20, 0.85);
    --border:   rgba(255,255,255,0.08);
    --border-gold: rgba(200,146,42,0.25);
    --text:     #e6e1d6;
    --muted:    #7a7060;
    --muted-2:  #6a6258;
    --orange:   #ec5607;
    --ff-head:  "Danger Neue Free Regular","Danger Neue",sans-serif;
    --ff-body:  "Rajdhani","ABC Diatype",sans-serif;
    --hero-min-height: {{ section.settings.hero_height | default: 75 }}vh;

    /* ─── Typography Variables (size / weight / color) ─────────────────── */
    /* Welcome label */
    --tstn-welcome-size:   {{ section.settings.welcome_size   | default: 14 }}px;
    --tstn-welcome-weight: {{ section.settings.welcome_weight | default: '400' }};
    --tstn-welcome-color:  {{ section.settings.welcome_color  | default: '#c8922a' }};

    /* Hero heading */
    --tstn-heading-size:   {{ section.settings.heading_size   | default: 78 }}px;
    --tstn-heading-weight: {{ section.settings.heading_weight | default: '400' }};
    --tstn-heading-color:  {{ section.settings.heading_color  | default: '#ffffff' }};

    /* Hero description */
    --tstn-desc-size:   {{ section.settings.desc_size   | default: 14 }}px;
    --tstn-desc-weight: {{ section.settings.desc_weight | default: '400' }};
    --tstn-desc-color:  {{ section.settings.desc_color  | default: 'rgba(230,225,214,0.78)' }};

    /* Buttons */
    --tstn-btn-size:    {{ section.settings.btn_size    | default: 12 }}px;
    --tstn-btn-weight:  {{ section.settings.btn_weight  | default: '700' }};
    --tstn-btn-gold-color:    {{ section.settings.btn_gold_color    | default: '#111111' }};
    --tstn-btn-outline-color: {{ section.settings.btn_outline_color | default: '#e6e1d6' }};

    /* Badges */
    --tstn-badge-title-size:   {{ section.settings.badge_title_size   | default: 11 }}px;
    --tstn-badge-title-weight: {{ section.settings.badge_title_weight | default: '700' }};
    --tstn-badge-title-color:  {{ section.settings.badge_title_color  | default: '#e6e1d6' }};
    --tstn-badge-title-gold-color: {{ section.settings.badge_title_gold_color | default: '#c8922a' }};
    --tstn-badge-sub-size:     {{ section.settings.badge_sub_size     | default: 11 }}px;
    --tstn-badge-sub-weight:   {{ section.settings.badge_sub_weight   | default: '400' }};
    --tstn-badge-sub-color:    {{ section.settings.badge_sub_color    | default: '#7a7060' }};

    /* Guest overlay */
    --tstn-guest-brand-size:    {{ section.settings.guest_brand_size    | default: 14 }}px;
    --tstn-guest-brand-weight:  {{ section.settings.guest_brand_weight  | default: '400' }};
    --tstn-guest-brand-color:   {{ section.settings.guest_brand_color   | default: '#c8922a' }};
    --tstn-guest-heading-size:  {{ section.settings.guest_heading_size  | default: 96 }}px;
    --tstn-guest-heading-weight:{{ section.settings.guest_heading_weight| default: '400' }};
    --tstn-guest-heading-color: {{ section.settings.guest_heading_color | default: '#ffffff' }};
    --tstn-guest-desc-size:     {{ section.settings.guest_desc_size     | default: 15 }}px;
    --tstn-guest-desc-weight:   {{ section.settings.guest_desc_weight   | default: '400' }};
    --tstn-guest-desc-color:    {{ section.settings.guest_desc_color    | default: 'rgba(230,225,214,0.85)' }};
    --tstn-guest-cta-size:      {{ section.settings.guest_cta_size      | default: 13 }}px;
    --tstn-guest-cta-weight:    {{ section.settings.guest_cta_weight    | default: '700' }};
    --tstn-guest-cta-color:     {{ section.settings.guest_cta_color     | default: '#ffffff' }};

    /* Card labels (Status / Points) */
    --tstn-card-label-size:   {{ section.settings.card_label_size   | default: 10 }}px;
    --tstn-card-label-weight: {{ section.settings.card_label_weight | default: '600' }};
    --tstn-card-label-color:  {{ section.settings.card_label_color  | default: '#7a7060' }};

    /* Tier name (current display) */
    --tstn-tier-name-size:   {{ section.settings.tier_name_size   | default: 30 }}px;
    --tstn-tier-name-weight: {{ section.settings.tier_name_weight | default: '400' }};
    --tstn-tier-name-color:  {{ section.settings.tier_name_color  | default: '#c8922a' }};

    /* Tier icon labels */
    --tstn-tier-icon-size:   {{ section.settings.tier_icon_size   | default: 9 }}px;
    --tstn-tier-icon-weight: {{ section.settings.tier_icon_weight | default: '600' }};
    --tstn-tier-icon-color:  {{ section.settings.tier_icon_color  | default: '#7a7060' }};
    --tstn-tier-icon-active-color: {{ section.settings.tier_icon_active_color | default: '#c8922a' }};

    /* Points value */
    --tstn-points-size:   {{ section.settings.points_size   | default: 44 }}px;
    --tstn-points-weight: {{ section.settings.points_weight | default: '400' }};
    --tstn-points-color:  {{ section.settings.points_color  | default: '#c8922a' }};

    /* Points subtitle */
    --tstn-points-sub-size:   {{ section.settings.points_sub_size   | default: 11 }}px;
    --tstn-points-sub-weight: {{ section.settings.points_sub_weight | default: '400' }};
    --tstn-points-sub-color:  {{ section.settings.points_sub_color  | default: '#7a7060' }};

    /* How It Works heading */
    --tstn-how-heading-size:   {{ section.settings.how_heading_size   | default: 22 }}px;
    --tstn-how-heading-weight: {{ section.settings.how_heading_weight | default: '400' }};
    --tstn-how-heading-color:  {{ section.settings.how_heading_color  | default: '#e6e1d6' }};

    /* View All link */
    --tstn-view-all-size:   {{ section.settings.view_all_size   | default: 11 }}px;
    --tstn-view-all-weight: {{ section.settings.view_all_weight | default: '600' }};
    --tstn-view-all-color:  {{ section.settings.view_all_color  | default: '#c8922a' }};

    /* Step number */
    --tstn-step-num-size:   {{ section.settings.step_num_size   | default: 38 }}px;
    --tstn-step-num-weight: {{ section.settings.step_num_weight | default: '400' }};
    --tstn-step-num-color:  {{ section.settings.step_num_color  | default: 'rgba(255,255,255,0.12)' }};

    /* Step title */
    --tstn-step-title-size:   {{ section.settings.step_title_size   | default: 13 }}px;
    --tstn-step-title-weight: {{ section.settings.step_title_weight | default: '700' }};
    --tstn-step-title-color:  {{ section.settings.step_title_color  | default: '#e6e1d6' }};

    /* Step description */
    --tstn-step-desc-size:   {{ section.settings.step_desc_size   | default: 12 }}px;
    --tstn-step-desc-weight: {{ section.settings.step_desc_weight | default: '400' }};
    --tstn-step-desc-color:  {{ section.settings.step_desc_color  | default: '#7a7060' }};
  }

  #shopify-section-{{ section.id }} *,
  #shopify-section-{{ section.id }} *::before,
  #shopify-section-{{ section.id }} *::after { box-sizing: border-box; }

  /* ─── Growave wrapper / bg ──────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .growave_tiers_wrapper {
    position: relative;
    width: 100%;
    background: var(--bg);
    color: var(--text);
    font-family: var(--ff-body);
    overflow: hidden;
  }

  #shopify-section-{{ section.id }} .gtw_image_wrapper {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }
  #shopify-section-{{ section.id }} .gtw_image_wrapper img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    opacity: 0.65;
    filter: brightness(0.7) saturate(0.8);
  }
  #shopify-section-{{ section.id }} .gtw_image_wrapper::after {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(100deg,
      rgba(8,7,5,0.85) 0%,
      rgba(8,7,5,0.55) 35%,
      rgba(8,7,5,0.25) 60%,
      rgba(8,7,5,0.45) 100%);
  }

  #shopify-section-{{ section.id }} .gtw_content_wrapper {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  /* ─── HERO LAYOUT ─────────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .tstn-hero-layout {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: flex-start;
    min-height: var(--hero-min-height);
    max-width: 1400px;
    margin: 0 auto;
    padding: 60px 48px;
  }

  /* Guest override */
  #shopify-section-{{ section.id }} .non_customer_class .tstn-copy { display: none; }
  #shopify-section-{{ section.id }} .non_customer_class .tstn-hero-layout {
    justify-content: center;
  }

  /* ─── LEFT COPY ─────────────────────────────────────────────────────── */
  #shopify-section-{{ section.id }} .tstn-copy {
    display: flex;
    flex-direction: column;
    justify-content: center;
    max-width: 720px;
    width: 100%;
  }

  #shopify-section-{{ section.id }} .tstn-welcome-row {
    display: flex;
    align-items: center;
    margin-bottom: 6px;
  }
  #shopify-section-{{ section.id }} .tstn-welcome-text {
    font-family: var(--ff-head);
    font-size: var(--tstn-welcome-size) !important;
    font-weight: var(--tstn-welcome-weight) !important;
    letter-spacing: 3px;
    color: var(--tstn-welcome-color) !important;
    text-transform: uppercase;
  }

  #shopify-section-{{ section.id }} .tstn-heading {
    font-family: var(--ff-head) !important;
    font-size: clamp(calc(var(--tstn-heading-size) * 0.45), 7vw, var(--tstn-heading-size)) !important;
    font-weight: var(--tstn-heading-weight) !important;
    line-height: 0.92;
    letter-spacing: 2px;
    color: var(--tstn-heading-color) !important;
    margin: 0 0 20px;
    text-transform: uppercase;
    text-shadow: 0 2px 24px rgba(0,0,0,0.6);
  }

  #shopify-section-{{ section.id }} .tstn-desc {
    font-size: var(--tstn-desc-size) !important;
    font-weight: var(--tstn-desc-weight) !important;
    line-height: 1.65;
    color: var(--tstn-desc-color) !important;
    max-width: 420px;
    margin: 0 0 26px;
  }

  #shopify-section-{{ section.id }} .tstn-ctas {
    display: flex;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

