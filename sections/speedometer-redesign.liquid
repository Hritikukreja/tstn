{% if customer %}
  {% assign vip_tier = customer.metafields["app--144550"]["growave_vip_tier"] %}
  
  {% if vip_tier != blank %}
    <div class="vip_tier_new_updated" style="display:none;">
       {{ vip_tier }}
    </div>
  {% endif %}
{% endif %}

{% comment %} Main TSTN Club Widget - Redesigned to match provided mockup {% endcomment %}
<div class="tston-club-wrapper">
  <div class="dashboard-container">
    <!-- Top Navigation -->
    <nav class="top-nav">
      <div class="nav-logo">
        <img src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/TSTN_logo_white.png?v=174XXXXXX" alt="TSTN" style="height:28px;">
      </div>
      <div class="nav-links">
        <a href="/">HOME</a>
        <a href="#" class="active">TSTN CLUB</a>
        <a href="/collections/merch">MERCH</a>
        <a href="/collections/brands">BRANDS</a>
        <a href="/collections/all">COLLECTION</a>
      </div>
      <div class="nav-icons">
        <span class="search-icon">🔍</span>
        <span class="account-icon">👤</span>
        <span class="cart-icon">🛒</span>
      </div>
    </nav>

    <div class="dashboard-main">
      <!-- Background Image Layer -->
      <div class="dashboard-bg">
        {% if section.settings.feat_image %}
          <img src="{{ section.settings.feat_image | img_url: 'master' }}" alt="Dashboard Background">
        {% else %}
          <img src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/tstn-dashboard-bg.jpg" alt="Dashboard Background">
        {% endif %}
      </div>

      <!-- Content Overlay -->
      <div class="dashboard-overlay">
        <!-- Welcome Header -->
        <div class="welcome-header">
          <div class="welcome-badge">
            <img src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/image_1_1_76d32aab-2b4e-4c68-a411-5a2a219321bf.png?v=1770384836" alt="TSTN" class="badge-icon">
            <span>WELCOME TO TSTN CLUB</span>
          </div>
          <p class="welcome-desc">Join the club. Earn points for every lighting or recovery upgrade and level up your journey with TSTN.</p>
          
          <div class="action-buttons">
            <a href="#how-it-works" class="btn btn-primary">HOW IT WORKS →</a>
            <a href="/collections/merch" class="btn btn-secondary">SHOP MERCH</a>
          </div>
        </div>

        <!-- Gauges Section -->
        <div class="gauges-section">
          <!-- Left small gauge -->
          <div class="gauge-small left-gauge">
            <svg id="leftGauge" viewBox="0 0 200 200" class="gauge-svg"></svg>
          </div>

          <!-- Center Main Gauge -->
          <div class="gauge-center">
            <svg id="centerGauge" viewBox="0 0 200 200" class="gauge-svg"></svg>
            <div class="center-value">
              <span id="center_gauge_value">0</span>
            </div>
          </div>

          <!-- Right Tier Badge -->
          <div class="tier-badge-container">
            <img id="tier_diagram" src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_1_a6b1bf9c-5113-4864-b2aa-53fb77a68341.png?v=1770810715" alt="BASE CAMP" class="tier-badge">
          </div>
        </div>

        <!-- Dashboard Info Bar -->
        <div class="dashboard-info">
          <div class="info-item">
            <span class="label">COMFORT</span>
            <span class="value" id="comfortText">P</span>
          </div>
          <div class="info-item">
            <span class="label">28°C</span>
          </div>
          <div class="info-item">
            <span class="label">14:18</span>
          </div>
          <div class="info-item">
            <span class="label">22°C</span>
          </div>
          <div class="info-item air-bag">
            <span>AIR</span>
            <span>BAG</span>
          </div>
          <div class="battery-info">
            <svg width="18" height="18" viewBox="0 0 512 512" fill="#fff">
              <path d="M315.27 33L96 304h128l-31.51 173.23a2.36 2.36 0 002.33 2.77h0a2.36 2.36 0 001.89-.95L416 208H288l31.66-173.25a2.45 2.45 0 00-2.44-2.75h0a2.42 2.42 0 00-1.95 1z"></path>
            </svg>
          </div>
        </div>

        <!-- Progress Section -->
        <div class="progress-section">
          <div class="progress-header">
            <div class="tier-labels">
              <span class="current-tier">BASE CAMP</span>
              <span class="next-tier">SCOUT</span>
              <span class="final-tier">LEAD</span>
            </div>
            <div class="points-display">
              <span class="points-label">YOUR TSTN POINTS</span>
              <span id="points-total" class="points-number">1,250</span>
            </div>
          </div>
          
          <div class="progress-bar-wrapper">
            <div class="progress-track">
              <div id="meterFill" class="progress-fill"></div>
            </div>
            <div class="tier-markers">
              <div class="marker base"></div>
              <div class="marker scout"></div>
              <div class="marker lead"></div>
            </div>
          </div>
        </div>

        <!-- How It Works -->
        <div class="how-it-works" id="how-it-works">
          <div class="section-header">
            <h3>HOW IT WORKS</h3>
            <a href="#" class="view-all">VIEW ALL BENEFITS →</a>
          </div>
          
          <div class="steps-grid">
            <div class="step">
              <div class="step-number">01</div>
              <div class="step-icon">🛍️</div>
              <div class="step-text">
                <strong>SHOP</strong><br>
                Buy eligible lighting or recovery products.
              </div>
            </div>
            <div class="step">
              <div class="step-number">02</div>
              <div class="step-icon">⭐</div>
              <div class="step-text">
                <strong>EARN</strong><br>
                Earn points for every qualified purchase.
              </div>
            </div>
            <div class="step">
              <div class="step-number">03</div>
              <div class="step-icon">🏆</div>
              <div class="step-text">
                <strong>LEVEL UP</strong><br>
                Climb ranks and unlock exclusive rewards.
              </div>
            </div>
            <div class="step">
              <div class="step-number">04</div>
              <div class="step-icon">🎁</div>
              <div class="step-text">
                <strong>REDEEM</strong><br>
                Use your points for merch, discounts & more.
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Mobile Preview / Fallback -->
  <div class="mobile-preview">
    <!-- Mobile content would mirror above but is handled via CSS media queries -->
  </div>
</div>

{% unless customer %}
<div class="non-customer-overlay">
  <div class="non-customer-content">
    <img src="https://cdn.shopify.com/s/files/1/0686/9486/8103/files/image_1_1_76d32aab-2b4e-4c68-a411-5a2a219321bf.png?v=1770384836" alt="TSTN">
    <h2>JOIN THE TRIBE</h2>
    <p>Earn Points. Get Featured. Unlock the Inner Circle.</p>
    <a href="/account/register" class="btn btn-primary">CREATE ACCOUNT</a>
  </div>
</div>
{% endunless %}

<script>
  // ==================== CORE FUNCTIONALITY (Preserved & Improved) ====================
  const STORAGE_KEYS = { tier: "tstn_cs_vp_m_t", bar: "tstn_cs_vp_m_b" };
  
  function getStoredTier() { return sessionStorage.getItem(STORAGE_KEYS.tier); }
  function setStoredTier(tier) { sessionStorage.setItem(STORAGE_KEYS.tier, tier); }
  function getStoredBar() { return Number(sessionStorage.getItem(STORAGE_KEYS.bar) || 0); }
  function setStoredBar(value) { sessionStorage.setItem(STORAGE_KEYS.bar, value); }

  const TIER_ORDER = ["base", "scout", "lead"];
  const TIER_CONFIG = {
    base: { regex: /\b(base|base\s*camp)\b/i, bar: 0, img: "https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_1_a6b1bf9c-5113-4864-b2aa-53fb77a68341.png?v=1770810715" },
    scout: { regex: /\b(scout)\b/i, bar: 50, img: "https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_2_fe25c4de-0871-4b74-8114-8473656bf229.png?v=1770810716" },
    lead: { regex: /\b(lead|leader)\b/i, bar: 100, img: "https://cdn.shopify.com/s/files/1/0686/9486/8103/files/ChatGPT_Image_Jan_22_2026_05_29_18_PM_3_3062b154-429b-4483-939f-042e342cf355.png?v=1770810716" }
  };

  let currentPoints = 0;
  const TOTAL_POINTS = 4000;
  const MAX_PROGRESS = 3000;

  // Gauge Creator (SVG)
  function createSpeedometer(svgId, options) {
    const svg = document.getElementById(svgId);
    if (!svg) return;
    svg.innerHTML = "";

    const value = options.value || 200;
    const max = options.max || 4000;
    const minAngle = options.minAngle || -200;
    const maxAngle = options.maxAngle || 20;
    const angle = minAngle + (value / max) * (maxAngle - minAngle);

    // Ticks + Labels (simplified for new design)
    for (let i = 0; i <= 8; i++) {
      const tickAngle = minAngle + (i / 8) * (maxAngle - minAngle);
      const rad = (tickAngle * Math.PI) / 180;
      const x1 = 100 + 72 * Math.cos(rad);
      const y1 = 100 + 72 * Math.sin(rad);
      const x2 = 100 + 88 * Math.cos(rad);
      const y2 = 100 + 88 * Math.sin(rad);

      const line = document.createElementNS("http://www.w3.org/2000/svg", "line");
      line.setAttribute("x1", x1); line.setAttribute("y1", y1);
      line.setAttribute("x2", x2); line.setAttribute("y2", y2);
      line.setAttribute("stroke", "#fff"); line.setAttribute("stroke-width", "2");
      svg.appendChild(line);
    }

    // Needle
    const needleGroup = document.createElementNS("http://www.w3.org/2000/svg", "g");
    needleGroup.style.transformOrigin = "100px 100px";
    needleGroup.style.transform = `rotate(${angle}deg)`;

    const needle = document.createElementNS("http://www.w3.org/2000/svg", "path");
    needle.setAttribute("d", "M100 98 L165 100 L100 102 Z");
    needle.setAttribute("fill", "#ec5607");
    needleGroup.appendChild(needle);
    svg.appendChild(needleGroup);

    // Center Hub
    const hub = document.createElementNS("http://www.w3.org/2000/svg", "circle");
    hub.setAttribute("cx", "100"); hub.setAttribute("cy", "100");
    hub.setAttribute("r", "8"); hub.setAttribute("fill", "#ff7a00");
    svg.appendChild(hub);
  }

  function updateNeedle(svgId, value, max = TOTAL_POINTS) {
    const svg = document.getElementById(svgId);
    if (!svg) return;
    const needle = svg.querySelector("g");
    if (!needle) return;
    const minAngle = -200, maxAngle = 20;
    const angle = minAngle + (Math.min(value, max) / max) * (maxAngle - minAngle);
    needle.style.transform = `rotate(${angle}deg)`;
  }

  function getTierFromPoints(points) {
    if (points >= 3000) return "lead";
    if (points >= 1500) return "scout";
    return "base";
  }

  function applyTierUI(tierKey) {
    if (!tierKey || !TIER_CONFIG[tierKey]) return;
    const finalTier = TIER_ORDER.indexOf(getStoredTier() || "base") > TIER_ORDER.indexOf(tierKey) 
                     ? getStoredTier() : tierKey;
    
    setStoredTier(finalTier);
    const config = TIER_CONFIG[finalTier];
    
    const tierImg = document.getElementById("tier_diagram");
    if (tierImg) tierImg.src = config.img;

    // Progress bar
    let progress = Math.min((currentPoints / MAX_PROGRESS) * 100, 100);
    const tierMin = config.bar;
    progress = Math.max(progress, tierMin);
    
    const fill = document.getElementById("meterFill");
    if (fill) fill.style.width = `${progress}%`;
  }

  function updateUI() {
    // Update center gauge value
    const valueEl = document.getElementById("center_gauge_value");
    if (valueEl) valueEl.textContent = Math.floor(currentPoints / 10) * 10; // rounded like mockup

    document.getElementById("points-total").textContent = currentPoints.toLocaleString();

    const tier = getTierFromPoints(currentPoints);
    applyTierUI(tier);

    updateNeedle("centerGauge", currentPoints);
    updateNeedle("leftGauge", (currentPoints / TOTAL_POINTS) * 7, 7);
  }

  // Growave Points Observer
  window.addEventListener("DOMContentLoaded", () => {
    createSpeedometer("leftGauge", { value: 0, max: 7, minAngle: -210, maxAngle: 0 });
    createSpeedometer("centerGauge", { value: 1250, max: TOTAL_POINTS, minAngle: -200, maxAngle: 20 });

    const observer = new MutationObserver(() => {
      const placeholder = document.querySelector(".gw-rd-customer-points-balance-inline-widget-placeholder");
      if (!placeholder) return;
      
      const match = placeholder.textContent.match(/\d+/);
      if (!match) return;
      
      const newPoints = Number(match[0]);
      if (newPoints !== currentPoints) {
        currentPoints = newPoints;
        updateUI();
      }
    });

    observer.observe(document.body, { childList: true, subtree: true });

    // Initial fallback
    setTimeout(() => {
      if (currentPoints === 0) {
        const vipEl = document.querySelector(".vip_tier_new_updated");
        if (vipEl) {
          const tier = Object.keys(TIER_CONFIG).find(k => TIER_CONFIG[k].regex.test(vipEl.innerText));
          if (tier) applyTierUI(tier);
        }
      }
    }, 800);
  });
</script>

<style>
  .tston-club-wrapper {
    font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, sans-serif;
    color: white;
    background: #111;
    overflow: hidden;
    position: relative;
  }

  .dashboard-container {
    position: relative;
    max-width: 1280px;
    margin: 0 auto;
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 20px 60px rgba(0,0,0,0.8);
  }

  .dashboard-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: brightness(0.85);
  }

  .dashboard-overlay {
    position: absolute;
    inset: 0;
    display: grid;
    grid-template-rows: auto 1fr auto auto;
    padding: 2rem;
    background: linear-gradient(to bottom, rgba(0,0,0,0.4), rgba(0,0,0,0.85));
  }

  .welcome-header {
    text-align: left;
  }

  .welcome-badge {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    background: rgba(255,255,255,0.1);
    padding: 12px 28px;
    border-radius: 9999px;
    backdrop-filter: blur(10px);
    margin-bottom: 1rem;
  }

  .welcome-badge span {
    font-size: 1.75rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
  }

  .action-buttons {
    display: flex;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .btn {
    padding: 14px 32px;
    border-radius: 6px;
    font-weight: 600;
    text-decoration: none;
    transition: all 0.2s;
  }

  .btn-primary {
    background: #f5a623;
    color: black;
  }

  .btn-secondary {
    background: transparent;
    color: white;
    border: 2px solid white;
  }

  .gauges-section {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 2rem;
    margin: 2rem 0;
  }

  .gauge-small, .gauge-center {
    width: 180px;
    height: 180px;
  }

  .gauge-center {
    width: 260px;
    height: 260px;
    position: relative;
  }

  .center-value {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    font-size: 2.5rem;
    font-weight: 700;
    color: white;
    text-shadow: 0 0 20px rgba(236, 86, 7, 0.6);
  }

  .tier-badge-container {
    width: 140px;
  }

  .tier-badge {
    width: 100%;
    filter: drop-shadow(0 10px 20px rgba(0,0,0,0.6));
  }

  .progress-section {
    background: rgba(0,0,0,0.6);
    padding: 1.5rem;
    border-radius: 12px;
    margin: 1.5rem 0;
  }

  .progress-track {
    height: 12px;
    background: #333;
    border-radius: 9999px;
    position: relative;
    overflow: hidden;
  }

  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, #f5a623, #ffcc00);
    width: 35%;
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .how-it-works {
    background: rgba(0,0,0,0.7);
    padding: 2rem;
    border-radius: 12px;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .step {
    text-align: center;
  }

  /* Mobile Styles */
  @media (max-width: 768px) {
    .dashboard-overlay {
      padding: 1.25rem;
    }
    .gauges-section {
      gap: 1rem;
    }
    .gauge-small, .gauge-center { width: 120px; height: 120px; }
    .center-value { font-size: 1.8rem; }
  }

  /* Hide original Growave widget */
  .visibility_hidden { display: none !important; }
</style>

{% schema %}
{
  "name": "TSTN Club Dashboard",
  "settings": [
    {
      "type": "image_picker",
      "id": "feat_image",
      "label": "Dashboard Background Image"
    }
  ],
  "presets": [{ "name": "TSTN Club" }]
}
{% endschema %}