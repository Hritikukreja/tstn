{% liquid
  assign section_id = 'FeatureGallery-' | append: section.id
%}

<link rel="preconnect" href="https://fonts.cdnfonts.com" crossorigin>
<link href="https://fonts.cdnfonts.com/css/danger-neue" rel="stylesheet">

<section id="{{ section_id }}" class="feature-gallery color-{{ section.settings.color_scheme }} gradient">
  <div class="page-width">
    <div class="feature-gallery__header">
      {% if section.settings.kicker != blank %}
        <p class="feature-gallery__kicker">{{ section.settings.kicker }}</p>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="feature-gallery__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="feature-gallery__text rte">{{ section.settings.text }}</div>
      {% endif %}
    </div>

    <div class="feature-gallery__grid feature-gallery__grid--{{ section.settings.columns_desktop }}">
      {% for block in section.blocks %}
        {%- liquid
          assign img_sizes = '(min-width: 990px) calc(100vw / ' | append: section.settings.columns_desktop | append: '), 100vw'
        -%}
        <article class="feature-gallery__card feature-gallery__card--align-{{ section.settings.card_alignment }}" {{ block.shopify_attributes }}>
          <div class="feature-gallery__media-wrap">
            {% if block.settings.media_type == 'video' and block.settings.video != blank %}
              {{
                block.settings.video
                | video_tag:
                  image_size: '1200x',
                  autoplay: true,
                  loop: true,
                  muted: true,
                  controls: block.settings.show_controls,
                  class: 'feature-gallery__media'
              }}
            {% elsif block.settings.image != blank %}
              {{
                block.settings.image
                | image_url: width: 1600
                | image_tag:
                  loading: 'lazy',
                  widths: '360, 540, 720, 960, 1200, 1600',
                  sizes: img_sizes,
                  class: 'feature-gallery__media',
                  alt: block.settings.image.alt
              }}
            {% else %}
              {{ 'image' | placeholder_svg_tag: 'feature-gallery__placeholder' }}
            {% endif %}
          </div>

          <div class="feature-gallery__content">
            {% if block.settings.title != blank %}
              <h3 class="feature-gallery__card-title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.description != blank %}
              <div class="feature-gallery__card-text rte">{{ block.settings.description }}</div>
            {% endif %}
            {% if block.settings.link_label != blank %}
              <a class="link underlined-link" href="{{ block.settings.link | default: '#' }}">{{ block.settings.link_label }}</a>
            {% endif %}
          </div>
        </article>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  /* ── Danger Neue applied to all headings site-wide within this section ── */
  #{{ section_id }} h2,
  #{{ section_id }} h3 {
    font-family: 'Danger Neue', sans-serif;
  }

  /* ── Section: fluid vertical rhythm ── */
  #{{ section_id }} {
    /*
      Dynamic padding: scales smoothly from 40px (mobile) → 120px (desktop).
      clamp(MIN, PREFERRED, MAX) — the preferred value grows with viewport width.
    */
    padding-top:    clamp(4rem, {{ section.settings.padding_top }}px + 4vw, calc({{ section.settings.padding_top }}px + 4rem));
    padding-bottom: clamp(4rem, {{ section.settings.padding_bottom }}px + 4vw, calc({{ section.settings.padding_bottom }}px + 4rem));

    /* Subtle horizontal breathing room on smaller viewports */
    padding-left:  clamp(1.6rem, 4vw, 0rem);
    padding-right: clamp(1.6rem, 4vw, 0rem);
  }

  /* ── Header block ── */
  #{{ section_id }} .feature-gallery__header {
    text-align: center;
    margin: 0 auto;
    /* Dynamic bottom margin: tighter on mobile, generous on desktop */
    margin-bottom: clamp(2.4rem, 5vw, 5.6rem);
    max-width: 76rem;
    /* Fluid horizontal padding so text never crowds the edges */
    padding: 0 clamp(1.6rem, 4vw, 4rem);
  }

  #{{ section_id }} .feature-gallery__kicker {
    margin: 0;
    font-size: clamp(1.1rem, 1.3vw, 1.4rem);
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: rgb(var(--color-foreground));
    opacity: 0.55;
  }

  #{{ section_id }} .feature-gallery__heading {
    /* Fluid type: 2.8rem mobile → 5.4rem wide desktop */
    margin: clamp(0.6rem, 1.2vw, 1rem) 0 0;
    font-size: clamp(2.8rem, 5.5vw, 5.4rem);
    line-height: 1.06;
    letter-spacing: -0.01em;
    color: rgb(var(--color-foreground));
  }

  #{{ section_id }} .feature-gallery__text {
    /* Fluid gap between heading and body text */
    margin-top: clamp(0.8rem, 1.5vw, 1.6rem);
    font-size: clamp(1.5rem, 1.7vw, 1.8rem);
    line-height: 1.65;
    color: rgb(var(--color-foreground));
    opacity: 0.75;
  }

  /* ── Grid ── */
  #{{ section_id }} .feature-gallery__grid {
    display: grid;
    /* Fluid gap: tighter on mobile, roomier on desktop */
    gap: clamp(1.4rem, 2.5vw, 2.8rem);
    grid-template-columns: 1fr;
  }

  @media screen and (min-width: 750px) {
    #{{ section_id }} .feature-gallery__grid--2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    #{{ section_id }} .feature-gallery__grid--3,
    #{{ section_id }} .feature-gallery__grid--4 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media screen and (min-width: 990px) {
    #{{ section_id }} .feature-gallery__grid--2 {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
    #{{ section_id }} .feature-gallery__grid--3 {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }
    #{{ section_id }} .feature-gallery__grid--4 {
      grid-template-columns: repeat(4, minmax(0, 1fr));
    }
  }

  /* ── Cards ── */
  #{{ section_id }} .feature-gallery__card {
    border-radius: clamp(1rem, 1.5vw, 2rem);
    overflow: hidden;
    background: rgba(var(--color-foreground), 0.03);
    border: 0.1rem solid rgba(var(--color-foreground), 0.08);
    transition: border-color 0.25s ease, transform 0.25s ease, box-shadow 0.25s ease;
  }

  #{{ section_id }} .feature-gallery__card:hover {
    border-color: rgba(var(--color-foreground), 0.2);
    transform: translateY(-3px);
    box-shadow: 0 1.2rem 3.6rem rgba(0, 0, 0, 0.45);
  }

  /* ── Media wrapper ── */
  #{{ section_id }} .feature-gallery__media-wrap {
    position: relative;
    background: rgba(var(--color-foreground), 0.05);
    aspect-ratio: {{ section.settings.media_aspect_ratio }};
    overflow: hidden;
  }

  #{{ section_id }} .feature-gallery__media,
  #{{ section_id }} .feature-gallery__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.45s ease;
  }

  #{{ section_id }} .feature-gallery__card:hover .feature-gallery__media {
    transform: scale(1.04);
  }

  /* ── Card content: fluid inner padding ── */
  #{{ section_id }} .feature-gallery__content {
    /* Fluid padding: compact on mobile, spacious on desktop */
    padding: clamp(1.4rem, 2.5vw, 2.4rem) clamp(1.4rem, 2.5vw, 2.4rem);
  }

  #{{ section_id }} .feature-gallery__card--align-center .feature-gallery__content {
    text-align: center;
  }

  #{{ section_id }} .feature-gallery__card--align-center .feature-gallery__content .link {
    display: block;
  }

  #{{ section_id }} .feature-gallery__card-title {
    margin: 0;
    /* Fluid card title sizing */
    font-size: clamp(1.6rem, 2vw, 2.2rem);
    letter-spacing: -0.005em;
    color: rgb(var(--color-foreground));
  }

  #{{ section_id }} .feature-gallery__card-text {
    /* Fluid spacing below title */
    margin-top: clamp(0.6rem, 1vw, 1.2rem);
    font-size: clamp(1.3rem, 1.5vw, 1.6rem);
    line-height: 1.6;
    color: rgb(var(--color-foreground));
    opacity: 0.72;
  }

  #{{ section_id }} .feature-gallery__content .link {
    display: inline-block;
    margin-top: clamp(0.8rem, 1.2vw, 1.4rem);
    font-size: clamp(1.2rem, 1.4vw, 1.4rem);
    letter-spacing: 0.04em;
    text-transform: uppercase;
  }
</style>

{% schema %}
{
  "name": "Feature gallery",
  "tag": "section",
  "class": "section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Top text",
      "default": "Feature gallery"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Designed to showcase key features"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Description",
      "default": "<p>Add up to eight feature cards with image or video.</p>"
    },
    {
      "type": "select",
      "id": "columns_desktop",
      "label": "Desktop columns",
      "default": "3",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ]
    },
    {
      "type": "select",
      "id": "card_alignment",
      "label": "Card content alignment",
      "default": "left",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ]
    },
    {
      "type": "text",
      "id": "media_aspect_ratio",
      "label": "Media aspect ratio",
      "info": "e.g. 4 / 5, 16 / 9, 1 / 1",
      "default": "4 / 5"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature card",
      "settings": [
        {
          "type": "select",
          "id": "media_type",
          "label": "Media type",
          "default": "image",
          "options": [
            { "value": "image", "label": "Image" },
            { "value": "video", "label": "Video" }
          ]
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "video",
          "id": "video",
          "label": "Video"
        },
        {
          "type": "checkbox",
          "id": "show_controls",
          "label": "Show video controls",
          "default": false
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Feature title"
        },
        {
          "type": "richtext",
          "id": "description",
          "label": "Description",
          "default": "<p>Describe this feature in one or two lines.</p>"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Learn more"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Feature gallery",
      "blocks": [
        { "type": "feature" },
        { "type": "feature" },
        { "type": "feature" }
      ]
    }
  ]
}
{% endschema %}
