{% comment %}
  TSTN Club Footer
  - Logo (TSTN CLUB) on the left
  - Center: text links (About, Contact, Privacy Policy, Terms)
  - Right: social icons
  - Copyright in the middle row
{% endcomment %}

<style>
  @font-face {
    font-family: 'Danger Neue Free Regular';
    src: url('https://cdn.shopify.com/s/files/1/0000/0000/files/danger-neue-free-regular.woff2?v=1') format('woff2');
    font-weight: 400;
    font-style: normal;
    font-display: swap;
  }

  #shopify-section-{{ section.id }} {
    --tstn-orange: #F56300;
    --tstn-bg: #0a0a0a;
    --tstn-text: #ffffff;
    --tstn-muted: #b0b0b0;
    --tstn-border: rgba(255,255,255,0.1);
    --tstn-font-display: "Danger Neue Free Regular", "Inter", sans-serif;
  }

  .tstn-footer {
    background: var(--tstn-bg);
    color: var(--tstn-text);
    padding: clamp(28px, 3vw, 36px) clamp(16px, 4vw, 40px);
    border-top: 1px solid var(--tstn-border);
  }
  .tstn-footer__inner {
    max-width: 1400px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: auto 1fr auto auto;
    gap: clamp(20px, 3vw, 40px);
    align-items: center;
  }

  .tstn-footer__logo {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    text-decoration: none;
  }
  .tstn-footer__logo-tstn {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(20px, 2vw, 26px);
    color: var(--tstn-text);
    line-height: 1;
  }
  .tstn-footer__logo-club {
    font-family: var(--tstn-font-display);
    font-weight: 400;
    font-size: clamp(20px, 2vw, 26px);
    color: var(--tstn-orange);
    line-height: 1;
    font-style: italic;
  }

  .tstn-footer__links {
    display: flex;
    gap: clamp(16px, 2.5vw, 32px);
    flex-wrap: wrap;
    justify-content: center;
  }
  .tstn-footer__link {
    color: var(--tstn-muted);
    text-decoration: none;
    font-size: 13px;
    transition: color 0.2s ease;
  }
  .tstn-footer__link:hover { color: var(--tstn-orange); }

  .tstn-footer__copy {
    color: var(--tstn-muted);
    font-size: 13px;
    text-align: center;
    white-space: nowrap;
  }

  .tstn-footer__socials {
    display: flex;
    gap: 14px;
    align-items: center;
  }
  .tstn-footer__social {
    color: var(--tstn-text);
    transition: color 0.2s ease;
    display: inline-flex;
  }
  .tstn-footer__social:hover { color: var(--tstn-orange); }

  /* Mobile */
  @media (max-width: 980px) {
    .tstn-footer__inner {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 20px;
      justify-items: center;
    }
    .tstn-footer__copy { white-space: normal; }
  }
</style>

<footer class="tstn-footer">
  <div class="tstn-footer__inner">

    <a href="{{ section.settings.logo_link | default: '/' }}" class="tstn-footer__logo">
      <span class="tstn-footer__logo-tstn">{{ section.settings.logo_one | default: 'TSTN' }}</span>
      <span class="tstn-footer__logo-club">{{ section.settings.logo_two | default: 'CLUB' }}</span>
    </a>

    <nav class="tstn-footer__links">
      {% for block in section.blocks %}
        {% if block.type == 'link' %}
          <a href="{{ block.settings.link | default: '#' }}" class="tstn-footer__link" {{ block.shopify_attributes }}>{{ block.settings.label }}</a>
        {% endif %}
      {% endfor %}
    </nav>

    <div class="tstn-footer__copy">{{ section.settings.copyright | default: '© 2024 TSTN Club. All rights reserved.' }}</div>

    <div class="tstn-footer__socials">
      {% if section.settings.instagram_link != blank %}
        <a href="{{ section.settings.instagram_link }}" class="tstn-footer__social" aria-label="Instagram" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
        </a>
      {% endif %}
      {% if section.settings.youtube_link != blank %}
        <a href="{{ section.settings.youtube_link }}" class="tstn-footer__social" aria-label="YouTube" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22.54 6.42a2.78 2.78 0 0 0-1.94-2C18.88 4 12 4 12 4s-6.88 0-8.6.46a2.78 2.78 0 0 0-1.94 2A29 29 0 0 0 1 11.75a29 29 0 0 0 .46 5.33A2.78 2.78 0 0 0 3.4 19c1.72.46 8.6.46 8.6.46s6.88 0 8.6-.46a2.78 2.78 0 0 0 1.94-2 29 29 0 0 0 .46-5.25 29 29 0 0 0-.46-5.33z"></path><polygon points="9.75 15.02 15.5 11.75 9.75 8.48 9.75 15.02"></polygon></svg>
        </a>
      {% endif %}
      {% if section.settings.twitter_link != blank %}
        <a href="{{ section.settings.twitter_link }}" class="tstn-footer__social" aria-label="Twitter" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"></path></svg>
        </a>
      {% endif %}
      {% if section.settings.linkedin_link != blank %}
        <a href="{{ section.settings.linkedin_link }}" class="tstn-footer__social" aria-label="LinkedIn" target="_blank" rel="noopener">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
        </a>
      {% endif %}
    </div>

  </div>
</footer>

{% schema %}
{
  "name": "TSTN Club Footer",
  "settings": [
    { "type": "header", "content": "Logo" },
    { "type": "text", "id": "logo_one", "label": "Logo (white)", "default": "TSTN" },
    { "type": "text", "id": "logo_two", "label": "Logo (orange italic)", "default": "CLUB" },
    { "type": "url", "id": "logo_link", "label": "Logo Link" },
    { "type": "header", "content": "Copyright" },
    { "type": "text", "id": "copyright", "label": "Copyright", "default": "© 2024 TSTN Club. All rights reserved." },
    { "type": "header", "content": "Social Links" },
    { "type": "url", "id": "instagram_link", "label": "Instagram URL" },
    { "type": "url", "id": "youtube_link", "label": "YouTube URL" },
    { "type": "url", "id": "twitter_link", "label": "Twitter / X URL" },
    { "type": "url", "id": "linkedin_link", "label": "LinkedIn URL" }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Footer Link",
      "settings": [
        { "type": "text", "id": "label", "label": "Label", "default": "About" },
        { "type": "url", "id": "link", "label": "Link" }
      ]
    }
  ],
  "max_blocks": 8,
  "presets": [
    {
      "name": "TSTN Club Footer",
      "blocks": [
        { "type": "link", "settings": { "label": "About" } },
        { "type": "link", "settings": { "label": "Contact" } },
        { "type": "link", "settings": { "label": "Privacy Policy" } },
        { "type": "link", "settings": { "label": "Terms & Conditions" } }
      ]
    }
  ]
}
{% endschema %}
